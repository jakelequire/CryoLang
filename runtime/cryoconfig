# Cryo Runtime Configuration
# This file defines the build configuration for the Cryo Language Runtime.
#
# The runtime is a special library that provides:
# - Program entry point (main function)
# - Runtime initialization and shutdown
# - Panic handling
# - Memory management hooks
# - Signal handling
# - Platform abstraction
#
# NOTE: Building the runtime requires special compiler flags that are not
# yet fully supported by the standard `cryo build` command. Until the
# build system is updated, use the Makefile targets or build scripts.

[project]
project_name = "cryo-runtime"
output_dir = "build"
target_type = "static_library"

# Runtime-specific settings (proposed extensions to cryoconfig format)
# entry_point = "entry.cryo"       # The file containing main()
# source_dir = "."                  # Root directory for source files
# include_patterns = ["*.cryo", "platform/*.cryo"]

[compiler]
debug = false
optimize = true
# The runtime requires special compilation flags:
# --stdlib-mode: Compile in stdlib mode (no auto-imports, generates full implementations)
# --no-std: Don't link the standard library (runtime IS the lowest layer)
# --emit-llvm: Output LLVM bitcode for linking
# -c: Compile only, don't link
args = ["--stdlib-mode", "--no-std", "--emit-llvm", "-c"]

[build]
# Proposed section for advanced build configuration
# link_with = []                    # Libraries to link with
# llvm_link = true                  # Use llvm-link to combine bitcode
# llvm_ar = true                    # Create static archive with llvm-ar
# pic = true                        # Generate position-independent code

[sources]
# Proposed section for explicit source file ordering
# (important for the runtime due to dependencies)
# files = [
#     "version.cryo",
#     "platform/linux.cryo",
#     "platform/_module.cryo",
#     "platform.cryo",
#     "memory.cryo",
#     "atexit.cryo",
#     "signal.cryo",
#     "panic.cryo",
#     "init.cryo",
#     "entry.cryo",
#     "lib.cryo"
# ]

[dependencies]
# The runtime has no external dependencies - it's the foundation layer
# std = false  # Explicitly disable stdlib dependency

