# Cryo Runtime Configuration
#
# The runtime is a special library that provides:
# - Program entry point (main function)
# - Runtime initialization and shutdown
# - Panic handling
# - Memory management hooks
# - Signal handling
# - Platform abstraction

[project]
project_name = "cryo-runtime"
output_dir = "build"
target_type = "static_library"
entry_point = "lib.cryo"
source_dir = "."

[compiler]
debug = false
optimize = true
stdlib_mode = true
args = ["--ir", "--emit-llvm"]

[dependencies]
# The runtime has no external dependencies - it's the foundation layer

