# ================================================================
# CryoLang WebAssembly Build Configuration
# ================================================================

# Emscripten Configuration
ifeq ($(OS),Windows_NT)
    EMSCRIPTEN_ROOT := $(shell cd)\\emsdk
    EMSDK_PATH := $(EMSCRIPTEN_ROOT)
    EMSDK_NODE := $(EMSDK_PATH)\\node\\22.16.0_64bit\\bin
    EMSDK_PYTHON := $(EMSDK_PATH)\\python\\3.13.3_64bit
else
    EMSCRIPTEN_ROOT := $(shell pwd)/emsdk
    EMSDK_PATH := $(EMSCRIPTEN_ROOT)
    EMSDK_NODE := $(EMSDK_PATH)/node/22.16.0_64bit/bin
    EMSDK_PYTHON := $(EMSDK_PATH)/python/3.13.3_64bit
endif

# Emscripten Compiler
ifeq ($(OS),Windows_NT)
    EMCC := $(EMSDK_PATH)\\upstream\\emscripten\\emcc.bat
    EMCPP := $(EMSDK_PATH)\\upstream\\emscripten\\em++.bat
else
    EMCC := $(EMSDK_PATH)/upstream/emscripten/emcc
    EMCPP := $(EMSDK_PATH)/upstream/emscripten/em++
endif

# WASM-specific Flags
WASM_CFLAGS := -std=c++23 \
               -I./include \
               -I$(EMSDK_PATH)/upstream/emscripten/system/include \
               -DWASM_BUILD \
               -O2 \
               -g \
               -s WASM=1 \
               -s ALLOW_MEMORY_GROWTH=1 \
               -s INITIAL_MEMORY=67108864 \
               -s MAXIMUM_MEMORY=134217728 \
               -s EXPORTED_RUNTIME_METHODS='["ccall","cwrap","getValue","setValue"]' \
               -s MODULARIZE=1 \
               -s EXPORT_NAME='CryoCompiler'

# WASM Exports (C functions visible to JavaScript)
WASM_EXPORTS := -s EXPORTED_FUNCTIONS='[ \
    "_cryo_wasm_initialize", \
    "_cryo_wasm_shutdown", \
    "_cryo_wasm_alloc", \
    "_cryo_wasm_free", \
    "_cryo_wasm_string_from_js", \
    "_cryo_wasm_string_to_js", \
    "_cryo_wasm_get_heap_size", \
    "_cryo_wasm_get_allocated_bytes", \
    "_cryo_main", \
    "_cryo_compile_source", \
    "_cryo_get_ast", \
    "_cryo_get_errors" \
]'

# JavaScript Library for Interop
JS_LIBRARY := --js-library src/wasm/cryo_js_library.js

# Source Files for WASM Build
WASM_SOURCES := src/wasm/WASMRuntimeAdapter.cpp \
                src/wasm/WASMCodegenVisitor.cpp \
                src/wasm/CryoWASMAPI.cpp \
                src/Lexer/lexer.cpp \
                src/Parser/Parser.cpp \
                src/AST/ASTNode.cpp \
                src/AST/ASTBuilder.cpp \
                src/AST/ASTContext.cpp \
                src/AST/Type.cpp \
                src/AST/TypeChecker.cpp \
                src/AST/SymbolTable.cpp \
                src/Codegen/CodeGenerator.cpp \
                src/Codegen/CodegenVisitor.cpp \
                src/Codegen/LLVMContext.cpp \
                src/Codegen/TypeMapper.cpp \
                src/GDM/GDM.cpp \
                src/Utils/Logger.cpp

# Output Files
WASM_OUTPUT := bin/cryo-compiler.wasm
WASM_JS_OUTPUT := bin/cryo-compiler.js
WASM_HTML_OUTPUT := bin/cryo-compiler.html

# ================================================================
# WASM Build Targets
# ================================================================

.PHONY: wasm wasm-debug wasm-release wasm-clean

# Main WASM build target
wasm: wasm-release

# Debug WASM build
wasm-debug: WASM_CFLAGS += -g -O0 -DDEBUG
wasm-debug: $(WASM_OUTPUT)

# Release WASM build  
wasm-release: WASM_CFLAGS += -O2 -DNDEBUG
wasm-release: $(WASM_OUTPUT)

# Build the WASM module
$(WASM_OUTPUT): $(WASM_SOURCES) src/wasm/cryo_js_library.js
	@echo "Building CryoLang WebAssembly Module..."
ifeq ($(OS),Windows_NT)
	@if not exist bin mkdir bin
else
	@mkdir -p bin
endif
	$(EMCPP) $(WASM_CFLAGS) $(WASM_EXPORTS) $(JS_LIBRARY) \
		$(WASM_SOURCES) \
		-o $(WASM_JS_OUTPUT)
	@echo "✓ WASM build completed: $(WASM_JS_OUTPUT)"

# Test WASM build with a simple HTML page
wasm-test: $(WASM_OUTPUT)
	@echo "Generating test HTML page..."
	@echo "Test completed - WASM files generated"
	@echo "✓ Test page generated: $(WASM_HTML_OUTPUT)"
	@echo "Open $(WASM_HTML_OUTPUT) in a web browser to test"

# Clean WASM build artifacts
wasm-clean:
	@echo "Cleaning WASM build artifacts..."
	@rm -f $(WASM_OUTPUT) $(WASM_JS_OUTPUT) $(WASM_HTML_OUTPUT)
	@rm -f bin/cryo-compiler.wasm.map
	@echo "✓ WASM artifacts cleaned"

# ================================================================
# WASM Development Helpers
# ================================================================

# Start a local HTTP server for WASM testing
wasm-serve: $(WASM_OUTPUT)
	@echo "Starting local server for WASM testing..."
	@echo "Open http://localhost:8000/$(WASM_HTML_OUTPUT) in your browser"
	@cd bin && python3 -m http.server 8000

# Analyze WASM output size
wasm-analyze: $(WASM_OUTPUT)
	@echo "WASM Module Analysis:"
	@echo "==================="
	@ls -lh $(WASM_OUTPUT) $(WASM_JS_OUTPUT)
	@echo ""
	@echo "WASM file size: $$(wc -c < $(WASM_OUTPUT)) bytes"
	@echo "JS file size: $$(wc -c < $(WASM_JS_OUTPUT)) bytes"