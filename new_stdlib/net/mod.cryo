///! Network Module
///!
///! This module provides networking primitives for TCP/UDP communication.
///!
///! # Submodules
///!
///! - `addr` - IP addresses and socket addresses
///! - `tcp` - TCP streams and listeners
///! - `udp` - UDP sockets

namespace std::net;

pub import <net/addr>;
pub import <net/tcp>;
pub import <net/udp>;

