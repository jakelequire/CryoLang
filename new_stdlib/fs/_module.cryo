///! Filesystem Module
///!
///! This module provides filesystem operations including file I/O,
///! path manipulation, directory operations, and metadata access.
///!
///! # Submodules
///!
///! - `file` - File types and operations
///! - `path` - Path manipulation
///! - `dir` - Directory operations
///! - `metadata` - File metadata

namespace std::fs;

public import <fs/file>;
public import <fs/path>;
public import <fs/dir>;
public import <fs/metadata>;

