// Test global variables
import IO from <io/stdio>;

mut global_counter: int = 42;

function main() -> int {
    IO::println("Testing global variables...");
    IO::print_int(global_counter);

    // Try to use the global variable
    global_counter = 100;
    IO::printf("Updated global counter:\n");
    IO::print_int(global_counter);
    
    return 0;
}
