namespace Collections::Stack;

type struct IntStack {
    data:  i32[];
    count: i64;

    static new() -> IntStack {
        mut s: IntStack;
        s.data  = [];
        s.count = 0;
        return s;
    }

    push(mut &this, value: i32) -> void {
        this.data.push(value);
        this.count = this.count + 1;
    }

    is_empty(&this) -> boolean {
        return this.count == 0;
    }

    size(&this) -> i64 {
        return this.count;
    }
}
