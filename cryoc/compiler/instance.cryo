namespace Compiler::Instance;

type struct InstanceState {
    source_file: string;
    debug: boolean;
}

type struct CompilerInstance {
public:
    state: InstanceState;

    /// The default constructor for CompilerInstance initializes the state with default values.
    static new() -> CompilerInstance {
        return CompilerInstance {
            state: InstanceState {
                source_file: "",
                debug: false,
            },
        };
    }

private:
}
