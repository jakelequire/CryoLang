// ============================================================================
// Cross-module free function stubs
//
// These delegate to the real implementations in their respective modules.
// They exist because the compiler does not yet propagate transitive imports
// into the LLVM module — codegen processes pass_registry function bodies
// before the imported modules' function declarations are created, causing
// E0636 "Unknown function" errors.  Once transitive free-function resolution
// is fixed in CompilerInstance/ModuleLoader, these stubs can be removed.
// ============================================================================

function run_name_resolution_pass(ctx: CompilationContext*) -> PassResult {
    if (ctx.debug_mode) {
        printf("[NameResolution] Resolving names (stub — real impl in NameResolution module)\n");
    }

    return PassResult::ok([Provision::NamesResolved]);
}

function run_template_registration_pass(ctx: CompilationContext*) -> PassResult {
    if (ctx.debug_mode) {
        printf("[TemplateRegistration] Registering templates (stub)\n");
    }

    return PassResult::ok([Provision::TemplatesRegistered]);
}

function run_monomorphization_pass(ctx: CompilationContext*) -> PassResult {
    if (ctx.debug_mode) {
        printf("[Monomorphization] Processing instantiations (stub)\n");
    }

    return PassResult::ok([Provision::MonomorphizationComplete]);
}

function run_generic_expression_resolution_pass(ctx: CompilationContext*) -> PassResult {
    if (ctx.debug_mode) {
        printf("[GenericExpressionResolution] Resolving generic expressions (stub)\n");
    }

    return PassResult::ok([Provision::GenericExpressionsResolved]);
}
