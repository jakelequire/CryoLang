/// AST Type Substituter
///
/// Walks a cloned AST and rewrites type annotations and generic name references
/// to reflect concrete type arguments.  Used after ASTCloner to transform a
/// generic declaration clone into a concrete specialization.
///
/// Example: For `Array<T>` specialized with T=i32:
///   - Named("T") annotations → Named("i32") or Primitive("i32")
///   - StructDeclNode.name "Array" → "Array_i32"
///   - generic_args [Named("T")] → [Named("i32")] (via substitute_annotation)
///   - generic_params cleared (the specialization is concrete)

namespace Compiler::AST::Substituter;

import Compiler::Diag;
import Compiler::AST::Node;
import Compiler::AST::Expression;
import Compiler::AST::Statement;
import Compiler::AST::Declaration;
import Compiler::AST::Pattern;
import Compiler::AST::Visitor;
import Compiler::Types;
import Compiler::Types::Substitution;
import Compiler::Resolver::InternTable;


// ============================================================================
// ASTTypeSubstituter — Rewrites type annotations and names on a cloned AST
// ============================================================================

type class ASTTypeSubstituter : BaseASTVisitor {
public:
    subst:             TypeSubstitution*;
    arena:             TypeArena*;
    intern_table:      InternTable*;
    base_name:         SymbolStr;         // "Array"
    spec_name:         SymbolStr;         // "Array_i32"
    param_names:       SymbolStr[];       // ["T"]
    type_arg_displays: SymbolStr[];       // ["i32"]

    ASTTypeSubstituter(subst: TypeSubstitution*, arena: TypeArena*,
                       intern_table: InternTable*,
                       base_name: SymbolStr, spec_name: SymbolStr,
                       param_names: SymbolStr[], type_arg_displays: SymbolStr[])
        : BaseASTVisitor() {
        this.subst             = subst;
        this.arena             = arena;
        this.intern_table      = intern_table;
        this.base_name         = base_name;
        this.spec_name         = spec_name;
        this.param_names       = param_names;
        this.type_arg_displays = type_arg_displays;
    }


    // ----------------------------------------------------------------
    // Type annotation substitution
    // ----------------------------------------------------------------

    /// Substitute type parameters in a type annotation.
    /// Returns a new annotation if changes were made, or the original if not.
    substitute_annotation(ann: TypeAnnotation*) -> TypeAnnotation* {
        if (ann == null) { return null; }

        match (*ann) {
            TypeAnnotation::Named(named) => {
                return this.substitute_named_annotation(ann, named);
            }
            TypeAnnotation::Primitive(prim) => {
                // Primitives never contain generic params
                return ann;
            }
            TypeAnnotation::Pointer(ptr) => {
                // In-place: recurse into inner (cloned AST)
                this.substitute_annotation(ptr.inner);
                return ann;
            }
            TypeAnnotation::Reference(ref) => {
                this.substitute_annotation(ref.inner);
                return ann;
            }
            TypeAnnotation::Array(arr) => {
                this.substitute_annotation(arr.element);
                return ann;
            }
            TypeAnnotation::Optional(opt) => {
                this.substitute_annotation(opt.inner);
                return ann;
            }
            TypeAnnotation::Function(func) => {
                return this.substitute_function_annotation(ann, func);
            }
            TypeAnnotation::Tuple(tup) => {
                return this.substitute_tuple_annotation(ann, tup);
            }
            TypeAnnotation::Generic(gen) => {
                return this.substitute_generic_annotation(ann, gen);
            }
        }

        return ann;
    }


    // ----------------------------------------------------------------
    // Annotation substitution helpers
    // ----------------------------------------------------------------

    substitute_named_annotation(ann: TypeAnnotation*, named: NamedAnnotation*) -> TypeAnnotation* {
        // Check if this named annotation is one of our generic params.
        // Modify in-place (the AST was already cloned) to avoid malloc
        // issues with the C++ compiler's codegen for struct-literal
        // assignment through pointers.
        for (mut i: i64 = 0; i < this.param_names.length; i++) {
            if (named.name.equals(this.param_names[i])) {
                named.name = this.type_arg_displays[i];
                return ann;
            }
        }

        // Rewrite the base type name to the specialized name.
        // e.g. `&this` on `Pair<T>` has annotation Reference(Named("Pair"))
        // which must become Reference(Named("Pair_string")) after substitution.
        if (named.name.equals(this.base_name)) {
            named.name = this.spec_name;
            return ann;
        }

        return ann;
    }

    substitute_function_annotation(ann: TypeAnnotation*, func: FunctionAnnotation*) -> TypeAnnotation* {
        // In-place: recurse into params and return type (cloned AST)
        for (mut i: i64 = 0; i < func.parameters.length; i++) {
            this.substitute_annotation(func.parameters[i]);
        }
        this.substitute_annotation(func.return_type);
        return ann;
    }

    substitute_tuple_annotation(ann: TypeAnnotation*, tup: TupleAnnotation*) -> TypeAnnotation* {
        // In-place: recurse into elements (cloned AST)
        for (mut i: i64 = 0; i < tup.elements.length; i++) {
            this.substitute_annotation(tup.elements[i]);
        }
        return ann;
    }

    substitute_generic_annotation(ann: TypeAnnotation*, gen: GenericAnnotation*) -> TypeAnnotation* {
        // Check BEFORE substitution whether the base is our type being specialized.
        mut is_self_type: boolean = this.is_named_matching_base(gen.base);

        // Normal recursion: substitute base and args.
        // For the base, this rewrites Named("Pair") → Named("Pair_string")
        // via substitute_named_annotation.  Args get T → i32 etc.
        this.substitute_annotation(gen.base);
        for (mut i: i64 = 0; i < gen.args.length; i++) {
            this.substitute_annotation(gen.args[i]);
        }

        // If the base was our type, collapse Generic(Named("Pair_string"), [string])
        // down to just Named("Pair_string").  The type args are already baked into
        // the specialized name, so keeping the Generic wrapper would cause the
        // resolver to create a spurious Pair_string<string> instantiation.
        if (is_self_type) {
            *ann = *gen.base;
            return ann;
        }

        return ann;
    }

    /// Helper: returns true if the annotation is Named(base_name).
    is_named_matching_base(ann: TypeAnnotation*) -> boolean {
        if (ann == null) { return false; }
        match (*ann) {
            TypeAnnotation::Named(named) => {
                return named.name.equals(this.base_name);
            }
            _ => { return false; }
        }
        return false;
    }


    // ----------------------------------------------------------------
    // TypeAnnotation-level generic_args substitution
    // ----------------------------------------------------------------

    /// Substitute type parameters in generic arg annotations.
    /// Delegates to substitute_annotation() for each element, preserving
    /// the full structure (pointers, arrays, nested generics, etc.).
    substitute_generic_type_args(args: TypeAnnotation*[]) -> TypeAnnotation*[] {
        mut result: TypeAnnotation*[] = [];
        for (mut i: i64 = 0; i < args.length; i++) {
            result.push(this.substitute_annotation(args[i]));
        }
        return result;
    }


    // ================================================================
    // Declaration visitors — rename + substitute annotations
    // ================================================================

    override visit(node: StructDeclNode*) -> void {
        // NOTE: Rename and generic_params clearing are done by ASTCloner
        // during specialization cloning (via ASTCloner::for_specialization).
        // Doing field-level writes here (a class with vtable) caused memory
        // corruption due to C++ codegen vtable-offset bugs on class hierarchies.
        // Substitute field type annotations
        for (mut i: i64 = 0; i < node.fields.length; i++) {
            this.visit_field_decl(node.fields[i]);
        }
        // Substitute method annotations
        for (mut i: i64 = 0; i < node.methods.length; i++) {
            node.methods[i].accept(this);
        }
    }

    override visit(node: ClassDeclNode*) -> void {
        // NOTE: See StructDeclNode comment — no field-level writes here.
        for (mut i: i64 = 0; i < node.fields.length; i++) {
            this.visit_field_decl(node.fields[i]);
        }
        for (mut i: i64 = 0; i < node.methods.length; i++) {
            node.methods[i].accept(this);
        }
    }

    override visit(node: EnumDeclNode*) -> void {
        // NOTE: See StructDeclNode comment — no field-level writes here.
        for (mut i: i64 = 0; i < node.variants.length; i++) {
            node.variants[i].accept(this);
        }
    }

    override visit(node: EnumVariantNode*) -> void {
        // Substitute type annotations in associated types.
        // Now uses structured TypeAnnotation* — the same substitute_annotation()
        // used for fields, parameters, etc.
        for (mut i: i64 = 0; i < node.associated_types.length; i++) {
            this.substitute_annotation(node.associated_types[i]);
        }
    }

    override visit(node: FunctionDeclNode*) -> void {
        // NOTE: See StructDeclNode comment — no field-level writes here.
        // Substitute parameter type annotations
        for (mut i: i64 = 0; i < node.parameters.length; i++) {
            this.visit_var_decl(node.parameters[i]);
        }
        // Substitute return type annotation
        if (node.return_type_annotation != null) {
            this.substitute_annotation(node.return_type_annotation);
        }
        // Recurse into body
        if (node.has_body()) {
            node.body.accept(this);
        }
    }

    override visit(node: MethodNode*) -> void {
        // Delegate to function
        node.func.accept(this);
        // Substitute base_ctor_args expressions
        for (mut i: i64 = 0; i < node.base_ctor_args.length; i++) {
            node.base_ctor_args[i].accept(this);
        }
    }

    override visit(node: VarDeclNode*) -> void {
        this.visit_var_decl(node);
    }

    override visit(node: FieldDeclNode*) -> void {
        this.visit_field_decl(node);
    }

    override visit(node: ImplBlockNode*) -> void {
        // NOTE: See StructDeclNode comment — no field-level writes here.
        for (mut i: i64 = 0; i < node.methods.length; i++) {
            node.methods[i].accept(this);
        }
    }

    override visit(node: TypeAliasDeclNode*) -> void {
        if (node.target_annotation != null) {
            node.target_annotation = this.substitute_annotation(node.target_annotation);
        }
        // NOTE: generic_params clearing done by cloner — see StructDeclNode comment.
    }

    override visit(node: TraitDeclNode*) -> void {
        node.generic_params = [];
        for (mut i: i64 = 0; i < node.methods.length; i++) {
            node.methods[i].accept(this);
        }
    }

    override visit(node: CastExprNode*) -> void {
        node.expression.accept(this);
        if (node.target_annotation != null) {
            node.target_annotation = this.substitute_annotation(node.target_annotation);
        }
    }


    // ================================================================
    // Expression visitors — rewrite generic_args
    // ================================================================

    override visit(node: CallExprNode*) -> void {
        node.callee.accept(this);
        for (mut i: i64 = 0; i < node.arguments.length; i++) {
            node.arguments[i].accept(this);
        }
        if (node.generic_args.length > 0) {
            node.generic_args = this.substitute_generic_type_args(node.generic_args);
        }
    }

    override visit(node: NewExprNode*) -> void {
        if (node.type_name.equals(this.base_name)) {
            node.type_name = this.spec_name;
        }
        for (mut i: i64 = 0; i < node.arguments.length; i++) {
            node.arguments[i].accept(this);
        }
        if (node.generic_args.length > 0) {
            node.generic_args = this.substitute_generic_type_args(node.generic_args);
        }
        if (node.array_size != null) {
            node.array_size.accept(this);
        }
    }

    override visit(node: StructLiteralNode*) -> void {
        if (node.struct_type.equals(this.base_name)) {
            node.struct_type = this.spec_name;
        }
        if (node.generic_args.length > 0) {
            node.generic_args = this.substitute_generic_type_args(node.generic_args);
        }
        for (mut i: i64 = 0; i < node.field_inits.length; i++) {
            const val: ExpressionNode* = node.field_inits[i].value;
            if (val != null) {
                val.accept(this);
            }
        }
    }

    override visit(node: ScopeResolutionNode*) -> void {
        if (node.scope_name.equals(this.base_name)) {
            node.scope_name = this.spec_name;
        }
        if (node.generic_args.length > 0) {
            node.generic_args = this.substitute_generic_type_args(node.generic_args);
        }
        if (node.scope_generic_args.length > 0) {
            node.scope_generic_args = this.substitute_generic_type_args(node.scope_generic_args);
        }
    }

    override visit(node: SizeofExprNode*) -> void {
        for (mut i: i64 = 0; i < this.param_names.length; i++) {
            if (node.type_name.equals(this.param_names[i])) {
                node.type_name = this.type_arg_displays[i];
                break;
            }
        }
        if (node.type_name.equals(this.base_name)) {
            node.type_name = this.spec_name;
        }
    }

    override visit(node: AlignofExprNode*) -> void {
        for (mut i: i64 = 0; i < this.param_names.length; i++) {
            if (node.type_name.equals(this.param_names[i])) {
                node.type_name = this.type_arg_displays[i];
                break;
            }
        }
        if (node.type_name.equals(this.base_name)) {
            node.type_name = this.spec_name;
        }
    }


    override visit(node: TypeofExprNode*) -> void {
        if (node.operand != null) { node.operand.accept(this); }
    }

    override visit(node: DeleteExprNode*) -> void {
        if (node.operand != null) { node.operand.accept(this); }
    }

    override visit(node: AwaitExprNode*) -> void {
        if (node.operand != null) { node.operand.accept(this); }
    }

    override visit(node: YieldExprNode*) -> void {
        if (node.operand != null) { node.operand.accept(this); }
    }


    // ================================================================
    // Statement visitors — recurse into children
    // ================================================================

    override visit(node: BlockStmtNode*) -> void {
        for (mut i: i64 = 0; i < node.statements.length; i++) {
            node.statements[i].accept(this);
        }
    }

    override visit(node: UnsafeBlockStmtNode*) -> void {
        node.block.accept(this);
    }

    override visit(node: ReturnStmtNode*) -> void {
        if (node.expression != null) {
            node.expression.accept(this);
        }
    }

    override visit(node: IfStmtNode*) -> void {
        node.condition.accept(this);
        node.then_stmt.accept(this);
        if (node.else_stmt != null) {
            node.else_stmt.accept(this);
        }
    }

    override visit(node: WhileStmtNode*) -> void {
        node.condition.accept(this);
        node.body.accept(this);
    }

    override visit(node: DoWhileStmtNode*) -> void {
        node.body.accept(this);
        node.condition.accept(this);
    }

    override visit(node: LoopStmtNode*) -> void {
        if (node.body != null) { node.body.accept(this); }
    }

    override visit(node: ForStmtNode*) -> void {
        if (node.init != null) { node.init.accept(this); }
        if (node.condition != null) { node.condition.accept(this); }
        if (node.update != null) { node.update.accept(this); }
        node.body.accept(this);
    }

    override visit(node: MatchStmtNode*) -> void {
        node.subject.accept(this);
        for (mut i: i64 = 0; i < node.arms.length; i++) {
            node.arms[i].accept(this);
        }
    }

    override visit(node: SwitchStmtNode*) -> void {
        node.expression.accept(this);
        for (mut i: i64 = 0; i < node.cases.length; i++) {
            node.cases[i].accept(this);
        }
    }

    override visit(node: CaseStmtNode*) -> void {
        if (node.value != null) { node.value.accept(this); }
        node.body.accept(this);
    }

    override visit(node: ExprStmtNode*) -> void {
        node.expression.accept(this);
    }

    override visit(node: DeclStmtNode*) -> void {
        node.declaration.accept(this);
    }

    // Remaining expression visitors — recurse into children

    override visit(node: BinaryExprNode*) -> void {
        node.left.accept(this);
        node.right.accept(this);
    }

    override visit(node: UnaryExprNode*) -> void {
        node.operand.accept(this);
    }

    override visit(node: TernaryExprNode*) -> void {
        node.condition.accept(this);
        node.true_expr.accept(this);
        node.false_expr.accept(this);
    }

    override visit(node: IfExprNode*) -> void {
        node.condition.accept(this);
        node.then_expr.accept(this);
        if (node.else_expr != null) {
            node.else_expr.accept(this);
        }
    }

    override visit(node: MatchExprNode*) -> void {
        node.subject.accept(this);
        for (mut i: i64 = 0; i < node.arms.length; i++) {
            node.arms[i].accept(this);
        }
    }

    override visit(node: ArrayLiteralNode*) -> void {
        for (mut i: i64 = 0; i < node.elements.length; i++) {
            node.elements[i].accept(this);
        }
        // Substitute element_type string (element_type stays string, resolve SymbolStr for comparison)
        for (mut i: i64 = 0; i < this.param_names.length; i++) {
            if (node.element_type == this.intern_table.resolve(this.param_names[i])) {
                node.element_type = this.intern_table.resolve(this.type_arg_displays[i]);
                break;
            }
        }
        if (node.repeat_count_expr != null) {
            node.repeat_count_expr.accept(this);
        }
    }

    override visit(node: TupleLiteralNode*) -> void {
        for (mut i: i64 = 0; i < node.elements.length; i++) {
            node.elements[i].accept(this);
        }
    }

    override visit(node: LambdaExprNode*) -> void {
        for (mut i: i64 = 0; i < node.parameters.length; i++) {
            this.visit_var_decl(node.parameters[i]);
        }
        if (node.body != null) {
            node.body.accept(this);
        }
    }

    override visit(node: ArrayAccessNode*) -> void {
        node.array.accept(this);
        node.index.accept(this);
    }

    override visit(node: MemberAccessNode*) -> void {
        node.object.accept(this);
    }

    override visit(node: MatchArmNode*) -> void {
        for (mut i: i64 = 0; i < node.patterns.length; i++) {
            node.patterns[i].accept(this);
        }
        if (node.body != null) {
            node.body.accept(this);
        }
    }

    override visit(node: EnumPatternNode*) -> void {
        if (node.enum_name.equals(this.base_name)) {
            node.enum_name = this.spec_name;
        }
    }


    // ================================================================
    // Internal helpers
    // ================================================================

    visit_var_decl(node: VarDeclNode*) -> void {
        if (node.type_annotation != null) {
            node.type_annotation = this.substitute_annotation(node.type_annotation);
        }
        if (node.initializer != null) {
            node.initializer.accept(this);
        }
    }

    visit_field_decl(node: FieldDeclNode*) -> void {
        if (node.type_annotation != null) {
            node.type_annotation = this.substitute_annotation(node.type_annotation);
        }
        if (node.default_value != null) {
            node.default_value.accept(this);
        }
    }
}
