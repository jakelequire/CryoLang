namespace CLI;

public module Commands;

import Compiler;
import Compiler::Lex;
import Utils;
import Utils::File;
import CLI::Commands;

type struct Argument {
    name:          string;
    description:   string;
    default_value: string;
    aliases:       string[];
    required:      boolean;
    is_flag:       boolean;
}

type struct ParsedArgs {
private:
    args:        Map<string, Argument>;
    flags:       Map<string, Argument>;
    defines:     Map<string, Argument>;
    positionals: Argument[];

public:
    set_arg(&this, key: string, arg: Argument) -> void {
        this.args.set(key, arg);
    }

    get_arg(&this, key: string) -> Argument* {
        return this.args.get(key);
    }

    has_arg(&this, key: string) -> boolean {
        return this.args.get(key) != null;
    }

    set_flag(&this, key: string, value: string) -> void {
        const flag: Argument = Argument {
            name:          key,
            description:   "",
            default_value: value,
            aliases:       [],
            required:      false,
            is_flag:       true,
        };
        this.flags.set(key, flag);
    }

    has_flag(&this, key: string) -> boolean {
        return this.flags.get(key) != null;
    }

    add_positional(&this, value: string) -> void {
        const arg: Argument = Argument {
            name:          value,
            description:   "",
            default_value: "",
            aliases:       [],
            required:      false,
            is_flag:       false,
        };
        const idx: int = this.positionals.length;
        this.positionals[idx] = arg;
    }

    positional_count(&this) -> int {
        return this.positionals.length;
    }

    input_file(&this) -> string {
        if (this.positionals.length > 0) {
            return this.positionals[0].name;
        }
        return "";
    }
}

type struct Command {
    name:        string;
    description: string;
    usage:       string;
    arguments:   Argument[];

    static new(name: string, description: string, usage: string) -> Command {
        return Command {
            name:        name,
            description: description,
            usage:       usage,
            arguments:   [],
        };
    }

    add_argument(&this, arg: Argument) -> void {
        const l: int = this.arguments.length;
        this.arguments[l] = arg;
    }
}



type struct ArgumentParser {
    /// Parses command-line arguments starting from the given index in argv.
    /// Flags (starting with '-') go into the flags map, `-D` prefixed args
    /// go into defines, and everything else is collected as a positional.
    static parse(argc: int, argv: string*, start: int) -> ParsedArgs {
        mut result: ParsedArgs = ParsedArgs {
            args:        Map<string, Argument>::new(),
            flags:       Map<string, Argument>::new(),
            defines:     Map<string, Argument>::new(),
            positionals: [],
        };

        for (mut i: int = start; i < argc; i++) {
            const arg: string = argv[i];
            const len: int = strlen(arg) as int;

            // -D defines: -DFOO=bar or -DFOO (defaults to "true")
            if (len > 2 && strncmp(arg, "-D", 2) == 0) {
                const define_str: string = ptr_add(arg as void*, 2) as string;
                result.defines.set(define_str, Argument {
                    name:          define_str,
                    description:   "",
                    default_value: "true",
                    aliases:       [],
                    required:      false,
                    is_flag:       false,
                });
                continue;
            }

            // Flags: anything starting with '-'
            if (len >= 2 && strncmp(arg, "-", 1) == 0) {
                const name: string = ArgumentParser::normalize_flag_name(arg);
                result.set_flag(name, "true");
                continue;
            }

            // Positional argument
            result.add_positional(arg);
        }

        return result;
    }

    /// Strips leading '--' or '-' from a flag string.
    static normalize_flag_name(name: string) -> string {
        if (strncmp(name, "--", 2) == 0) {
            return ptr_add(name as void*, 2) as string;
        }
        if (strncmp(name, "-", 1) == 0) {
            return ptr_add(name as void*, 1) as string;
        }
        return name;
    }
}


type struct Runner {
private:
    commands:      Map<string, Command>;
    program_name:  string;
    version:       string;

public:
    static new(program_name: string, version: string) -> Runner {
        return Runner {
            commands:      Map<string, Command>::new(),
            program_name:  program_name,
            version:       version,
        };
    }

    /// Main entry point. Parses argv and dispatches to the appropriate
    /// command or falls back to direct file compilation.
    run(&this, argc: int, argv: string*) -> int {
        // No arguments — show help
        if (argc < 2) {
            this.print_help();
            return 0;
        }

        const first_arg: string = argv[1];

        // Global flags: --help / -h
        if (first_arg == "--help" || first_arg == "-h") {
            this.print_help();
            return 0;
        }

        // Global flags: --version / -v
        if (first_arg == "--version" || first_arg == "-v") {
            this.print_version();
            return 0;
        }

        // Try to match a registered command by name
        const cmd: Command* = this.commands.get(first_arg);
        if (cmd != null) {
            const args: ParsedArgs = ArgumentParser::parse(argc, argv, 2);
            return this.dispatch(first_arg, args);
        }

        // Not a known command — check if it's a file for direct compilation
        if (File::exists(first_arg)) {
            const args: ParsedArgs = ArgumentParser::parse(argc, argv, 2);
            return CLI::Commands::Executor::compile_file(first_arg, args);
        }

        // Nothing matched
        printf("Error: Unknown command or file '%s'\n\n", first_arg);
        this.print_help();
        return 1;
    }

    /// Registers the built-in commands.
    init_commands(&this) -> Runner {
        this.add_command(Command::new(
            "help",
            "Display help information",
            "cryoc help [command]"
        ));

        this.add_command(Command::new(
            "version",
            "Display version information",
            "cryoc version"
        ));

        return this;
    }

    add_command(&this, cmd: Command) -> void {
        this.commands.set(cmd.name, cmd);
    }

    print_help(&this) -> void {
        printf("%s %s\n\n", this.program_name, this.version);
        printf("Usage: %s <command> [options]\n", this.program_name);
        printf("       %s <file.cryo> [options]\n\n", this.program_name);
        printf("Commands:\n");
        for (mut i: int = 0; i < this.commands.keys.length; i++) {
            const cmd_name: string = this.commands.keys[i];
            const cmd: Command = this.commands.values[i];
            printf("  %-12s %s\n", cmd_name, cmd.description);
        }
        printf("\nFlags:\n");
        printf("  --help, -h     Display this help message\n");
        printf("  --version, -v  Display version information\n");
    }

    print_version(&this) -> void {
        printf("%s version %s\n", this.program_name, this.version);
    }

private:
    /// Routes a named command to the appropriate handler.
    dispatch(&this, cmd_name: string, args: ParsedArgs) -> int {
        if (cmd_name == "help") {
            this.print_help();
            return 0;
        }
        if (cmd_name == "version") {
            this.print_version();
            return 0;
        }

        printf("Error: Command '%s' is not yet implemented.\n", cmd_name);
        return 1;
    }
}

