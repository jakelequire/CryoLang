/// Pass Identity
///
/// Type-safe pass identity system replacing string-typed PassProvides
/// identifiers and the PassStage numeric enum.  Every pass has a PassID
/// (enum variant), declares its requirements and provisions as Provision
/// enum values, and is grouped into a PassStage.  ProvisionSet is a u32
/// bitset for O(1) dependency checking.

namespace Compiler::Passes::PassID;

import Compiler::Diag;
import Compiler::Diag::Snapshot;
import Compiler::Diag::Sink;


// ============================================================================
// PassID — Unique identity for every compiler pass
// ============================================================================

type enum PassID {
    // Stage 1: Frontend
    Lexing;
    Parsing;
    ASTValidation;
    CHeaderImport;

    // Stage 2: Module Resolution
    AutoImport;
    ImportResolution;
    NameResolution;

    // Stage 3: Declaration Collection
    TypeDeclaration;
    FunctionSignature;
    TemplateRegistration;

    // Stage 4: Type Resolution
    TypeResolution;
    StructFieldTypeSync;

    // Stage 5: Specialization
    DirectiveProcessing;        // Will NOT be implemented pre-self-hosting, but reserving the slot for after self-hosting is complete. synax: `![directive]`
    Monomorphization;
    GenericExpressionResolution;
    GenericValidation;

    // Stage 6: Semantic Analysis
    FunctionBodyTypeCheck;

    // Stage 7: Codegen Preparation (after sema validates everything)
    TypeLowering;
    FunctionDeclaration;

    // Stage 8: IR Generation
    IRGeneration;

    // Stage 9: Output
    Optimization;
    ObjectEmission;
    Linking;
}

implement enum PassID {
    /// Human-readable name for logging.
    name(&this) -> string {
        return match (this) {
            PassID::Lexing                      => { "Lexing"                      }
            PassID::Parsing                     => { "Parsing"                     }
            PassID::ASTValidation               => { "ASTValidation"               }
            PassID::CHeaderImport               => { "CHeaderImport"               }
            PassID::AutoImport                  => { "AutoImport"                  }
            PassID::ImportResolution            => { "ImportResolution"            }
            PassID::NameResolution              => { "NameResolution"              }
            PassID::TypeDeclaration             => { "TypeDeclaration"             }
            PassID::FunctionSignature           => { "FunctionSignature"           }
            PassID::TemplateRegistration        => { "TemplateRegistration"        }
            PassID::TypeResolution              => { "TypeResolution"              }
            PassID::StructFieldTypeSync         => { "StructFieldTypeSync"         }
            PassID::DirectiveProcessing         => { "DirectiveProcessing"         }
            PassID::Monomorphization            => { "Monomorphization"            }
            PassID::GenericExpressionResolution => { "GenericExpressionResolution" }
            PassID::GenericValidation           => { "GenericValidation"           }
            PassID::FunctionBodyTypeCheck       => { "FunctionBodyTypeCheck"       }
            PassID::TypeLowering                => { "TypeLowering"                }
            PassID::FunctionDeclaration         => { "FunctionDeclaration"         }
            PassID::IRGeneration                => { "IRGeneration"                }
            PassID::Optimization                => { "Optimization"                }
            PassID::ObjectEmission              => { "ObjectEmission"              }
            PassID::Linking                     => { "Linking"                     }
        };
    }

    /// Which pipeline stage this pass belongs to.
    stage(&this) -> PassStage {
        return match (this) {
            PassID::Lexing                      => { PassStage::Frontend              }
            PassID::Parsing                     => { PassStage::Frontend              }
            PassID::ASTValidation               => { PassStage::Frontend              }
            PassID::CHeaderImport               => { PassStage::Frontend              }
            PassID::AutoImport                  => { PassStage::ModuleResolution      }
            PassID::ImportResolution            => { PassStage::ModuleResolution      }
            PassID::NameResolution              => { PassStage::ModuleResolution      }
            PassID::TypeDeclaration             => { PassStage::DeclarationCollection }
            PassID::FunctionSignature           => { PassStage::DeclarationCollection }
            PassID::TemplateRegistration        => { PassStage::DeclarationCollection }
            PassID::TypeResolution              => { PassStage::TypeResolution        }
            PassID::StructFieldTypeSync         => { PassStage::TypeResolution        }
            PassID::DirectiveProcessing         => { PassStage::Specialization        }
            PassID::Monomorphization            => { PassStage::Specialization        }
            PassID::GenericExpressionResolution => { PassStage::Specialization        }
            PassID::GenericValidation           => { PassStage::Specialization        }
            PassID::FunctionBodyTypeCheck       => { PassStage::SemanticAnalysis      }
            PassID::TypeLowering                => { PassStage::CodegenPreparation    }
            PassID::FunctionDeclaration         => { PassStage::CodegenPreparation    }
            PassID::IRGeneration                => { PassStage::IRGeneration          }
            PassID::Optimization                => { PassStage::Output                }
            PassID::ObjectEmission              => { PassStage::Output                }
            PassID::Linking                     => { PassStage::Output                }
        };
    }

    /// Execution order within the full pipeline (0-based).
    order(&this) -> u32 {
        return match (this) {
            PassID::Lexing                      => { 0  }
            PassID::Parsing                     => { 1  }
            PassID::ASTValidation               => { 2  }
            PassID::CHeaderImport               => { 3  }
            PassID::AutoImport                  => { 4  }
            PassID::ImportResolution            => { 5  }
            PassID::NameResolution              => { 6  }
            PassID::TypeDeclaration             => { 7  }
            PassID::FunctionSignature           => { 8  }
            PassID::TemplateRegistration        => { 9  }
            PassID::TypeResolution              => { 10 }
            PassID::StructFieldTypeSync         => { 11 }
            PassID::DirectiveProcessing         => { 12 }
            PassID::Monomorphization            => { 13 }
            PassID::GenericExpressionResolution => { 14 }
            PassID::GenericValidation           => { 15 }
            PassID::FunctionBodyTypeCheck       => { 16 }
            PassID::TypeLowering                => { 17 }
            PassID::FunctionDeclaration         => { 18 }
            PassID::IRGeneration                => { 19 }
            PassID::Optimization                => { 20 }
            PassID::ObjectEmission              => { 21 }
            PassID::Linking                     => { 22 }
        };
    }

    /// Whether failure in this pass should abort the pipeline.
    fatal_on_failure(&this) -> boolean {
        return match (this) {
            PassID::Lexing                => { true  }
            PassID::Parsing               => { true  }
            PassID::ASTValidation         => { true  }
            PassID::CHeaderImport         => { false }
            PassID::NameResolution        => { true  }
            PassID::TypeResolution        => { false }
            PassID::GenericValidation     => { true  }
            PassID::FunctionBodyTypeCheck => { false }
            PassID::IRGeneration          => { true  }
            _                             => { false }
        };
    }
}


// ============================================================================
// Provision — What a pass produces
// ============================================================================

/// Each provision represents a capability or data artifact that a pass makes
/// available to downstream passes.  23 provisions fit in a u32 bitset.
type enum Provision {
    Tokens;
    AST;
    ASTValidated;
    CHeadersImported;
    ImportsDiscovered;
    ModulesLoaded;
    ModuleOrder;
    NamesResolved;
    TypeDeclarations;
    FunctionSignatures;
    TemplatesRegistered;
    TypesResolved;
    StructFieldsSynced;
    DirectivesProcessed;
    BodiesTypeChecked;
    MonomorphizationComplete;
    GenericExpressionsResolved;
    GenericsValidated;
    TypesLowered;
    FunctionsDeclared;
    IRGenerated;
    Optimized;
    ObjectsEmitted;
    Linked;
}

implement enum Provision {
    /// Bit index for the ProvisionSet bitset.
    bit_index(&this) -> u32 {
        return match (this) {
            Provision::Tokens                     => { 0  }
            Provision::AST                        => { 1  }
            Provision::ASTValidated               => { 2  }
            Provision::CHeadersImported           => { 3  }
            Provision::ImportsDiscovered          => { 4  }
            Provision::ModulesLoaded              => { 5  }
            Provision::ModuleOrder                => { 6  }
            Provision::NamesResolved              => { 7  }
            Provision::TypeDeclarations           => { 8  }
            Provision::FunctionSignatures         => { 9  }
            Provision::TemplatesRegistered        => { 10 }
            Provision::TypesResolved              => { 11 }
            Provision::StructFieldsSynced         => { 12 }
            Provision::DirectivesProcessed        => { 13 }
            Provision::BodiesTypeChecked          => { 14 }
            Provision::MonomorphizationComplete   => { 15 }
            Provision::GenericExpressionsResolved => { 16 }
            Provision::GenericsValidated          => { 17 }
            Provision::TypesLowered               => { 18 }
            Provision::FunctionsDeclared          => { 19 }
            Provision::IRGenerated                => { 20 }
            Provision::Optimized                  => { 21 }
            Provision::ObjectsEmitted             => { 22 }
            Provision::Linked                     => { 23 }
        };
    }

    name(&this) -> string {
        return match (this) {
            Provision::Tokens                     => { "Tokens"                     }
            Provision::AST                        => { "AST"                        }
            Provision::ASTValidated               => { "ASTValidated"               }
            Provision::CHeadersImported           => { "CHeadersImported"           }
            Provision::ImportsDiscovered          => { "ImportsDiscovered"          }
            Provision::ModulesLoaded              => { "ModulesLoaded"              }
            Provision::ModuleOrder                => { "ModuleOrder"                }
            Provision::NamesResolved              => { "NamesResolved"              }
            Provision::TypeDeclarations           => { "TypeDeclarations"           }
            Provision::FunctionSignatures         => { "FunctionSignatures"         }
            Provision::TemplatesRegistered        => { "TemplatesRegistered"        }
            Provision::TypesResolved              => { "TypesResolved"              }
            Provision::StructFieldsSynced         => { "StructFieldsSynced"         }
            Provision::DirectivesProcessed        => { "DirectivesProcessed"        }
            Provision::BodiesTypeChecked          => { "BodiesTypeChecked"          }
            Provision::MonomorphizationComplete   => { "MonomorphizationComplete"   }
            Provision::GenericExpressionsResolved => { "GenericExpressionsResolved" }
            Provision::GenericsValidated          => { "GenericsValidated"          }
            Provision::TypesLowered               => { "TypesLowered"               }
            Provision::FunctionsDeclared          => { "FunctionsDeclared"          }
            Provision::IRGenerated                => { "IRGenerated"                }
            Provision::Optimized                  => { "Optimized"                  }
            Provision::ObjectsEmitted             => { "ObjectsEmitted"             }
            Provision::Linked                     => { "Linked"                     }
        };
    }
}


// ============================================================================
// PassStage — Pipeline stage grouping
// ============================================================================

type enum PassStage {
    Frontend;
    ModuleResolution;
    DeclarationCollection;
    TypeResolution;
    Specialization;
    SemanticAnalysis;
    CodegenPreparation;
    IRGeneration;
    Output;
}

implement enum PassStage {
    label(&this) -> string {
        return match (this) {
            PassStage::Frontend              => { "Frontend"              }
            PassStage::ModuleResolution      => { "ModuleResolution"      }
            PassStage::DeclarationCollection => { "DeclarationCollection" }
            PassStage::TypeResolution        => { "TypeResolution"        }
            PassStage::Specialization        => { "Specialization"        }
            PassStage::SemanticAnalysis      => { "SemanticAnalysis"      }
            PassStage::CodegenPreparation    => { "CodegenPreparation"    }
            PassStage::IRGeneration          => { "IRGeneration"          }
            PassStage::Output                => { "Output"               }
        };
    }

    /// Numeric ordering for stage comparison.
    to_int(&this) -> u32 {
        return match (this) {
            PassStage::Frontend              => { 0 }
            PassStage::ModuleResolution      => { 1 }
            PassStage::DeclarationCollection => { 2 }
            PassStage::TypeResolution        => { 3 }
            PassStage::Specialization        => { 4 }
            PassStage::SemanticAnalysis      => { 5 }
            PassStage::CodegenPreparation    => { 6 }
            PassStage::IRGeneration          => { 7 }
            PassStage::Output                => { 8 }
        };
    }
}


// ============================================================================
// ProvisionSet — Bitset for O(1) provision tracking
// ============================================================================

type struct ProvisionSet {
    bits: u32;

    static empty() -> ProvisionSet {
        return ProvisionSet {
            bits: 0,
        };
    }

    /// Mark a provision as satisfied.
    mark(mut &this, p: Provision) -> void {
        const shift: u32 = p.bit_index();
        this.bits = this.bits | (1 << shift);
    }

    /// Check whether a provision has been satisfied.
    has(&this, p: Provision) -> boolean {
        const shift: u32 = p.bit_index();
        return (this.bits & (1 << shift)) != 0;
    }

    /// Reset all provisions.
    clear(mut &this) -> void {
        this.bits = 0;
    }
}


// ============================================================================
// PassRequirement — Dependency declaration
// ============================================================================

type struct PassRequirement {
    provision:   Provision;
    is_required: boolean;

    static required(p: Provision) -> PassRequirement {
        return PassRequirement {
            provision:   p,
            is_required: true,
        };
    }

    static optional(p: Provision) -> PassRequirement {
        return PassRequirement {
            provision:   p,
            is_required: false,
        };
    }
}


// ============================================================================
// PassMetadata — Static metadata for a pass
// ============================================================================

type struct PassMetadata {
    id:               PassID;
    name:             string;
    stage:            PassStage;
    order:            u32;
    requirements:     PassRequirement[];
    provisions:       Provision[];
}


// ============================================================================
// get_pass_metadata — Pure function "vtable" for all passes
// ============================================================================

/// Returns the static metadata for a given pass.  This is the single source
/// of truth for what each pass requires and provides.
function get_pass_metadata(id: PassID) -> PassMetadata {
    return match (id) {
        PassID::Lexing => {
            PassMetadata {
                id:               PassID::Lexing,
                name:             "Lexing",
                stage:            PassStage::Frontend,
                order:            0,
                requirements:     [],
                provisions:       [Provision::Tokens],
            }
        }
        PassID::Parsing => {
            PassMetadata {
                id:               PassID::Parsing,
                name:             "Parsing",
                stage:            PassStage::Frontend,
                order:            1,
                requirements:     [PassRequirement::required(Provision::Tokens)],
                provisions:       [Provision::AST],
            }
        }
        PassID::ASTValidation => {
            PassMetadata {
                id:               PassID::ASTValidation,
                name:             "ASTValidation",
                stage:            PassStage::Frontend,
                order:            2,
                requirements:     [PassRequirement::required(Provision::AST)],
                provisions:       [Provision::ASTValidated],
            }
        }
        PassID::CHeaderImport => {
            PassMetadata {
                id:               PassID::CHeaderImport,
                name:             "CHeaderImport",
                stage:            PassStage::Frontend,
                order:            3,
                requirements:     [PassRequirement::required(Provision::ASTValidated)],
                provisions:       [Provision::CHeadersImported],
            }
        }
        PassID::AutoImport => {
            PassMetadata {
                id:               PassID::AutoImport,
                name:             "AutoImport",
                stage:            PassStage::ModuleResolution,
                order:            4,
                requirements:     [PassRequirement::required(Provision::ASTValidated),
                                   PassRequirement::optional(Provision::CHeadersImported)],
                provisions:       [Provision::ImportsDiscovered],
            }
        }
        PassID::ImportResolution => {
            PassMetadata {
                id:               PassID::ImportResolution,
                name:             "ImportResolution",
                stage:            PassStage::ModuleResolution,
                order:            5,
                requirements:     [PassRequirement::required(Provision::ImportsDiscovered)],
                provisions:       [Provision::ModulesLoaded, Provision::ModuleOrder],
            }
        }
        PassID::NameResolution => {
            PassMetadata {
                id:               PassID::NameResolution,
                name:             "NameResolution",
                stage:            PassStage::ModuleResolution,
                order:            6,
                requirements:     [PassRequirement::required(Provision::ASTValidated),
                                   PassRequirement::optional(Provision::ModulesLoaded)],
                provisions:       [Provision::NamesResolved],
            }
        }
        PassID::TypeDeclaration => {
            PassMetadata {
                id:               PassID::TypeDeclaration,
                name:             "TypeDeclaration",
                stage:            PassStage::DeclarationCollection,
                order:            7,
                requirements:     [PassRequirement::required(Provision::ASTValidated),
                                   PassRequirement::required(Provision::NamesResolved)],
                provisions:       [Provision::TypeDeclarations],
            }
        }
        PassID::FunctionSignature => {
            PassMetadata {
                id:               PassID::FunctionSignature,
                name:             "FunctionSignature",
                stage:            PassStage::DeclarationCollection,
                order:            8,
                requirements:     [PassRequirement::required(Provision::TypeDeclarations)],
                provisions:       [Provision::FunctionSignatures],
            }
        }
        PassID::TemplateRegistration => {
            PassMetadata {
                id:               PassID::TemplateRegistration,
                name:             "TemplateRegistration",
                stage:            PassStage::DeclarationCollection,
                order:            9,
                requirements:     [PassRequirement::required(Provision::FunctionSignatures)],
                provisions:       [Provision::TemplatesRegistered],
            }
        }
        PassID::TypeResolution => {
            PassMetadata {
                id:               PassID::TypeResolution,
                name:             "TypeResolution",
                stage:            PassStage::TypeResolution,
                order:            10,
                requirements:     [PassRequirement::required(Provision::TemplatesRegistered)],
                provisions:       [Provision::TypesResolved],
            }
        }
        PassID::StructFieldTypeSync => {
            PassMetadata {
                id:               PassID::StructFieldTypeSync,
                name:             "StructFieldTypeSync",
                stage:            PassStage::TypeResolution,
                order:            11,
                requirements:     [PassRequirement::required(Provision::TypesResolved)],
                provisions:       [Provision::StructFieldsSynced],
            }
        }
        PassID::DirectiveProcessing => {
            PassMetadata {
                id:               PassID::DirectiveProcessing,
                name:             "DirectiveProcessing",
                stage:            PassStage::SemanticAnalysis,
                order:            12,
                requirements:     [PassRequirement::required(Provision::TypesResolved)],
                provisions:       [Provision::DirectivesProcessed],
            }
        }
        PassID::Monomorphization => {
            PassMetadata {
                id:               PassID::Monomorphization,
                name:             "Monomorphization",
                stage:            PassStage::Specialization,
                order:            13,
                requirements:     [PassRequirement::required(Provision::StructFieldsSynced),
                                   PassRequirement::optional(Provision::DirectivesProcessed)],
                provisions:       [Provision::MonomorphizationComplete],
            }
        }
        PassID::GenericExpressionResolution => {
            PassMetadata {
                id:               PassID::GenericExpressionResolution,
                name:             "GenericExpressionResolution",
                stage:            PassStage::Specialization,
                order:            14,
                requirements:     [PassRequirement::required(Provision::MonomorphizationComplete)],
                provisions:       [Provision::GenericExpressionsResolved],
            }
        }
        PassID::GenericValidation => {
            PassMetadata {
                id:               PassID::GenericValidation,
                name:             "GenericValidation",
                stage:            PassStage::Specialization,
                order:            15,
                requirements:     [PassRequirement::required(Provision::GenericExpressionsResolved)],
                provisions:       [Provision::GenericsValidated],
            }
        }
        PassID::FunctionBodyTypeCheck => {
            PassMetadata {
                id:               PassID::FunctionBodyTypeCheck,
                name:             "FunctionBodyTypeCheck",
                stage:            PassStage::SemanticAnalysis,
                order:            16,
                requirements:     [PassRequirement::required(Provision::GenericsValidated)],
                provisions:       [Provision::BodiesTypeChecked],
            }
        }
        PassID::TypeLowering => {
            PassMetadata {
                id:               PassID::TypeLowering,
                name:             "TypeLowering",
                stage:            PassStage::CodegenPreparation,
                order:            17,
                requirements:     [PassRequirement::required(Provision::BodiesTypeChecked)],
                provisions:       [Provision::TypesLowered],
            }
        }
        PassID::FunctionDeclaration => {
            PassMetadata {
                id:               PassID::FunctionDeclaration,
                name:             "FunctionDeclaration",
                stage:            PassStage::CodegenPreparation,
                order:            18,
                requirements:     [PassRequirement::required(Provision::TypesLowered)],
                provisions:       [Provision::FunctionsDeclared],
            }
        }
        PassID::IRGeneration => {
            PassMetadata {
                id:               PassID::IRGeneration,
                name:             "IRGeneration",
                stage:            PassStage::IRGeneration,
                order:            19,
                requirements:     [PassRequirement::required(Provision::FunctionsDeclared)],
                provisions:       [Provision::IRGenerated],
            }
        }
        PassID::Optimization => {
            PassMetadata {
                id:               PassID::Optimization,
                name:             "Optimization",
                stage:            PassStage::Output,
                order:            20,
                requirements:     [PassRequirement::required(Provision::IRGenerated)],
                provisions:       [Provision::Optimized],
            }
        }
        PassID::ObjectEmission => {
            PassMetadata {
                id:               PassID::ObjectEmission,
                name:             "ObjectEmission",
                stage:            PassStage::Output,
                order:            21,
                requirements:     [PassRequirement::required(Provision::IRGenerated),
                                   PassRequirement::optional(Provision::Optimized)],
                provisions:       [Provision::ObjectsEmitted],
            }
        }
        PassID::Linking => {
            PassMetadata {
                id:               PassID::Linking,
                name:             "Linking",
                stage:            PassStage::Output,
                order:            22,
                requirements:     [PassRequirement::required(Provision::ObjectsEmitted)],
                provisions:       [Provision::Linked],
            }
        }
    };
}


// ============================================================================
// PassResult — Return value from running a single pass
// ============================================================================

type struct PassResult {
    success:          boolean;
    skipped:          boolean;
    errors_emitted:   u32;
    warnings_emitted: u32;

    /// The pass succeeded.
    static ok() -> PassResult {
        return PassResult {
            success:          true,
            skipped:          false,
            errors_emitted:   0,
            warnings_emitted: 0,
        };
    }

    /// The pass was skipped (not yet implemented).
    static stub() -> PassResult {
        return PassResult {
            success:          true,
            skipped:          true,
            errors_emitted:   0,
            warnings_emitted: 0,
        };
    }

    /// The pass failed, emitting this many errors.
    static failure(errors: u32) -> PassResult {
        return PassResult {
            success:          false,
            skipped:          false,
            errors_emitted:   errors,
            warnings_emitted: 0,
        };
    }

    /// Build a PassResult from a DiagnosticSink snapshot comparison.
    static from_snapshot(sink: DiagnosticSink, before: DiagnosticSnapshot) -> PassResult {
        const errors: u32   = sink.errors_since(before);
        const warnings: u32 = sink.warnings_since(before);
        return PassResult {
            success:          errors == 0,
            skipped:          false,
            errors_emitted:   errors,
            warnings_emitted: warnings,
        };
    }
}
