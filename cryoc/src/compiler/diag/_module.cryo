/// Diagnostics Module
///
/// Unified diagnostic system replacing DiagEmitter and manual error-count
/// diffing.  DiagnosticSink collects all diagnostics; DiagnosticSnapshot
/// enables per-pass error isolation without global counter manipulation.

namespace Compiler::Diag;

public module Severity;
public module SourceSpan;
public module SpanLabel;
public module Suggestion;
public module Diagnostic;
public module Snapshot;
public module Sink;
public module Renderer;
public module Config;
public module Lsp;


type enum ErrorCode {
    // Unknown Error
    E0000_UNKNOWN = 0;

    /* Lexical Analysis Errors (E0001-E0099) */
    E0001_UNEXPECTED_CHARACTER    = 1;
    E0002_UNTERMINATED_STRING     = 2;
    E0003_UNTERMINATED_CHAR       = 3;
    E0004_INVALID_NUMBER          = 4;
    E0005_INVALID_ESCAPE          = 5;
    E0006_INVALID_UNICODE         = 6;
    E0007_INVALID_HEX             = 7;
    E0008_INVALID_BINARY          = 8;
    E0009_INVALID_OCTAL           = 9;
    E0010_NUMBER_TOO_LARGE        = 10;
    E0011_LEXING_EXCEPTION        = 11;

    /* AST Validation Errors (E0050-E0069) */
    E0050_NULL_AST_NODE              = 50;
    E0051_MISSING_FUNCTION_NAME      = 51;
    E0052_MISSING_TYPE_NAME          = 52;
    E0053_NULL_PARAMETER             = 53;
    E0054_NULL_FIELD                 = 54;
    E0055_NULL_METHOD                = 55;
    E0056_METHOD_MISSING_FUNC        = 56;
    E0057_EMPTY_ENUM_VARIANTS        = 57;
    E0058_NULL_ENUM_VARIANT          = 58;
    E0059_NULL_BLOCK_STATEMENT       = 59;
    E0060_EMPTY_PROGRAM              = 60;
    E0061_TYPE_ALIAS_MISSING_TARGET  = 61;
    E0062_IMPL_MISSING_TARGET        = 62;
    E0063_IMPORT_MISSING_PATH        = 63;

    /* Syntax Errors (E0100-E0199) */
    E0100_EXPECTED_TOKEN          = 100;
    E0101_UNEXPECTED_TOKEN        = 101;
    E0102_EXPECTED_EXPRESSION     = 102;
    E0103_EXPECTED_STATEMENT      = 103;
    E0104_EXPECTED_TYPE           = 104;
    E0105_EXPECTED_IDENTIFIER     = 105;
    E0106_EXPECTED_SEMICOLON      = 106;
    E0107_EXPECTED_PAREN          = 107;
    E0108_EXPECTED_BRACE          = 108;
    E0109_EXPECTED_BRACKET        = 109;
    E0110_MISMATCHED_DELIMITERS   = 110;
    E0111_INVALID_SYNTAX          = 111;
    E0112_UNEXPECTED_EOF          = 112;
    E0113_INVALID_PATTERN         = 113;
    E0114_DUPLICATE_DEFAULT       = 114;
    E0115_PARSE_RECOVERY_FAILED   = 115;
    E0116_PARSE_EXCEPTION         = 116;

    /* Type Checking Errors (E0200-E0399) */
    E0200_TYPE_MISMATCH             = 200;
    E0201_UNDEFINED_VARIABLE        = 201;
    E0202_UNDEFINED_FUNCTION        = 202;
    E0203_UNDEFINED_TYPE            = 203;
    E0204_UNDEFINED_FIELD           = 204;
    E0205_REDEFINED_SYMBOL          = 205;
    E0206_REDEFINED_FUNCTION        = 206;
    E0207_REDEFINED_TYPE            = 207;
    E0208_INVALID_CAST              = 208;
    E0209_INVALID_OPERATION         = 209;
    E0210_INVALID_ASSIGNMENT        = 210;
    E0211_INCOMPATIBLE_TYPES        = 211;
    E0212_VOID_VALUE_USED           = 212;
    E0213_NON_CALLABLE              = 213;
    E0214_ARGUMENT_MISMATCH         = 214;
    E0215_TOO_MANY_ARGS             = 215;
    E0216_TOO_FEW_ARGS              = 216;
    E0217_CONST_VIOLATION           = 217;
    E0218_IMMUTABLE_ASSIGNMENT      = 218;
    E0219_UNINITIALIZED_VAR         = 219;
    E0220_UNREACHABLE_CODE          = 220;
    E0221_CIRCULAR_DEPENDENCY       = 221;
    E0222_INVALID_DEREF             = 222;
    E0223_INVALID_ADDRESS_OF        = 223;
    E0224_INVALID_INDEX             = 224;
    E0225_INDEX_OUT_OF_BOUNDS       = 225;
    E0226_DIVISION_BY_ZERO          = 226;
    E0227_OVERFLOW                  = 227;
    E0228_UNDERFLOW                 = 228;
    E0229_INVALID_BINARY_OP         = 229;
    E0230_INVALID_UNARY_OP          = 230;
    E0231_NON_CALLABLE_TYPE         = 231;
    E0232_INVALID_ASSIGNMENT_TARGET = 232;
    E0233_UNDEFINED_SYMBOL          = 233;

    /* Generic/Template Errors (E0300-E0349) */
    E0300_GENERIC_INSTANTIATION_FAILED   =  300;
    E0301_GENERIC_TYPE_RESOLUTION_FAILED =  301;
    E0302_GENERIC_PARAM_MISMATCH         =  302;
    E0303_INVALID_GENERIC_CONSTRAINT     =  303;
    E0304_AMBIGUOUS_GENERIC              =  304;
    E0305_RECURSIVE_GENERIC              =  305;

    /* Struct/Class Errors (E0350-E0399) */
    E0350_STRUCT_FIELD_NOT_FOUND = 350;
    E0351_CLASS_MEMBER_NOT_FOUND = 351;
    E0352_CONSTRUCTOR_NOT_FOUND  = 352;
    E0353_PRIVATE_ACCESS         = 353;
    E0354_ABSTRACT_METHOD_CALL   = 354;
    E0355_MISSING_FIELD_INIT     = 355;
    E0356_DUPLICATE_FIELD        = 356;
    E0357_INVALID_INSTANTIATION  = 357;
    E0358_UNDEFINED_METHOD_IMPL  = 358;

    /* Control Flow Errors (E0400-E0449) */
    E0400_INVALID_BREAK          = 400;
    E0401_INVALID_CONTINUE       = 401;
    E0402_INVALID_RETURN         = 402;
    E0403_MISSING_RETURN         = 403;
    E0404_UNREACHABLE_PATTERN    = 404;
    E0405_NON_EXHAUSTIVE_MATCH   = 405;

    /* Memory Management Errors (E0450-E0499) */
    E0450_INVALID_BORROW         = 450;
    E0451_BORROW_CHECK_FAILED    = 451;
    E0452_USE_AFTER_MOVE         = 452;
    E0453_DOUBLE_FREE            = 453;
    E0454_MEMORY_LEAK            = 454;
    E0455_DANGLING_POINTER       = 455;

    /* Module System Errors (E0500-E0549) */
    E0500_MODULE_NOT_FOUND       = 500;
    E0501_CIRCULAR_IMPORT        = 501;
    E0502_INVALID_IMPORT         = 502;
    E0503_PRIVATE_SYMBOL_ACCESS  = 503;
    E0504_NAMESPACE_CONFLICT     = 504;

    /* Code Generation Errors (E0600-E0699) */
    E0600_CODEGEN_FAILED                = 600;
    E0601_LLVM_ERROR                    = 601;
    E0602_INVALID_LLVM_TYPE             = 602;
    E0603_INVALID_LLVM_VALUE            = 603;
    E0604_UNIMPLEMENTED_INTRINSIC       = 604;
    E0605_OPTIMIZATION_FAILED           = 605;
    E0606_FUNCTION_GENERATION_ERROR     = 606;
    E0607_VARIABLE_GENERATION_ERROR     = 607;
    E0608_INTRINSIC_GENERATION_ERROR    = 608;
    E0609_TYPE_MAPPING_ERROR            = 609;
    E0610_CLASS_GENERATION_ERROR        = 610;
    E0611_ENUM_GENERATION_ERROR         = 611;
    E0612_STRUCT_GENERATION_ERROR       = 612;
    E0613_CONTROL_FLOW_ERROR            = 613;
    E0614_ASSIGNMENT_ERROR              = 614;
    E0615_BINARY_OPERATION_ERROR        = 615;
    E0616_UNARY_OPERATION_ERROR         = 616;
    E0617_MEMORY_OPERATION_ERROR        = 617;
    E0618_CONSTRUCTOR_GENERATION_ERROR  = 618;
    E0619_METHOD_GENERATION_ERROR       = 619;
    E0620_MODULE_CONTEXT_ERROR          = 620;
    E0621_ARRAY_OPERATION_ERROR         = 621;
    E0622_MEMBER_ACCESS_ERROR           = 622;
    E0623_SCOPE_RESOLUTION_ERROR        = 623;
    E0624_EXCEPTION_HANDLER_ERROR       = 624;
    E0625_LITERAL_GENERATION_ERROR      = 625;
    E0626_CAST_OPERATION_ERROR          = 626;
    E0627_LOOP_GENERATION_ERROR         = 627;
    E0628_PATTERN_MATCHING_ERROR        = 628;
    E0629_TEMPLATE_INSTANTIATION_ERROR  = 629;
    E0630_OPTIMIZATION_ERROR            = 630;
    E0631_ENUM_OPERATION_ERROR          = 631;
    E0632_TYPE_RESOLUTION_ERROR         = 632;
    E0633_FUNCTION_BODY_ERROR           = 633;
    E0634_VARIABLE_INITIALIZATION_ERROR = 634;
    E0635_TYPE_CONSTRUCTOR_UNDEFINED    = 635;
    E0636_UNDEFINED_FUNCTION_CALL       = 636;
    E0637_INVALID_GENERIC_INSTANTIATION = 637;
    E0638_INVALID_STRUCT_INITIALIZATION = 638;
    E0639_INVALID_CLASS_INSTANTIATION   = 639;
    E0640_INVALID_ENUM_VARIANT_ACCESS   = 640;
    E0641_NULL_CAST_EXPRESSION          = 641;
    E0642_PARAM_TYPE_ERROR              = 642;
    E0643_RETURN_TYPE_ERROR             = 643;
    E0644_FIELD_TYPE_ERROR              = 644;

    /* Linker Errors (E0700-E0799) */
    E0700_LINK_ERROR                    = 700;
    E0701_UNDEFINED_SYMBOL_LINK         = 701;
    E0702_DUPLICATE_SYMBOL_LINK         = 702;
    E0703_LIBRARY_NOT_FOUND             = 703;
    E0704_INVALID_TARGET                = 704;

    /* System/IO Errors (E0800-E0899) */
    E0800_FILE_NOT_FOUND                = 800;
    E0801_FILE_READ_ERROR               = 801;
    E0802_FILE_WRITE_ERROR              = 802;
    E0803_PERMISSION_DENIED             = 803;
    E0804_OUT_OF_MEMORY                 = 804;
    E0805_INTERNAL_ERROR                = 805;

    /* Internal Compiler Errors (E0900-E0999) */
    E0900_INTERNAL_COMPILER_ERROR           = 900;
    E0901_UNEXPECTED_COMPILER_STATE         = 901;
    E0902_COMPILER_ASSERTION_FAILED         = 902;
    E0903_UNHANDLED_EXCEPTION               = 903;
    E0904_COMPILER_CONFIGURATION_ERROR      = 904;
    E0905_SRM_MANAGER_UNAVAILABLE           = 905;
    E0906_SRM_TYPE_RESOLUTION_FAILED        = 906;
    E0907_METHOD_NOT_FOUND                  = 907;
    E0908_SRM_METHOD_RESOLUTION_FAILED      = 908;
    E0909_SRM_CONSTRUCTOR_GENERATION_FAILED = 909;

    /* Warning Codes (W0001-W9999) */
    W0001_UNUSED_VARIABLE               = 10001;
    W0002_UNUSED_FUNCTION               = 10002;
    W0003_UNUSED_IMPORT                 = 10003;
    W0004_SHADOWED_VARIABLE             = 10004;
    W0005_IMPLICIT_CONVERSION           = 10005;
    W0006_LOSSY_CONVERSION              = 10006;
    W0007_DEPRECATED                    = 10007;
    W0008_UNNECESSARY_CAST              = 10008;
    W0009_DEAD_CODE                     = 10009;
    W0010_MISSING_DOCS                  = 10010;
}

implement enum ErrorCode {
    /// Format as "E0200" or "W0001" depending on the code range.
    format(&this) -> string {
        const val: u32 = this as u32;
        if (val >= 10000) {
            // Warning codes: W + (val - 10000) zero-padded to 4 digits
            return sprintf("W%04u", val - 10000);
        }
        return sprintf("E%04u", val);
    }

    /// Return the numeric value as u32 for formatting purposes.
    to_u32(&this) -> u32 {
        return this as u32;
    }

    /// Returns true for warning codes (>= 10000).
    is_warning_code(&this) -> boolean {
        return (this as u32) >= 10000;
    }

    to_string(&this) -> string {
        return match (this) {
            // Unknown
            E0000_UNKNOWN => { "E0000: Unknown Error" }

            // Lexical Analysis Errors
            E0001_UNEXPECTED_CHARACTER => { "E0001: Unexpected Character" }
            E0002_UNTERMINATED_STRING  => { "E0002: Unterminated String" }
            E0003_UNTERMINATED_CHAR    => { "E0003: Unterminated Character" }
            E0004_INVALID_NUMBER       => { "E0004: Invalid Number" }
            E0005_INVALID_ESCAPE       => { "E0005: Invalid Escape Sequence" }
            E0006_INVALID_UNICODE      => { "E0006: Invalid Unicode" }
            E0007_INVALID_HEX          => { "E0007: Invalid Hexadecimal" }
            E0008_INVALID_BINARY       => { "E0008: Invalid Binary" }
            E0009_INVALID_OCTAL        => { "E0009: Invalid Octal" }
            E0010_NUMBER_TOO_LARGE     => { "E0010: Number Too Large" }
            E0011_LEXING_EXCEPTION     => { "E0011: Lexing Exception" }

            // AST Validation Errors
            E0050_NULL_AST_NODE             => { "E0050: Null AST Node" }
            E0051_MISSING_FUNCTION_NAME     => { "E0051: Missing Function Name" }
            E0052_MISSING_TYPE_NAME         => { "E0052: Missing Type Name" }
            E0053_NULL_PARAMETER            => { "E0053: Null Parameter" }
            E0054_NULL_FIELD                => { "E0054: Null Field" }
            E0055_NULL_METHOD               => { "E0055: Null Method" }
            E0056_METHOD_MISSING_FUNC       => { "E0056: Method Missing Function" }
            E0057_EMPTY_ENUM_VARIANTS       => { "E0057: Enum Has No Variants" }
            E0058_NULL_ENUM_VARIANT         => { "E0058: Null Enum Variant" }
            E0059_NULL_BLOCK_STATEMENT      => { "E0059: Null Block Statement" }
            E0060_EMPTY_PROGRAM             => { "E0060: Empty Program" }
            E0061_TYPE_ALIAS_MISSING_TARGET => { "E0061: Type Alias Missing Target" }
            E0062_IMPL_MISSING_TARGET       => { "E0062: Impl Block Missing Target" }
            E0063_IMPORT_MISSING_PATH       => { "E0063: Import Missing Path" }

            // Syntax Errors
            E0100_EXPECTED_TOKEN        => { "E0100: Expected Token" }
            E0101_UNEXPECTED_TOKEN      => { "E0101: Unexpected Token" }
            E0102_EXPECTED_EXPRESSION   => { "E0102: Expected Expression" }
            E0103_EXPECTED_STATEMENT    => { "E0103: Expected Statement" }
            E0104_EXPECTED_TYPE         => { "E0104: Expected Type" }
            E0105_EXPECTED_IDENTIFIER   => { "E0105: Expected Identifier" }
            E0106_EXPECTED_SEMICOLON    => { "E0106: Expected Semicolon" }
            E0107_EXPECTED_PAREN        => { "E0107: Expected Parenthesis" }
            E0108_EXPECTED_BRACE        => { "E0108: Expected Brace" }
            E0109_EXPECTED_BRACKET      => { "E0109: Expected Bracket" }
            E0110_MISMATCHED_DELIMITERS => { "E0110: Mismatched Delimiters" }
            E0111_INVALID_SYNTAX        => { "E0111: Invalid Syntax" }
            E0112_UNEXPECTED_EOF        => { "E0112: Unexpected End of File" }
            E0113_INVALID_PATTERN       => { "E0113: Invalid Pattern" }
            E0114_DUPLICATE_DEFAULT     => { "E0114: Duplicate Default" }
            E0115_PARSE_RECOVERY_FAILED => { "E0115: Parse Recovery Failed" }
            E0116_PARSE_EXCEPTION       => { "E0116: Parse Exception" }

            // Type Checking Errors
            E0200_TYPE_MISMATCH             => { "E0200: Type Mismatch" }
            E0201_UNDEFINED_VARIABLE        => { "E0201: Undefined Variable" }
            E0202_UNDEFINED_FUNCTION        => { "E0202: Undefined Function" }
            E0203_UNDEFINED_TYPE            => { "E0203: Undefined Type" }
            E0204_UNDEFINED_FIELD           => { "E0204: Undefined Field" }
            E0205_REDEFINED_SYMBOL          => { "E0205: Redefined Symbol" }
            E0206_REDEFINED_FUNCTION        => { "E0206: Redefined Function" }
            E0207_REDEFINED_TYPE            => { "E0207: Redefined Type" }
            E0208_INVALID_CAST              => { "E0208: Invalid Cast" }
            E0209_INVALID_OPERATION         => { "E0209: Invalid Operation" }
            E0210_INVALID_ASSIGNMENT        => { "E0210: Invalid Assignment" }
            E0211_INCOMPATIBLE_TYPES        => { "E0211: Incompatible Types" }
            E0212_VOID_VALUE_USED           => { "E0212: Void Value Used" }
            E0213_NON_CALLABLE              => { "E0213: Non-Callable" }
            E0214_ARGUMENT_MISMATCH         => { "E0214: Argument Mismatch" }
            E0215_TOO_MANY_ARGS             => { "E0215: Too Many Arguments" }
            E0216_TOO_FEW_ARGS              => { "E0216: Too Few Arguments" }
            E0217_CONST_VIOLATION           => { "E0217: Const Violation" }
            E0218_IMMUTABLE_ASSIGNMENT      => { "E0218: Immutable Assignment" }
            E0219_UNINITIALIZED_VAR         => { "E0219: Uninitialized Variable" }
            E0220_UNREACHABLE_CODE          => { "E0220: Unreachable Code" }
            E0221_CIRCULAR_DEPENDENCY       => { "E0221: Circular Dependency" }
            E0222_INVALID_DEREF             => { "E0222: Invalid Dereference" }
            E0223_INVALID_ADDRESS_OF        => { "E0223: Invalid Address-Of" }
            E0224_INVALID_INDEX             => { "E0224: Invalid Index" }
            E0225_INDEX_OUT_OF_BOUNDS       => { "E0225: Index Out of Bounds" }
            E0226_DIVISION_BY_ZERO          => { "E0226: Division by Zero" }
            E0227_OVERFLOW                  => { "E0227: Overflow" }
            E0228_UNDERFLOW                 => { "E0228: Underflow" }
            E0229_INVALID_BINARY_OP         => { "E0229: Invalid Binary Operation" }
            E0230_INVALID_UNARY_OP          => { "E0230: Invalid Unary Operation" }
            E0231_NON_CALLABLE_TYPE         => { "E0231: Non-Callable Type" }
            E0232_INVALID_ASSIGNMENT_TARGET => { "E0232: Invalid Assignment Target" }
            E0233_UNDEFINED_SYMBOL          => { "E0233: Undefined Symbol" }

            // Generic/Template Errors
            E0300_GENERIC_INSTANTIATION_FAILED   => { "E0300: Generic Instantiation Failed" }
            E0301_GENERIC_TYPE_RESOLUTION_FAILED => { "E0301: Generic Type Resolution Failed" }
            E0302_GENERIC_PARAM_MISMATCH         => { "E0302: Generic Parameter Mismatch" }
            E0303_INVALID_GENERIC_CONSTRAINT     => { "E0303: Invalid Generic Constraint" }
            E0304_AMBIGUOUS_GENERIC              => { "E0304: Ambiguous Generic" }
            E0305_RECURSIVE_GENERIC              => { "E0305: Recursive Generic" }

            // Struct/Class Errors
            E0350_STRUCT_FIELD_NOT_FOUND => { "E0350: Struct Field Not Found" }
            E0351_CLASS_MEMBER_NOT_FOUND => { "E0351: Class Member Not Found" }
            E0352_CONSTRUCTOR_NOT_FOUND  => { "E0352: Constructor Not Found" }
            E0353_PRIVATE_ACCESS         => { "E0353: Private Access Violation" }
            E0354_ABSTRACT_METHOD_CALL   => { "E0354: Abstract Method Call" }
            E0355_MISSING_FIELD_INIT     => { "E0355: Missing Field Initialization" }
            E0356_DUPLICATE_FIELD        => { "E0356: Duplicate Field" }
            E0357_INVALID_INSTANTIATION  => { "E0357: Invalid Instantiation" }
            E0358_UNDEFINED_METHOD_IMPL  => { "E0358: Undefined Method Implementation" }

            // Control Flow Errors
            E0400_INVALID_BREAK        => { "E0400: Invalid Break" }
            E0401_INVALID_CONTINUE     => { "E0401: Invalid Continue" }
            E0402_INVALID_RETURN       => { "E0402: Invalid Return" }
            E0403_MISSING_RETURN       => { "E0403: Missing Return" }
            E0404_UNREACHABLE_PATTERN  => { "E0404: Unreachable Pattern" }
            E0405_NON_EXHAUSTIVE_MATCH => { "E0405: Non-Exhaustive Match" }

            // Memory Management Errors
            E0450_INVALID_BORROW      => { "E0450: Invalid Borrow" }
            E0451_BORROW_CHECK_FAILED => { "E0451: Borrow Check Failed" }
            E0452_USE_AFTER_MOVE      => { "E0452: Use After Move" }
            E0453_DOUBLE_FREE         => { "E0453: Double Free" }
            E0454_MEMORY_LEAK         => { "E0454: Memory Leak" }
            E0455_DANGLING_POINTER    => { "E0455: Dangling Pointer" }

            // Module System Errors
            E0500_MODULE_NOT_FOUND      => { "E0500: Module Not Found" }
            E0501_CIRCULAR_IMPORT       => { "E0501: Circular Import" }
            E0502_INVALID_IMPORT        => { "E0502: Invalid Import" }
            E0503_PRIVATE_SYMBOL_ACCESS => { "E0503: Private Symbol Access" }
            E0504_NAMESPACE_CONFLICT    => { "E0504: Namespace Conflict" }

            // Code Generation Errors
            E0600_CODEGEN_FAILED                => { "E0600: Code Generation Failed" }
            E0601_LLVM_ERROR                    => { "E0601: LLVM Error" }
            E0602_INVALID_LLVM_TYPE             => { "E0602: Invalid LLVM Type" }
            E0603_INVALID_LLVM_VALUE            => { "E0603: Invalid LLVM Value" }
            E0604_UNIMPLEMENTED_INTRINSIC       => { "E0604: Unimplemented Intrinsic" }
            E0605_OPTIMIZATION_FAILED           => { "E0605: Optimization Failed" }
            E0606_FUNCTION_GENERATION_ERROR     => { "E0606: Function Generation Error" }
            E0607_VARIABLE_GENERATION_ERROR     => { "E0607: Variable Generation Error" }
            E0608_INTRINSIC_GENERATION_ERROR    => { "E0608: Intrinsic Generation Error" }
            E0609_TYPE_MAPPING_ERROR            => { "E0609: Type Mapping Error" }
            E0610_CLASS_GENERATION_ERROR        => { "E0610: Class Generation Error" }
            E0611_ENUM_GENERATION_ERROR         => { "E0611: Enum Generation Error" }
            E0612_STRUCT_GENERATION_ERROR       => { "E0612: Struct Generation Error" }
            E0613_CONTROL_FLOW_ERROR            => { "E0613: Control Flow Error" }
            E0614_ASSIGNMENT_ERROR              => { "E0614: Assignment Error" }
            E0615_BINARY_OPERATION_ERROR        => { "E0615: Binary Operation Error" }
            E0616_UNARY_OPERATION_ERROR         => { "E0616: Unary Operation Error" }
            E0617_MEMORY_OPERATION_ERROR        => { "E0617: Memory Operation Error" }
            E0618_CONSTRUCTOR_GENERATION_ERROR  => { "E0618: Constructor Generation Error" }
            E0619_METHOD_GENERATION_ERROR       => { "E0619: Method Generation Error" }
            E0620_MODULE_CONTEXT_ERROR          => { "E0620: Module Context Error" }
            E0621_ARRAY_OPERATION_ERROR         => { "E0621: Array Operation Error" }
            E0622_MEMBER_ACCESS_ERROR           => { "E0622: Member Access Error" }
            E0623_SCOPE_RESOLUTION_ERROR        => { "E0623: Scope Resolution Error" }
            E0624_EXCEPTION_HANDLER_ERROR       => { "E0624: Exception Handler Error" }
            E0625_LITERAL_GENERATION_ERROR      => { "E0625: Literal Generation Error" }
            E0626_CAST_OPERATION_ERROR          => { "E0626: Cast Operation Error" }
            E0627_LOOP_GENERATION_ERROR         => { "E0627: Loop Generation Error" }
            E0628_PATTERN_MATCHING_ERROR        => { "E0628: Pattern Matching Error" }
            E0629_TEMPLATE_INSTANTIATION_ERROR  => { "E0629: Template Instantiation Error" }
            E0630_OPTIMIZATION_ERROR            => { "E0630: Optimization Error" }
            E0631_ENUM_OPERATION_ERROR          => { "E0631: Enum Operation Error" }
            E0632_TYPE_RESOLUTION_ERROR         => { "E0632: Type Resolution Error" }
            E0633_FUNCTION_BODY_ERROR           => { "E0633: Function Body Error" }
            E0634_VARIABLE_INITIALIZATION_ERROR => { "E0634: Variable Initialization Error" }
            E0635_TYPE_CONSTRUCTOR_UNDEFINED    => { "E0635: Type Constructor Undefined" }
            E0636_UNDEFINED_FUNCTION_CALL       => { "E0636: Undefined Function Call" }
            E0637_INVALID_GENERIC_INSTANTIATION => { "E0637: Invalid Generic Instantiation" }
            E0638_INVALID_STRUCT_INITIALIZATION => { "E0638: Invalid Struct Initialization" }
            E0639_INVALID_CLASS_INSTANTIATION   => { "E0639: Invalid Class Instantiation" }
            E0640_INVALID_ENUM_VARIANT_ACCESS   => { "E0640: Invalid Enum Variant Access" }
            E0641_NULL_CAST_EXPRESSION          => { "E0641: Null Cast Expression" }
            E0642_PARAM_TYPE_ERROR              => { "E0642: Parameter Type Error" }
            E0643_RETURN_TYPE_ERROR             => { "E0643: Return Type Error" }
            E0644_FIELD_TYPE_ERROR              => { "E0644: Field Type Error" }

            // Linker Errors
            E0700_LINK_ERROR             => { "E0700: Link Error" }
            E0701_UNDEFINED_SYMBOL_LINK  => { "E0701: Undefined Symbol (Linker)" }
            E0702_DUPLICATE_SYMBOL_LINK  => { "E0702: Duplicate Symbol (Linker)" }
            E0703_LIBRARY_NOT_FOUND      => { "E0703: Library Not Found" }
            E0704_INVALID_TARGET         => { "E0704: Invalid Target" }

            // System/IO Errors
            E0800_FILE_NOT_FOUND    => { "E0800: File Not Found" }
            E0801_FILE_READ_ERROR   => { "E0801: File Read Error" }
            E0802_FILE_WRITE_ERROR  => { "E0802: File Write Error" }
            E0803_PERMISSION_DENIED => { "E0803: Permission Denied" }
            E0804_OUT_OF_MEMORY     => { "E0804: Out of Memory" }
            E0805_INTERNAL_ERROR    => { "E0805: Internal Error" }

            // Internal Compiler Errors
            E0900_INTERNAL_COMPILER_ERROR           => { "E0900: Internal Compiler Error" }
            E0901_UNEXPECTED_COMPILER_STATE         => { "E0901: Unexpected Compiler State" }
            E0902_COMPILER_ASSERTION_FAILED         => { "E0902: Compiler Assertion Failed" }
            E0903_UNHANDLED_EXCEPTION               => { "E0903: Unhandled Exception" }
            E0904_COMPILER_CONFIGURATION_ERROR      => { "E0904: Compiler Configuration Error" }
            E0905_SRM_MANAGER_UNAVAILABLE           => { "E0905: SRM Manager Unavailable" }
            E0906_SRM_TYPE_RESOLUTION_FAILED        => { "E0906: SRM Type Resolution Failed" }
            E0907_METHOD_NOT_FOUND                  => { "E0907: Method Not Found" }
            E0908_SRM_METHOD_RESOLUTION_FAILED      => { "E0908: SRM Method Resolution Failed" }
            E0909_SRM_CONSTRUCTOR_GENERATION_FAILED => { "E0909: SRM Constructor Generation Failed" }

            // Warnings
            W0001_UNUSED_VARIABLE     => { "W0001: Unused Variable" }
            W0002_UNUSED_FUNCTION     => { "W0002: Unused Function" }
            W0003_UNUSED_IMPORT       => { "W0003: Unused Import" }
            W0004_SHADOWED_VARIABLE   => { "W0004: Shadowed Variable" }
            W0005_IMPLICIT_CONVERSION => { "W0005: Implicit Conversion" }
            W0006_LOSSY_CONVERSION    => { "W0006: Lossy Conversion" }
            W0007_DEPRECATED          => { "W0007: Deprecated" }
            W0008_UNNECESSARY_CAST    => { "W0008: Unnecessary Cast" }
            W0009_DEAD_CODE           => { "W0009: Dead Code" }
            W0010_MISSING_DOCS        => { "W0010: Missing Documentation" }
        }
    }

}

