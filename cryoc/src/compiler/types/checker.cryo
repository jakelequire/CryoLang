///! TypeChecker
///!
///! Determines type compatibility, validates operations, and provides
///! numeric promotion rules.  Mirrors the C++ compiler's TypeChecker.

namespace Compiler::Types::Checker;

import Compiler::Resolver::SymbolStr;
import Compiler::Types::Generic;
import Compiler::Types::UserDefined;
import Compiler::Types::Compound;
import Compiler::Types::Type;
import Compiler::Types;
import Compiler::Types::Arena;
import Compiler::Types::TypeRef;
import Compiler::Resolver::InternTable;
import Utils::Logger;


// ============================================================================
// TypeCompatibility — Result of comparing two types
// ============================================================================

type enum TypeCompatibility {
    /// Types are exactly the same.
    Identical;
    /// Types are structurally compatible (e.g., same layout).
    Compatible;
    /// Source can be implicitly converted to target (widening).
    ImplicitConvert;
    /// Source requires explicit cast to target (narrowing or lossy).
    ExplicitCast;
    /// Types are incompatible.
    Incompatible;
}

implement enum TypeCompatibility {
    to_string(&this) -> string {
        return match (this) {
            TypeCompatibility::Identical       => { "Identical" }
            TypeCompatibility::Compatible      => { "Compatible" }
            TypeCompatibility::ImplicitConvert => { "ImplicitConvert" }
            TypeCompatibility::ExplicitCast    => { "ExplicitCast" }
            TypeCompatibility::Incompatible    => { "Incompatible" }
        };
    }

    is_assignable(&this) -> boolean {
        return match (this) {
            TypeCompatibility::Identical       => { true }
            TypeCompatibility::Compatible      => { true }
            TypeCompatibility::ImplicitConvert => { true }
            _                                  => { false }
        };
    }
}


// ============================================================================
// TypeCheckResult — Result of a type-checking operation
// ============================================================================

type struct TypeCheckResult {
    result_type:   TypeRef;
    success:       boolean;
    error_message: string;

    static ok(result_type: TypeRef) -> TypeCheckResult {
        return TypeCheckResult {
            result_type:   result_type,
            success:       true,
            error_message: "",
        };
    }

    static fail(message: string) -> TypeCheckResult {
        return TypeCheckResult {
            result_type:   TypeRef::invalid(),
            success:       false,
            error_message: message,
        };
    }
}


// ============================================================================
// ConversionInfo — Details about a type conversion
// ============================================================================

type struct ConversionInfo {
    from_type:     TypeRef;
    to_type:       TypeRef;
    compatibility: TypeCompatibility;
    is_narrowing:  boolean;

    static new(from: TypeRef, to: TypeRef, compat: TypeCompatibility, narrowing: boolean) -> ConversionInfo {
        return ConversionInfo {
            from_type:     from,
            to_type:       to,
            compatibility: compat,
            is_narrowing:  narrowing,
        };
    }
}


// ============================================================================
// TypeChecker
// ============================================================================

type struct TypeChecker {
    arena: TypeArena*;

    static new(arena: TypeArena*) -> TypeChecker {
        return TypeChecker {
            arena: arena,
        };
    }


    // ----------------------------------------------------------------
    // Core compatibility checking
    // ----------------------------------------------------------------

    /// Check compatibility between two types.
    check_compatibility(&this, from: TypeRef, to: TypeRef) -> TypeCompatibility {
        LOG_DEBUG(LogComponent::TypeChecker, "[TypeChecker] check_compatibility() from=%lu to=%lu", from.id, to.id);
        // Same type ID → identical
        if (from.equals(to)) {
            return TypeCompatibility::Identical;
        }

        // Invalid types are incompatible
        if (from.is_invalid() || to.is_invalid()) {
            return TypeCompatibility::Incompatible;
        }

        // Dereference InstantiatedType → resolved_type on both sides.
        // After monomorphization, InstantiatedType(base=Pair, args=[string])
        // has resolved_type pointing to the concrete Pair_string StructType.
        // Without this, the concrete type and the instantiation have different
        // TypeIDs and would always compare as Incompatible.
        mut effective_from: TypeRef = from;
        mut effective_to:   TypeRef = to;

        mut from_type: Type* = this.arena.lookup(from.id);
        mut to_type: Type*   = this.arena.lookup(to.id);

        if (from_type != null && from_type.kind == TypeKind::InstantiatedType) {
            const from_inst: InstantiatedType* = from_type as InstantiatedType*;
            if (from_inst.has_resolved_type()) {
                effective_from = from_inst.resolved_type;
                from_type = this.arena.lookup(effective_from.id);
            }
        }
        if (to_type != null && to_type.kind == TypeKind::InstantiatedType) {
            const to_inst: InstantiatedType* = to_type as InstantiatedType*;
            if (to_inst.has_resolved_type()) {
                effective_to = to_inst.resolved_type;
                to_type = this.arena.lookup(effective_to.id);
            }
        }

        // Re-check identity after dereferencing
        if (effective_from.equals(effective_to)) {
            return TypeCompatibility::Identical;
        }

        if (from_type == null || to_type == null) {
            return TypeCompatibility::Incompatible;
        }

        // Error types are compatible with everything (prevents cascading errors)
        if (from_type.is_error() || to_type.is_error()) {
            return TypeCompatibility::Compatible;
        }

        // Never type is compatible with any type (it diverges)
        if (from_type.kind == TypeKind::Never) {
            return TypeCompatibility::Compatible;
        }

        // Numeric conversions
        if (from_type.kind == TypeKind::Int && to_type.kind == TypeKind::Int) {
            return this.check_int_compatibility(from_type, to_type);
        }

        if (from_type.kind == TypeKind::Float && to_type.kind == TypeKind::Float) {
            return this.check_float_compatibility(from_type, to_type);
        }

        if (from_type.kind == TypeKind::Int && to_type.kind == TypeKind::Float) {
            return TypeCompatibility::ImplicitConvert;
        }

        if (from_type.kind == TypeKind::Float && to_type.kind == TypeKind::Int) {
            return TypeCompatibility::ExplicitCast;
        }

        // Array coercion: T[N] → T[] (sized array assignable to dynamic array)
        if (from_type.kind == TypeKind::Array && to_type.kind == TypeKind::Array) {
            const from_arr: ArrayType* = from_type as ArrayType*;
            const to_arr: ArrayType* = to_type as ArrayType*;
            // Check element compatibility by ID first, then by kind.
            mut elems_ok: boolean = from_arr.element.equals(to_arr.element);
            if (!elems_ok) {
                const ea: Type* = this.arena.lookup(from_arr.element.id);
                const eb: Type* = this.arena.lookup(to_arr.element.id);
                if (ea != null && eb != null && ea.kind == eb.kind) {
                    elems_ok = true;
                }
            }
            if (elems_ok) {
                if (to_arr.is_dynamic() || from_arr.size == to_arr.size) {
                    return TypeCompatibility::Compatible;
                }
            }
            // Different element types but both integer/char: allow coercion
            // for patterns like `char[] = [0; N]` where 0 is i32.
            if (to_arr.is_dynamic() || from_arr.is_dynamic()) {
                const from_elem: Type* = this.arena.lookup(from_arr.element.id);
                const to_elem: Type* = this.arena.lookup(to_arr.element.id);
                if (from_elem != null && to_elem != null &&
                    from_elem.kind == TypeKind::Int && to_elem.kind == TypeKind::Int) {
                    return TypeCompatibility::ImplicitConvert;
                }
                // i32[] → char[] (char is integer-compatible)
                if (from_elem != null && to_elem != null &&
                    from_elem.kind == TypeKind::Int && to_elem.kind == TypeKind::Char) {
                    return TypeCompatibility::ImplicitConvert;
                }
            }
        }

        // Array → string coercion: [0; N] buffer allocation pattern.
        // In Cryo, `string` is a raw char pointer — initializing it from
        // an integer/char array fill expression is a standard buffer allocation.
        if (from_type.kind == TypeKind::Array && to_type.kind == TypeKind::String) {
            return TypeCompatibility::ImplicitConvert;
        }

        // Reference structural equality: &T ≡ &T, &mut T ≡ &mut T
        // Needed because the arena may allocate duplicate ReferenceType objects
        // with different TypeRef IDs for the same logical type.
        if (from_type.kind == TypeKind::Reference && to_type.kind == TypeKind::Reference) {
            const from_ref: ReferenceType* = from_type as ReferenceType*;
            const to_ref: ReferenceType* = to_type as ReferenceType*;
            if (from_ref.referent.equals(to_ref.referent) &&
                from_ref.is_mutable() == to_ref.is_mutable()) {
                return TypeCompatibility::Identical;
            }
        }

        // Pointer conversions
        if (from_type.kind == TypeKind::Pointer && to_type.kind == TypeKind::Pointer) {
            const from_ptr: PointerType* = from_type as PointerType*;
            const to_ptr: PointerType* = to_type as PointerType*;
            // void* → T* and T* → void* are implicit (C-style universal pointer)
            const from_inner: Type* = this.arena.lookup(from_ptr.pointee.id);
            const to_inner: Type* = this.arena.lookup(to_ptr.pointee.id);
            if ((from_inner != null && from_inner.kind == TypeKind::Void) ||
                (to_inner != null && to_inner.kind == TypeKind::Void)) {
                return TypeCompatibility::ImplicitConvert;
            }
            // Same pointee type after deref
            if (from_ptr.pointee.equals(to_ptr.pointee)) {
                return TypeCompatibility::Identical;
            }
            // Class hierarchy upcast: Derived* → Base* is implicit.
            // Walk the from-side inheritance chain to check if the to-side
            // class is an ancestor.  This handles the common OOP pattern of
            // returning a subclass pointer from a function typed as base.
            if (from_inner != null && to_inner != null &&
                from_inner.kind == TypeKind::Class && to_inner.kind == TypeKind::Class) {
                if (this.is_subclass_of(from_ptr.pointee, to_ptr.pointee)) {
                    return TypeCompatibility::ImplicitConvert;
                }
            }

            // Recursive pointee compatibility (e.g., i8** → string*
            // follows from i8* → string).
            const pointee_compat: TypeCompatibility = this.check_compatibility(
                from_ptr.pointee, to_ptr.pointee);
            if (pointee_compat.is_assignable()) {
                return TypeCompatibility::ImplicitConvert;
            }
            return TypeCompatibility::ExplicitCast;
        }

        // i8* → string: C string to Cryo string (string is i8* at LLVM level)
        if (from_type.kind == TypeKind::Pointer && to_type.kind == TypeKind::String) {
            const from_ptr: PointerType* = from_type as PointerType*;
            const pointee: Type* = this.arena.lookup(from_ptr.pointee.id);
            if (pointee != null && pointee.kind == TypeKind::Int) {
                const int_t: IntType* = pointee as IntType*;
                if (int_t.bit_width() == 8) {
                    return TypeCompatibility::ImplicitConvert;
                }
            }
        }

        // string → i8*: Cryo string to C string
        if (from_type.kind == TypeKind::String && to_type.kind == TypeKind::Pointer) {
            const to_ptr: PointerType* = to_type as PointerType*;
            const pointee: Type* = this.arena.lookup(to_ptr.pointee.id);
            if (pointee != null && pointee.kind == TypeKind::Int) {
                const int_t: IntType* = pointee as IntType*;
                if (int_t.bit_width() == 8) {
                    return TypeCompatibility::ImplicitConvert;
                }
            }
        }

        // void → T* (null literal): void value used as null pointer
        if (from_type.kind == TypeKind::Void && to_type.kind == TypeKind::Pointer) {
            return TypeCompatibility::ImplicitConvert;
        }

        // u64 ↔ pointer: pointer-sized integer conversions
        if (from_type.kind == TypeKind::Int && to_type.kind == TypeKind::Pointer) {
            const from_int: IntType* = from_type as IntType*;
            if (from_int.bit_width() == 64) {
                return TypeCompatibility::ImplicitConvert;
            }
        }
        if (from_type.kind == TypeKind::Pointer && to_type.kind == TypeKind::Int) {
            const to_int: IntType* = to_type as IntType*;
            if (to_int.bit_width() == 64) {
                return TypeCompatibility::ImplicitConvert;
            }
        }

        // &T → T* (reference to pointer coercion)
        if (from_type.kind == TypeKind::Reference && to_type.kind == TypeKind::Pointer) {
            const from_ref: ReferenceType* = from_type as ReferenceType*;
            const to_ptr: PointerType* = to_type as PointerType*;
            if (from_ref.referent.equals(to_ptr.pointee)) {
                return TypeCompatibility::ImplicitConvert;
            }
            // Cross-module: referent and pointee may have different TypeIDs.
            // Compare by kind — same kind means structurally compatible.
            const ri: Type* = this.arena.lookup(from_ref.referent.id);
            const pi: Type* = this.arena.lookup(to_ptr.pointee.id);
            if (ri != null && pi != null && ri.kind == pi.kind) {
                return TypeCompatibility::ImplicitConvert;
            }
            // &T → void* is also valid
            const to_inner: Type* = this.arena.lookup(to_ptr.pointee.id);
            if (to_inner != null && to_inner.kind == TypeKind::Void) {
                return TypeCompatibility::ImplicitConvert;
            }
        }

        // T → &T / T → &mut T (auto-referencing for method chaining)
        if (to_type.kind == TypeKind::Reference) {
            const to_ref: ReferenceType* = to_type as ReferenceType*;
            if (effective_from.equals(to_ref.referent)) {
                return TypeCompatibility::ImplicitConvert;
            }
        }

        // Bool coercion: integers, chars, pointers, enums → boolean (implicit)
        // Mirrors C-style truthiness: any integer/char/pointer/enum can be tested for truth.
        // Floats → boolean require explicit cast (prevents silent `const z: boolean = 3.14;`).
        if (to_type.kind == TypeKind::Bool) {
            if (from_type.kind == TypeKind::Int ||
                from_type.kind == TypeKind::Char ||
                from_type.kind == TypeKind::Pointer ||
                from_type.kind == TypeKind::Enum ||
                from_type.kind == TypeKind::Struct ||
                from_type.kind == TypeKind::Class) {
                return TypeCompatibility::ImplicitConvert;
            }
            if (from_type.kind == TypeKind::Float) {
                return TypeCompatibility::ExplicitCast;
            }
        }

        // Char ↔ integer conversions
        if (from_type.kind == TypeKind::Char && to_type.kind == TypeKind::Int) {
            return TypeCompatibility::ImplicitConvert;
        }
        if (from_type.kind == TypeKind::Int && to_type.kind == TypeKind::Char) {
            return TypeCompatibility::ImplicitConvert;
        }

        // Optional wrapping: T → T?
        if (to_type.kind == TypeKind::Optional) {
            mut opt: OptionalType* = to_type as OptionalType*;
            mut inner_compat: TypeCompatibility = this.check_compatibility(from, opt.wrapped);
            if (inner_compat.is_assignable()) {
                return TypeCompatibility::ImplicitConvert;
            }
        }

        // Generic base ↔ instantiation compatibility:
        // When an enum variant constructor like Optional::Some("Hello") returns
        // the base enum type (Optional), but the expected type is a specialization
        // (Optional_string), treat as compatible.  Check the ORIGINAL (pre-deref)
        // TypeRefs: if one is an InstantiatedType whose generic_base matches the
        // other's TypeRef, they're compatible.
        {
            mut orig_from: Type* = this.arena.lookup(from.id);
            mut orig_to:   Type* = this.arena.lookup(to.id);
            if (orig_to != null && orig_to.kind == TypeKind::InstantiatedType) {
                const to_inst: InstantiatedType* = orig_to as InstantiatedType*;
                if (to_inst.generic_base.equals(from)) {
                    return TypeCompatibility::Compatible;
                }
            }
            if (orig_from != null && orig_from.kind == TypeKind::InstantiatedType) {
                const from_inst: InstantiatedType* = orig_from as InstantiatedType*;
                if (from_inst.generic_base.equals(to)) {
                    return TypeCompatibility::Compatible;
                }
            }
        }

        // TypeAlias: resolve and check
        if (from_type.kind == TypeKind::TypeAlias) {
            mut alias: TypeAliasType* = from_type as TypeAliasType*;
            if (alias.has_target()) {
                return this.check_compatibility(alias.target, to);
            }
        }
        if (to_type.kind == TypeKind::TypeAlias) {
            mut alias: TypeAliasType* = to_type as TypeAliasType*;
            if (alias.has_target()) {
                return this.check_compatibility(from, alias.target);
            }
        }

        return TypeCompatibility::Incompatible;
    }

    /// Whether from can be assigned to to (Identical, Compatible, or ImplicitConvert).
    can_assign(&this, _from: TypeRef, to: TypeRef) -> boolean {
        return this.check_compatibility(_from, to).is_assignable();
    }

    /// Whether from can be implicitly converted to to.
    can_implicit_convert(&this, _from: TypeRef, to: TypeRef) -> boolean {
        mut compat: TypeCompatibility = this.check_compatibility(_from, to);
        return match (compat) {
            TypeCompatibility::Identical       => { true }
            TypeCompatibility::Compatible      => { true }
            TypeCompatibility::ImplicitConvert => { true }
            _                                  => { false }
        };
    }


    // ----------------------------------------------------------------
    // Numeric compatibility helpers
    // ----------------------------------------------------------------

    check_int_compatibility(&this, _from: Type*, to: Type*) -> TypeCompatibility {
        mut from_int: IntType* = _from as IntType*;
        mut to_int: IntType*   = to as IntType*;

        mut from_width: u64 = from_int.bit_width();
        mut to_width: u64   = to_int.bit_width();

        mut from_signed: boolean = from_int.is_signed();
        mut to_signed: boolean   = to_int.is_signed();

        // Same signedness
        if (from_signed == to_signed) {
            if (from_width < to_width) {
                return TypeCompatibility::ImplicitConvert;   // Widening
            }
            if (from_width > to_width) {
                return TypeCompatibility::ExplicitCast;      // Narrowing
            }
            return TypeCompatibility::Identical;
        }

        // Different signedness, same width → explicit cast
        if (from_width == to_width) {
            return TypeCompatibility::ExplicitCast;
        }

        // Unsigned to signed with wider width → implicit
        if (!from_signed && to_signed && from_width < to_width) {
            return TypeCompatibility::ImplicitConvert;
        }

        // Otherwise → explicit cast
        return TypeCompatibility::ExplicitCast;
    }

    check_float_compatibility(&this, _from: Type*, to: Type*) -> TypeCompatibility {
        mut from_float: FloatType* = _from as FloatType*;
        mut to_float: FloatType*   = to as FloatType*;

        if (from_float.bit_width() < to_float.bit_width()) {
            return TypeCompatibility::ImplicitConvert;   // f32 → f64
        }
        if (from_float.bit_width() > to_float.bit_width()) {
            return TypeCompatibility::ExplicitCast;      // f64 → f32
        }
        return TypeCompatibility::Identical;
    }


    // ----------------------------------------------------------------
    // Operation type checking
    // ----------------------------------------------------------------

    /// Check a binary operation and return the result type.
    check_binary_op(&this, op: string, lhs: TypeRef, rhs: TypeRef) -> TypeCheckResult {
        LOG_DEBUG(LogComponent::TypeChecker, "[TypeChecker] check_binary_op() op='%s' lhs=%lu rhs=%lu", op, lhs.id, rhs.id);
        if (lhs.is_invalid() || rhs.is_invalid()) {
            return TypeCheckResult::fail("Cannot apply operator to invalid types");
        }

        mut lhs_type: Type* = this.arena.lookup(lhs.id);
        mut rhs_type: Type* = this.arena.lookup(rhs.id);

        if (lhs_type == null || rhs_type == null) {
            return TypeCheckResult::fail("Type lookup failed");
        }

        // Arithmetic: + - * / %
        if (op == "+" || op == "-" || op == "*" || op == "/" || op == "%") {
            if (lhs_type.is_numeric() && rhs_type.is_numeric()) {
                return TypeCheckResult::ok(this.get_common_numeric_type(lhs, rhs));
            }
            // String concatenation
            if (op == "+" && lhs_type.kind == TypeKind::String && rhs_type.kind == TypeKind::String) {
                return TypeCheckResult::ok(this.arena.get_string());
            }
            return TypeCheckResult::fail(format("Cannot apply '%s' to %s and %s",
                op, lhs_type.kind.to_string(), rhs_type.kind.to_string()));
        }

        // Comparison: == != < > <= >=
        if (op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">=") {
            if (lhs_type.is_numeric() && rhs_type.is_numeric()) {
                return TypeCheckResult::ok(this.arena.get_bool());
            }
            if (lhs_type.kind == TypeKind::Bool && rhs_type.kind == TypeKind::Bool) {
                return TypeCheckResult::ok(this.arena.get_bool());
            }
            if (lhs_type.kind == TypeKind::String && rhs_type.kind == TypeKind::String) {
                return TypeCheckResult::ok(this.arena.get_bool());
            }
            if (lhs_type.kind == TypeKind::Char && rhs_type.kind == TypeKind::Char) {
                return TypeCheckResult::ok(this.arena.get_bool());
            }
            // Pointer equality/inequality: ptr == null, ptr != null, ptr == ptr
            if (lhs_type.kind == TypeKind::Pointer || rhs_type.kind == TypeKind::Pointer) {
                return TypeCheckResult::ok(this.arena.get_bool());
            }
            // Class/reference null checks: obj == null, &ref == null
            if (lhs_type.kind == TypeKind::Class || rhs_type.kind == TypeKind::Class ||
                lhs_type.kind == TypeKind::Reference || rhs_type.kind == TypeKind::Reference) {
                return TypeCheckResult::ok(this.arena.get_bool());
            }
            // Void on either side (null literal)
            if (lhs_type.kind == TypeKind::Void || rhs_type.kind == TypeKind::Void) {
                return TypeCheckResult::ok(this.arena.get_bool());
            }
            // Enum equality
            if (lhs_type.kind == TypeKind::Enum && rhs_type.kind == TypeKind::Enum) {
                return TypeCheckResult::ok(this.arena.get_bool());
            }
            return TypeCheckResult::fail(format("Cannot compare %s and %s",
                lhs_type.kind.to_string(), rhs_type.kind.to_string()));
        }

        // Logical: && ||
        if (op == "&&" || op == "||") {
            if (lhs_type.kind == TypeKind::Bool && rhs_type.kind == TypeKind::Bool) {
                return TypeCheckResult::ok(this.arena.get_bool());
            }
            return TypeCheckResult::fail(format("Logical '%s' requires boolean operands", op));
        }

        // Bitwise: & | ^ << >>
        if (op == "&" || op == "|" || op == "^" || op == "<<" || op == ">>") {
            if (lhs_type.kind == TypeKind::Int && rhs_type.kind == TypeKind::Int) {
                return TypeCheckResult::ok(this.get_common_numeric_type(lhs, rhs));
            }
            return TypeCheckResult::fail(format("Bitwise '%s' requires integer operands", op));
        }

        return TypeCheckResult::fail(format("Unknown binary operator '%s'", op));
    }

    /// Check a unary operation and return the result type.
    check_unary_op(&this, op: string, operand: TypeRef) -> TypeCheckResult {
        if (operand.is_invalid()) {
            return TypeCheckResult::fail("Cannot apply unary operator to invalid type");
        }

        mut op_type: Type* = this.arena.lookup(operand.id);
        if (op_type == null) {
            return TypeCheckResult::fail("Type lookup failed");
        }

        // Negation: -
        if (op == "-") {
            if (op_type.is_numeric()) {
                return TypeCheckResult::ok(operand);
            }
            return TypeCheckResult::fail("Negation requires numeric operand");
        }

        // Logical not: !
        if (op == "!") {
            if (op_type.kind == TypeKind::Bool) {
                return TypeCheckResult::ok(operand);
            }
            return TypeCheckResult::fail("Logical NOT requires boolean operand");
        }

        // Bitwise not: ~
        if (op == "~") {
            if (op_type.kind == TypeKind::Int) {
                return TypeCheckResult::ok(operand);
            }
            return TypeCheckResult::fail("Bitwise NOT requires integer operand");
        }

        // Dereference: *
        if (op == "*") {
            if (op_type.kind == TypeKind::Pointer) {
                mut ptr: PointerType* = op_type as PointerType*;
                return TypeCheckResult::ok(ptr.pointee);
            }
            if (op_type.kind == TypeKind::Reference) {
                mut ref_type: ReferenceType* = op_type as ReferenceType*;
                return TypeCheckResult::ok(ref_type.referent);
            }
            return TypeCheckResult::fail("Dereference requires pointer or reference operand");
        }

        // Address-of: & produces an immutable reference (&T), not a raw pointer (T*)
        if (op == "&") {
            return TypeCheckResult::ok(
                this.arena.get_reference_to(operand, RefMutability::Immutable));
        }

        return TypeCheckResult::fail(format("Unknown unary operator '%s'", op));
    }

    /// Check a function call with the given argument types.
    check_function_call(&this, func: TypeRef, args: TypeRef[]) -> TypeCheckResult {
        LOG_DEBUG(LogComponent::TypeChecker, "[TypeChecker] check_function_call() func=%lu args=%lld", func.id, args.length);
        mut func_type: Type* = this.arena.lookup(func.id);
        if (func_type == null || func_type.kind != TypeKind::Function) {
            return TypeCheckResult::fail("Called expression is not a function type");
        }

        mut fn_type: FunctionType* = func_type as FunctionType*;

        // Check arity
        if (!fn_type.is_variadic && args.length != fn_type.param_types.length) {
            return TypeCheckResult::fail(format("Expected %ld arguments, got %ld",
                fn_type.param_types.length, args.length));
        }

        if (fn_type.is_variadic && args.length < fn_type.param_types.length) {
            return TypeCheckResult::fail(format("Expected at least %ld arguments, got %ld",
                fn_type.param_types.length, args.length));
        }

        // Check each argument type
        for (mut i: i64 = 0; i < fn_type.param_types.length; i++) {
            if (!this.can_assign(args[i], fn_type.param_types[i])) {
                return TypeCheckResult::fail(format("Argument %ld type mismatch", i + 1));
            }
        }

        return TypeCheckResult::ok(fn_type.return_type);
    }

    /// Check field access on a type.
    check_field_access(&this, base: TypeRef, field_name: SymbolStr) -> TypeCheckResult {
        LOG_DEBUG(LogComponent::TypeChecker, "[TypeChecker] check_field_access() base=%lu field_id=%u", base.id, field_name.id);
        mut base_type: Type* = this.arena.lookup(base.id);
        if (base_type == null) {
            return TypeCheckResult::fail("Type lookup failed for field access");
        }

        // Auto-dereference pointer and reference types for member access.
        // ptr->field and ref.field both access the pointee's fields.
        if (base_type.kind == TypeKind::Pointer) {
            const ptr: PointerType* = base_type as PointerType*;
            base_type = this.arena.lookup(ptr.pointee.id);
            if (base_type == null) {
                return TypeCheckResult::fail("Type lookup failed for pointer dereference");
            }
        } else if (base_type.kind == TypeKind::Reference) {
            const ref: ReferenceType* = base_type as ReferenceType*;
            base_type = this.arena.lookup(ref.referent.id);
            if (base_type == null) {
                return TypeCheckResult::fail("Type lookup failed for reference dereference");
            }
        }

        // Dereference InstantiatedType to its concrete resolved type
        // so field lookups work on Pair<string> → Pair_string, etc.
        if (base_type.kind == TypeKind::InstantiatedType) {
            const inst: InstantiatedType* = base_type as InstantiatedType*;
            if (inst.has_resolved_type()) {
                base_type = this.arena.lookup(inst.resolved_type.id);
                if (base_type == null) {
                    return TypeCheckResult::fail("Type lookup failed for resolved instantiated type");
                }
            }
        }

        if (base_type.kind == TypeKind::Struct) {
            mut st: StructType* = base_type as StructType*;
            mut field: FieldInfo* = st.get_field(field_name);
            if (field != null) {
                return TypeCheckResult::ok(field.field_type);
            }
            return TypeCheckResult::fail(format("Struct '%s' has no field '%s'",
                st.display_name(), st.intern_table.resolve(field_name)));
        }

        if (base_type.kind == TypeKind::Class) {
            mut ct: ClassType* = base_type as ClassType*;
            // Walk the inheritance chain for field lookup
            mut current: ClassType* = ct;
            while (current != null) {
                mut field: FieldInfo* = current.get_field(field_name);
                if (field != null) {
                    return TypeCheckResult::ok(field.field_type);
                }
                // Walk to parent class
                if (current.has_base && current.base_class.is_valid()) {
                    const parent_t: Type* = this.arena.lookup(current.base_class.id);
                    if (parent_t != null && parent_t.kind == TypeKind::Class) {
                        current = parent_t as ClassType*;
                    } else {
                        current = null;
                    }
                } else {
                    current = null;
                }
            }
            return TypeCheckResult::fail(format("Class '%s' has no field '%s'",
                ct.display_name(), ct.intern_table.resolve(field_name)));
        }

        // Tuple index access (0, 1, 2, ...)
        if (base_type.kind == TypeKind::Tuple) {
            return TypeCheckResult::fail("Tuple field access requires numeric index");
        }

        return TypeCheckResult::fail(format("Cannot access field on type %s",
            base_type.kind.to_string()));
    }

    /// Check index access (array[index]).
    check_index_access(&this, base: TypeRef, index: TypeRef) -> TypeCheckResult {
        mut base_type: Type* = this.arena.lookup(base.id);
        if (base_type == null) {
            return TypeCheckResult::fail("Type lookup failed for index access");
        }

        // Dereference InstantiatedType to its concrete resolved type
        if (base_type.kind == TypeKind::InstantiatedType) {
            const inst: InstantiatedType* = base_type as InstantiatedType*;
            if (inst.has_resolved_type()) {
                base_type = this.arena.lookup(inst.resolved_type.id);
                if (base_type == null) {
                    return TypeCheckResult::fail("Type lookup failed for resolved instantiated type");
                }
            }
        }

        if (base_type.kind == TypeKind::Array) {
            mut arr: ArrayType* = base_type as ArrayType*;
            // Index must be integer
            mut idx_type: Type* = this.arena.lookup(index.id);
            if (idx_type != null && idx_type.kind == TypeKind::Int) {
                return TypeCheckResult::ok(arr.element);
            }
            return TypeCheckResult::fail("Array index must be an integer");
        }

        // Pointer indexing: T*[i] → T (pointer arithmetic)
        if (base_type.kind == TypeKind::Pointer) {
            const ptr_type: PointerType* = base_type as PointerType*;
            return TypeCheckResult::ok(ptr_type.pointee);
        }

        // String indexing: string[i] → char
        if (base_type.kind == TypeKind::String) {
            return TypeCheckResult::ok(this.arena.get_char());
        }

        return TypeCheckResult::fail(format("Cannot index into type %s",
            base_type.kind.to_string()));
    }


    // ----------------------------------------------------------------
    // Numeric promotion
    // ----------------------------------------------------------------

    /// Get the common type for a numeric binary operation.
    /// Promotes to the wider/higher-precision type.
    get_common_numeric_type(&this, a: TypeRef, b: TypeRef) -> TypeRef {
        if (a.equals(b)) {
            return a;
        }

        mut a_type: Type* = this.arena.lookup(a.id);
        mut b_type: Type* = this.arena.lookup(b.id);

        if (a_type == null || b_type == null) {
            return TypeRef::invalid();
        }

        // Float beats int
        if (a_type.kind == TypeKind::Float && b_type.kind == TypeKind::Int) {
            return a;
        }
        if (a_type.kind == TypeKind::Int && b_type.kind == TypeKind::Float) {
            return b;
        }

        // Both float → wider wins
        if (a_type.kind == TypeKind::Float && b_type.kind == TypeKind::Float) {
            mut a_float: FloatType* = a_type as FloatType*;
            mut b_float: FloatType* = b_type as FloatType*;
            if (a_float.bit_width() >= b_float.bit_width()) {
                return a;
            }
            return b;
        }

        // Both int → wider wins; same width → prefer unsigned (C/Rust convention)
        if (a_type.kind == TypeKind::Int && b_type.kind == TypeKind::Int) {
            mut a_int: IntType* = a_type as IntType*;
            mut b_int: IntType* = b_type as IntType*;
            if (a_int.bit_width() > b_int.bit_width()) {
                return a;
            }
            if (b_int.bit_width() > a_int.bit_width()) {
                return b;
            }
            // Same width — prefer unsigned (u32 op i32 → u32)
            if (!a_int.is_signed()) {
                return a;
            }
            return b;
        }

        return a;  // Fallback
    }


    // ----------------------------------------------------------------
    // Class hierarchy helpers
    // ----------------------------------------------------------------

    /// Check whether `derived` is a subclass of `base` by walking the
    /// inheritance chain.  Both TypeRefs must point to ClassType objects.
    /// Limits depth to 32 to prevent infinite loops from malformed data.
    is_subclass_of(&this, derived: TypeRef, base: TypeRef) -> boolean {
        if (derived.equals(base)) { return true; }

        mut current: TypeRef = derived;
        mut depth: i32 = 0;
        while (depth < 32) {
            const t: Type* = this.arena.lookup(current.id);
            if (t == null || t.kind != TypeKind::Class) { return false; }
            const ct: ClassType* = t as ClassType*;
            if (!ct.has_base || !ct.base_class.is_valid()) { return false; }
            if (ct.base_class.equals(base)) { return true; }
            current = ct.base_class;
            depth = depth + 1;
        }
        return false;
    }
}
