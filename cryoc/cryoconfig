# Cryo Project Configuration
# cryoc is the rewrite of the original C++ Cryo Compiler in Cryo itself, aiming to be a self-hosted compiler.

[project]
project_name = "cryoc"
output_dir = "build"
target_type = "executable"
entry_point = "src/main.cryo"

# Compiler options
[compiler]
debug = false
optimize = true
args = ["--emit-llvm"]
no_std = false
link_libs = ["LLVM-20"]
link_paths = ["/usr/lib/llvm-20/lib"]

