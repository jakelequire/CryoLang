# Cryo Project Configuration
# cryoc is the rewrite of the original C++ Cryo Compiler in Cryo itself, aiming to be a self-hosted compiler.

[project]
project_name = "cryoc"
output_dir = "build"
target_type = "executable"
entry_point = "main.cryo"

# Compiler options
[compiler]
