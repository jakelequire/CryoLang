namespace Test;

type struct Point {
    x: i32;
    y: i32;
}

type struct Foo {
    a: i32;
    b: i32;

    print(this) -> void {
        printf("Foo { a: %d, b: %d }\n", this.a, this.b);
    }

    static static_method() -> void {
        puts("Called static method on Foo");
    }
}

// Return By Value
function rbv() -> Foo {
    return Foo { a: 1, b: 2 };
}

// Return By Pointer
function rbp() -> Foo * {
    const foo: Foo = Foo { a: 3, b: 4 };
    const p: Foo* = malloc(sizeof(Foo));
    memcpy(p, &foo, sizeof(Foo));

    return p;
}

function ifexpr(b: boolean) -> Foo {
    const foo: Foo = if (b) {
        Foo { a: 69, b: 69 }
    } else {
        Foo { a: 420, b: 8008 }
    };
    return foo;
}

function matchexpr(n: i32) -> Foo {
    const foo: Foo = Foo {
        a: match (n) {
            1 => { 10 }
            2 => { 20 }
            _ => { 30 }
        },
        b: match (n) {
            1 => { 100 }
            2 => { 200 }
            _ => { 300 }
        }
    };
    return foo;
}

function loops() -> void {
    mut i: i32 = 0;
    loop {
        if (i >= 10) {
            break;
        }
        i++;
        printf("Loop iteration: %d\n", i);
    }

    for (mut j: i32 = 0; j < 5; j++) {
        printf("For loop iteration: %d\n", j);
    }

    while (i < 15) {
        i++;
        printf("While loop iteration: %d\n", i);
    }
}

function main(argc: i32, argv: string[]) -> i32 {
    puts("This is a raw assembly test.");

    const p: Point = Point { x: 10, y: 20 };
    printf("Point coordinates: (%d, %d)\n", p.x, p.y);

    const foo: Foo = rbv();
    printf("Foo values: a = %d, b = %d\n", foo.a, foo.b);
    printf("Foo address: %p\n", &foo);

    foo.print();
    Foo::static_method();

    const foo_ptr: Foo* = rbp();
    printf("Foo pointer address: %p\n", foo_ptr);
    printf("Foo pointer values: a = %d, b = %d\n", foo_ptr.a, foo_ptr.b);

    const foo_if: Foo = ifexpr(false);
    printf("IfExpr Foo values: a = %d, b = %d\n",
        foo_if.a, foo_if.b);

    const foo_match: Foo = matchexpr(999);
    printf("MatchExpr Foo values: a = %d, b = %d\n",
        foo_match.a, foo_match.b);

    loops();

    return 42;
}
