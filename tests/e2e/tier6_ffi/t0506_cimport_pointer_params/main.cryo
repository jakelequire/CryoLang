// @test: cimport_pointer_params
// @expect: compile_success
// @mode: project
// @stdout: value = 42
// @tags: ffi, cimport, pointers
// @description: CImport with int pointer parameters - write to and read from pointer.

namespace Main;

c := extern "C" {
    #include "./funcs.h"
}

function main() -> i32 {
    const buf: i32* = malloc(4) as i32*;
    c::write_to_ptr(buf, 42);
    const val: i32 = c::read_from_ptr(buf);
    printf("value = %d\n", val);
    free(buf);
    return 0;
}
