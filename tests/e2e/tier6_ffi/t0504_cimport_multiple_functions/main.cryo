// @test: cimport_multiple_functions
// @expect: compile_success
// @mode: project
// @stdout: A
// @stdout: B
// @stdout: C
// @stdout: 84
// @tags: ffi, cimport, multiple
// @description: Import multiple functions from a single C header and call them all.

namespace Main;

extern "CImport" lib {
    #include "./funcs.h"
}

function main() -> i32 {
    lib::func_a();
    lib::func_b();
    lib::func_c();
    const result: i32 = lib::func_d(42);
    printf("%d\n", result);
    return 0;
}
