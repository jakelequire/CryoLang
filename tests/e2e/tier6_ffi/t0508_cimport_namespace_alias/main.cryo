// @test: cimport_namespace_alias
// @expect: compile_success
// @mode: project
// @stdout: mylib says 777
// @tags: ffi, cimport, namespace
// @description: Verify that the namespace alias name is used correctly for scoped access.

namespace Main;

mylib := extern "C" {
    #include "./funcs.h"
}

function main() -> i32 {
    const v: i32 = mylib::get_value();
    printf("mylib says %d\n", v);
    return 0;
}
