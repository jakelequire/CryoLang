// @test: cimport_callback_api
// @expect: compile_success
// @mode: project
// @stdout: value: 99
// @stdout: add: 13
// @stdout: sub: 7
// @stdout: mul: 30
// @tags: ffi, cimport, api, compute
// @description: CImport with a C API using operation codes as a simpler alternative to function pointers. Tests multiple function calls with different parameters.

namespace Main;

extern "CImport" c {
    #include "./funcs.h"
}

function main() -> i32 {
    c::run_with_value(99);
    const add_result: i32 = c::compute_pair(10, 3, 0);
    printf("add: %d\n", add_result);
    const sub_result: i32 = c::compute_pair(10, 3, 1);
    printf("sub: %d\n", sub_result);
    const mul_result: i32 = c::compute_pair(10, 3, 2);
    printf("mul: %d\n", mul_result);
    return 0;
}
