// @test: cimport_forward_declared_struct
// @expect: compile_success
// @mode: project
// @stdout: addr: localhost:8080
// @tags: ffi, cimport, forward_decl, opaque, struct
// @description: CImport with forward-declared structs that are never fully defined in the header. Uses them only as opaque pointers.

namespace Main;

extern "CImport" c {
    #include "./funcs.h"
}

function main() -> i32 {
    const conn: void* = c::conn_open("localhost:8080") as void*;
    const addr: string = c::conn_address(conn) as string;
    printf("addr: %s\n", addr);
    c::conn_close(conn);
    return 0;
}
