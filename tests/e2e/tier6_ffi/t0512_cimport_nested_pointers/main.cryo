// @test: cimport_nested_pointers
// @expect: compile_success
// @mode: project
// @stdout: total length: 11
// @tags: ffi, cimport, pointers, double_pointer
// @description: CImport with char** (double pointer) parameter - tests nested pointer type mapping.

namespace Main;

c := extern "C" {
    #include "./funcs.h"
}

function main() -> i32 {
    // Allocate an array of 3 string pointers
    const strs: i8** = malloc(24) as i8**;
    strs[0] = "hello";
    strs[1] = " ";
    strs[2] = "world";
    const total: i32 = c::count_strings(strs, 3);
    printf("total length: %d\n", total);
    free(strs);
    return 0;
}
