// @test: cimport_multi_param_function
// @expect: compile_success
// @mode: project
// @stdout: sum: 15
// @stdout: one two three four five
// @tags: ffi, cimport, multi_param
// @description: CImport with functions taking 5 parameters - tests ABI for many arguments.

namespace Main;

extern "CImport" c {
    #include "./funcs.h"
}

function main() -> i32 {
    const sum: i32 = c::compute(1, 2, 3, 4, 5);
    printf("sum: %d\n", sum);
    c::print_five("one", "two", "three", "four", "five");
    return 0;
}
