// @test: cimport_multiple_headers
// @expect: compile_success
// @mode: project
// @stdout: alpha
// @stdout: beta
// @stdout: 99
// @tags: ffi, cimport, multiple_headers
// @description: Import from multiple C headers in a single CImport block.

namespace Main;

extern "CImport" c {
    #include "./alpha.h"
    #include "./beta.h"
}

function main() -> i32 {
    c::alpha_func();
    c::beta_func();
    const val: i32 = c::beta_value();
    printf("%d\n", val);
    return 0;
}
