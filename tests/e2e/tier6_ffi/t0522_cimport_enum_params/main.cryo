// @test: cimport_enum_params
// @expect: compile_success
// @mode: project
// @stdout: color: green
// @stdout: value: 2
// @tags: ffi, cimport, enum, typedef
// @description: CImport with typedef'd enum types used as function parameters. Enums map to i32.

namespace Main;

extern "CImport" c {
    #include "./funcs.h"
}

function main() -> i32 {
    const name: string = c::color_name(1) as string;
    printf("color: %s\n", name);
    const val: i32 = c::color_value(2);
    printf("value: %d\n", val);
    return 0;
}
