// @test: cimport_typedef_chain
// @expect: compile_success
// @mode: project
// @stdout: result: 300
// @stdout: greet: Cryo
// @tags: ffi, cimport, typedef, chain
// @description: CImport with chained typedefs that resolve through multiple levels.

namespace Main;

extern "CImport" c {
    #include "./funcs.h"
}

function main() -> i32 {
    const result: i32 = c::chain_add(100, 200);
    printf("result: %d\n", result);
    const greeting: string = c::chain_greet("Cryo") as string;
    printf("greet: %s\n", greeting);
    return 0;
}
