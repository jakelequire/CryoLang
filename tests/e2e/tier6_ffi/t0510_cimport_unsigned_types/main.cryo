// @test: cimport_unsigned_types
// @expect: compile_success
// @mode: project
// @stdout: unsigned: 4000000000
// @stdout: byte: 255
// @stdout: ushort: 65535
// @tags: ffi, cimport, unsigned, types
// @description: CImport with unsigned C types - unsigned int, unsigned char, unsigned short, unsigned long long.

namespace Main;

c := extern "C" {
    #include "./funcs.h"
}

function main() -> i32 {
    const u: u32 = c::get_unsigned();
    printf("unsigned: %u\n", u);
    const b: u8 = c::get_byte();
    printf("byte: %u\n", b as u32);
    const s: u16 = c::get_ushort();
    printf("ushort: %u\n", s as u32);
    return 0;
}
