// @test: cimport_enum_return_value
// @expect: compile_success
// @mode: project
// @stdout: status: ok
// @stdout: status: error
// @tags: ffi, cimport, enum, return_value
// @description: CImport with enum return values from C functions.

namespace Main;

extern "CImport" c {
    #include "./funcs.h"
}

function main() -> i32 {
    const s1: i32 = c::do_operation(1);
    const msg1: string = c::status_string(s1) as string;
    printf("status: %s\n", msg1);
    const s2: i32 = c::do_operation(0);
    const msg2: string = c::status_string(s2) as string;
    printf("status: %s\n", msg2);
    return 0;
}
