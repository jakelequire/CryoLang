// @test: cimport_typedef_alias
// @expect: compile_success
// @mode: project
// @stdout: sum: 30
// @stdout: byte: 100
// @stdout: big: 9876543210
// @tags: ffi, cimport, typedef, alias, primitive
// @description: CImport with typedef'd primitive types. The CParser resolves typedef chains.

namespace Main;

extern "CImport" c {
    #include "./funcs.h"
}

function main() -> i32 {
    const sum: i32 = c::add_myint(10, 20);
    printf("sum: %d\n", sum);
    const b: i32 = c::get_byte();
    printf("byte: %d\n", b);
    const big: i64 = c::get_big();
    printf("big: %lld\n", big);
    return 0;
}
