// @test: cimport_math_operations
// @expect: compile_success
// @mode: project
// @stdout: abs(-5) = 5
// @stdout: max(3,7) = 7
// @stdout: min(3,7) = 3
// @stdout: clamp(15,0,10) = 10
// @stdout: 5! = 120
// @tags: ffi, cimport, math, comprehensive
// @description: Comprehensive CImport test with a math library - multiple functions with various integer operations. Exercises the full pipeline end-to-end.

namespace Main;

m := extern "C" {
    #include "./mathlib.h"
}

function main() -> i32 {
    printf("abs(-5) = %d\n", m::abs_val(-5));
    printf("max(3,7) = %d\n", m::max_val(3, 7));
    printf("min(3,7) = %d\n", m::min_val(3, 7));
    printf("clamp(15,0,10) = %d\n", m::clamp(15, 0, 10));
    printf("5! = %d\n", m::factorial(5));
    return 0;
}
