// @test: cimport_opaque_handle
// @expect: compile_success
// @mode: project
// @stdout: ctx id: 42
// @tags: ffi, cimport, opaque_handle, typedef, llvm_pattern
// @description: LLVM-style opaque handle pattern using typedef struct X *XRef. Critical for LLVM-C API interop.

namespace Main;

c := extern "C" {
    #include "./funcs.h"
}

function main() -> i32 {
    const ctx: void* = c::create_ctx(42);
    const id: i32 = c::ctx_get_id(ctx);
    printf("ctx id: %d\n", id);
    c::destroy_ctx(ctx);
    return 0;
}
