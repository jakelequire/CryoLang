// @test: cimport_struct_pointer
// @expect: compile_success
// @mode: project
// @stdout: point: 10, 20
// @tags: ffi, cimport, struct, pointer
// @description: CImport with struct pointer parameters. Struct pointers are opaque from Cryo's perspective.

namespace Main;

extern "CImport" c {
    #include "./funcs.h"
}

function main() -> i32 {
    const p: void* = c::create_point(10, 20);
    const x: i32 = c::point_x(p);
    const y: i32 = c::point_y(p);
    printf("point: %d, %d\n", x, y);
    c::free_point(p);
    return 0;
}
