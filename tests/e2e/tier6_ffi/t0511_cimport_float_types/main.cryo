// @test: cimport_float_types
// @expect: compile_success
// @mode: project
// @stdout: float: 3.500000
// @stdout: double: 3.140000
// @tags: ffi, cimport, float, double, types
// @description: CImport with float and double parameter/return types.

namespace Main;

extern "CImport" c {
    #include "./funcs.h"
}

function main() -> i32 {
    const f: f32 = c::float_add(1.5, 2.0);
    printf("float: %f\n", f as f64);
    const d: f64 = c::double_add(1.14, 2.0);
    printf("double: %f\n", d);
    return 0;
}
