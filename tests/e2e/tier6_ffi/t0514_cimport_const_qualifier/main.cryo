// @test: cimport_const_qualifier
// @expect: compile_success
// @mode: project
// @stdout: length: 5
// @stdout: const works
// @tags: ffi, cimport, const, qualifier
// @description: CImport with const-qualified parameters and return types.

namespace Main;

extern "CImport" c {
    #include "./funcs.h"
}

function main() -> i32 {
    const len: i32 = c::string_length("hello");
    printf("length: %d\n", len);
    c::print_message("const works");
    return 0;
}
