// @test: cimport_void_pointer
// @expect: compile_success
// @mode: project
// @stdout: stored and loaded: 12345
// @tags: ffi, cimport, void_pointer, opaque
// @description: CImport with void* parameters and return - opaque pointer passing.

namespace Main;

extern "CImport" mem {
    #include "./funcs.h"
}

function main() -> i32 {
    const ptr: void* = mem::my_alloc(4);
    mem::store_int(ptr, 12345);
    const val: i32 = mem::load_int(ptr);
    printf("stored and loaded: %d\n", val);
    mem::my_free(ptr);
    return 0;
}
