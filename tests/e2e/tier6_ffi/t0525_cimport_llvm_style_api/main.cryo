// @test: cimport_llvm_style_api
// @expect: compile_success
// @mode: project
// @stdout: module: TestModule
// @stdout: type: Int
// @tags: ffi, cimport, llvm, opaque_handle, enum, comprehensive
// @description: Mock LLVM-C API with opaque handles, enum types, and mixed parameters. This is the key pattern for the Cryo compiler rewrite.

namespace Main;

extern "CImport" c {
    #include "./llvm_mock.h"
}

function main() -> i32 {
    const m: void* = c::module_create("TestModule");
    const name: string = c::module_get_name(m) as string;
    printf("module: %s\n", name);

    const b: void* = c::builder_create();
    c::builder_dispose(b);

    const tname: string = c::type_kind_name(1) as string;
    printf("type: %s\n", tname);

    c::module_dispose(m);
    return 0;
}
