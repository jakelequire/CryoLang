// @test: cimport_complex_header
// @expect: compile_success
// @mode: project
// @stdout: [WARN] world
// @stdout: count: 2
// @tags: ffi, cimport, complex, struct, enum, typedef
// @description: Complex C header with forward-declared structs, enums, typedefs, and multiple functions.

namespace Main;

api := extern "C" {
    #include "./api.h"
}

function main() -> i32 {
    const lg: void* = api::logger_create(1) as void*;
    api::logger_log(lg, 0, "hello");
    api::logger_log(lg, 2, "world");
    const cnt: i32 = api::logger_count(lg) as i32;
    printf("count: %d\n", cnt);
    api::logger_destroy(lg);
    return 0;
}
