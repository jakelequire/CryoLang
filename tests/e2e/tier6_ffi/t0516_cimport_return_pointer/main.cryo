// @test: cimport_return_pointer
// @expect: compile_success
// @mode: project
// @stdout: name: CryoFFI
// @stdout: value: 999
// @tags: ffi, cimport, return_pointer
// @description: CImport with functions that return pointer types (const char*, int*).

namespace Main;

c := extern "C" {
    #include "./funcs.h"
}

function main() -> i32 {
    const name: string = c::get_name() as string;
    printf("name: %s\n", name);
    const ptr: i32* = c::create_int(999);
    printf("value: %d\n", ptr[0]);
    c::destroy_int(ptr);
    return 0;
}
