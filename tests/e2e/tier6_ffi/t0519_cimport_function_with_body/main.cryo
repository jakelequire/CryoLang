// @test: cimport_function_with_body
// @expect: compile_success
// @mode: project
// @stdout: square(7) = 49
// @tags: ffi, cimport, inline, function_body
// @description: CImport header with inline function definitions (bodies). The CParser must skip function bodies and only extract prototypes. Tests resilience of the parser.

namespace Main;

c := extern "C" {
    #include "./funcs.h"
}

function main() -> i32 {
    c::print_square(7);
    return 0;
}
