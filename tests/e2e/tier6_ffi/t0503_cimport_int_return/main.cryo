// @test: cimport_int_return
// @expect: compile_success
// @mode: project
// @stdout: 3 + 4 = 7
// @stdout: 3 * 4 = 12
// @tags: ffi, cimport, int, return_value
// @description: CImport functions that return int values - verify return value passing.

namespace Main;

math := extern "C" {
    #include "./funcs.h"
}

function main() -> i32 {
    const sum: i32 = math::add(3, 4);
    const product: i32 = math::multiply(3, 4);
    printf("3 + 4 = %d\n", sum);
    printf("3 * 4 = %d\n", product);
    return 0;
}
