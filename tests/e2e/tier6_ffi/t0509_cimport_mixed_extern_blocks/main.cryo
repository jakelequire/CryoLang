// @test: cimport_mixed_extern_blocks
// @expect: compile_success
// @mode: project
// @stdout: from CImport
// @stdout: from extern C
// @tags: ffi, cimport, extern_c, mixed
// @description: Mix a CImport block and a traditional extern "C" block in the same file. The manual_func is defined in imported.c (auto-discovered via CImport) but declared manually in extern "C".

namespace Main;

extern "CImport" a {
    #include "./imported.h"
}

extern "C" {
    function manual_func() -> void;
}

function main() -> i32 {
    a::imported_func();
    manual_func();
    return 0;
}
