// @test: cimport_typedef_passthrough
// @expect: compile_success
// @mode: project
// @stdout: signed: -10
// @stdout: unsigned: 30
// @stdout: wide: 200
// @tags: ffi, cimport, stdint, fixed_width, typedef
// @description: CImport with stdint.h fixed-width types (int32_t, uint32_t, int64_t). These get expanded by the preprocessor and the CParser must handle them. Critical for LLVM interop.

namespace Main;

c := extern "C" {
    #include "./funcs.h"
}

function main() -> i32 {
    const s: i32 = c::signed_op(10, 20);
    printf("signed: %d\n", s);
    const u: u32 = c::unsigned_op(10, 20);
    printf("unsigned: %u\n", u);
    const w: i64 = c::wide_op(10, 20);
    printf("wide: %lld\n", w);
    return 0;
}
