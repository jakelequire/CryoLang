// @test: cimport_size_t_params
// @expect: compile_success
// @mode: project
// @stdout: length: 11
// @tags: ffi, cimport, size_t, stddef
// @description: CImport with size_t parameters - requires stddef.h preprocessing. Critical for stdlib interop since many C APIs use size_t.

namespace Main;

c := extern "C" {
    #include "./funcs.h"
}

function main() -> i32 {
    const len: u64 = c::my_strlen("hello world");
    printf("length: %llu\n", len);
    return 0;
}
