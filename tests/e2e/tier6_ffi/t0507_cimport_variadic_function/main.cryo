// @test: cimport_variadic_function
// @expect: compile_success
// @mode: project
// @stdout: formatted: hello 42
// @tags: ffi, cimport, variadic
// @description: CImport with a variadic C function (uses ...).

namespace Main;

c := extern "C" {
    #include "./funcs.h"
}

function main() -> i32 {
    const buf: i8* = malloc(64) as i8*;
    c::c_sprintf(buf, "hello %d", 42);
    printf("formatted: %s\n", buf);
    free(buf);
    return 0;
}
