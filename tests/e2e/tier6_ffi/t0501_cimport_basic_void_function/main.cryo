// @test: cimport_basic_void_function
// @expect: compile_success
// @mode: project
// @stdout: hello from C
// @tags: ffi, cimport, basic
// @description: Simplest CImport test - import a void function from C and call it.

namespace Main;

c := extern "C" {
    #include "./funcs.h"
}

function main() -> i32 {
    c::say_hello();
    return 0;
}
