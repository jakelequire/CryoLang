// Basic function declaration and calling test
// This test verifies that functions can be declared, called, and return values correctly

import IO from <io/stdio>;

function add(x: int, y: int) -> int {
    return x + y;
}

function subtract(x: int, y: int) -> int {
    return x - y;
}

function multiply(x: int, y: int) -> int {
    return x * y;
}

function divide(x: int, y: int) -> int {
    if (y != 0) {
        return x / y;
    }
    return 0;
}

function factorial(n: int) -> int {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

function fibonacci(n: int) -> int {
    if (n <= 1) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

function main() -> int {
    // Test basic arithmetic functions
    const sum: int = add(10, 5);
    const diff: int = subtract(10, 5);
    const product: int = multiply(10, 5);
    const quotient: int = divide(10, 5);
    
    IO::println("Testing basic functions:");
    IO::print_int(sum);      // Should print 15
    IO::print_int(diff);     // Should print 5
    IO::print_int(product);  // Should print 50
    IO::print_int(quotient); // Should print 2
    
    // Test recursive functions
    const fact5: int = factorial(5);
    const fib8: int = fibonacci(8);
    
    IO::println("Testing recursive functions:");
    IO::print_int(fact5);    // Should print 120
    IO::print_int(fib8);     // Should print 21
    
    // Test function composition
    const complex_result: int = add(multiply(3, 4), subtract(10, 2));
    IO::print_int(complex_result); // Should print 20 (12 + 8)
    
    return 0;
}