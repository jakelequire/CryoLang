// Generic types and template instantiation testing
// This test verifies that generic structs and functions work correctly

import IO from <io/stdio>;

// Generic container struct
type struct Container<T> {
    value: T;
    
    Container(v: T);
    ~Container() default;
    
    get() -> T;
    set(new_value: T) -> void;
    is_equal(other: Container<T>) -> boolean;
}

implement Container<T> {
    Container(v: T) {
        this.value = v;
    }
    
    get() -> T {
        return this.value;
    }
    
    set(new_value: T) -> void {
        this.value = new_value;
        return;
    }
    
    is_equal(other: Container<T>) -> boolean {
        return this.value == other.value;
    }
}

// Generic pair struct
type struct Pair<T, U> {
    first: T;
    second: U;
    
    Pair(f: T, s: U);
    ~Pair() default;
    
    get_first() -> T;
    get_second() -> U;
    swap() -> Pair<U, T>;
}

implement Pair<T, U> {
    Pair(f: T, s: U) {
        this.first = f;
        this.second = s;
    }
    
    get_first() -> T {
        return this.first;
    }
    
    get_second() -> U {
        return this.second;
    }
    
    swap() -> Pair<U, T> {
        return new Pair<U, T>(this.second, this.first);
    }
}

// Generic array-like structure
type struct Array<T> {
    data: T*;
    size: u64;
    capacity: u64;
    
    Array(initial_capacity: u64);
    ~Array() default;
    
    get(index: u64) -> T;
    set(index: u64, value: T) -> void;
    length() -> u64;
    is_empty() -> boolean;
}

implement Array<T> {
    Array(initial_capacity: u64) {
        this.data = Runtime::cryo_alloc(initial_capacity * sizeof(T));
        this.size = 0;
        this.capacity = initial_capacity;
    }
    
    get(index: u64) -> T {
        if (index < this.size) {
            return this.data[index];
        }
        // Return default value - this would need proper error handling
        return this.data[0];
    }
    
    set(index: u64, value: T) -> void {
        if (index < this.capacity) {
            this.data[index] = value;
            if (index >= this.size) {
                this.size = index + 1;
            }
        }
        return;
    }
    
    length() -> u64 {
        return this.size;
    }
    
    is_empty() -> boolean {
        return this.size == 0;
    }
}

// Generic functions
function max<T>(a: T, b: T) -> T {
    if (a > b) {
        return a;
    }
    return b;
}

function min<T>(a: T, b: T) -> T {
    if (a < b) {
        return a;
    }
    return b;
}

function swap<T>(a: T*, b: T*) -> void {
    const temp: T = *a;
    *a = *b;
    *b = temp;
    return;
}

function main() -> int {
    IO::println("Testing generic types and functions:");
    
    // Test Container<int>
    const int_container: Container<int> = new Container<int>(42);
    const value: int = int_container.get();
    IO::println("Integer container value:");
    IO::print_int(value);  // Should print 42
    
    int_container.set(100);
    const new_value: int = int_container.get();
    IO::print_int(new_value);  // Should print 100
    
    // Test Container<float>
    const float_container: Container<float> = new Container<float>(3.14);
    const float_value: float = float_container.get();
    IO::println("Float container value:");
    IO::print_float(float_value);  // Should print 3.14
    
    // Test Container equality
    const int_container2: Container<int> = new Container<int>(100);
    const are_equal: boolean = int_container.is_equal(int_container2);
    IO::println("Containers equal:");
    IO::print_bool(are_equal);  // Should print true
    
    // Test Pair<int, string>
    const int_string_pair: Pair<int, string> = new Pair<int, string>(1, "hello");
    const first: int = int_string_pair.get_first();
    const second: string = int_string_pair.get_second();
    
    IO::println("Pair values:");
    IO::print_int(first);     // Should print 1
    IO::println(second);      // Should print "hello"
    
    // Test Pair swapping
    const swapped: Pair<string, int> = int_string_pair.swap();
    const swapped_first: string = swapped.get_first();
    const swapped_second: int = swapped.get_second();
    
    IO::println("Swapped pair values:");
    IO::println(swapped_first);  // Should print "hello"
    IO::print_int(swapped_second);  // Should print 1
    
    // Test Array<int>
    const int_array: Array<int> = new Array<int>(10);
    
    // Fill array with values
    for (mut i: u64 = 0; i < 5; i++) {
        int_array.set(i, int(i * 2));
    }
    
    IO::println("Array values:");
    for (mut j: u64 = 0; j < int_array.length(); j++) {
        const array_value: int = int_array.get(j);
        IO::print_int(array_value);  // Should print 0, 2, 4, 6, 8
    }
    
    const array_length: u64 = int_array.length();
    IO::println("Array length:");
    IO::print_int(int(array_length));  // Should print 5
    
    // Test generic functions
    const max_int: int = max<int>(15, 23);
    const min_int: int = min<int>(15, 23);
    
    IO::println("Max and min:");
    IO::print_int(max_int);  // Should print 23
    IO::print_int(min_int);  // Should print 15
    
    const max_float: float = max<float>(2.5, 1.8);
    const min_float: float = min<float>(2.5, 1.8);
    
    IO::print_float(max_float);  // Should print 2.5
    IO::print_float(min_float);  // Should print 1.8
    
    // Test generic swap function
    mut x: int = 10;
    mut y: int = 20;
    
    IO::println("Before swap:");
    IO::print_int(x);  // Should print 10
    IO::print_int(y);  // Should print 20
    
    swap<int>(&x, &y);
    
    IO::println("After swap:");
    IO::print_int(x);  // Should print 20
    IO::print_int(y);  // Should print 10
    
    return 0;
}