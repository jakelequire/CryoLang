// Struct declaration, instantiation, and method testing
// This test verifies struct definitions, field access, constructors, and methods

import IO from <io/stdio>;

type struct Point {
    x: int;
    y: int;
    
    Point(x: int, y: int);
    ~Point() default;
    
    distance_from_origin() -> float;
    move(dx: int, dy: int) -> void;
    get_quadrant() -> int;
}

implement Point {
    Point(x: int, y: int) {
        this.x = x;
        this.y = y;
    }
    
    distance_from_origin() -> float {
        const x_squared: float = float(this.x * this.x);
        const y_squared: float = float(this.y * this.y);
        return sqrt(x_squared + y_squared);
    }
    
    move(dx: int, dy: int) -> void {
        this.x = this.x + dx;
        this.y = this.y + dy;
        return;
    }
    
    get_quadrant() -> int {
        if (this.x > 0 && this.y > 0) {
            return 1;
        } else if (this.x < 0 && this.y > 0) {
            return 2;
        } else if (this.x < 0 && this.y < 0) {
            return 3;
        } else if (this.x > 0 && this.y < 0) {
            return 4;
        }
        return 0; // On axis
    }
}

type struct Rectangle {
    top_left: Point;
    width: int;
    height: int;
    
    Rectangle(x: int, y: int, w: int, h: int);
    ~Rectangle() default;
    
    area() -> int;
    perimeter() -> int;
    contains_point(p: Point) -> boolean;
}

implement Rectangle {
    Rectangle(x: int, y: int, w: int, h: int) {
        this.top_left = new Point(x, y);
        this.width = w;
        this.height = h;
    }
    
    area() -> int {
        return this.width * this.height;
    }
    
    perimeter() -> int {
        return 2 * (this.width + this.height);
    }
    
    contains_point(p: Point) -> boolean {
        const right: int = this.top_left.x + this.width;
        const bottom: int = this.top_left.y - this.height;
        
        return p.x >= this.top_left.x && p.x <= right &&
               p.y <= this.top_left.y && p.y >= bottom;
    }
}

type struct Circle {
    center: Point;
    radius: float;
    
    Circle(x: int, y: int, r: float);
    ~Circle() default;
    
    area() -> float;
    circumference() -> float;
    contains_point(p: Point) -> boolean;
}

implement Circle {
    Circle(x: int, y: int, r: float) {
        this.center = new Point(x, y);
        this.radius = r;
    }
    
    area() -> float {
        return 3.14159 * this.radius * this.radius;
    }
    
    circumference() -> float {
        return 2.0 * 3.14159 * this.radius;
    }
    
    contains_point(p: Point) -> boolean {
        const dx: int = p.x - this.center.x;
        const dy: int = p.y - this.center.y;
        const distance_squared: float = float(dx * dx + dy * dy);
        const radius_squared: float = this.radius * this.radius;
        
        return distance_squared <= radius_squared;
    }
}

function main() -> int {
    IO::println("Testing struct declarations and methods:");
    
    // Test Point struct
    const p1: Point = new Point(3, 4);
    const p2: Point = new Point(-2, 1);
    
    IO::println("Point coordinates:");
    IO::print_int(p1.x);  // Should print 3
    IO::print_int(p1.y);  // Should print 4
    
    const distance: float = p1.distance_from_origin();
    IO::println("Distance from origin:");
    IO::print_float(distance);  // Should print 5.0
    
    const quadrant: int = p1.get_quadrant();
    IO::println("Quadrant:");
    IO::print_int(quadrant);  // Should print 1
    
    // Test point movement
    p1.move(2, -1);
    IO::println("After move:");
    IO::print_int(p1.x);  // Should print 5
    IO::print_int(p1.y);  // Should print 3
    
    // Test Rectangle struct
    const rect: Rectangle = new Rectangle(0, 10, 8, 6);
    const rect_area: int = rect.area();
    const rect_perimeter: int = rect.perimeter();
    
    IO::println("Rectangle area and perimeter:");
    IO::print_int(rect_area);      // Should print 48
    IO::print_int(rect_perimeter); // Should print 28
    
    const point_in_rect: Point = new Point(4, 7);
    const is_inside: boolean = rect.contains_point(point_in_rect);
    IO::println("Point inside rectangle:");
    IO::print_bool(is_inside);  // Should print true
    
    // Test Circle struct
    const circle: Circle = new Circle(0, 0, 5.0);
    const circle_area: float = circle.area();
    const circle_circumference: float = circle.circumference();
    
    IO::println("Circle area and circumference:");
    IO::print_float(circle_area);          // Should print ~78.54
    IO::print_float(circle_circumference); // Should print ~31.42
    
    const point_in_circle: Point = new Point(3, 4);
    const is_in_circle: boolean = circle.contains_point(point_in_circle);
    IO::println("Point inside circle:");
    IO::print_bool(is_in_circle);  // Should print true (distance = 5.0, radius = 5.0)
    
    return 0;
}