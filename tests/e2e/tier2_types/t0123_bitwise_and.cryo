namespace BitwiseAnd;

function main() -> int {
    const a: int = 5;
    const b: int = 3;
    const c: int = a & b;
    printf("%d\n", 6 & 1);
    printf("%d\n", 7 & 5);
    printf("%d\n", 7 | 5);
    return 0;
}
