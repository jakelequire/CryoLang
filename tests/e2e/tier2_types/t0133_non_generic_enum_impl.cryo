// @test: non_generic_enum_impl
// @expect: compile_success
// @mode: raw
// @stdout: -1
// @stdout: 0
// @stdout: 1
// @stdout: 1
// @tags: enums, implement

namespace NonGenEnumImpl;

enum Ordering {
    Less;
    Equal;
    Greater;
}

implement enum Ordering {
    to_int(&this) -> int {
        match (&this) {
            Ordering::Less => { return -1; }
            Ordering::Equal => { return 0; }
            Ordering::Greater => { return 1; }
            _ => { return 0; }
        }
    }

    is_eq(&this) -> int {
        match (&this) {
            Ordering::Equal => { return 1; }
            _ => { return 0; }
        }
    }
}

function main() -> int {
    const a: Ordering = Ordering::Less;
    const b: Ordering = Ordering::Equal;
    const c: Ordering = Ordering::Greater;
    printf("%d\n", a.to_int());
    printf("%d\n", b.to_int());
    printf("%d\n", c.to_int());
    printf("%d\n", b.is_eq());
    return 0;
}
