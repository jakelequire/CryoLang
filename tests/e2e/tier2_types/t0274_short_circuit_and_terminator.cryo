// @test: short_circuit_and_terminator
// @expect: compile_success
// @mode: raw
// @stdout: both true
// @stdout: short circuited
// @stdout: three way: yes
// @tags: control_flow, logical_and, short_circuit, stdlib_root_cause
// @description: RC7 - Short-circuit && evaluation must produce proper basic block terminators. When the LHS of && is false, the RHS must not be evaluated, and the and.rhs/and.merge blocks must be properly terminated with branch instructions.

namespace ShortCircuitTerminator;

function check_positive(x: int) -> boolean {
    return x > 0;
}

function check_even(x: int) -> boolean {
    return (x % 2) == 0;
}

function main() -> int {
    const a: int = 4;
    const b: int = -1;

    // Basic short-circuit &&
    if (check_positive(a) && check_even(a)) {
        printf("both true\n");
    }

    // Short circuit: first is false, second should NOT execute
    if (check_positive(b) && check_even(b)) {
        printf("should not print\n");
    } else {
        printf("short circuited\n");
    }

    // Three-way &&
    if (a > 0 && a < 10 && a == 4) {
        printf("three way: yes\n");
    }

    return 0;
}
