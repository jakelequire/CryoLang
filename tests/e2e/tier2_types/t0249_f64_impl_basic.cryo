// @test: f64_impl_basic
// @expect: compile_success
// @mode: raw
// @stdout: 1
// @stdout: 0
// @tags: f64, implement, baseline
// @description: Baseline - implement block on f64 with simple expressions using `this` (no function calls)

namespace F64ImplBasic;

implement f64 {
    is_positive(&this) -> boolean {
        return this > 0.0;
    }

    is_negative(&this) -> boolean {
        return this < 0.0;
    }
}

function main() -> int {
    const x: f64 = 3.14;
    if (x.is_positive()) {
        printf("1\n");
    } else {
        printf("0\n");
    }
    if (x.is_negative()) {
        printf("1\n");
    } else {
        printf("0\n");
    }
    return 0;
}
