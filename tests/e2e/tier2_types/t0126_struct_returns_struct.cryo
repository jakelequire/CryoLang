// @test: struct_returns_struct
// @expect: compile_success
// @mode: raw
// @stdout: 1:10
// @stdout: 2:20
// @stdout: 3:30
// @tags: structs, methods, return

namespace StructReturnsStruct;

type struct Item {
    key: int;
    value: int;

    static new(k: int, v: int) -> Item {
        return Item { key: k, value: v };
    }
}

type struct Iter {
    data: Item*;
    pos: int;
    len: int;

    static new(d: Item*, n: int) -> Iter {
        return Iter { data: d, pos: 0, len: n };
    }

    has_next(&this) -> int {
        if (this.pos < this.len) {
            return 1;
        }
        return 0;
    }

    next(mut &this) -> Item {
        const idx: int = this.pos;
        this.pos = this.pos + 1;
        return this.data[idx];
    }
}

type struct Collection {
    items: Item*;
    count: int;

    static new(d: Item*, n: int) -> Collection {
        return Collection { items: d, count: n };
    }

    iter(&this) -> Iter {
        return Iter::new(this.items, this.count);
    }
}

function main() -> int {
    mut data: Item[3] = [
        Item::new(1, 10),
        Item::new(2, 20),
        Item::new(3, 30)
    ];
    const c: Collection = Collection::new(&data[0], 3);
    mut it: Iter = c.iter();
    while (it.has_next()) {
        const item: Item = it.next();
        printf("%d:%d\n", item.key, item.value);
    }
    return 0;
}
