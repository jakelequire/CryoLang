// @test: ptr_index_field_assign
// @expect: compile_success
// @mode: raw
// @stdout: 0:empty
// @stdout: 1:hello
// @stdout: 2:empty
// @tags: structs, pointers, indexing, assignment

namespace PtrIdxFieldAssign;

const STATE_EMPTY: int = 0;
const STATE_OCCUPIED: int = 1;

type struct Bucket {
    key: string;
    state: int;
}

type struct Table {
    entries: Bucket*;
    cap: int;

    static new(cap: int) -> Table {
        const ptr: Bucket* = calloc(cap, sizeof(Bucket));
        return Table { entries: ptr, cap: cap };
    }

    insert(mut &this, idx: int, key: string) -> void {
        this.entries[idx].key = key;
        this.entries[idx].state = STATE_OCCUPIED;
    }

    dump(&this) -> void {
        mut i: int = 0;
        while (i < this.cap) {
            if (this.entries[i].state == STATE_OCCUPIED) {
                printf("%d:%s\n", i, this.entries[i].key);
            } else {
                printf("%d:empty\n", i);
            }
            i = i + 1;
        }
    }

    drop(mut &this) -> void {
        free(this.entries);
    }
}

function main() -> int {
    mut t: Table = Table::new(3);
    t.insert(1, "hello");
    t.dump();
    t.drop();
    return 0;
}
