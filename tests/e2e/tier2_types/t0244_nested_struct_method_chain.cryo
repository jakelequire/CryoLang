// @test: nested_struct_method_chain
// @expect: compile_success
// @mode: raw
// @stdout: 3
// @stdout: hello world!
// @tags: structs, methods, chaining, nested

namespace NestedMethodChain;

type struct Inner {
    data: string;
    len: int;

    static new(s: string, l: int) -> Inner {
        return Inner { data: s, len: l };
    }

    length(&this) -> int {
        return this.len;
    }

    get_data(&this) -> string {
        return this.data;
    }
}

type struct Outer {
    inner: Inner;
    label: string;

    static new(s: string, l: int, label: string) -> Outer {
        return Outer { inner: Inner::new(s, l), label: label };
    }

    get_inner_length(&this) -> int {
        return this.inner.length();
    }

    get_inner_data(&this) -> string {
        return this.inner.get_data();
    }
}

function main() -> int {
    const o: Outer = Outer::new("hello world!", 3, "test");
    printf("%d\n", o.get_inner_length());
    printf("%s\n", o.get_inner_data());
    return 0;
}
