// @test: mut_field_in_loop
// @expect: compile_success
// @mode: raw
// @stdout: 1
// @stdout: 2
// @stdout: 4
// @stdout: 8
// @stdout: 16
// @stdout: 32
// @tags: structs, mutation, while, member_access

namespace MutFieldInLoop;

type struct Counter {
    value: int;
    limit: int;

    static new(lim: int) -> Counter {
        return Counter { value: 1, limit: lim };
    }

    step(mut &this) -> void {
        this.value = this.value * 2;
    }

    done(&this) -> int {
        if (this.value > this.limit) {
            return 1;
        }
        return 0;
    }
}

function main() -> int {
    mut c: Counter = Counter::new(16);
    while (c.done() == 0) {
        printf("%d\n", c.value);
        c.step();
    }
    printf("%d\n", c.value);
    return 0;
}
