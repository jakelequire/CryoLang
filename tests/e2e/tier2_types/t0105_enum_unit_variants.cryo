// @test: enum_unit_variants
// @expect: compile_success
// @mode: raw
// @stdout: red
// @tags: enums, match

namespace EnumUnit;

enum Color {
    Red;
    Green;
    Blue;
}

function print_color(c: Color) -> void {
    match (c) {
        Color::Red => {
            printf("red\n");
        },
        Color::Green => {
            printf("green\n");
        },
        Color::Blue => {
            printf("blue\n");
        },
    }
}

function main() -> int {
    const c: Color = Color::Red;
    print_color(c);
    return 0;
}
