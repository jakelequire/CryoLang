// @test: string_loop_assign
// @expect: compile_success
// @mode: raw
// @stdout: ABCD
// @tags: strings, indexing, assignment, loops, primitives_bug
// @description: Isolates E0614 - assigning chars to string in a loop (str[i] = chars[i])

namespace StrLoopAssign;

function main() -> int {
    mut buf: char[5] = ['A', 'B', 'C', 'D', '\0'];
    mut str: string = "xxxx";
    for (mut i: int = 0; i < 4; i = i + 1) {
        str[i] = buf[i];
    }
    printf("%s\n", str);
    return 0;
}
