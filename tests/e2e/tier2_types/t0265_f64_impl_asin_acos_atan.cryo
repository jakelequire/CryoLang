// @test: f64_impl_asin_acos_atan
// @expect: compile_success
// @mode: raw
// @stdout_contains: 0.0
// @stdout_contains: 1.6
// @tags: f64, implement, intrinsics, asin, acos, atan, primitives_bug
// @description: Isolates E0601 - f64 implement block calling asin/acos/atan via &this

namespace F64ImplInvTrig;

implement f64 {
    asin(&this) -> f64 {
        return asin(&this);
    }

    acos(&this) -> f64 {
        return acos(&this);
    }

    atan(&this) -> f64 {
        return atan(&this);
    }
}

function main() -> int {
    const zero: f64 = 0.0;
    // asin(0) = 0.0
    printf("%.1f\n", zero.asin());
    // acos(0) = pi/2 ≈ 1.57
    printf("%.1f\n", zero.acos());
    // atan(0) = 0.0
    printf("%.1f\n", zero.atan());
    return 0;
}
