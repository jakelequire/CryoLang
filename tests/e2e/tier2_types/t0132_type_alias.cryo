// @test: type_alias
// @expect: compile_success
// @mode: raw
// @stdout: 42
// @stdout: 100
// @tags: types, alias

namespace TypeAlias;

type MyInt = i32;
type Size = u64;

function main() -> int {
    const a: MyInt = 42;
    const b: Size = 100;
    printf("%d\n", a);
    printf("%lu\n", b);
    return 0;
}
