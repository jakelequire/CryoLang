// @test: match_value_expression
// @expect: compile_success
// @mode: raw
// @stdout: got_one
// @stdout: got_two
// @stdout: got_other
// @tags: match, expressions

namespace MatchValExpr;

enum Color {
    Red;
    Green;
    Blue;
}

function color_name(c: Color) -> int {
    match (c) {
        Color::Red => {
            printf("got_one\n");
            return 1;
        }
        Color::Green => {
            printf("got_two\n");
            return 2;
        }
        Color::Blue => {
            printf("got_other\n");
            return 3;
        }
    }
}

function main() -> int {
    color_name(Color::Red);
    color_name(Color::Green);
    color_name(Color::Blue);
    return 0;
}
