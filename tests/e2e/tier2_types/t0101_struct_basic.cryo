// @test: struct_basic
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: 20
// @tags: structs

namespace StructBasic;

type struct Point {
    x: int;
    y: int;

    static new(x: int, y: int) -> Point {
        return Point { x: x, y: y };
    }
}

function main() -> int {
    const p: Point = Point::new(10, 20);
    printf("%d\n", p.x);
    printf("%d\n", p.y);
    return 0;
}
