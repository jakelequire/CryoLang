// @test: static_new_returns_ptr
// @expect: compile_success
// @mode: raw
// @stdout: 128
// @tags: structs, static_methods, pointers, new_constructor, stdlib_bug
// @description: Isolates E0200 - static new() returning pointer type resolved as value type

namespace StaticNewReturnsPtr;

type struct Node {
    value: int;
    next: Node*;

    static new(val: int) -> Node* {
        const n: Node* = malloc(sizeof(Node));
        if (n == null) {
            return null;
        }
        n.value = val;
        n.next = null;
        return n;
    }
}

function main() -> int {
    const n: Node* = Node::new(128);
    if (n == null) {
        return 1;
    }
    printf("%d\n", n.value);
    free(n);
    return 0;
}
