// @test: struct_const_members
// @expect: compile_success
// @mode: raw
// @stdout: 16
// @stdout: 32
// @tags: structs, constants, methods

namespace StructConstMembers;

const DEFAULT_CAPACITY: int = 16;
const GROWTH_FACTOR: int = 2;

type struct Buffer {
    data: int*;
    len: int;
    cap: int;

    static new() -> Buffer {
        const ptr: int* = malloc(sizeof(int) * DEFAULT_CAPACITY);
        return Buffer { data: ptr, len: 0, cap: DEFAULT_CAPACITY };
    }

    capacity(&this) -> int {
        return this.cap;
    }

    grow(mut &this) -> void {
        const new_cap: int = this.cap * GROWTH_FACTOR;
        const new_ptr: int* = realloc(this.data, sizeof(int) * new_cap);
        this.data = new_ptr;
        this.cap = new_cap;
    }

    drop(mut &this) -> void {
        free(this.data);
    }
}

function main() -> int {
    mut buf: Buffer = Buffer::new();
    printf("%d\n", buf.capacity());
    buf.grow();
    printf("%d\n", buf.capacity());
    buf.drop();
    return 0;
}
