// @test: f64_impl_pow
// @expect: compile_success
// @mode: raw
// @stdout: 8.000000
// @tags: f64, implement, intrinsics, pow, primitives_bug
// @description: Isolates E0601 - f64 implement block calling pow intrinsic via &this. LLVM error shows ptr passed where double expected.

namespace F64ImplPow;

implement f64 {
    powf(&this, n: f64) -> f64 {
        return pow(&this, n);
    }
}

function main() -> int {
    const x: f64 = 2.0;
    printf("%f\n", x.powf(3.0));
    return 0;
}
