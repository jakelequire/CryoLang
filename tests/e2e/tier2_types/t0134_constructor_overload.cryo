// @test: constructor_overload
// @expect: compile_success
// @mode: raw
// @stdout: 0
// @stdout: 0
// @stdout: 5
// @stdout: 10
// @tags: structs, constructors, overload

namespace CtorOverload;

type struct Buffer {
    capacity: int;
    len: int;

    static new() -> Buffer {
        return Buffer { capacity: 16, len: 0 };
    }

    static new(cap: int) -> Buffer {
        return Buffer { capacity: cap, len: 0 };
    }

    get_capacity(&this) -> int {
        return this.capacity;
    }

    get_len(&this) -> int {
        return this.len;
    }
}

function main() -> int {
    const a: Buffer = Buffer::new();
    const b: Buffer = Buffer::new(5);
    printf("%d\n", a.get_len());
    printf("%d\n", b.get_len());
    printf("%d\n", b.get_capacity());
    printf("%d\n", b.get_capacity() * 2);
    return 0;
}
