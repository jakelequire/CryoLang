// @test: string_index_read
// @expect: compile_success
// @mode: raw
// @stdout: H
// @stdout: e
// @tags: strings, indexing, baseline
// @description: Baseline test - reading characters from a string by index should work

namespace StrIdxRead;

function main() -> int {
    const str: string = "Hello";
    const c0: char = str[0];
    const c1: char = str[1];
    printf("%c\n", c0);
    printf("%c\n", c1);
    return 0;
}
