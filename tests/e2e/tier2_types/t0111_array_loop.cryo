// @test: array_loop
// @expect: compile_success
// @mode: raw
// @stdout: 1
// @stdout: 2
// @stdout: 3
// @stdout: 4
// @stdout: 5
// @tags: arrays, loops

namespace ArrayLoop;

function main() -> int {
    const arr: int[5] = [1, 2, 3, 4, 5];
    for (mut i: int = 0; i < 5; i++) {
        printf("%d\n", arr[i]);
    }
    return 0;
}
