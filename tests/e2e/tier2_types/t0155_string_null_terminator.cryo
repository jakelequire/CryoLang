// @test: string_null_terminator
// @expect: compile_success
// @mode: raw
// @stdout: Hi!
// @tags: strings, char, null_terminator

namespace StrNullTerm;

function main() -> int {
    mut buf: u8[4] = [0; 4];
    buf[0] = 'H';
    buf[1] = 'i';
    buf[2] = '!';
    buf[3] = '\0';
    printf("%s\n", &buf[0] as string);
    return 0;
}
