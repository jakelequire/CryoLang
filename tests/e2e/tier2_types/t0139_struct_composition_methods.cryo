// @test: struct_composition_methods
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: 20
// @stdout: 200
// @tags: structs, methods, composition

namespace StructCompMethods;

type struct Size {
    w: int;
    h: int;

    static new(w: int, h: int) -> Size {
        return Size { w: w, h: h };
    }

    area(&this) -> int {
        return this.w * this.h;
    }
}

type struct Rect {
    origin_x: int;
    origin_y: int;
    size: Size;

    static new(x: int, y: int, w: int, h: int) -> Rect {
        return Rect { origin_x: x, origin_y: y, size: Size::new(w, h) };
    }

    get_area(&this) -> int {
        return this.size.area();
    }
}

function main() -> int {
    const r: Rect = Rect::new(10, 20, 10, 20);
    printf("%d\n", r.origin_x);
    printf("%d\n", r.origin_y);
    printf("%d\n", r.get_area());
    return 0;
}
