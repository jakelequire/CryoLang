// @test: struct_with_opaque_ffi_field
// @expect: compile_success
// @mode: raw
// @stdout: locked
// @stdout: unlocked
// @tags: structs, ffi, opaque_types, stdlib_root_cause
// @description: RC2 - Struct containing opaque FFI type fields (like PThreadMutex wrapping pthread_mutex_t). The compiler must correctly size and layout structs that contain fixed-size opaque byte arrays used to represent C types.

namespace StructOpaqueFfi;

/// Simulates an opaque FFI type with a known fixed size.
/// pthread_mutex_t is typically 40 bytes on Linux x86_64.
type struct OpaqueSync {
    data: u8[48];

    static default() -> OpaqueSync {
        mut result: OpaqueSync = OpaqueSync { data: 0 };
        return result;
    }
}

/// A higher-level struct that contains an opaque FFI field.
/// This mirrors sync/barrier.cryo's Barrier { mutex: PThreadMutex; ... }
type struct Guard {
    lock: OpaqueSync;
    count: u64;
    active: boolean;

    static new() -> Guard {
        return Guard {
            lock: OpaqueSync::default(),
            count: 0,
            active: false
        };
    }

    acquire(mut &this) -> void {
        this.active = true;
        this.count = this.count + 1;
    }

    release(mut &this) -> void {
        this.active = false;
    }

    is_active(&this) -> boolean {
        return this.active;
    }
}

function main() -> int {
    mut g: Guard = Guard::new();
    g.acquire();
    if (g.is_active()) {
        printf("locked\n");
    }
    g.release();
    if (!g.is_active()) {
        printf("unlocked\n");
    }
    return 0;
}
