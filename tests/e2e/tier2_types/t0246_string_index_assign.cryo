// @test: string_index_assign
// @expect: compile_success
// @mode: raw
// @stdout: Hello
// @tags: strings, indexing, assignment, primitives_bug
// @description: Isolates E0614 - assigning a character to a string index (str[i] = char)

namespace StrIdxAssign;

function main() -> int {
    mut str: string = "hello";
    str[0] = 'H';
    printf("%s\n", str);
    return 0;
}
