// @test: pointer_deref_after_cast
// @expect: compile_success
// @mode: raw
// @stdout: 42
// @tags: pointers, casting, dereference

namespace PtrDerefCast;

function main() -> int {
    mut val: int = 42;
    const vp: void* = &val as void*;
    const result: int = *(vp as int*);
    printf("%d\n", result);
    return 0;
}
