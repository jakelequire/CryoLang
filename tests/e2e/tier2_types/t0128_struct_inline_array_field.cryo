// @test: struct_inline_array_field
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: 20
// @stdout: 30
// @tags: structs, arrays, member_access

namespace StructInlineArr;

type struct SmallVec {
    data: int[4];
    len: int;

    static new() -> SmallVec {
        return SmallVec { data: [0, 0, 0, 0], len: 0 };
    }

    push(mut &this, val: int) -> void {
        this.data[this.len] = val;
        this.len = this.len + 1;
    }

    get(&this, index: int) -> int {
        return this.data[index];
    }
}

function main() -> int {
    mut v: SmallVec = SmallVec::new();
    v.push(10);
    v.push(20);
    v.push(30);
    printf("%d\n", v.get(0));
    printf("%d\n", v.get(1));
    printf("%d\n", v.get(2));
    return 0;
}
