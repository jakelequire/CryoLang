// @test: f64_impl_hyperbolic
// @expect: compile_success
// @mode: raw
// @stdout_contains: 0.0
// @stdout_contains: 1.0
// @stdout_contains: 0.0
// @tags: f64, implement, intrinsics, sinh, cosh, tanh, primitives_bug
// @description: Isolates E0601 - f64 implement block calling sinh/cosh/tanh via &this

namespace F64ImplHyperbolic;

implement f64 {
    sinh(&this) -> f64 {
        return sinh(&this);
    }

    cosh(&this) -> f64 {
        return cosh(&this);
    }

    tanh(&this) -> f64 {
        return tanh(&this);
    }
}

function main() -> int {
    const zero: f64 = 0.0;
    // sinh(0) = 0.0, cosh(0) = 1.0, tanh(0) = 0.0
    printf("%.1f\n", zero.sinh());
    printf("%.1f\n", zero.cosh());
    printf("%.1f\n", zero.tanh());
    return 0;
}
