// @test: void_star_param
// @expect: compile_success
// @mode: raw
// @stdout: 42
// @stdout: 99
// @tags: pointers, void, casting, ffi

namespace VoidStarParam;

function read_int(ptr: void*) -> int {
    const ip: int* = ptr as int*;
    return *ip;
}

function main() -> int {
    mut a: int = 42;
    mut b: int = 99;
    printf("%d\n", read_int(&a as void*));
    printf("%d\n", read_int(&b as void*));
    return 0;
}
