// @test: struct_static_methods
// @expect: compile_success
// @mode: raw
// @stdout: 0
// @stdout: 0
// @tags: structs, static

namespace StructStatic;

type struct Counter {
    value: int;

    static zero() -> Counter {
        return Counter { value: 0 };
    }

    get(&this) -> int {
        return this.value;
    }
}

function main() -> int {
    const c: Counter = Counter::zero();
    printf("%d\n", c.value);
    printf("%d\n", c.get());
    return 0;
}
