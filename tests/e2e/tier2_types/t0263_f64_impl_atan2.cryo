// @test: f64_impl_atan2
// @expect: compile_success
// @mode: raw
// @stdout_contains: 0.8
// @tags: f64, implement, intrinsics, atan2, primitives_bug
// @description: Isolates E0601 - f64 implement block calling atan2 intrinsic with &this and extra param

namespace F64ImplAtan2;

implement f64 {
    atan2(&this, x: f64) -> f64 {
        return atan2(&this, x);
    }
}

function main() -> int {
    const y: f64 = 1.0;
    // atan2(1.0, 1.0) = pi/4 ≈ 0.785
    printf("%.1f\n", y.atan2(1.0));
    return 0;
}
