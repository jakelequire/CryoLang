// @test: struct_fn_ptr_field_call
// @expect: compile_success
// @mode: raw
// @stdout: write_called: hello
// @stdout: flush_called
// @tags: structs, function_pointers, member_access, stdlib_bug
// @description: RC3 - Calling function-pointer fields on structs (e.g. this.write_fn(...) in Writer)

namespace StructFnPtrField;

function my_write(handle: void*, data: u8*, len: u64) -> int {
    printf("write_called: %s\n", data);
    return len;
}

function my_flush(handle: void*) -> int {
    printf("flush_called\n");
    return 0;
}

type struct Writer {
    handle: void*;
    write_fn: (void*, u8*, u64) -> int;
    flush_fn: (void*) -> int;

    static new(
        handle: void*,
        wfn: (void*, u8*, u64) -> int,
        ffn: (void*) -> int
    ) -> Writer {
        return Writer {
            handle: handle,
            write_fn: wfn,
            flush_fn: ffn
        };
    }

    write(&this, data: u8*, len: u64) -> int {
        return this.write_fn(this.handle, data, len);
    }

    flush(&this) -> int {
        return this.flush_fn(this.handle);
    }
}

function main() -> int {
    const w: Writer = Writer::new(null, my_write, my_flush);
    w.write("hello", 5);
    w.flush();
    return 0;
}
