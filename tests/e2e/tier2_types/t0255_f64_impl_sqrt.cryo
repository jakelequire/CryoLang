// @test: f64_impl_sqrt
// @expect: compile_success
// @mode: raw
// @stdout: 3.000000
// @tags: f64, implement, intrinsics, sqrt, primitives_bug
// @description: Isolates E0601 - f64 implement block calling sqrt intrinsic via &this. LLVM error: "Intrinsic has incorrect return type! ptr @llvm.sqrt.p0"

namespace F64ImplSqrt;

implement f64 {
    sqrt(&this) -> f64 {
        return sqrt(&this);
    }
}

function main() -> int {
    const x: f64 = 9.0;
    printf("%f\n", x.sqrt());
    return 0;
}
