// @test: method_chaining
// @expect: compile_success
// @mode: raw
// @stdout: 6
// @tags: structs, methods, chaining

namespace MethodChain;

type struct Builder {
    total: int;

    static new() -> Builder {
        return Builder { total: 0 };
    }

    add(mut &this, n: int) -> void {
        this.total = this.total + n;
    }

    result(&this) -> int {
        return this.total;
    }
}

function main() -> int {
    mut b: Builder = Builder::new();
    b.add(1);
    b.add(2);
    b.add(3);
    printf("%d\n", b.result());
    return 0;
}
