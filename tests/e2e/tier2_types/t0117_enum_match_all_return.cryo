// @test: enum_match_all_return
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: -1
// @tags: enums, match, return

namespace EnumMatchAllReturn;

enum Status {
    Ok(int);
    Error;
}

function get_value(s: Status) -> int {
    match (s) {
        Status::Ok(v) => { return v; }
        Status::Error => { return -1; }
        _ => { return -1; }
    }
}

function main() -> int {
    const a: Status = Status::Ok(10);
    const b: Status = Status::Error;
    printf("%d\n", get_value(a));
    printf("%d\n", get_value(b));
    return 0;
}
