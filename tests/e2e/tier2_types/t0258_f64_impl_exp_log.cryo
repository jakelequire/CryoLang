// @test: f64_impl_exp_log
// @expect: compile_success
// @mode: raw
// @stdout_contains: 1.0
// @stdout_contains: 0.0
// @tags: f64, implement, intrinsics, exp, log, primitives_bug
// @description: Isolates E0601 - f64 implement block calling exp/log intrinsics via &this

namespace F64ImplExpLog;

implement f64 {
    exp(&this) -> f64 {
        return exp(&this);
    }

    ln(&this) -> f64 {
        return log(&this);
    }
}

function main() -> int {
    const zero: f64 = 0.0;
    const one: f64 = 1.0;
    // exp(0) = 1.0
    printf("%.1f\n", zero.exp());
    // ln(1) = 0.0
    printf("%.1f\n", one.ln());
    return 0;
}
