// @test: f64_impl_remainder
// @expect: compile_success
// @mode: raw
// @stdout: 1.500000
// @tags: f64, implement, intrinsics, remainder, primitives_bug
// @description: Isolates E0601 - f64 implement block calling remainder intrinsic via &this

namespace F64ImplRemainder;

implement f64 {
    ieee_remainder(&this, other: f64) -> f64 {
        return remainder(&this, other);
    }
}

function main() -> int {
    const x: f64 = 7.5;
    // remainder(7.5, 3.0) = 1.5
    printf("%f\n", x.ieee_remainder(3.0));
    return 0;
}
