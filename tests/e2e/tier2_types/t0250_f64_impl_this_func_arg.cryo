// @test: f64_impl_this_func_arg
// @expect: compile_success
// @mode: raw
// @stdout: 5.000000
// @tags: f64, implement, function_call
// @description: Implement block on f64 passing `this` (value) to a regular function

namespace F64ImplThisArg;

function my_abs(x: f64) -> f64 {
    if (x < 0.0) {
        return -x;
    }
    return x;
}

implement f64 {
    abs(&this) -> f64 {
        return my_abs(this);
    }
}

function main() -> int {
    const x: f64 = -5.0;
    const result: f64 = x.abs();
    printf("%f\n", result);
    return 0;
}
