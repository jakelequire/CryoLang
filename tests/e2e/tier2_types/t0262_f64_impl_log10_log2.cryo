// @test: f64_impl_log10_log2
// @expect: compile_success
// @mode: raw
// @stdout_contains: 2.0
// @stdout_contains: 3.3
// @tags: f64, implement, intrinsics, log10, log2, primitives_bug
// @description: Isolates E0601 - f64 implement block calling log10/log2 intrinsics via &this

namespace F64ImplLog10Log2;

implement f64 {
    log10(&this) -> f64 {
        return log10(&this);
    }

    log2(&this) -> f64 {
        return log2(&this);
    }
}

function main() -> int {
    const hundred: f64 = 100.0;
    const ten: f64 = 10.0;
    // log10(100) = 2.0
    printf("%.1f\n", hundred.log10());
    // log2(10) ≈ 3.32
    printf("%.1f\n", ten.log2());
    return 0;
}
