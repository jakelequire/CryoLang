// @test: f64_impl_fabs_this_value
// @expect: compile_success
// @mode: raw
// @stdout: 5.000000
// @tags: f64, implement, intrinsics, fabs, diagnostic
// @description: Diagnostic - f64 implement block calling fabs with `this` (value) instead of `&this` (address). Compares with t0252 to isolate if &this is the problem.

namespace F64ImplFabsThisVal;

implement f64 {
    abs(&this) -> f64 {
        return fabs(this);
    }
}

function main() -> int {
    const x: f64 = -5.0;
    const result: f64 = x.abs();
    printf("%f\n", result);
    return 0;
}
