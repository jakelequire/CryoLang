// @test: enum_multi_payload
// @expect: compile_success
// @mode: raw
// @stdout: int:42
// @stdout: str:hello
// @stdout: pair:3,7
// @stdout: none
// @tags: enums, match, payload

namespace EnumMultiPayload;

enum Value {
    IntVal(int);
    StrVal(string);
    PairVal(int, int);
    Nothing;
}

function describe(v: Value) -> void {
    match (v) {
        Value::IntVal(n) => {
            printf("int:%d\n", n);
        }
        Value::StrVal(s) => {
            printf("str:%s\n", s);
        }
        Value::PairVal(a, b) => {
            printf("pair:%d,%d\n", a, b);
        }
        Value::Nothing => {
            printf("none\n");
        }
    }
}

function main() -> int {
    describe(Value::IntVal(42));
    describe(Value::StrVal("hello"));
    describe(Value::PairVal(3, 7));
    describe(Value::Nothing);
    return 0;
}
