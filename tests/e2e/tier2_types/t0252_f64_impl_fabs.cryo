// @test: f64_impl_fabs
// @expect: compile_success
// @mode: raw
// @stdout: 5.000000
// @tags: f64, implement, intrinsics, fabs, primitives_bug
// @description: Isolates E0601 - f64 implement block calling fabs intrinsic via &this. Pattern from primitives.cryo abs() method.

namespace F64ImplFabs;

implement f64 {
    abs(&this) -> f64 {
        return fabs(&this);
    }
}

function main() -> int {
    const x: f64 = -5.0;
    const result: f64 = x.abs();
    printf("%f\n", result);
    return 0;
}
