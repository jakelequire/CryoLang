// @test: f64_direct_intrinsic_call
// @expect: compile_success
// @mode: raw
// @stdout: 5.000000
// @stdout: 3.000000
// @stdout: 4.000000
// @tags: f64, intrinsics, baseline
// @description: Baseline - calling f64 intrinsics directly (not through implement block) should work

namespace F64DirectIntrinsic;

function main() -> int {
    const x: f64 = -5.0;
    const y: f64 = 3.7;
    printf("%f\n", fabs(x));
    printf("%f\n", floor(y));
    printf("%f\n", ceil(y));
    return 0;
}
