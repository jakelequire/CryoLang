// @test: sizeof_operator
// @expect: compile_success
// @mode: raw
// @stdout: 4
// @stdout: 8
// @stdout: 1
// @tags: types, sizeof

namespace SizeofOp;

function main() -> int {
    const a: u64 = sizeof(i32);
    const b: u64 = sizeof(i64);
    const c: u64 = sizeof(u8);
    printf("%lu\n", a);
    printf("%lu\n", b);
    printf("%lu\n", c);
    return 0;
}
