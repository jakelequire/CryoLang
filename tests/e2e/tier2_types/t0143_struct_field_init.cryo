// @test: struct_field_init
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: 20
// @stdout: 0
// @tags: structs, initialization

namespace StructFieldInit;

type struct Pair {
    a: int;
    b: int;
}

type struct Duration {
    secs: u64;
    nanos: u32;
}

function main() -> int {
    const p: Pair = Pair { a: 10, b: 20 };
    printf("%d\n", p.a);
    printf("%d\n", p.b);
    const d: Duration = Duration { secs: 0, nanos: 0 };
    printf("%lu\n", d.secs);
    return 0;
}
