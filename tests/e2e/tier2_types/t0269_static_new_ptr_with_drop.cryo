// @test: static_new_ptr_with_drop
// @expect: compile_success
// @mode: raw
// @stdout: 64
// @stdout: dropped
// @tags: structs, static_methods, pointers, new_constructor, stdlib_bug
// @description: Isolates E0200 - static new() returning pointer with drop method (like PoolBlock)

namespace StaticNewPtrDrop;

type struct Buffer {
    data: u8*;
    size: u64;

    static new(size: u64) -> Buffer* {
        const buf: Buffer* = malloc(sizeof(Buffer));
        if (buf == null) {
            return null;
        }
        buf.data = malloc(size);
        if (buf.data == null) {
            free(buf);
            return null;
        }
        buf.size = size;
        return buf;
    }

    drop(&this) -> void {
        printf("dropped\n");
        free(this.data);
        free(this);
    }
}

function main() -> int {
    const buf: Buffer* = Buffer::new(64);
    if (buf == null) {
        return 1;
    }
    printf("%lu\n", buf.size);
    buf.drop();
    return 0;
}
