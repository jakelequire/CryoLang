// @test: ptr_deref_member
// @expect: compile_success
// @mode: raw
// @stdout: 5
// @stdout: 10
// @stdout: 15
// @tags: pointers, structs, member_access

namespace PtrDerefMember;

type struct Vec2 {
    x: int;
    y: int;

    static new(a: int, b: int) -> Vec2 {
        return Vec2 { x: a, y: b };
    }

    sum(&this) -> int {
        return this.x + this.y;
    }
}

function read_via_ptr(p: Vec2*) -> int {
    return p.x + p.y;
}

function write_via_ptr(p: Vec2*, new_x: int, new_y: int) -> void {
    p.x = new_x;
    p.y = new_y;
}

function main() -> int {
    mut v: Vec2 = Vec2::new(2, 3);
    const p: Vec2* = &v;
    printf("%d\n", read_via_ptr(p));
    write_via_ptr(p, 4, 6);
    printf("%d\n", v.sum());
    write_via_ptr(p, 7, 8);
    printf("%d\n", read_via_ptr(p));
    return 0;
}
