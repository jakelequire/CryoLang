// @test: match_payload_method
// @expect: compile_success
// @mode: raw
// @stdout: 200
// @stdout: no_shape
// @tags: enums, match, methods

namespace MatchPayloadMethod;

type struct Rect {
    w: int;
    h: int;

    static new(w: int, h: int) -> Rect {
        return Rect { w: w, h: h };
    }

    area(&this) -> int {
        return this.w * this.h;
    }
}

enum Shape {
    Rectangle(Rect);
    None;
}

function describe(s: Shape) -> void {
    match (s) {
        Shape::Rectangle(r) => {
            printf("%d\n", r.area());
        }
        Shape::None => {
            printf("no_shape\n");
        }
        _ => {
            printf("unknown\n");
        }
    }
}

function main() -> int {
    describe(Shape::Rectangle(Rect::new(10, 20)));
    describe(Shape::None);
    return 0;
}
