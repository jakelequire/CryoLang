// @test: function_returns_pointer
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: 20
// @tags: pointers, functions, return

namespace FuncRetPtr;

function pick(arr: int*, index: int) -> int* {
    return &arr[index];
}

function main() -> int {
    mut data: int[3] = [10, 20, 30];
    const p: int* = pick(&data[0], 0);
    const q: int* = pick(&data[0], 1);
    printf("%d\n", *p);
    printf("%d\n", *q);
    return 0;
}
