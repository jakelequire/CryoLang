// @test: type_alias_generic_enum
// @expect: compile_success
// @mode: raw
// @stdout: got ptr
// @stdout: got err: 99
// @tags: type_alias, generics, enums, stdlib_root_cause

namespace TypeAliasTest;

type struct AllocError {
    code: int;
}

enum Result<T, E> {
    Ok(T);
    Err(E);
}

// Type alias where T=void* - mirrors stdlib AllocResult = Result<void*, AllocError>
type AllocResult = Result<void*, AllocError>;

function try_alloc(should_fail: boolean) -> AllocResult {
    if (should_fail) {
        const err: AllocError = AllocError { code: 99 };
        return Result::Err(err);
    }
    const ptr: void* = malloc(8);
    return Result::Ok(ptr);
}

function main() -> int {
    // Test 1: successful allocation
    const r1: AllocResult = try_alloc(false);
    match (r1) {
        Result::Ok(p) => { printf("got ptr\n"); free(p); }
        Result::Err(e) => { printf("got err: %d\n", e.code); }
    }

    // Test 2: failed allocation - variable declared with alias type
    const r2: AllocResult = try_alloc(true);
    match (r2) {
        Result::Ok(p) => { printf("got ptr\n"); free(p); }
        Result::Err(e) => { printf("got err: %d\n", e.code); }
    }

    return 0;
}
