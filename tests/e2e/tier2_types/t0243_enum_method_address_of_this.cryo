// @test: enum_method_address_of_this
// @expect: compile_success
// @mode: raw
// @stdout: red
// @stdout: unknown
// @tags: enums, implement, match, address_of_this

namespace EnumAddrThis;

enum Color {
    Red;
    Green;
    Blue;
}

implement enum Color {
    name(&this) -> string {
        match (&this) {
            Color::Red => { return "red"; }
            Color::Green => { return "green"; }
            Color::Blue => { return "blue"; }
            _ => { return "unknown"; }
        }
    }

    is_primary(&this) -> int {
        match (&this) {
            Color::Red => { return 1; }
            Color::Blue => { return 1; }
            _ => { return 0; }
        }
    }
}

function main() -> int {
    const c: Color = Color::Red;
    printf("%s\n", c.name());

    const d: Color = Color::Green;
    if (d.is_primary() == 0) {
        printf("unknown\n");
    }
    return 0;
}
