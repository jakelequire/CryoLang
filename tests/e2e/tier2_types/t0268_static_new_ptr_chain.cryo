// @test: static_new_ptr_chain
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: 20
// @tags: structs, static_methods, pointers, new_constructor, stdlib_bug
// @description: Isolates E0200 - static new() ptr return used in chained allocation (linked list)

namespace StaticNewPtrChain;

type struct ListNode {
    data: int;
    next: ListNode*;

    static new(data: int, next: ListNode*) -> ListNode* {
        const node: ListNode* = malloc(sizeof(ListNode));
        if (node == null) {
            return null;
        }
        node.data = data;
        node.next = next;
        return node;
    }
}

function main() -> int {
    const second: ListNode* = ListNode::new(20, null);
    const first: ListNode* = ListNode::new(10, second);
    if (first == null || second == null) {
        return 1;
    }
    printf("%d\n", first.data);
    printf("%d\n", first.next.data);
    free(second);
    free(first);
    return 0;
}
