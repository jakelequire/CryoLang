// @test: function_type_void
// @expect: compile_success
// @mode: raw
// @stdout: value:42
// @stdout: value:99
// @tags: types, function_type, void, callback

namespace FnTypeVoid;

function for_each(arr: int*, len: int, f: (int) -> void) -> void {
    for (mut i: int = 0; i < len; i++) {
        f(arr[i]);
    }
}

function print_value(v: int) -> void {
    printf("value:%d\n", v);
}

function main() -> int {
    mut data: int[2] = [42, 99];
    for_each(&data[0], 2, print_value);
    return 0;
}
