// @test: mut_this_field_assign
// @expect: compile_success
// @mode: raw
// @stdout: 0
// @stdout: 5
// @stdout: 10
// @tags: structs, methods, mutable, assignment

namespace MutThisFieldAssign;

type struct Counter {
    count: int;
    max: int;

    static new(max: int) -> Counter {
        return Counter { count: 0, max: max };
    }

    get(&this) -> int {
        return this.count;
    }

    increment(mut &this) -> void {
        this.count = this.count + 1;
    }

    add(mut &this, n: int) -> void {
        this.count = this.count + n;
    }

    reset(mut &this) -> void {
        this.count = 0;
    }
}

function main() -> int {
    mut c: Counter = Counter::new(100);
    printf("%d\n", c.get());
    c.add(5);
    printf("%d\n", c.get());
    c.add(5);
    printf("%d\n", c.get());
    return 0;
}
