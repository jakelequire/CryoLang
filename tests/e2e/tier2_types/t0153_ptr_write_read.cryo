// @test: ptr_write_read
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: 99
// @stdout: 99
// @tags: pointers, mutation, aliasing

namespace PtrWriteRead;

function main() -> int {
    mut x: int = 10;
    const p: int* = &x;
    printf("%d\n", x);
    *p = 99;
    printf("%d\n", *p);
    printf("%d\n", x);
    return 0;
}
