// @test: function_type_param
// @expect: compile_success
// @mode: raw
// @stdout: 20
// @stdout: 25
// @tags: types, function_type, callback

namespace FnTypeParam;

function apply(x: int, f: (int) -> int) -> int {
    return f(x);
}

function dub(n: int) -> int {
    return n * 2;
}

function add_five(n: int) -> int {
    return n + 5;
}

function main() -> int {
    printf("%d\n", apply(10, dub));
    printf("%d\n", apply(20, add_five));
    return 0;
}
