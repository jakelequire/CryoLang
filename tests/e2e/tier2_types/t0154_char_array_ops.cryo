namespace CharArrOps;

function main() -> int {
    mut buf: char[4] = ['H', 'i', '!', '\0'];
    printf("%d\n", buf[0]);
    printf("%d\n", buf[1]);
    printf("%d\n", buf[2]);
    return 0;
}
