// @test: array_literal_in_struct
// @expect: compile_success
// @mode: raw
// @stdout: 192
// @stdout: 168
// @stdout: 1
// @stdout: 1
// @tags: structs, arrays, initialization

namespace ArrLitInStruct;

type struct Addr {
    octets: u8[4];

    static new(a: u8, b: u8, c: u8, d: u8) -> Addr {
        return Addr { octets: [a, b, c, d] };
    }

    get(&this, i: int) -> u8 {
        return this.octets[i];
    }
}

function main() -> int {
    const ip: Addr = Addr::new(192, 168, 1, 1);
    printf("%d\n", ip.get(0));
    printf("%d\n", ip.get(1));
    printf("%d\n", ip.get(2));
    printf("%d\n", ip.get(3));
    return 0;
}
