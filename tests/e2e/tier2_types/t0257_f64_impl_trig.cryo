// @test: f64_impl_trig
// @expect: compile_success
// @mode: raw
// @stdout_contains: 0.0
// @stdout_contains: 1.0
// @tags: f64, implement, intrinsics, sin, cos, tan, primitives_bug
// @description: Isolates E0601 - f64 implement block calling sin/cos/tan intrinsics via &this. LLVM error: "Intrinsic has incorrect return type! ptr @llvm.sin.p0"

namespace F64ImplTrig;

implement f64 {
    sin(&this) -> f64 {
        return sin(&this);
    }

    cos(&this) -> f64 {
        return cos(&this);
    }

    tan(&this) -> f64 {
        return tan(&this);
    }
}

function main() -> int {
    const zero: f64 = 0.0;
    // sin(0) = 0.0, cos(0) = 1.0, tan(0) = 0.0
    printf("%.1f\n", zero.sin());
    printf("%.1f\n", zero.cos());
    printf("%.1f\n", zero.tan());
    return 0;
}
