// @test: struct_load_value_not_pointer
// @expect: compile_success
// @mode: raw
// @stdout: old=0 new=1
// @stdout: swapped: old=5 new=10
// @tags: structs, methods, value_params, stdlib_root_cause
// @description: RC6 - Method that loads a parameter value and uses it directly (not as pointer). Mirrors the atomic compare_exchange pattern where the codegen incorrectly double-dereferences a value parameter, generating "load i32, i32 %val" instead of using %val directly.

namespace StructLoadValNotPtr;

type struct AtomicVal {
    value: int;

    static new(val: int) -> AtomicVal {
        return AtomicVal { value: val };
    }

    load(&this) -> int {
        return this.value;
    }

    store(mut &this, val: int) -> void {
        this.value = val;
    }

    /// Compare and swap - takes current and new as value params.
    /// The compiler must NOT double-deref these value params.
    compare_and_swap(mut &this, current: int, new_val: int) -> int {
        const old: int = this.value;
        if (this.value == current) {
            this.value = new_val;
        }
        return old;
    }

    /// Swap - takes a value param and returns the old value
    swap(mut &this, new_val: int) -> int {
        const old: int = this.value;
        this.value = new_val;
        return old;
    }
}

function main() -> int {
    mut a: AtomicVal = AtomicVal::new(0);

    // compare_and_swap: current matches, should swap
    const old: int = a.compare_and_swap(0, 1);
    printf("old=%d new=%d\n", old, a.load());

    // swap
    mut b: AtomicVal = AtomicVal::new(5);
    const swapped: int = b.swap(10);
    printf("swapped: old=%d new=%d\n", swapped, b.load());

    return 0;
}
