// @test: multiple_functions
// @expect: compile_success
// @mode: raw
// @stdout: 15
// @tags: functions

namespace MultiFuncs;

function add(a: int, b: int) -> int {
    return a + b;
}

function square(x: int) -> int {
    return x * x;
}

function add_squares(a: int, b: int) -> int {
    return add(square(a), square(b));
}

function main() -> int {
    printf("%d\n", add(5, 10));
    return 0;
}
