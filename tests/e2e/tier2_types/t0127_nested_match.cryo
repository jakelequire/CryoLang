// @test: nested_match
// @expect: compile_success
// @mode: raw
// @stdout: circle:small
// @stdout: square:big
// @stdout: other:unknown
// @tags: match, enums, nested

namespace NestedMatch;

enum Shape {
    Circle(int);
    Square(int);
    Triangle;
}

enum Size {
    Small;
    Big;
}

function classify_size(n: int) -> Size {
    if (n < 50) {
        return Size::Small;
    }
    return Size::Big;
}

function describe(s: Shape) -> void {
    match (s) {
        Shape::Circle(r) => {
            const sz: Size = classify_size(r);
            match (sz) {
                Size::Small => { printf("circle:small\n"); }
                Size::Big => { printf("circle:big\n"); }
            }
        }
        Shape::Square(side) => {
            const sz: Size = classify_size(side);
            match (sz) {
                Size::Small => { printf("square:small\n"); }
                Size::Big => { printf("square:big\n"); }
            }
        }
        Shape::Triangle => {
            printf("other:unknown\n");
        }
    }
}

function main() -> int {
    describe(Shape::Circle(10));
    describe(Shape::Square(100));
    describe(Shape::Triangle);
    return 0;
}
