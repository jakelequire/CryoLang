// @test: f64_impl_round_trunc
// @expect: compile_success
// @mode: raw
// @stdout: 4.000000
// @stdout: 3.000000
// @tags: f64, implement, intrinsics, round, trunc, primitives_bug
// @description: Isolates E0601 - f64 implement block calling round/trunc intrinsics via &this

namespace F64ImplRoundTrunc;

implement f64 {
    round(&this) -> f64 {
        return round(&this);
    }

    trunc(&this) -> f64 {
        return trunc(&this);
    }
}

function main() -> int {
    const x: f64 = 3.7;
    printf("%f\n", x.round());
    printf("%f\n", x.trunc());
    return 0;
}
