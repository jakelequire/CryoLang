// @test: mutable_array_fill
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: 20
// @stdout: 30
// @tags: arrays, mutable, assignment

namespace MutArrFill;

function main() -> int {
    mut arr: int[3] = [0, 0, 0];
    arr[0] = 10;
    arr[1] = 20;
    arr[2] = 30;
    printf("%d\n", arr[0]);
    printf("%d\n", arr[1]);
    printf("%d\n", arr[2]);
    return 0;
}
