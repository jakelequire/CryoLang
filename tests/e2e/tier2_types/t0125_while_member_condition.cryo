// @test: while_member_condition
// @expect: compile_success
// @mode: raw
// @stdout: filled 5 slots
// @tags: structs, while, member_access

namespace WhileMemberCond;

type struct Buffer {
    count: int;
    capacity: int;

    static new(cap: int) -> Buffer {
        return Buffer { count: 0, capacity: cap };
    }

    is_full(&this) -> int {
        if (this.count >= this.capacity) {
            return 1;
        }
        return 0;
    }

    add(mut &this) -> void {
        this.count = this.count + 1;
    }
}

function main() -> int {
    mut buf: Buffer = Buffer::new(5);
    while (buf.count < buf.capacity) {
        buf.add();
    }
    printf("filled %d slots\n", buf.count);
    return 0;
}
