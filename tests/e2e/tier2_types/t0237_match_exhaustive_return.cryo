// @test: match_exhaustive_return
// @expect: compile_success
// @mode: raw
// @stdout: ok:42
// @stdout: err:fail
// @tags: match, return, exhaustive, enums

namespace MatchExhaustReturn;

enum Result_i32 {
    Ok(int);
    Err(string);
}

function describe(r: Result_i32) -> string {
    match (r) {
        Result_i32::Ok(v) => {
            printf("ok:%d\n", v);
            return "ok";
        }
        Result_i32::Err(e) => {
            printf("err:%s\n", e);
            return "err";
        }
        _ => {
            return "unknown";
        }
    }
}

function main() -> int {
    const a: Result_i32 = Result_i32::Ok(42);
    const b: Result_i32 = Result_i32::Err("fail");
    describe(a);
    describe(b);
    return 0;
}
