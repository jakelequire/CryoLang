// @test: match_wildcard
// @expect: compile_success
// @mode: raw
// @stdout: other
// @tags: match, wildcard

namespace MatchWild;

function main() -> int {
    const x: int = 99;
    match (x) {
        1 => {
            printf("one\n");
        },
        2 => {
            printf("two\n");
        },
        _ => {
            printf("other\n");
        },
    }
    return 0;
}
