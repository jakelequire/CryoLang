// @test: reference_params
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: 20
// @tags: pointers, functions

namespace RefParams;

function double_it(p: int*) -> void {
    *p = *p * 2;
}

function main() -> int {
    mut x: int = 10;
    printf("%d\n", x);
    double_it(&x);
    printf("%d\n", x);
    return 0;
}
