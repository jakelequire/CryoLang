// @test: ptr_index_member_assign
// @expect: compile_success
// @mode: raw
// @stdout: 0
// @stdout: 99
// @stdout: 0
// @tags: pointers, arrays, member_access, assignment

namespace PtrIdxMemberAssign;

type struct Slot {
    state: int;
    value: int;

    static new(s: int, v: int) -> Slot {
        return Slot { state: s, value: v };
    }
}

function main() -> int {
    mut slots: Slot[3] = [
        Slot::new(0, 0),
        Slot::new(0, 0),
        Slot::new(0, 0)
    ];
    const ptr: Slot* = &slots[0];
    ptr[1].value = 99;
    ptr[1].state = 1;
    printf("%d\n", slots[0].value);
    printf("%d\n", slots[1].value);
    printf("%d\n", slots[2].value);
    return 0;
}
