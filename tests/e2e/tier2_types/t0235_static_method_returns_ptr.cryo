// @test: static_method_returns_ptr
// @expect: compile_success
// @mode: raw
// @stdout: 64
// @tags: structs, static_methods, pointers

namespace StaticMethodPtr;

type struct Block {
    size: int;
    next: Block*;

    static create(size: int) -> Block* {
        const b: Block* = malloc(sizeof(Block));
        if (b == null) {
            return null;
        }
        b.size = size;
        b.next = null;
        return b;
    }
}

function main() -> int {
    const b: Block* = Block::create(64);
    if (b == null) {
        printf("null\n");
        return 1;
    }
    printf("%d\n", b.size);
    free(b);
    return 0;
}
