// @test: ptr_index_field_access
// @expect: compile_success
// @mode: raw
// @stdout: 10:active
// @stdout: 20:inactive
// @tags: structs, pointers, indexing, member_access

namespace PtrIdxField;

type struct Slot {
    value: int;
    state: int;
}

function main() -> int {
    const slots: Slot* = malloc(sizeof(Slot) * 2);

    // Assign through pointer index
    slots[0].value = 10;
    slots[0].state = 1;
    slots[1].value = 20;
    slots[1].state = 0;

    // Read through pointer index + field access
    mut i: int = 0;
    while (i < 2) {
        if (slots[i].state == 1) {
            printf("%d:active\n", slots[i].value);
        } else {
            printf("%d:inactive\n", slots[i].value);
        }
        i = i + 1;
    }

    free(slots);
    return 0;
}
