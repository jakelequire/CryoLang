// @test: f64_impl_floor_ceil
// @expect: compile_success
// @mode: raw
// @stdout: 3.000000
// @stdout: 4.000000
// @tags: f64, implement, intrinsics, floor, ceil, primitives_bug
// @description: Isolates E0601 - f64 implement block calling floor/ceil intrinsics via &this

namespace F64ImplFloorCeil;

implement f64 {
    floor(&this) -> f64 {
        return floor(&this);
    }

    ceil(&this) -> f64 {
        return ceil(&this);
    }
}

function main() -> int {
    const x: f64 = 3.7;
    printf("%f\n", x.floor());
    printf("%f\n", x.ceil());
    return 0;
}
