// @test: f64_impl_addr_this_func_arg
// @expect: compile_success
// @mode: raw
// @stdout: 5.000000
// @tags: f64, implement, address_of_this, primitives_bug
// @description: Implement block on f64 passing `&this` (address) to a function expecting f64 value. This isolates the &this codegen issue.

namespace F64ImplAddrThisArg;

function my_abs(x: f64) -> f64 {
    if (x < 0.0) {
        return -x;
    }
    return x;
}

implement f64 {
    abs(&this) -> f64 {
        return my_abs(&this);
    }
}

function main() -> int {
    const x: f64 = -5.0;
    const result: f64 = x.abs();
    printf("%f\n", result);
    return 0;
}
