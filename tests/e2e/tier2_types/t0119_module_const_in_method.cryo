// @test: module_const_in_method
// @expect: compile_success
// @mode: raw
// @stdout: 16
// @stdout: 32
// @tags: structs, constants, methods

namespace ModConstMethod;

const DEFAULT_CAPACITY: int = 16;

type struct Buffer {
    capacity: int;

    static new() -> Buffer {
        return Buffer { capacity: DEFAULT_CAPACITY };
    }

    static with_capacity(cap: int) -> Buffer {
        return Buffer { capacity: cap };
    }

    get_capacity(&this) -> int {
        return this.capacity;
    }

    grow(mut &this) -> void {
        this.capacity = this.capacity * 2;
    }
}

function main() -> int {
    mut buf: Buffer = Buffer::new();
    printf("%d\n", buf.get_capacity());
    buf.grow();
    printf("%d\n", buf.get_capacity());
    return 0;
}
