// @test: array_element_assign
// @expect: compile_success
// @mode: raw
// @stdout: 0
// @stdout: 99
// @stdout: 0
// @tags: arrays, assignment

namespace ArrElemAssign;

function main() -> int {
    mut arr: int[3] = [0, 0, 0];
    arr[1] = 99;
    printf("%d\n", arr[0]);
    printf("%d\n", arr[1]);
    printf("%d\n", arr[2]);
    return 0;
}
