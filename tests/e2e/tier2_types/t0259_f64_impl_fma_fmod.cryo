// @test: f64_impl_fma_fmod
// @expect: compile_success
// @mode: raw
// @stdout: 7.000000
// @stdout: 1.500000
// @stdout: 3.000000
// @stdout: 5.000000
// @tags: f64, implement, intrinsics, fma, fmod, fmin, fmax, primitives_bug
// @description: Isolates E0601 - f64 implement block calling fma/fmod/fmin/fmax via &this

namespace F64ImplFmaFmod;

implement f64 {
    /// Fused multiply-add: this * a + b
    mul_add(&this, a: f64, b: f64) -> f64 {
        return fma(&this, a, b);
    }

    /// Floating-point modulo
    rem(&this, other: f64) -> f64 {
        return fmod(&this, other);
    }

    /// Minimum of two values
    min(&this, other: f64) -> f64 {
        return fmin(&this, other);
    }

    /// Maximum of two values
    max(&this, other: f64) -> f64 {
        return fmax(&this, other);
    }
}

function main() -> int {
    const x: f64 = 2.0;
    // fma(2.0, 3.0, 1.0) = 2*3+1 = 7.0
    printf("%f\n", x.mul_add(3.0, 1.0));
    // fmod(7.5, 3.0) = 1.5
    const y: f64 = 7.5;
    printf("%f\n", y.rem(3.0));
    // fmin(3.0, 5.0) = 3.0
    const a: f64 = 3.0;
    printf("%f\n", a.min(5.0));
    // fmax(3.0, 5.0) = 5.0
    printf("%f\n", a.max(5.0));
    return 0;
}
