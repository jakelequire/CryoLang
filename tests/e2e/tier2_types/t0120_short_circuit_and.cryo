// @test: short_circuit_and
// @expect: compile_success
// @mode: raw
// @stdout: both_true
// @stdout: short_circuited
// @stdout: second_false
// @tags: logical_ops, control_flow

namespace ShortCircuitAnd;

function check(a: int, b: int) -> void {
    if (a > 0 && b > 0) {
        printf("both_true\n");
    } else {
        if (a <= 0) {
            printf("short_circuited\n");
        } else {
            printf("second_false\n");
        }
    }
}

function main() -> int {
    check(1, 1);
    check(-1, 1);
    check(1, -1);
    return 0;
}
