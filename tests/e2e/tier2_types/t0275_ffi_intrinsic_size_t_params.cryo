// @test: ffi_intrinsic_size_t_params
// @expect: compile_success
// @mode: raw
// @stdout: wrote 5 bytes
// @stdout: read back: hello
// @tags: ffi, intrinsics, types, stdlib_root_cause
// @description: RC5 - FFI/intrinsic functions with size_t (u64) parameters. The stdlib net/tcp module calls recv/send with truncated i32 length args but the LLVM declarations use i64 (size_t on x86_64). This test verifies that intrinsic functions receiving u64 length arguments are called with the correct types.

namespace FfiSizeTParams;

function main() -> int {
    // Test that memcpy (which takes size_t/u64 len) works correctly
    const src: string = "hello";
    const len: u64 = strlen(src);
    const dest: u8* = malloc(len + 1);
    memcpy(dest, src, len);
    dest[len] = 0;

    printf("wrote %llu bytes\n", len);
    printf("read back: %s\n", dest);

    free(dest);
    return 0;
}
