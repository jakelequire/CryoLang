// @test: string_null_assign
// @expect: compile_success
// @mode: raw
// @stdout: He
// @tags: strings, indexing, assignment, null_terminator, primitives_bug
// @description: Isolates E0614 - assigning null terminator to string index (str[i] = '\0')

namespace StrNullAssign;

function main() -> int {
    mut str: string = "Hello";
    str[2] = '\0';
    printf("%s\n", str);
    return 0;
}
