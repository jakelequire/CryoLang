// @test: array_index_member_access
// @expect: compile_success
// @mode: raw
// @stdout: alice:90
// @stdout: bob:85
// @tags: structs, arrays, member_access, indexing

namespace ArrIdxMember;

type struct Entry {
    name: string;
    score: int;

    static new(name: string, score: int) -> Entry {
        return Entry { name: name, score: score };
    }
}

function main() -> int {
    mut entries: Entry[3] = [
        Entry::new("alice", 90),
        Entry::new("bob", 85),
        Entry::new("carol", 78)
    ];

    // Access fields through array indexing
    printf("%s:%d\n", entries[0].name, entries[0].score);
    printf("%s:%d\n", entries[1].name, entries[1].score);
    return 0;
}
