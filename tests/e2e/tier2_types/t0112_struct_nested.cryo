// @test: struct_nested
// @expect: compile_success
// @mode: raw
// @stdout: 1
// @stdout: 2
// @tags: structs, nested

namespace StructNested;

type struct Point {
    x: int;
    y: int;

    static new(x: int, y: int) -> Point {
        return Point { x: x, y: y };
    }
}

type struct Line {
    start: Point;
    end_pt: Point;

    static new(sx: int, sy: int, ex: int, ey: int) -> Line {
        return Line { start: Point::new(sx, sy), end_pt: Point::new(ex, ey) };
    }
}

function main() -> int {
    const line: Line = Line::new(1, 2, 3, 4);
    printf("%d\n", line.start.x);
    printf("%d\n", line.start.y);
    return 0;
}
