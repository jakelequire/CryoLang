// @test: address_of_array_element
// @expect: compile_success
// @mode: raw
// @stdout: 20
// @stdout: 30
// @tags: pointers, arrays

namespace AddrOfArrElem;

function main() -> int {
    mut arr: int[3] = [10, 20, 30];
    const p1: int* = &arr[1];
    const p2: int* = &arr[2];
    printf("%d\n", *p1);
    printf("%d\n", *p2);
    return 0;
}
