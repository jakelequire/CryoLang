// @test: match_expression
// @expect: compile_success
// @mode: raw
// @stdout: two
// @tags: match, control_flow

namespace MatchExpr;

function describe(n: int) -> void {
    match (n) {
        1 => {
            printf("one\n");
        },
        2 => {
            printf("two\n");
        },
        3 => {
            printf("three\n");
        },
        _ => {
            printf("other\n");
        },
    }
}

function main() -> int {
    describe(2);
    return 0;
}
