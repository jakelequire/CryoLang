// @test: struct_null_ptr_field
// @expect: compile_success
// @mode: raw
// @stdout: is_null
// @stdout: not_null
// @tags: structs, pointers, null

namespace StructNullPtr;

type struct Container {
    data: int*;
    len: int;

    static empty() -> Container {
        return Container { data: null, len: 0 };
    }

    static from(ptr: int*, n: int) -> Container {
        return Container { data: ptr, len: n };
    }

    is_empty(&this) -> int {
        if (this.data == null) {
            return 1;
        }
        return 0;
    }
}

function main() -> int {
    const a: Container = Container::empty();
    if (a.is_empty() == 1) {
        printf("is_null\n");
    }
    mut val: int = 42;
    const b: Container = Container::from(&val, 1);
    if (b.is_empty() == 0) {
        printf("not_null\n");
    }
    return 0;
}
