// @test: postfix_increment_on_member_access
// @expect: compile_success
// @stdout: 1
// @stdout: 2
// @stdout: 3
// @tags: structs, operators, increment, parser
// @description: Postfix ++ and -- on member access expressions (this.field++ / this.field--)

namespace PostfixMember;

type struct Counter {
    value: int;

    static new() -> Counter {
        return Counter { value: 0 };
    }

    increment(mut &this) -> void {
        this.value++;
    }

    decrement(mut &this) -> void {
        this.value--;
    }

    get(this: Counter*) -> int {
        return this.value;
    }
}

function main() -> int {
    mut c: Counter = Counter::new();

    c.increment();
    printf("%d\n", c.get());

    c.increment();
    printf("%d\n", c.get());

    c.increment();
    c.increment();
    c.decrement();
    printf("%d\n", c.get());

    return 0;
}
