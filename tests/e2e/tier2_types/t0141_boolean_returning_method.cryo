// @test: boolean_returning_method
// @expect: compile_success
// @mode: raw
// @stdout: empty
// @stdout: not_empty
// @tags: structs, methods, boolean

namespace BoolRetMethod;

type struct Stack {
    count: int;

    static new() -> Stack {
        return Stack { count: 0 };
    }

    is_empty(&this) -> boolean {
        return this.count == 0;
    }

    push(mut &this) -> void {
        this.count = this.count + 1;
    }
}

function main() -> int {
    mut s: Stack = Stack::new();
    if (s.is_empty()) {
        printf("empty\n");
    }
    s.push();
    if (!s.is_empty()) {
        printf("not_empty\n");
    }
    return 0;
}
