// @test: struct_array_field_access
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: 20
// @stdout: 30
// @tags: structs, arrays, member_access

namespace StructArrFieldAccess;

type struct Entry {
    key: int;
    value: int;

    static new(k: int, v: int) -> Entry {
        return Entry { key: k, value: v };
    }
}

type struct Table {
    entries: Entry*;
    count: int;

    static new(data: Entry*, n: int) -> Table {
        return Table { entries: data, count: n };
    }

    get_value(&this, index: int) -> int {
        return this.entries[index].value;
    }
}

function main() -> int {
    mut data: Entry[3] = [
        Entry::new(1, 10),
        Entry::new(2, 20),
        Entry::new(3, 30)
    ];
    const t: Table = Table::new(&data[0], 3);
    printf("%d\n", t.get_value(0));
    printf("%d\n", t.get_value(1));
    printf("%d\n", t.get_value(2));
    return 0;
}
