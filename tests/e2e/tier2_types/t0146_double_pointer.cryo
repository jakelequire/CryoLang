// @test: double_pointer
// @expect: compile_success
// @mode: raw
// @stdout: 42
// @stdout: 99
// @tags: pointers, double_pointer

namespace DoublePtr;

function main() -> int {
    mut a: int = 42;
    mut b: int = 99;
    mut pa: int* = &a;
    mut pb: int* = &b;
    mut pp: int** = &pa;
    printf("%d\n", **pp);
    pp = &pb;
    printf("%d\n", **pp);
    return 0;
}
