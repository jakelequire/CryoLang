// @test: module_scope_constants_in_methods
// @expect: compile_success
// @mode: raw
// @stdout: occupied
// @stdout: empty
// @stdout: deleted
// @tags: constants, structs, methods, stdlib_root_cause
// @description: RC3 - Module-scoped constants used inside struct method bodies. The stdlib hashmap defines BUCKET_EMPTY/BUCKET_OCCUPIED/BUCKET_DELETED as module-level constants and references them inside HashMap methods. The compiler must resolve these constants during codegen.

namespace ModScopeConst;

const STATE_EMPTY: u8 = 0;
const STATE_OCCUPIED: u8 = 1;
const STATE_DELETED: u8 = 2;

const DEFAULT_CAPACITY: u64 = 16;
const MAX_LOAD_NUM: u64 = 3;
const MAX_LOAD_DEN: u64 = 4;

type struct Bucket {
    key: int;
    value: int;
    state: u8;

    static empty() -> Bucket {
        return Bucket { key: 0, value: 0, state: STATE_EMPTY };
    }

    static with_data(k: int, v: int) -> Bucket {
        return Bucket { key: k, value: v, state: STATE_OCCUPIED };
    }

    is_empty(&this) -> boolean {
        return this.state == STATE_EMPTY;
    }

    is_occupied(&this) -> boolean {
        return this.state == STATE_OCCUPIED;
    }

    is_deleted(&this) -> boolean {
        return this.state == STATE_DELETED;
    }

    mark_deleted(mut &this) -> void {
        this.state = STATE_DELETED;
    }
}

type struct Table {
    entries: Bucket*;
    len: u64;
    cap: u64;

    static new() -> Table {
        const cap: u64 = DEFAULT_CAPACITY;
        const entries: Bucket* = calloc(cap, sizeof(Bucket));
        return Table {
            entries: entries,
            len: 0,
            cap: cap
        };
    }

    should_grow(&this) -> boolean {
        // Uses module-scoped constants in a method
        return this.len * MAX_LOAD_DEN > this.cap * MAX_LOAD_NUM;
    }
}

function main() -> int {
    const b1: Bucket = Bucket::with_data(1, 100);
    const b2: Bucket = Bucket::empty();
    mut b3: Bucket = Bucket::with_data(2, 200);
    b3.mark_deleted();

    if (b1.is_occupied()) {
        printf("occupied\n");
    }
    if (b2.is_empty()) {
        printf("empty\n");
    }
    if (b3.is_deleted()) {
        printf("deleted\n");
    }
    return 0;
}
