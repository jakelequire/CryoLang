// @test: enum_payload
// @expect: compile_success
// @mode: raw
// @stdout_contains: 42
// @tags: enums, payload

namespace EnumPayload;

enum Value {
    Integer(int);
    Nothing;
}

function main() -> int {
    const v: Value = Value::Integer(42);
    match (v) {
        Value::Integer(n) => {
            printf("%d\n", n);
        },
        Value::Nothing => {
            printf("nothing\n");
        },
    }
    return 0;
}
