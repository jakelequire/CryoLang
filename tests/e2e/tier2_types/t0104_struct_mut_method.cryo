// @test: struct_mut_method
// @expect: compile_success
// @mode: raw
// @stdout: 0
// @stdout: 5
// @tags: structs, mutation

namespace StructMut;

type struct Counter {
    value: int;

    static new() -> Counter {
        return Counter { value: 0 };
    }

    get(&this) -> int {
        return this.value;
    }

    add(mut &this, n: int) -> void {
        this.value = this.value + n;
    }
}

function main() -> int {
    mut c: Counter = Counter::new();
    printf("%d\n", c.get());
    c.add(5);
    printf("%d\n", c.get());
    return 0;
}
