// @test: struct_methods
// @expect: compile_success
// @mode: raw
// @stdout: 50
// @tags: structs, methods

namespace StructMethods;

type struct Rect {
    width: int;
    height: int;

    static new(w: int, h: int) -> Rect {
        return Rect { width: w, height: h };
    }

    area(&this) -> int {
        return this.width * this.height;
    }
}

function main() -> int {
    const r: Rect = Rect::new(5, 10);
    printf("%d\n", r.area());
    return 0;
}
