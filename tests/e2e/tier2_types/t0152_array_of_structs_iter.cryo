// @test: array_of_structs_iter
// @expect: compile_success
// @mode: raw
// @stdout: 1:10
// @stdout: 2:20
// @stdout: 3:30
// @tags: arrays, structs, loops

namespace ArrStructIter;

type struct Entry {
    key: int;
    val: int;

    static new(k: int, v: int) -> Entry {
        return Entry { key: k, val: v };
    }
}

function main() -> int {
    mut entries: Entry[3] = [
        Entry::new(1, 10),
        Entry::new(2, 20),
        Entry::new(3, 30)
    ];
    for (mut i: int = 0; i < 3; i++) {
        printf("%d:%d\n", entries[i].key, entries[i].val);
    }
    return 0;
}
