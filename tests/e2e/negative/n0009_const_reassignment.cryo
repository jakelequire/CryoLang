// @test: const_reassignment
// @expect: compile_fail
// @mode: raw
// @description: Reassigning const variable should fail
// @tags: variables, const, errors
// @xfail: Const reassignment not caught at compile time

namespace NegConstReassign;

function main() -> int {
    const x: int = 5;
    x = 10;
    return 0;
}
