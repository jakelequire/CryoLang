// @test: class_multiple_new
// @expect: compile_success
// @mode: raw
// @stdout: p1=(1, 2)
// @stdout: p2=(3, 4)
// @stdout: p3=(5, 6)
// @stdout: p4=(7, 8)
// @tags: classes, new, heap, multiple
// @description: Multiple sequential heap allocations to verify malloc works correctly

namespace MultipleNew;

type class Pair {
public:
    a: i32;
    b: i32;

    Pair(_a: i32, _b: i32) {
        this.a = _a;
        this.b = _b;
    }

    print(label: string) -> void {
        printf("%s=(%d, %d)\n", label, this.a, this.b);
    }
}

function main() -> i32 {
    const p1: Pair* = new Pair(1, 2);
    const p2: Pair* = new Pair(3, 4);
    const p3: Pair* = new Pair(5, 6);
    const p4: Pair* = new Pair(7, 8);
    p1.print("p1");
    p2.print("p2");
    p3.print("p3");
    p4.print("p4");
    return 0;
}
