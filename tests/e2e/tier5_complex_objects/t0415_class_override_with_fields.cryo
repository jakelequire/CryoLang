// @test: class_override_with_fields
// @expect: compile_success
// @mode: raw
// @stdout: Employee: Alice, salary: 50000
// @stdout: Manager: Bob, salary: 80000, reports: 5
// @tags: classes, inheritance, override, fields
// @description: Derived class adds fields and overrides a virtual method that uses them

namespace OverrideFields;

type class Employee {
public:
    name: string;
    salary: i32;

    Employee(_name: string, _salary: i32) {
        this.name = _name;
        this.salary = _salary;
    }

    virtual describe() -> void {
        printf("Employee: %s, salary: %d\n", this.name, this.salary);
    }
}

type class Manager : Employee {
public:
    reports: i32;

    Manager(_name: string, _salary: i32, _reports: i32) : Employee(_name, _salary) {
        this.reports = _reports;
    }

    override describe() -> void {
        printf("Manager: %s, salary: %d, reports: %d\n", this.name, this.salary, this.reports);
    }
}

function print_employee(e: Employee*) -> void {
    e.describe();
}

function main() -> i32 {
    const alice: Employee* = new Employee("Alice", 50000);
    const bob: Manager* = new Manager("Bob", 80000, 5);
    print_employee(alice);
    print_employee(bob);
    return 0;
}
