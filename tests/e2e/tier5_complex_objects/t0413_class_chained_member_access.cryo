// @test: class_chained_member_access
// @expect: compile_success
// @mode: raw
// @stdout: engine horsepower: 200
// @stdout: car brand: Tesla, engine hp: 200
// @tags: classes, member_access, chaining, pointers
// @description: Chained member access through pointer fields (car.engine.horsepower)

namespace ChainedAccess;

type class Engine {
public:
    horsepower: i32;

    Engine(_hp: i32) {
        this.horsepower = _hp;
    }

    describe() -> void {
        printf("engine horsepower: %d\n", this.horsepower);
    }
}

type class Car {
public:
    brand: string;
    engine: Engine*;

    Car(_brand: string, _engine: Engine*) {
        this.brand = _brand;
        this.engine = _engine;
    }

    describe() -> void {
        printf("car brand: %s, engine hp: %d\n", this.brand, this.engine.horsepower);
    }
}

function main() -> i32 {
    const e: Engine* = new Engine(200);
    const c: Car* = new Car("Tesla", e);
    e.describe();
    c.describe();
    return 0;
}
