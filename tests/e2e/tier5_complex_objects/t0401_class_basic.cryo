// @test: class_basic
// @expect: compile_success
// @mode: raw
// @stdout: Alice
// @stdout: 30
// @tags: classes, basic
// @description: Basic class declaration with fields and constructor

namespace ClassBasic;

type class Person {
public:
    name: string;
    age: i32;

    Person(_name: string, _age: i32) {
        this.name = _name;
        this.age = _age;
    }
}

function main() -> i32 {
    const p: Person* = new Person("Alice", 30);
    printf("%s\n", p.name);
    printf("%d\n", p.age);
    return 0;
}
