// @test: class_constructor_chaining
// @expect: compile_success
// @mode: raw
// @stdout: Vehicle type: Car, wheels: 4
// @stdout: Vehicle type: Bike, wheels: 2
// @tags: classes, inheritance, constructor
// @description: Derived constructors calling base constructors with arguments

namespace CtorChaining;

type class Vehicle {
public:
    vehicle_type: string;
    wheels: i32;

    Vehicle(_type: string, _wheels: i32) {
        this.vehicle_type = _type;
        this.wheels = _wheels;
    }

    describe() -> void {
        printf("Vehicle type: %s, wheels: %d\n", this.vehicle_type, this.wheels);
    }
}

type class Car : Vehicle {
public:
    Car() : Vehicle("Car", 4) {
    }
}

type class Bike : Vehicle {
public:
    Bike() : Vehicle("Bike", 2) {
    }
}

function main() -> i32 {
    const c: Car* = new Car();
    const b: Bike* = new Bike();
    c.describe();
    b.describe();
    return 0;
}
