// @test: class_deep_inheritance
// @expect: compile_success
// @mode: raw
// @stdout: GoldenRetriever: Buddy (Dog, Animal)
// @tags: classes, inheritance, deep
// @description: Three-level inheritance chain (Animal -> Dog -> GoldenRetriever)

namespace DeepInherit;

type class Animal {
public:
    species: string;

    Animal(_species: string) {
        this.species = _species;
    }
}

type class Dog : Animal {
public:
    breed: string;

    Dog(_breed: string) : Animal("Dog") {
        this.breed = _breed;
    }
}

type class GoldenRetriever : Dog {
public:
    name: string;

    GoldenRetriever(_name: string) : Dog("GoldenRetriever") {
        this.name = _name;
    }

    introduce() -> void {
        printf("%s: %s (%s, %s)\n", this.breed, this.name, this.breed, this.species);
    }
}

function main() -> i32 {
    const g: GoldenRetriever* = new GoldenRetriever("Buddy");
    g.introduce();
    return 0;
}
