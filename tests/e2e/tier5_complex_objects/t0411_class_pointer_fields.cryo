// @test: class_pointer_fields
// @expect: compile_success
// @mode: raw
// @stdout: parent name: Root
// @stdout: child name: Leaf
// @stdout: child's parent: Root
// @tags: classes, pointers, fields
// @description: Class with pointer-typed fields referencing other class instances

namespace PointerFields;

type class Node {
public:
    name: string;
    parent: Node*;

    Node(_name: string, _parent: Node*) {
        this.name = _name;
        this.parent = _parent;
    }
}

function main() -> i32 {
    const root: Node* = new Node("Root", root);
    const leaf: Node* = new Node("Leaf", root);
    printf("parent name: %s\n", root.name);
    printf("child name: %s\n", leaf.name);
    printf("child's parent: %s\n", leaf.parent.name);
    return 0;
}
