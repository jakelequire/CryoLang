// @test: class_pointer_fields
// @expect: compile_success
// @mode: raw
// @stdout: a name: Root
// @stdout: b name: Leaf
// @stdout: b parent name: Root
// @tags: classes, pointers, fields
// @description: Class with pointer-typed fields referencing other class instances

namespace PointerFields;

type class Node {
public:
    name: string;

    Node(_name: string) {
        this.name = _name;
    }
}

type class Link {
public:
    label: string;
    target: Node*;

    Link(_label: string, _target: Node*) {
        this.label = _label;
        this.target = _target;
    }
}

function main() -> i32 {
    const a: Node* = new Node("Root");
    const b: Link* = new Link("Leaf", a);
    printf("a name: %s\n", a.name);
    printf("b name: %s\n", b.label);
    printf("b parent name: %s\n", b.target.name);
    return 0;
}
