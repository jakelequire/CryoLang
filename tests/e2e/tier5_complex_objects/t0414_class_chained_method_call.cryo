// @test: class_chained_method_call
// @expect: compile_success
// @mode: raw
// @stdout: inner says hello
// @tags: classes, methods, chaining
// @description: Calling a method on a pointer field (outer.inner.greet())

namespace ChainedMethodCall;

type class Inner {
public:
    msg: string;

    Inner(_msg: string) {
        this.msg = _msg;
    }

    greet() -> void {
        printf("inner says %s\n", this.msg);
    }
}

type class Outer {
public:
    inner: Inner*;

    Outer(_inner: Inner*) {
        this.inner = _inner;
    }
}

function main() -> i32 {
    const i: Inner* = new Inner("hello");
    const o: Outer* = new Outer(i);
    o.inner.greet();
    return 0;
}
