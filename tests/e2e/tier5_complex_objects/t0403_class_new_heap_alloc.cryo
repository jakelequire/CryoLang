// @test: class_new_heap_alloc
// @expect: compile_success
// @mode: raw
// @stdout: Point(10, 20)
// @stdout: Point(3, 4)
// @stdout: Point(0, 0)
// @tags: classes, new, heap
// @description: Multiple heap allocations with new, different constructor args

namespace ClassNewHeap;

type class Point {
public:
    x: i32;
    y: i32;

    Point(_x: i32, _y: i32) {
        this.x = _x;
        this.y = _y;
    }

    print() -> void {
        printf("Point(%d, %d)\n", this.x, this.y);
    }
}

function main() -> i32 {
    const a: Point* = new Point(10, 20);
    const b: Point* = new Point(3, 4);
    const c: Point* = new Point(0, 0);
    a.print();
    b.print();
    c.print();
    return 0;
}
