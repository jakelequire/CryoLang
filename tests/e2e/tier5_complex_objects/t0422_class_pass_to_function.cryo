// @test: class_pass_to_function
// @expect: compile_success
// @mode: raw
// @stdout: Processing: Item(7, active)
// @stdout: Processing: Item(3, inactive)
// @tags: classes, functions, pointers
// @description: Passing class pointers to free functions

namespace PassToFunc;

type class Item {
public:
    id: i32;
    active: i32;

    Item(_id: i32, _active: i32) {
        this.id = _id;
        this.active = _active;
    }
}

function process(item: Item*) -> void {
    if (item.active == 1) {
        printf("Processing: Item(%d, active)\n", item.id);
    } else {
        printf("Processing: Item(%d, inactive)\n", item.id);
    }
}

function main() -> i32 {
    const a: Item* = new Item(7, 1);
    const b: Item* = new Item(3, 0);
    process(a);
    process(b);
    return 0;
}
