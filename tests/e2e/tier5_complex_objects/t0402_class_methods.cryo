// @test: class_methods
// @expect: compile_success
// @mode: raw
// @stdout: Woof! I am Rex
// @stdout: Rex is 5 years old
// @tags: classes, methods
// @description: Class with non-virtual instance methods

namespace ClassMethods;

type class Dog {
public:
    name: string;
    age: i32;

    Dog(_name: string, _age: i32) {
        this.name = _name;
        this.age = _age;
    }

    speak() -> void {
        printf("Woof! I am %s\n", this.name);
    }

    describe() -> void {
        printf("%s is %d years old\n", this.name, this.age);
    }
}

function main() -> i32 {
    const d: Dog* = new Dog("Rex", 5);
    d.speak();
    d.describe();
    return 0;
}
