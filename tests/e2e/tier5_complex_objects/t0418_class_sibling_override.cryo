// @test: class_sibling_override
// @expect: compile_success
// @mode: raw
// @stdout: A::value = 10
// @stdout: B::value = 20
// @stdout: C::value = 30
// @tags: classes, inheritance, virtual, siblings
// @description: Multiple sibling classes each override the same virtual method differently

namespace SiblingOverride;

type class Base {
public:
    Base() {
    }

    virtual get_value() -> i32;
}

type class A : Base {
public:
    A() : Base() {
    }

    override get_value() -> i32 {
        return 10;
    }
}

type class B : Base {
public:
    B() : Base() {
    }

    override get_value() -> i32 {
        return 20;
    }
}

type class C : Base {
public:
    C() : Base() {
    }

    override get_value() -> i32 {
        return 30;
    }
}

function show(label: string, obj: Base*) -> void {
    printf("%s::value = %d\n", label, obj.get_value());
}

function main() -> i32 {
    const a: A* = new A();
    const b: B* = new B();
    const c: C* = new C();
    show("A", a);
    show("B", b);
    show("C", c);
    return 0;
}
