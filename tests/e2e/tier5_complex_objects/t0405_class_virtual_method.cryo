// @test: class_virtual_method
// @expect: compile_success
// @mode: raw
// @stdout: Circle::area = 314
// @tags: classes, virtual, override
// @description: Virtual method declared in base, overridden in derived

namespace VirtualMethod;

type class Shape {
public:
    name: string;

    Shape(_name: string) {
        this.name = _name;
    }

    virtual area() -> i32;
}

type class Circle : Shape {
public:
    radius: i32;

    Circle(_radius: i32) : Shape("Circle") {
        this.radius = _radius;
    }

    override area() -> i32 {
        // Approximate: pi * r^2 ~= 314 for r=10
        return 314;
    }
}

function main() -> i32 {
    const c: Circle* = new Circle(10);
    printf("Circle::area = %d\n", c.area());
    return 0;
}
