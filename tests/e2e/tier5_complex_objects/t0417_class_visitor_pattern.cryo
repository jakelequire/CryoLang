// @test: class_visitor_pattern
// @expect: compile_success
// @mode: raw
// @stdout: Add(Num(1), Num(2))
// @stdout: Result: 3
// @tags: classes, virtual, visitor, inheritance, pattern
// @description: Full visitor pattern with AST nodes and two visitor implementations

namespace VisitorPattern;

type class Expr {
public:
    kind: string;

    Expr(_kind: string) {
        this.kind = _kind;
    }

    virtual accept(v: ExprVisitor*) -> void;
}

type class NumExpr : Expr {
public:
    value: i32;

    NumExpr(_value: i32) : Expr("Num") {
        this.value = _value;
    }

    override accept(v: ExprVisitor*) -> void {
        v.visit_num(this);
    }
}

type class AddExpr : Expr {
public:
    left: Expr*;
    right: Expr*;

    AddExpr(_left: Expr*, _right: Expr*) : Expr("Add") {
        this.left = _left;
        this.right = _right;
    }

    override accept(v: ExprVisitor*) -> void {
        v.visit_add(this);
    }
}

type class ExprVisitor {
public:
    ExprVisitor() {
    }

    virtual visit_num(node: NumExpr*) -> void;
    virtual visit_add(node: AddExpr*) -> void;
}

// Visitor that prints the expression tree
type class PrintExprVisitor : ExprVisitor {
public:
    PrintExprVisitor() : ExprVisitor() {
    }

    override visit_num(node: NumExpr*) -> void {
        printf("Num(%d)", node.value);
    }

    override visit_add(node: AddExpr*) -> void {
        printf("Add(");
        node.left.accept(this);
        printf(", ");
        node.right.accept(this);
        printf(")");
    }
}

// Visitor that evaluates the expression
type class EvalExprVisitor : ExprVisitor {
public:
    result: i32;

    EvalExprVisitor() : ExprVisitor() {
        this.result = 0;
    }

    override visit_num(node: NumExpr*) -> void {
        this.result = node.value;
    }

    override visit_add(node: AddExpr*) -> void {
        node.left.accept(this);
        const lhs: i32 = this.result;
        node.right.accept(this);
        const rhs: i32 = this.result;
        this.result = lhs + rhs;
    }
}

function main() -> i32 {
    // Build: 1 + 2
    const one: NumExpr* = new NumExpr(1);
    const two: NumExpr* = new NumExpr(2);
    const add: AddExpr* = new AddExpr(one, two);

    // Print tree
    const printer: PrintExprVisitor* = new PrintExprVisitor();
    add.accept(printer);
    printf("\n");

    // Evaluate
    const evaluator: EvalExprVisitor* = new EvalExprVisitor();
    add.accept(evaluator);
    printf("Result: %d\n", evaluator.result);

    return 0;
}
