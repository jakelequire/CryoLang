// @test: class_virtual_return_value
// @expect: compile_success
// @mode: raw
// @stdout: total=150
// @tags: classes, virtual, return_value
// @description: Virtual methods that return values, used in computation

namespace VirtualReturnVal;

type class Pricer {
public:
    Pricer() {
    }

    virtual price() -> i32;
}

type class FlatPricer : Pricer {
public:
    amount: i32;

    FlatPricer(_amount: i32) : Pricer() {
        this.amount = _amount;
    }

    override price() -> i32 {
        return this.amount;
    }
}

type class DoublePricer : Pricer {
public:
    base: i32;

    DoublePricer(_base: i32) : Pricer() {
        this.base = _base;
    }

    override price() -> i32 {
        return this.base * 2;
    }
}

function total_price(a: Pricer*, b: Pricer*) -> i32 {
    return a.price() + b.price();
}

function main() -> i32 {
    const flat: FlatPricer* = new FlatPricer(50);
    const dbl: DoublePricer* = new DoublePricer(50);
    const total: i32 = total_price(flat, dbl);
    printf("total=%d\n", total);
    return 0;
}
