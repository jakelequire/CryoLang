// @test: class_field_mutation
// @expect: compile_success
// @mode: raw
// @stdout: count=0
// @stdout: count=1
// @stdout: count=5
// @tags: classes, fields, mutation
// @description: Mutating fields on a heap-allocated class instance through methods

namespace FieldMutation;

type class Counter {
public:
    count: i32;

    Counter() {
        this.count = 0;
    }

    increment() -> void {
        this.count = this.count + 1;
    }

    add(n: i32) -> void {
        this.count = this.count + n;
    }

    print() -> void {
        printf("count=%d\n", this.count);
    }
}

function main() -> i32 {
    const c: Counter* = new Counter();
    c.print();
    c.increment();
    c.print();
    c.add(4);
    c.print();
    return 0;
}
