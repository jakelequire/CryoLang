// @test: class_conditional_dispatch
// @expect: compile_success
// @mode: raw
// @stdout: loud: HELLO
// @stdout: quiet: ...hello...
// @tags: classes, virtual, dispatch, conditional
// @description: Choose which derived class to create based on a condition, dispatch through base

namespace ConditionalDispatch;

type class Greeter {
public:
    Greeter() {
    }

    virtual greet(name: string) -> void;
}

type class LoudGreeter : Greeter {
public:
    LoudGreeter() : Greeter() {
    }

    override greet(name: string) -> void {
        printf("loud: %s\n", name);
    }
}

type class QuietGreeter : Greeter {
public:
    QuietGreeter() : Greeter() {
    }

    override greet(name: string) -> void {
        printf("quiet: ...%s...\n", name);
    }
}

function make_greeter(loud: i32) -> Greeter* {
    if (loud == 1) {
        const g: LoudGreeter* = new LoudGreeter();
        return g;
    }
    const g: QuietGreeter* = new QuietGreeter();
    return g;
}

function main() -> i32 {
    const g1: Greeter* = make_greeter(1);
    const g2: Greeter* = make_greeter(0);
    g1.greet("HELLO");
    g2.greet("hello");
    return 0;
}
