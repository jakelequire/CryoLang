// @test: class_multiple_virtual_methods
// @expect: compile_success
// @mode: raw
// @stdout: name=Widget
// @stdout: width=100
// @stdout: height=50
// @tags: classes, virtual, multiple
// @description: Class with multiple virtual methods, all overridden in derived

namespace MultiVirtual;

type class Widget {
public:
    Widget() {
    }

    virtual get_name() -> string;
    virtual get_width() -> i32;
    virtual get_height() -> i32;
}

type class Button : Widget {
public:
    label: string;
    w: i32;
    h: i32;

    Button(_label: string, _w: i32, _h: i32) : Widget() {
        this.label = _label;
        this.w = _w;
        this.h = _h;
    }

    override get_name() -> string {
        return this.label;
    }

    override get_width() -> i32 {
        return this.w;
    }

    override get_height() -> i32 {
        return this.h;
    }
}

function print_widget(w: Widget*) -> void {
    printf("name=%s\n", w.get_name());
    printf("width=%d\n", w.get_width());
    printf("height=%d\n", w.get_height());
}

function main() -> i32 {
    const btn: Button* = new Button("Widget", 100, 50);
    print_widget(btn);
    return 0;
}
