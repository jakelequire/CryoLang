// @test: class_virtual_dispatch_loop
// @expect: compile_success
// @mode: raw
// @stdout: Square: area=25
// @stdout: Rect: area=24
// @stdout: Square: area=100
// @tags: classes, virtual, dispatch, loop
// @description: Virtual dispatch on multiple objects through base pointer in a loop-like pattern

namespace VDispatchLoop;

type class Shape {
public:
    label: string;

    Shape(_label: string) {
        this.label = _label;
    }

    virtual area() -> i32;
}

type class Square : Shape {
public:
    side: i32;

    Square(_label: string, _side: i32) : Shape(_label) {
        this.side = _side;
    }

    override area() -> i32 {
        return this.side * this.side;
    }
}

type class Rect : Shape {
public:
    w: i32;
    h: i32;

    Rect(_label: string, _w: i32, _h: i32) : Shape(_label) {
        this.w = _w;
        this.h = _h;
    }

    override area() -> i32 {
        return this.w * this.h;
    }
}

function print_area(s: Shape*) -> void {
    printf("%s: area=%d\n", s.label, s.area());
}

function main() -> i32 {
    const s1: Square* = new Square("Square", 5);
    const r1: Rect* = new Rect("Rect", 6, 4);
    const s2: Square* = new Square("Square", 10);

    print_area(s1);
    print_area(r1);
    print_area(s2);
    return 0;
}
