// @test: class_constructor_args_forwarding
// @expect: compile_success
// @mode: raw
// @stdout: Colored shape: red, sides: 4
// @stdout: Colored shape: blue, sides: 3
// @tags: classes, inheritance, constructor, args
// @description: Derived constructor forwards arguments to base constructor

namespace CtorForward;

type class Shape {
public:
    sides: i32;

    Shape(_sides: i32) {
        this.sides = _sides;
    }
}

type class ColoredShape : Shape {
public:
    color: string;

    ColoredShape(_color: string, _sides: i32) : Shape(_sides) {
        this.color = _color;
    }

    describe() -> void {
        printf("Colored shape: %s, sides: %d\n", this.color, this.sides);
    }
}

function main() -> i32 {
    const sq: ColoredShape* = new ColoredShape("red", 4);
    const tri: ColoredShape* = new ColoredShape("blue", 3);
    sq.describe();
    tri.describe();
    return 0;
}
