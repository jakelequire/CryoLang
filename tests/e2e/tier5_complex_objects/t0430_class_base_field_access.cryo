// @test: class_base_field_access
// @expect: compile_success
// @mode: raw
// @stdout: id=1, tag=admin
// @stdout: id=2, tag=user
// @tags: classes, inheritance, fields, base
// @description: Derived class accessing fields defined in the base class via this

namespace BaseFieldAccess;

type class Entity {
public:
    id: i32;

    Entity(_id: i32) {
        this.id = _id;
    }
}

type class TaggedEntity : Entity {
public:
    tag: string;

    TaggedEntity(_id: i32, _tag: string) : Entity(_id) {
        this.tag = _tag;
    }

    describe() -> void {
        printf("id=%d, tag=%s\n", this.id, this.tag);
    }
}

function main() -> i32 {
    const admin: TaggedEntity* = new TaggedEntity(1, "admin");
    const user: TaggedEntity* = new TaggedEntity(2, "user");
    admin.describe();
    user.describe();
    return 0;
}
