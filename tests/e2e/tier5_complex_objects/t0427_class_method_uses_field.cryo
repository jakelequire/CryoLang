// @test: class_method_uses_field
// @expect: compile_success
// @mode: raw
// @stdout: Hello, World!
// @stdout: length=13
// @tags: classes, methods, fields, this
// @description: Method accessing this.field for computation

namespace MethodField;

type class Message {
public:
    text: string;
    len: i32;

    Message(_text: string, _len: i32) {
        this.text = _text;
        this.len = _len;
    }

    print_text() -> void {
        printf("%s\n", this.text);
    }

    print_length() -> void {
        printf("length=%d\n", this.len);
    }
}

function main() -> i32 {
    const m: Message* = new Message("Hello, World!", 13);
    m.print_text();
    m.print_length();
    return 0;
}
