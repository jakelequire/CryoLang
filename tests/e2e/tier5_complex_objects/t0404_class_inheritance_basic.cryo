// @test: class_inheritance_basic
// @expect: compile_success
// @mode: raw
// @stdout: Animal: Dog
// @stdout: Buddy says: Woof!
// @tags: classes, inheritance, basic
// @description: Simple single-level inheritance with base constructor call

namespace InheritBasic;

type class Animal {
public:
    kind: string;

    Animal(_kind: string) {
        this.kind = _kind;
    }

    describe() -> void {
        printf("Animal: %s\n", this.kind);
    }
}

type class Dog : Animal {
public:
    name: string;

    Dog(_name: string) : Animal("Dog") {
        this.name = _name;
    }

    bark() -> void {
        printf("%s says: Woof!\n", this.name);
    }
}

function main() -> i32 {
    const d: Dog* = new Dog("Buddy");
    d.describe();
    d.bark();
    return 0;
}
