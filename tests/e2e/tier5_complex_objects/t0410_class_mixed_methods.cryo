// @test: class_mixed_methods
// @expect: compile_success
// @mode: raw
// @stdout: Logger[INFO]: Hello
// @stdout: Logger[ERROR]: Something broke
// @tags: classes, methods, virtual, mixed
// @description: Mix of virtual, override, and regular non-virtual methods on one class

namespace MixedMethods;

type class Logger {
public:
    prefix: string;

    Logger(_prefix: string) {
        this.prefix = _prefix;
    }

    // Non-virtual method (not overridable)
    format(level: string, msg: string) -> void {
        printf("%s[%s]: %s\n", this.prefix, level, msg);
    }

    virtual log_info(msg: string) -> void;
    virtual log_error(msg: string) -> void;
}

type class ConsoleLogger : Logger {
public:
    ConsoleLogger() : Logger("Logger") {
    }

    override log_info(msg: string) -> void {
        this.format("INFO", msg);
    }

    override log_error(msg: string) -> void {
        this.format("ERROR", msg);
    }
}

function main() -> i32 {
    const logger: ConsoleLogger* = new ConsoleLogger();
    logger.log_info("Hello");
    logger.log_error("Something broke");
    return 0;
}
