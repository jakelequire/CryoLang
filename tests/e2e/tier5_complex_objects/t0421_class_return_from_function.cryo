// @test: class_return_from_function
// @expect: compile_success
// @mode: raw
// @stdout: Created: Widget(42)
// @tags: classes, new, functions, return
// @description: Function that creates and returns a class pointer

namespace ClassReturn;

type class Widget {
public:
    id: i32;

    Widget(_id: i32) {
        this.id = _id;
    }
}

function create_widget(id: i32) -> Widget* {
    return new Widget(id);
}

function main() -> i32 {
    const w: Widget* = create_widget(42);
    printf("Created: Widget(%d)\n", w.id);
    return 0;
}
