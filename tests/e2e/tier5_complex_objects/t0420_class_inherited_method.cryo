// @test: class_inherited_method
// @expect: compile_success
// @mode: raw
// @stdout: Base says hello
// @stdout: Derived also says hello
// @tags: classes, inheritance, methods
// @description: Derived class uses a non-virtual method defined in the base class

namespace InheritedMethod;

type class Base {
public:
    msg: string;

    Base(_msg: string) {
        this.msg = _msg;
    }

    greet() -> void {
        printf("%s says hello\n", this.msg);
    }
}

type class Derived : Base {
public:
    Derived(_msg: string) : Base(_msg) {
    }
}

function main() -> i32 {
    const b: Base* = new Base("Base");
    const d: Derived* = new Derived("Derived also");
    b.greet();
    d.greet();
    return 0;
}
