// @test: class_two_derived_virtual
// @expect: compile_success
// @mode: raw
// @stdout: [json] {"key":"hello"}
// @stdout: [text] key=hello
// @tags: classes, virtual, dispatch, two_derived
// @description: Two derived classes override same virtual method, dispatched through base pointer

namespace TwoDerived;

type class Formatter {
public:
    Formatter() {}

    virtual format(key: string, value: string) -> void;
}

type class JsonFormatter : Formatter {
public:
    JsonFormatter() : Formatter() {
    }

    override format(key: string, value: string) -> void {
        printf("[json] {\"%s\":\"%s\"}\n", key, value);
    }
}

type class TextFormatter : Formatter {
public:
    TextFormatter() : Formatter() {
    }

    override format(key: string, value: string) -> void {
        printf("[text] %s=%s\n", key, value);
    }
}

function emit(f: Formatter*, k: string, v: string) -> void {
    f.format(k, v);
}

function main() -> i32 {
    const json: JsonFormatter* = new JsonFormatter();
    const text: TextFormatter* = new TextFormatter();
    emit(json, "key", "hello");
    emit(text, "key", "hello");
    return 0;
}
