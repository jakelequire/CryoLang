// @test: class_string_fields
// @expect: compile_success
// @mode: raw
// @stdout: John Doe (john@example.com)
// @tags: classes, strings, fields
// @description: Class with multiple string fields

namespace StringFields;

type class User {
public:
    first_name: string;
    last_name: string;
    email: string;

    User(_first: string, _last: string, _email: string) {
        this.first_name = _first;
        this.last_name = _last;
        this.email = _email;
    }

    display() -> void {
        printf("%s %s (%s)\n", this.first_name, this.last_name, this.email);
    }
}

function main() -> i32 {
    const u: User* = new User("John", "Doe", "john@example.com");
    u.display();
    return 0;
}
