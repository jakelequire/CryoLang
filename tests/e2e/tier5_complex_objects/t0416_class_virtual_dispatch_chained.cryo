// @test: class_virtual_dispatch_chained
// @expect: compile_success
// @mode: raw
// @stdout: Visiting number: 42
// @tags: classes, virtual, dispatch, chaining
// @description: Virtual dispatch through a pointer field (node.accept calls visitor.visit via vtable)

namespace VDispatchChained;

type class Visitor {
public:
    Visitor() {
    }

    virtual visit_number(val: i32) -> void;
}

type class PrintVisitor : Visitor {
public:
    PrintVisitor() : Visitor() {
    }

    override visit_number(val: i32) -> void {
        printf("Visiting number: %d\n", val);
    }
}

type class NumberNode {
public:
    value: i32;

    NumberNode(_value: i32) {
        this.value = _value;
    }

    accept(v: Visitor*) -> void {
        v.visit_number(this.value);
    }
}

function main() -> i32 {
    const node: NumberNode* = new NumberNode(42);
    const vis: PrintVisitor* = new PrintVisitor();
    node.accept(vis);
    return 0;
}
