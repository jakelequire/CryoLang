namespace Data;

type struct Item {
    name: string;
    value: int;

    static new(n: string) -> Item {
        return Item {
            name: n,
            value: 0,
        };
    }
}

type struct Store {
    last_key: string;

    static new() -> Store {
        return Store {
            last_key: "",
        };
    }

    put(item: Item) -> void {
        this.last_key = item.name;
    }
}
