// @test: cross_module_struct_param_field_access
// @expect: compile_success
// @mode: project
// @stdout: stored=hello
// @tags: modules, project, cross_module, field_access, struct_param
// @description: Accessing fields on a struct-typed parameter within a method of another struct in the same module

namespace Main;

import Data;

function main() -> int {
    const item: Data::Item = Data::Item::new("hello");
    const store: Data::Store = Data::Store::new();
    store.put(item);
    printf("stored=%s\n", store.last_key);
    return 0;
}
