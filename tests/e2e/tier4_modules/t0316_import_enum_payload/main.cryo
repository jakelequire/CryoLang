// @test: import_enum_payload
// @expect: compile_success
// @mode: project
// @stdout: 5
// @tags: modules, project, import, enums, payload

namespace Main;

import Shapes;

function main() -> int {
    const s: Shapes::Shape = Shapes::Shape::Circle(5);
    match (s) {
        Shapes::Shape::Circle(r) => {
            printf("%d\n", r);
        },
        Shapes::Shape::Square(side) => {
            printf("%d\n", side);
        },
    }
    return 0;
}
