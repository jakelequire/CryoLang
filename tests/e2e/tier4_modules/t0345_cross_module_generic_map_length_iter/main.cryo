// @test: cross_module_generic_map_length_iter
// @expect: compile_success
// @mode: project
// @stdout: count=2
// @tags: modules, project, generics, cross_module, for_loop, array_length, map, multi_type_param, struct_value, transitive_import
// @description: Transitive cross-module generic: Main imports App which imports Utils. App struct has Map<string, Item> field. Map methods use .length and array indexing. Reproduces 'no field length found' error during cross-module instantiation via transitive imports.

namespace Main;

import App;

function main() -> int {
    const s: App::Store = App::Store::new();
    s.put("alpha", 10);
    s.put("beta", 20);
    printf("count=%d\n", s.total());
    return 0;
}
