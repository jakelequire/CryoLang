namespace Utils;

type struct Map<Key, Value> {
    keys: Key[];
    values: Value[];

    static new() -> Map<Key, Value> {
        return Map {
            keys: [],
            values: [],
        };
    }

    set(key: Key, value: Value) -> void {
        for (mut i: int = 0; i < this.keys.length; i++) {
            if (this.keys[i] == key) {
                this.values[i] = value;
                return;
            }
        }
        this.keys.push(key);
        this.values.push(value);
    }

    count() -> int {
        return this.keys.length;
    }
}
