namespace App;

import Utils;

type struct Item {
    name: string;
    value: int;
}

type struct Store {
    data: Map<string, Item>;

    static new() -> Store {
        return Store {
            data: Map<string, Item>::new(),
        };
    }

    put(key: string, val: int) -> void {
        const item: Item = Item { name: key, value: val };
        this.data.set(key, item);
    }

    total() -> int {
        return this.data.count();
    }

    key_count() -> int {
        return this.data.keys.length;
    }
}
