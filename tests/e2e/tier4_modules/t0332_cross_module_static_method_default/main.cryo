// @test: cross_module_static_method_default
// @expect: compile_success
// @mode: project
// @stdout: locked=0
// @stdout: locked=1
// @stdout: locked=0
// @stdout: count=1
// @tags: modules, project, structs, static_methods, stdlib_bug
// @description: RC4 - Cross-module static method call (e.g. PThreadMutex::default() from barrier.cryo)

namespace Main;

import Lock;

function main() -> int {
    mut m: Lock::Mutex = Lock::Mutex::default();
    printf("locked=%d\n", m.is_locked());

    m.lock();
    printf("locked=%d\n", m.is_locked());

    m.unlock();
    printf("locked=%d\n", m.is_locked());

    printf("count=%d\n", m.lock_count());
    return 0;
}
