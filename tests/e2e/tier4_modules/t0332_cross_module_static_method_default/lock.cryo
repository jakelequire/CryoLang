namespace Lock;

type struct Mutex {
    locked: boolean;
    count: int;

    static default() -> Mutex {
        return Mutex { locked: false, count: 0 };
    }

    lock(mut &this) -> void {
        this.locked = true;
        this.count = this.count + 1;
    }

    unlock(mut &this) -> void {
        this.locked = false;
    }

    is_locked(&this) -> boolean {
        return this.locked;
    }

    lock_count(&this) -> int {
        return this.count;
    }
}
