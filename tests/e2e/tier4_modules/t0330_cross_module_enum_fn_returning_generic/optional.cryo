namespace Optional;

enum Maybe<T> {
    Some(T);
    None;
}

implement enum Maybe<T> {
    unwrap_or(&this, d: T) -> T {
        match (&this) {
            Maybe::Some(v) => { return v; }
            Maybe::None => { return d; }
            _ => { return d; }
        }
    }

    or_else(&this, f: () -> Maybe<T>) -> Maybe<T> {
        match (&this) {
            Maybe::Some(_) => { return this; }
            Maybe::None => { return f(); }
        }
    }
}

function some(val: int) -> Maybe<int> {
    return Maybe::Some(val);
}

function none_int() -> Maybe<int> {
    return Maybe::None;
}
