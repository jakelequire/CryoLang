// @test: cross_module_enum_fn_returning_generic
// @expect: compile_success
// @mode: project
// @stdout: 42
// @stdout: 99
// @tags: modules, project, generics, enums, implement, cross_module, function_type
// @description: Cross-module enum with method taking function param that returns a generic type

namespace Main;

import Optional;

function fallback() -> Optional::Maybe<int> {
    return Optional::some(99);
}

function main() -> int {
    const a: Optional::Maybe<int> = Optional::some(42);
    const b: Optional::Maybe<int> = Optional::none_int();

    // a is Some(42), or_else should return a unchanged
    const r1: Optional::Maybe<int> = a.or_else(fallback);
    printf("%d\n", r1.unwrap_or(0));

    // b is None, or_else should call fallback() -> Some(99)
    const r2: Optional::Maybe<int> = b.or_else(fallback);
    printf("%d\n", r2.unwrap_or(0));

    return 0;
}
