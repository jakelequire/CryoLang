namespace Utils;

type struct Bucket<T> {
    items: T[];
    count: int;

    static new() -> Bucket<T> {
        return Bucket {
            items: [],
            count: 0,
        };
    }

    add(item: T) -> void {
        this.items.push(item);
        this.count = this.count + 1;
    }

    size() -> int {
        return this.count;
    }
}
