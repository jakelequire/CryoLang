// @test: cross_module_nested_generic_instance_method
// @expect: compile_success
// @mode: project
// @stdout: total=2
// @tags: modules, project, generics, cross_module, nested_field, instance_method
// @description: Non-generic struct with generic-typed field from imported module; calling instance methods on that field

namespace Main;

import Store;

function main() -> int {
    const r: Store::Registry = Store::Registry::new();
    r.put(10);
    r.put(20);
    printf("total=%d\n", r.total());
    return 0;
}
