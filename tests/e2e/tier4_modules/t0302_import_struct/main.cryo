// @test: import_struct
// @expect: compile_success
// @mode: project
// @stdout: area = 50
// @tags: modules, project, structs

namespace Main;

type struct Rect {
    width: int;
    height: int;
}

function main() -> int {
    const r: Rect = Rect { width: 10, height: 5 };
    const area: int = r.width * r.height;
    printf("area = %d\n", area);
    return 0;
}
