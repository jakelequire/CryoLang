namespace Registry;

const STATE_EMPTY: u8 = 0;
const STATE_ACTIVE: u8 = 1;
const STATE_REMOVED: u8 = 2;
const MAX_SLOTS: u64 = 8;
const GROW_FACTOR: u64 = 2;

type struct Entry<K, V> {
    key: K;
    value: V;
    state: u8;

    static make(k: K, v: V) -> Entry<K, V> {
        return Entry { key: k, value: v, state: STATE_ACTIVE };
    }

    static empty_entry(k: K, v: V) -> Entry<K, V> {
        return Entry { key: k, value: v, state: STATE_EMPTY };
    }

    is_active(&this) -> boolean {
        return this.state == STATE_ACTIVE;
    }

    is_empty(&this) -> boolean {
        return this.state == STATE_EMPTY;
    }

    mark_removed(mut &this) -> void {
        this.state = STATE_REMOVED;
    }

    state_code(&this) -> u8 {
        return this.state;
    }
}

type struct Pool<T> {
    data: T*;
    tags: u8*;
    cap: u64;
    len: u64;

    static create() -> Pool<T> {
        const c: u64 = MAX_SLOTS;
        const d: T* = calloc(c, sizeof(T));
        const t: u8* = calloc(c, sizeof(u8));
        return Pool { data: d, tags: t, cap: c, len: 0 };
    }

    insert(mut &this, val: T) -> boolean {
        if (this.len >= this.cap) {
            return false;
        }
        this.data[this.len] = val;
        this.tags[this.len] = STATE_ACTIVE;
        this.len = this.len + 1;
        return true;
    }

    remove(mut &this, idx: u64) -> boolean {
        if (idx >= this.len) {
            return false;
        }
        if (this.tags[idx] != STATE_ACTIVE) {
            return false;
        }
        this.tags[idx] = STATE_REMOVED;
        return true;
    }

    get_tag(&this, idx: u64) -> u8 {
        return this.tags[idx];
    }

    count_active(&this) -> u64 {
        mut count: u64 = 0;
        mut i: u64 = 0;
        while (i < this.len) {
            if (this.tags[i] == STATE_ACTIVE) {
                count = count + 1;
            }
            i = i + 1;
        }
        return count;
    }

    next_cap(&this) -> u64 {
        return this.cap * GROW_FACTOR;
    }

    drop(mut &this) -> void {
        free(this.data);
        free(this.tags);
    }
}
