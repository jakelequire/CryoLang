// @test: cross_module_multi_const_generics
// @expect: compile_success
// @mode: project
// @stdout: active=2
// @stdout: tag0=1
// @stdout: tag1=1
// @stdout: removed=1
// @stdout: tag0_after=2
// @stdout: count=1
// @stdout: next=16
// @stdout: pair_active=1
// @stdout: pair_empty=1
// @tags: modules, project, generics, constants
// @description: Multiple constants (5 consts, 2 types) used across two generic type instantiations in cross-module context

namespace Main;

import Registry;

function main() -> int {
    // Pool<int> — exercises constants in static, instance, loop, and arithmetic methods
    mut pool: Registry::Pool<int> = Registry::Pool<int>::create();
    pool.insert(42);
    pool.insert(99);

    printf("active=%d\n", pool.count_active());

    // Both entries should be STATE_ACTIVE (1)
    printf("tag0=%d\n", pool.get_tag(0));
    printf("tag1=%d\n", pool.get_tag(1));

    // Remove first entry — should become STATE_REMOVED (2)
    pool.remove(0);
    printf("removed=%d\n", pool.get_tag(0) == 2);
    printf("tag0_after=%d\n", pool.get_tag(0));
    printf("count=%d\n", pool.count_active());

    // Arithmetic on constants (GROW_FACTOR * cap)
    printf("next=%d\n", pool.next_cap());

    // Entry<string, int> — separate generic instantiation using same constants
    const pair: Registry::Entry<string, int> = Registry::Entry<string, int>::make("hello", 7);
    printf("pair_active=%d\n", pair.is_active());

    const blank: Registry::Entry<string, int> = Registry::Entry<string, int>::empty_entry("none", 0);
    printf("pair_empty=%d\n", blank.is_empty());

    pool.drop();
    return 0;
}
