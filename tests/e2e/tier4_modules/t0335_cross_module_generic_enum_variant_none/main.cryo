// @test: cross_module_generic_enum_variant_none
// @expect: compile_success
// @mode: project
// @stdout: 20
// @stdout: 0
// @tags: modules, project, generics, enums, variant_resolution, stdlib_bug
// @description: RC6 - Generic enum variant (Maybe::None) returned from cross-module monomorphized impl body

namespace Main;

import Optional;

function double_if_small(x: int) -> Optional::Maybe<int> {
    if (x < 50) {
        return Optional::Maybe::Some(x * 2);
    }
    return Optional::Maybe::None;
}

function main() -> int {
    const a: Optional::Maybe<int> = Optional::Maybe::Some(10);
    const b: Optional::Maybe<int> = Optional::Maybe::None;

    const r1: Optional::Maybe<int> = a.and_then(double_if_small);
    const r2: Optional::Maybe<int> = b.and_then(double_if_small);

    printf("%d\n", r1.unwrap_or(0));
    printf("%d\n", r2.unwrap_or(0));

    return 0;
}
