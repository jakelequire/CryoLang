namespace Optional;

enum Maybe<T> {
    Some(T);
    None;
}

implement enum Maybe<T> {
    is_some(&this) -> boolean {
        match (&this) {
            Maybe::Some(_) => { return true; }
            Maybe::None => { return false; }
        }
    }

    unwrap_or(&this, def: T) -> T {
        match (&this) {
            Maybe::Some(v) => { return v; }
            Maybe::None => { return def; }
        }
    }

    /// Key pattern: returns None variant from inside monomorphized body
    and_then(&this, f: (T) -> Maybe<T>) -> Maybe<T> {
        match (&this) {
            Maybe::Some(v) => { return f(v); }
            Maybe::None => { return Maybe::None; }
        }
    }
}
