namespace Types;

/// Generic two-param enum (like Result<T, E>).
enum Outcome<T, E> {
    Ok(T);
    Err(E);
}

implement enum Outcome<T, E> {
    is_ok(&this) -> int {
        match (&this) {
            Outcome::Ok(_) => { return 1; }
            Outcome::Err(_) => { return 0; }
            _ => { return 0; }
        }
    }

    unwrap_or(&this, d: T) -> T {
        match (&this) {
            Outcome::Ok(v) => { return v; }
            Outcome::Err(_) => { return d; }
            _ => { return d; }
        }
    }
}

function make_ok<T, E>(value: T) -> Outcome<T, E> {
    return Outcome::Ok(value);
}

function make_err<T, E>(error: E) -> Outcome<T, E> {
    return Outcome::Err(error);
}
