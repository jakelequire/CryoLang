namespace Handler;

import Types;

/// Struct with a method that returns a cross-module generic enum.
/// This mirrors the cryoc pattern where File::load() returns Result<boolean, string>.
type struct Handler {
    name: string;
    ready: boolean;

    static new(name: string) -> Handler {
        return Handler {
            name: name,
            ready: false,
        };
    }

    /// Method returning a cross-module generic enum instantiated with concrete types.
    /// This triggers the bug: parser creates ErrorType("unresolved generic: Outcome<boolean,string>")
    /// and TypeResolutionPass fails to resolve it for the cross-module case.
    init(this: Handler*) -> Types::Outcome<boolean, string> {
        if (this.ready) {
            return Types::make_ok(true);
        }
        this.ready = true;
        return Types::make_ok(true);
    }

    name(this: Handler*) -> string {
        return this.name;
    }

    is_ready(this: Handler*) -> boolean {
        return this.ready;
    }
}
