// @test: import_generic_enum
// @expect: compile_success
// @mode: project
// @stdout: 1
// @stdout: 0
// @stdout: 42
// @stdout: -1
// @tags: modules, project, generics, enums, implement

namespace Main;

import Types;

function main() -> int {
    const a: Types::Maybe<int> = Types::Maybe::Just(42);
    const b: Types::Maybe<int> = Types::Maybe::Nothing;
    printf("%d\n", a.is_just());
    printf("%d\n", b.is_just());
    printf("%d\n", a.unwrap_or(0));
    printf("%d\n", b.unwrap_or(-1));
    return 0;
}
