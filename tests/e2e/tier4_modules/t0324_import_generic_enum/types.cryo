namespace Types;

enum Maybe<T> {
    Just(T);
    Nothing;
}

implement enum Maybe<T> {
    is_just(&this) -> int {
        match (&this) {
            Maybe::Just(_) => { return 1; }
            Maybe::Nothing => { return 0; }
            _ => { return 0; }
        }
    }

    unwrap_or(&this, fallback: T) -> T {
        match (&this) {
            Maybe::Just(v) => { return v; }
            Maybe::Nothing => { return fallback; }
            _ => { return fallback; }
        }
    }
}
