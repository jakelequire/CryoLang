namespace Utils;

type struct List<T> {
    items: T[];

    static new() -> List<T> {
        return List {
            items: [],
        };
    }

    add(item: T) -> void {
        this.items.push(item);
    }

    sum_all() -> int {
        mut total: int = 0;
        for (mut i: int = 0; i < this.items.length; i++) {
            total = total + this.items[i];
        }
        return total;
    }
}
