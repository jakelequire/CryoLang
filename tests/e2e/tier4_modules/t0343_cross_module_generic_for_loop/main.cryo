// @test: cross_module_generic_for_loop
// @expect: compile_success
// @mode: project
// @stdout: sum=60
// @tags: modules, project, generics, cross_module, for_loop, array_length
// @description: Generic struct method with for-loop iterating array field using .length as bound during cross-module instantiation

namespace Main;

import Utils;

function main() -> int {
    const l: Utils::List<int> = Utils::List<int>::new();
    l.add(10);
    l.add(20);
    l.add(30);
    printf("sum=%d\n", l.sum_all());
    return 0;
}
