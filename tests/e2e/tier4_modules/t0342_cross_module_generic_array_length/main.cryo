// @test: cross_module_generic_array_length
// @expect: compile_success
// @mode: project
// @stdout: size=3
// @tags: modules, project, generics, cross_module, array_length
// @description: Generic struct method accessing .length property on an array field during cross-module instantiation

namespace Main;

import Utils;

function main() -> int {
    const c: Utils::Container<int> = Utils::Container<int>::new();
    c.add(10);
    c.add(20);
    c.add(30);
    printf("size=%d\n", c.size());
    return 0;
}
