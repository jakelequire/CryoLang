// @test: cross_module_qualified_fn_call
// @expect: compile_success
// @mode: project
// @stdout: length=2
// @tags: modules, project, cross_module, qualified_call
// @description: Non-generic struct method calling a module-qualified imported function (e.g. Utils::len)

namespace Main;

import Helpers;

type struct ItemList {
    items: int[];

    static new() -> ItemList {
        return ItemList {
            items: [],
        };
    }

    append(val: int) -> void {
        const l: int = Helpers::count(this.items);
        this.items[l] = val;
    }

    length() -> int {
        return Helpers::count(this.items);
    }
}

function main() -> int {
    const list: ItemList = ItemList::new();
    list.append(10);
    list.append(20);
    printf("length=%d\n", list.length());
    return 0;
}
