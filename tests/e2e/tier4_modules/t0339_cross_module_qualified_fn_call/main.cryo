// @test: cross_module_qualified_fn_call
// @expect: compile_success
// @mode: project
// @stdout: length=2
// @tags: modules, project, cross_module, qualified_call
// @description: Non-generic struct method calling a module-qualified imported function (e.g. Helpers::count)

namespace Main;

import Helpers;

type struct ItemList {
    items: int[];
    size: int;

    static new() -> ItemList {
        return ItemList {
            items: [],
            size: 0,
        };
    }

    append(val: int) -> void {
        this.items.push(val);
        this.size = this.size + 1;
    }

    length() -> int {
        return Helpers::count(this.size);
    }
}

function main() -> int {
    const list: ItemList = ItemList::new();
    list.append(10);
    list.append(20);
    printf("length=%d\n", list.length());
    return 0;
}
