// @test: cross_module_generic_member_access
// @expect: compile_success
// @mode: project
// @stdout: key=10 val=20
// @stdout: occupied=1
// @tags: modules, project, generics, member_access, stdlib_bug
// @description: RC1 - Member access on monomorphized generic struct fields across modules (e.g. entry.state)

namespace Main;

import Entry;

function main() -> int {
    const e: Entry::MapEntry<int, int> = Entry::MapEntry<int, int>::new(10, 20);
    printf("key=%d val=%d\n", e.get_key(), e.get_value());
    printf("occupied=%d\n", e.is_occupied());
    return 0;
}
