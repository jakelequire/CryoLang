namespace Entry;

type struct MapEntry<K, V> {
    key: K;
    value: V;
    state: u8;

    static new(k: K, v: V) -> MapEntry<K, V> {
        return MapEntry { key: k, value: v, state: 1 };
    }

    static empty() -> MapEntry<K, V> {
        return MapEntry { key: 0, value: 0, state: 0 };
    }

    is_occupied(&this) -> boolean {
        return this.state == 1;
    }

    get_key(&this) -> K {
        return this.key;
    }

    get_value(&this) -> V {
        return this.value;
    }
}
