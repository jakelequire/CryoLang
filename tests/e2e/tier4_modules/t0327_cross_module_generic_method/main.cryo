// @test: cross_module_generic_method
// @expect: compile_success
// @mode: project
// @stdout: 42
// @stdout: 100
// @stdout: hello
// @tags: modules, project, generics, methods, cross_module

namespace Main;

import Container;

function main() -> int {
    mut b: Container::Box<int> = Container::Box<int>::new(42);
    printf("%d\n", b.get());
    b.set(100);
    printf("%d\n", b.get());

    const s: Container::Box<string> = Container::Box<string>::new("hello");
    printf("%s\n", s.get());
    return 0;
}
