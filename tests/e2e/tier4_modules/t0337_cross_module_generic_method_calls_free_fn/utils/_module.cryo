namespace Utils;

function len(arr: void*) -> int {
    mut inc: int = 0;
    while(true) {
        if (arr[inc] == null) {
            break;
        }
        inc++;
    }
    return inc;
}

type struct Container<T> {
    items: T[];

    static new() -> Container {
        return Container {
            items: [],
        };
    }

    add(item: T) -> void {
        this.items.push(item);
    }

    count() -> int {
        return len(this.items);
    }
}
