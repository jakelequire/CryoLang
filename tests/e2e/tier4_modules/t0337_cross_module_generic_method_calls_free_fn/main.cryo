// @test: cross_module_generic_method_calls_free_fn
// @expect: compile_success
// @mode: project
// @stdout: count=4
// @tags: modules, project, generics, cross_module, free_function
// @description: Generic struct method calling a free function from the same module during cross-module instantiation

namespace Main;

import Utils;

function main() -> int {
    const c: Utils::Container<int> = Utils::Container<int>::new();
    c.add(10);
    c.add(20);
    printf("count=%d\n", c.count());
    return 0;
}
