// @test: cross_module_struct_param
// @expect: compile_success
// @mode: project
// @stdout: 10 32
// @tags: modules, project, import, structs, params

namespace Main;

import Geo;

function print_point(p: Geo::Point) -> void {
    printf("%d %d\n", p.x, p.y);
}

function main() -> int {
    const p: Geo::Point = Geo::Point::new(10, 32);
    print_point(p);
    return 0;
}
