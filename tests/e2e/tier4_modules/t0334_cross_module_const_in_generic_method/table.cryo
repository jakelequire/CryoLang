namespace Table;

const DEFAULT_CAP: u64 = 4;
const EMPTY: u8 = 0;
const USED: u8 = 1;

type struct Slot<T> {
    value: T;
    tag: u8;
}

type struct Table<T> {
    slots: Slot<T>*;
    cap: u64;
    len: u64;

    static new() -> Table<T> {
        const c: u64 = DEFAULT_CAP;
        const s: Slot<T>* = calloc(c, sizeof(Slot<T>));
        return Table { slots: s, cap: c, len: 0 };
    }

    put(mut &this, idx: u64, val: T) -> void {
        if (idx < this.cap) {
            this.slots[idx].value = val;
            this.slots[idx].tag = USED;
            this.len = this.len + 1;
        }
    }

    is_used(&this, idx: u64) -> boolean {
        return this.slots[idx].tag == USED;
    }

    is_empty(&this, idx: u64) -> boolean {
        return this.slots[idx].tag == EMPTY;
    }

    get(&this, idx: u64) -> T {
        return this.slots[idx].value;
    }

    drop(mut &this) -> void {
        free(this.slots);
    }
}
