// @test: cross_module_const_in_generic_method
// @expect: compile_success
// @mode: project
// @stdout: empty=1
// @stdout: val=99
// @stdout: used=1
// @tags: modules, project, generics, constants, stdlib_bug
// @description: RC2 - Module-level constants (DEFAULT_CAP, EMPTY, USED) used in generic struct methods across modules

namespace Main;

import Table;

function main() -> int {
    mut t: Table::Table<int> = Table::Table<int>::new();

    printf("empty=%d\n", t.is_empty(0));
    t.put(0, 99);
    printf("val=%d\n", t.get(0));
    printf("used=%d\n", t.is_used(0));

    t.drop();
    return 0;
}
