namespace Utils;

type struct Pair<K, V> {
    key: K;
    val: V;

    static create(k: K, v: V) -> Pair<K, V> {
        return Pair {
            key: k,
            val: v,
        };
    }

    get_key() -> K {
        return this.key;
    }

    get_val() -> V {
        return this.val;
    }
}
