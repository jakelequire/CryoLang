namespace Store;

import Utils;

type struct Registry {
    entry: Pair<string, int>;
    has_entry: boolean;

    static new() -> Registry {
        return Registry {
            entry: Pair<string, int>::create("", 0),
            has_entry: false,
        };
    }

    add(key: string, value: int) -> void {
        this.entry = Pair<string, int>::create(key, value);
        this.has_entry = true;
    }
}
