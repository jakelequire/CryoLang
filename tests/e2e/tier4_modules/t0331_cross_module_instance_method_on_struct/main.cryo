// @test: cross_module_instance_method_on_struct
// @expect: compile_success
// @mode: project
// @stdout: 10
// @stdout: 20
// @stdout: 30
// @tags: modules, project, structs, instance_methods, stdlib_bug
// @description: RC3 - Instance methods (first, second, etc.) on structs imported from another module

namespace Main;

import Pair;

function main() -> int {
    const p: Pair::Pair = Pair::Pair::new(10, 20);
    printf("%d\n", p.first());
    printf("%d\n", p.second());
    printf("%d\n", p.sum());
    return 0;
}
