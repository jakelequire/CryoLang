namespace Pair;

type struct Pair {
    a: int;
    b: int;

    static new(x: int, y: int) -> Pair {
        return Pair { a: x, b: y };
    }

    first(&this) -> int {
        return this.a;
    }

    second(&this) -> int {
        return this.b;
    }

    sum(&this) -> int {
        return this.a + this.b;
    }
}
