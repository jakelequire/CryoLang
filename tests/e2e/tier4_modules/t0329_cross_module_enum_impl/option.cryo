namespace Option;

enum Maybe<T> {
    Some(T);
    None;
}

implement enum Maybe<T> {
    is_some(&this) -> int {
        match (&this) {
            Maybe::Some(_) => { return 1; }
            Maybe::None => { return 0; }
            _ => { return 0; }
        }
    }

    unwrap_or(&this, d: T) -> T {
        match (&this) {
            Maybe::Some(v) => { return v; }
            Maybe::None => { return d; }
            _ => { return d; }
        }
    }
}

function some(val: int) -> Maybe<int> {
    return Maybe::Some(val);
}

function none_int() -> Maybe<int> {
    return Maybe::None;
}
