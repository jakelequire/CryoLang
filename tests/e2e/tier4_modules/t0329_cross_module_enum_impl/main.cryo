// @test: cross_module_enum_impl
// @expect: compile_success
// @mode: project
// @stdout: 1
// @stdout: 0
// @stdout: 42
// @stdout: -1
// @tags: modules, project, generics, enums, implement, cross_module

namespace Main;

import Option;

function main() -> int {
    const a: Option::Maybe<int> = Option::some(42);
    const b: Option::Maybe<int> = Option::none_int();

    printf("%d\n", a.is_some());
    printf("%d\n", b.is_some());
    printf("%d\n", a.unwrap_or(0));
    printf("%d\n", b.unwrap_or(-1));
    return 0;
}
