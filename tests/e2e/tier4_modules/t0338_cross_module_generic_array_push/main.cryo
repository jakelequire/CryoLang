// @test: cross_module_generic_array_push
// @expect: compile_success
// @mode: project
// @stdout: size=2
// @tags: modules, project, generics, cross_module, array_push
// @description: Generic struct method calling .push() on generic-typed array fields during cross-module instantiation

namespace Main;

import Utils;

function main() -> int {
    const bag: Utils::Bag<int> = Utils::Bag<int>::new();
    bag.add(42);
    bag.add(99);
    printf("size=%d\n", bag.size);
    return 0;
}
