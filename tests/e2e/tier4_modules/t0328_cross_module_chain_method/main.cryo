// @stdout: 200
// @stdout: 10
// @stdout: 20
// @tags: modules, project, methods, chaining, cross_module, nested

namespace Main;

import Types;

function main() -> int {
    const r: Types::Rect = Types::Rect::new(10, 20, 10, 20);
    printf("%d\n", r.area());
    printf("%d\n", r.origin_x());
    printf("%d\n", r.origin_y());
    return 0;
}
