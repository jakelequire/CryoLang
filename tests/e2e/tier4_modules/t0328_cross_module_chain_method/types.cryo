namespace Types;

type struct Point {
    x: int;
    y: int;

    static new(x: int, y: int) -> Point {
        return Point { x: x, y: y };
    }

    get_x(&this) -> int {
        return this.x;
    }

    get_y(&this) -> int {
        return this.y;
    }
}

type struct Rect {
    origin: Point;
    size: Point;

    static new(ox: int, oy: int, w: int, h: int) -> Rect {
        return Rect { origin: Point::new(ox, oy), size: Point::new(w, h) };
    }

    area(&this) -> int {
        return this.size.get_x() * this.size.get_y();
    }

    origin_x(&this) -> int {
        return this.origin.get_x();
    }

    origin_y(&this) -> int {
        return this.origin.get_y();
    }
}
