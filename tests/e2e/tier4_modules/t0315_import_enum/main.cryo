// @test: import_enum
// @expect: compile_success
// @mode: project
// @stdout: red
// @tags: modules, project, import, enums, match

namespace Main;

import Colors;

function main() -> int {
    const c: Colors::Color = Colors::Color::Red;
    match (c) {
        Colors::Color::Red => {
            printf("red\n");
        },
        Colors::Color::Green => {
            printf("green\n");
        },
        Colors::Color::Blue => {
            printf("blue\n");
        },
    }
    return 0;
}
