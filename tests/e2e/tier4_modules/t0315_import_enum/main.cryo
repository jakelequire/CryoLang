// @test: import_enum
// @expect: compile_success
// @mode: project
// @stdout: red
// @tags: modules, project, import, enums, match

namespace Main;

import Colors::Color;

function main() -> int {
    const c: Color = Color::Red;
    match (c) {
        Color::Red => {
            printf("red\n");
        },
        Color::Green => {
            printf("green\n");
        },
        Color::Blue => {
            printf("blue\n");
        },
    }
    return 0;
}
