// @test: import_generic_struct
// @expect: compile_success
// @mode: project
// @stdout: 10
// @stdout: hello
// @tags: modules, project, generics, structs

namespace Main;

import Containers;

function main() -> int {
    const a: Containers::Box<int> = Containers::Box<int>::new(10);
    const b: Containers::Box<string> = Containers::Box<string>::new("hello");
    printf("%d\n", a.get());
    printf("%s\n", b.get());
    return 0;
}
