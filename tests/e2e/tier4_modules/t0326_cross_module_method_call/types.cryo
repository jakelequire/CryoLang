namespace Types;

type struct Counter {
    value: int;

    static new(init: int) -> Counter {
        return Counter { value: init };
    }

    get(&this) -> int {
        return this.value;
    }

    increment(mut &this) -> void {
        this.value = this.value + 1;
    }

    add(mut &this, n: int) -> void {
        this.value = this.value + n;
    }

    is_zero(&this) -> int {
        if (this.value == 0) {
            return 1;
        }
        return 0;
    }
}
