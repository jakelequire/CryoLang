// @test: cross_module_method_call
// @expect: compile_success
// @mode: project
// @stdout: 0
// @stdout: 1
// @stdout: 5
// @stdout: 15
// @tags: modules, project, methods, cross_module

namespace Main;

import Types;

function main() -> int {
    mut c: Types::Counter = Types::Counter::new(0);
    printf("%d\n", c.get());
    printf("%d\n", c.is_zero());
    c.add(5);
    printf("%d\n", c.get());
    c.add(10);
    printf("%d\n", c.get());
    return 0;
}
