// @test: stdlib_result_unwrap_or
// @expect: compile_success
// @mode: stdlib
// @description: Result unwrap_or and expect
// @tags: stdlib, result
// @stdout: unwrap_or ok: ok
// @stdout: unwrap_or err: ok
// @stdout: expect: ok

namespace ResultUnwrapOr;

function main() -> i32 {
    const ok_val: Result<i64, string> = Result<i64, string>::Ok(42);
    const err_val: Result<i64, string> = Result<i64, string>::Err("failed");

    const a: i64 = ok_val.unwrap_or(0);
    assert(a == 42, "unwrap_or on Ok should return inner value");
    println("unwrap_or ok: ok");

    const b: i64 = err_val.unwrap_or(99);
    assert(b == 99, "unwrap_or on Err should return default");
    println("unwrap_or err: ok");

    const c: i64 = ok_val.expect("should not panic");
    assert(c == 42, "expect on Ok should return inner value");
    println("expect: ok");

    return 0;
}
