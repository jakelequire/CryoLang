// @test: stdlib_option_unwrap_or
// @expect: compile_success
// @mode: stdlib
// @description: Option unwrap_or and expect
// @tags: stdlib, option
// @stdout: unwrap_or some: ok
// @stdout: unwrap_or none: ok
// @stdout: expect: ok

namespace OptionUnwrapOr;

function main() -> i32 {
    const some_val: Option<i64> = some<i64>(42);
    const none_val: Option<i64> = none<i64>();

    const a: i64 = some_val.unwrap_or(0);
    assert(a == 42, "unwrap_or on Some should return inner value");
    println("unwrap_or some: ok");

    const b: i64 = none_val.unwrap_or(99);
    assert(b == 99, "unwrap_or on None should return default");
    println("unwrap_or none: ok");

    const c: i64 = some_val.expect("should not panic");
    assert(c == 42, "expect on Some should return inner value");
    println("expect: ok");

    return 0;
}
