// @test: stdlib_result_ok_err
// @expect: compile_success
// @mode: stdlib
// @description: Result Ok and Err basics
// @tags: stdlib, result
// @stdout: is_ok: ok
// @stdout: is_err: ok
// @stdout: unwrap: ok

namespace ResultOkErr;

function main() -> i32 {
    const ok_val: Result<i64, string> = Result<i64, string>::Ok(42);
    assert(ok_val.is_ok(), "Ok should be ok");
    assert(!ok_val.is_err(), "Ok should not be err");
    println("is_ok: ok");

    const err_val: Result<i64, string> = Result<i64, string>::Err("something failed");
    assert(err_val.is_err(), "Err should be err");
    assert(!err_val.is_ok(), "Err should not be ok");
    println("is_err: ok");

    const val: i64 = ok_val.unwrap();
    assert(val == 42, "unwrap should return 42");
    println("unwrap: ok");

    return 0;
}
