// @test: stdlib_result_ok_err_convert
// @expect: compile_success
// @mode: stdlib
// @description: Result::ok() and Result::err() conversion to Option
// @tags: stdlib, result, option
// @stdout: ok to option: ok
// @stdout: err to option: ok
// @stdout: ok err none: ok

namespace ResultOkErrConvert;

function main() -> i32 {
    const ok_val: Result<i64, string> = Result<i64, string>::Ok(42);
    const err_val: Result<i64, string> = Result<i64, string>::Err("failed");

    const opt_ok: Option<i64> = ok_val.ok();
    assert(opt_ok.is_some(), "Ok.ok() should be Some");
    assert(opt_ok.unwrap() == 42, "Ok.ok() should contain 42");
    println("ok to option: ok");

    const opt_err: Option<string> = err_val.err();
    assert(opt_err.is_some(), "Err.err() should be Some");
    println("err to option: ok");

    const opt_ok_none: Option<i64> = err_val.ok();
    assert(opt_ok_none.is_none(), "Err.ok() should be None");
    const opt_err_none: Option<string> = ok_val.err();
    assert(opt_err_none.is_none(), "Ok.err() should be None");
    println("ok err none: ok");

    return 0;
}
