// @test: stdlib_string_find_replace
// @expect: compile_success
// @mode: stdlib
// @description: String find, replace, count, substr
// @tags: stdlib, string
// @stdout: find: ok
// @stdout: count: ok
// @stdout: hello universe
// @stdout: replace: ok

namespace StringFindReplace;

function main() -> i32 {
    const s: String = String::from_cstr("hello world hello");

    const pos: Option<u64> = s.find("world");
    assert(pos.is_some(), "find should return Some");
    const idx: u64 = pos.unwrap();
    assert(idx == 6, "world should be at index 6");
    println("find: ok");

    const c: u64 = s.count("hello");
    assert(c == 2, "should count 2 occurrences of hello");
    println("count: ok");

    const s2: String = String::from_cstr("hello world");
    const replaced: String = s2.replace("world", "universe");
    println(replaced.as_cstr());
    assert(replaced.len() == 14, "replaced string should be 14 chars");
    println("replace: ok");

    return 0;
}
