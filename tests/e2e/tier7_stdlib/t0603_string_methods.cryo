// @test: stdlib_string_methods
// @expect: compile_success
// @mode: stdlib
// @description: String searching and transformation methods
// @tags: stdlib, string
// @stdout: HELLO WORLD
// @stdout: hello world
// @stdout: contains: ok
// @stdout: starts_with: ok
// @stdout: ends_with: ok

namespace StringMethods;

function main() -> i32 {
    const s: String = String::from_cstr("Hello World");

    const upper: String = s.to_uppercase();
    println(upper.as_cstr());

    const lower: String = s.to_lowercase();
    println(lower.as_cstr());

    assert(s.contains("World"), "should contain World");
    println("contains: ok");

    assert(s.starts_with("Hello"), "should start with Hello");
    println("starts_with: ok");

    assert(s.ends_with("World"), "should end with World");
    println("ends_with: ok");

    return 0;
}
