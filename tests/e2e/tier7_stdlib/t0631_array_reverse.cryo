// @test: stdlib_array_reverse
// @expect: compile_success
// @mode: stdlib
// @description: Array reverse in place
// @tags: stdlib, array
// @stdout: before: ok
// @stdout: reverse: ok
// @stdout: verify: ok

namespace ArrayReverse;

function main() -> i32 {
    mut arr: Array<i64> = Array<i64>::new();
    arr.push(1);
    arr.push(2);
    arr.push(3);
    arr.push(4);

    const f: Option<i64> = arr.first();
    assert(f.unwrap() == 1, "first should be 1 before reverse");
    println("before: ok");

    arr.reverse();
    println("reverse: ok");

    const f2: Option<i64> = arr.get(0);
    assert(f2.unwrap() == 4, "first should be 4 after reverse");
    const l2: Option<i64> = arr.get(3);
    assert(l2.unwrap() == 1, "last should be 1 after reverse");
    println("verify: ok");

    return 0;
}
