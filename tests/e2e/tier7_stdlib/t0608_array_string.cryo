// @test: stdlib_array_string
// @expect: compile_success
// @mode: stdlib
// @description: Array of String values
// @tags: stdlib, array, string
// @stdout: hello
// @stdout: world
// @stdout: count: ok

namespace ArrayString;

function main() -> i32 {
    mut arr: Array<String> = Array<String>::new();

    const s1: String = String::from_cstr("hello");
    const s2: String = String::from_cstr("world");
    arr.push(s1);
    arr.push(s2);

    assert(arr.len() == 2, "should have 2 strings");

    const first: Option<String> = arr.get(0);
    const v0: String = first.unwrap();
    println(v0.as_cstr());

    const second: Option<String> = arr.get(1);
    const v1: String = second.unwrap();
    println(v1.as_cstr());

    println("count: ok");

    return 0;
}
