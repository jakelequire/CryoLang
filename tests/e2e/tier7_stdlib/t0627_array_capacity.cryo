// @test: stdlib_array_capacity
// @expect: compile_success
// @mode: stdlib
// @description: Array capacity management
// @tags: stdlib, array
// @stdout: with_capacity: ok
// @stdout: reserve: ok
// @stdout: capacity: ok

namespace ArrayCapacity;

function main() -> i32 {
    mut arr: Array<i64> = Array<i64>::with_capacity(16);
    assert(arr.capacity() >= 16, "capacity should be at least 16");
    assert(arr.len() == 0, "len should be 0");
    println("with_capacity: ok");

    arr.push(1);
    arr.push(2);
    arr.reserve(100);
    assert(arr.capacity() >= 102, "capacity should be at least 102 after reserve");
    assert(arr.len() == 2, "len should still be 2");
    println("reserve: ok");

    const cap: u64 = arr.capacity();
    assert(cap > 0, "capacity should be positive");
    println("capacity: ok");

    return 0;
}
