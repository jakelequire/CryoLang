// @test: stdlib_string_new
// @expect: compile_success
// @mode: stdlib
// @description: String construction, len, is_empty, as_cstr
// @tags: stdlib, string
// @stdout: empty: ok
// @stdout: hello
// @stdout: from_cstr: ok

namespace StringNew;

function main() -> i32 {
    const s: String = String::new();
    assert(s.len() == 0, "empty string should have len 0");
    assert(s.is_empty(), "empty string should be empty");
    println("empty: ok");

    const s2: String = String::from_cstr("hello");
    println(s2.as_cstr());
    assert(s2.len() == 5, "from_cstr len should be 5");
    assert(!s2.is_empty(), "from_cstr should not be empty");
    println("from_cstr: ok");

    return 0;
}
