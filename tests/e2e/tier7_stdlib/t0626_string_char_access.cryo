// @test: stdlib_string_char_access
// @expect: compile_success
// @mode: stdlib
// @description: String byte_at and nth_char access
// @tags: stdlib, string
// @stdout: byte_at: ok
// @stdout: nth_char: ok
// @stdout: char_count: ok

namespace StringCharAccess;

function main() -> i32 {
    const s: String = String::from_cstr("Hello");

    const b: Option<u8> = s.byte_at(0);
    assert(b.is_some(), "byte_at(0) should be Some");
    const byte_val: u8 = b.unwrap();
    assert(byte_val == 72, "byte_at(0) should be 72 (H)");
    println("byte_at: ok");

    const c: Option<char> = s.nth_char(1);
    assert(c.is_some(), "nth_char(1) should be Some");
    println("nth_char: ok");

    const count: u64 = s.char_count();
    assert(count == 5, "char_count should be 5");
    println("char_count: ok");

    return 0;
}
