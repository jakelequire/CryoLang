// @test: stdlib_string_compare
// @expect: compile_success
// @mode: stdlib
// @description: String comparison methods
// @tags: stdlib, string
// @stdout: equal: ok
// @stdout: less: ok
// @stdout: compare_cstr: ok

namespace StringCompare;

function main() -> i32 {
    const a: String = String::from_cstr("apple");
    const b: String = String::from_cstr("apple");
    const c: String = String::from_cstr("banana");

    const cmp1: i32 = a.compare(b);
    assert(cmp1 == 0, "equal strings should compare to 0");
    println("equal: ok");

    const cmp2: i32 = a.compare(c);
    assert(cmp2 < 0, "apple should be less than banana");
    println("less: ok");

    const cmp3: i32 = a.compare_cstr("apple");
    assert(cmp3 == 0, "compare_cstr should match");
    println("compare_cstr: ok");

    return 0;
}
