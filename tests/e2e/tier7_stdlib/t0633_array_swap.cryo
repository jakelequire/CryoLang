// @test: stdlib_array_swap
// @expect: compile_success
// @mode: stdlib
// @description: Array swap two elements
// @tags: stdlib, array
// @stdout: before: ok
// @stdout: swap: ok

namespace ArraySwap;

function main() -> i32 {
    mut arr: Array<i64> = Array<i64>::new();
    arr.push(10);
    arr.push(20);
    arr.push(30);

    const a: Option<i64> = arr.get(0);
    const b: Option<i64> = arr.get(2);
    assert(a.unwrap() == 10, "arr[0] should be 10");
    assert(b.unwrap() == 30, "arr[2] should be 30");
    println("before: ok");

    arr.swap(0, 2);

    const c: Option<i64> = arr.get(0);
    const d: Option<i64> = arr.get(2);
    assert(c.unwrap() == 30, "arr[0] should be 30 after swap");
    assert(d.unwrap() == 10, "arr[2] should be 10 after swap");
    println("swap: ok");

    return 0;
}
