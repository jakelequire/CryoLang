// @test: stdlib_box_basic
// @expect: compile_success
// @mode: stdlib
// @description: Box heap allocation basics
// @tags: stdlib, box
// @stdout: deref: ok
// @stdout: get: ok

namespace BoxBasic;

function main() -> i32 {
    const b: Box<i64> = Box<i64>::new(42);

    const val: i64 = b.deref();
    assert(val == 42, "deref should return 42");
    println("deref: ok");

    const ptr: i64* = b.get();
    assert(ptr != null, "get should return non-null pointer");
    println("get: ok");

    return 0;
}
