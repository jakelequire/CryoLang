// @test: stdlib_min_max_clamp
// @expect: compile_success
// @mode: stdlib
// @description: Prelude generic min, max, clamp utilities
// @tags: stdlib, generics, utilities
// @stdout: min: ok
// @stdout: max: ok
// @stdout: clamp: ok

namespace MinMaxClamp;

function main() -> i32 {
    const a: i64 = min<i64>(3, 7);
    assert(a == 3, "min(3, 7) should be 3");
    const b: i64 = min<i64>(10, 2);
    assert(b == 2, "min(10, 2) should be 2");
    println("min: ok");

    const c: i64 = max<i64>(3, 7);
    assert(c == 7, "max(3, 7) should be 7");
    const d: i64 = max<i64>(10, 2);
    assert(d == 10, "max(10, 2) should be 10");
    println("max: ok");

    const e: i64 = clamp<i64>(5, 1, 10);
    assert(e == 5, "clamp(5, 1, 10) should be 5");
    const f: i64 = clamp<i64>(-3, 0, 100);
    assert(f == 0, "clamp(-3, 0, 100) should be 0");
    const g: i64 = clamp<i64>(200, 0, 100);
    assert(g == 100, "clamp(200, 0, 100) should be 100");
    println("clamp: ok");

    return 0;
}
