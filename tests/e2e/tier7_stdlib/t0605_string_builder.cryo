// @test: stdlib_string_builder
// @expect: compile_success
// @mode: stdlib
// @description: StringBuilder construction and building
// @tags: stdlib, string, string_builder
// @stdout: Hello, World!
// @stdout: build: ok

namespace StringBuilderTest;

// StringBuilder is available via prelude (collections::string re-export)

function main() -> i32 {
    mut sb: StringBuilder = StringBuilder::new();
    sb.append("Hello, ");
    sb.append("World!");
    const result: String = sb.build();

    println(result.as_cstr());

    assert(result.len() == 13, "built string should be 13 chars");
    println("build: ok");

    return 0;
}
