// @test: stdlib_array_sort
// @expect: compile_success
// @mode: stdlib
// @description: Array sort and is_sorted
// @tags: stdlib, array, sort
// @stdout: unsorted: ok
// @stdout: sorted: ok
// @stdout: is_sorted: ok

namespace ArraySort;

function main() -> i32 {
    mut arr: Array<i64> = Array<i64>::new();
    arr.push(30);
    arr.push(10);
    arr.push(20);

    assert(!arr.is_sorted(), "unsorted array should not be sorted");
    println("unsorted: ok");

    arr.sort();
    println("sorted: ok");

    assert(arr.is_sorted(), "array should be sorted after sort");

    const first: Option<i64> = arr.get(0);
    const v0: i64 = first.unwrap();
    assert(v0 == 10, "first element should be 10");

    const last: Option<i64> = arr.get(2);
    const v2: i64 = last.unwrap();
    assert(v2 == 30, "last element should be 30");
    println("is_sorted: ok");

    return 0;
}
