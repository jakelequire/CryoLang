// @test: stdlib_array_index_of
// @expect: compile_success
// @mode: stdlib
// @description: Array index_of and last_index_of
// @tags: stdlib, array, option
// @stdout: index_of: ok
// @stdout: last_index_of: ok
// @stdout: not_found: ok

namespace ArrayIndexOf;

function main() -> i32 {
    mut arr: Array<i64> = Array<i64>::new();
    arr.push(10);
    arr.push(20);
    arr.push(30);
    arr.push(20);

    const idx: Option<u64> = arr.index_of(20);
    assert(idx.is_some(), "index_of(20) should be Some");
    assert(idx.unwrap() == 1, "first 20 should be at index 1");
    println("index_of: ok");

    const last_idx: Option<u64> = arr.last_index_of(20);
    assert(last_idx.is_some(), "last_index_of(20) should be Some");
    assert(last_idx.unwrap() == 3, "last 20 should be at index 3");
    println("last_index_of: ok");

    const missing: Option<u64> = arr.index_of(99);
    assert(missing.is_none(), "index_of(99) should be None");
    println("not_found: ok");

    return 0;
}
