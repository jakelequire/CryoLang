// @test: stdlib_math_basic
// @expect: compile_success
// @mode: stdlib
// @description: Basic math functions from the math module
// @tags: stdlib, math
// @stdout: abs: ok
// @stdout: floor: ok
// @stdout: ceil: ok
// @stdout: sqrt: ok

namespace MathBasic;

import math;

function main() -> i32 {
    const a: f64 = math::abs(-5.0);
    assert(a == 5.0, "abs(-5.0) should be 5.0");
    println("abs: ok");

    const f: f64 = math::floor(3.7);
    assert(f == 3.0, "floor(3.7) should be 3.0");
    println("floor: ok");

    const c: f64 = math::ceil(3.2);
    assert(c == 4.0, "ceil(3.2) should be 4.0");
    println("ceil: ok");

    const s: f64 = math::sqrt(9.0);
    assert(s == 3.0, "sqrt(9.0) should be 3.0");
    println("sqrt: ok");

    return 0;
}
