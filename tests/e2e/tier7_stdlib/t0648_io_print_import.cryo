// @test: stdlib_io_print_import
// @expect: compile_success
// @mode: stdlib
// @description: print and println with explicit io::stdio import
// @tags: stdlib, io, print
// @stdout: Hello, World!

namespace IoPrintImport;

import io::stdio;

function main() -> i32 {
    print("Hello, ");
    println("World!");
    return 0;
}
