// @test: stdlib_string_push_pop
// @expect: compile_success
// @mode: stdlib
// @description: String mutation with push_char, push, and pop
// @tags: stdlib, string, mutation
// @stdout: push_char: ok
// @stdout: push: ok
// @stdout: pop: ok

namespace StringPushPop;

function main() -> i32 {
    mut s: String = String::new();
    s.push_char('H');
    s.push_char('i');
    assert(s.len() == 2, "len should be 2 after push_char");
    println("push_char: ok");

    s.push(" world");
    assert(s.len() == 8, "len should be 8 after push");
    println("push: ok");

    const c: Option<char> = s.pop();
    assert(c.is_some(), "pop should return Some");
    assert(s.len() == 7, "len should be 7 after pop");
    println("pop: ok");

    return 0;
}
