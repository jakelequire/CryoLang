// @test: stdlib_string_repeat
// @expect: compile_success
// @mode: stdlib
// @description: String::repeat creates repeated copies
// @tags: stdlib, string
// @stdout: abcabcabc
// @stdout: repeat: ok
// @stdout: empty repeat: ok

namespace StringRepeat;

function main() -> i32 {
    const s: String = String::from_cstr("abc");
    const repeated: String = s.repeat(3);
    println(repeated.as_cstr());
    assert(repeated.len() == 9, "repeated should have len 9");
    println("repeat: ok");

    const zero: String = s.repeat(0);
    assert(zero.len() == 0, "repeat(0) should be empty");
    println("empty repeat: ok");

    return 0;
}
