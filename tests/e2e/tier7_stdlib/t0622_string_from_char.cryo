// @test: stdlib_string_from_char
// @expect: compile_success
// @mode: stdlib
// @description: String::from_char and from_char_repeated
// @tags: stdlib, string
// @stdout: from_char: ok
// @stdout: aaaaa
// @stdout: repeated: ok

namespace StringFromChar;

function main() -> i32 {
    const s: String = String::from_char('X');
    assert(s.len() == 1, "from_char should have len 1");
    println("from_char: ok");

    const repeated: String = String::from_char_repeated('a', 5);
    println(repeated.as_cstr());
    assert(repeated.len() == 5, "repeated should have len 5");
    println("repeated: ok");

    return 0;
}
