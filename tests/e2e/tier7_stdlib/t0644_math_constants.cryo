// @test: stdlib_math_constants
// @expect: compile_success
// @mode: stdlib
// @description: Math module constants
// @tags: stdlib, math
// @stdout: E: ok
// @stdout: SQRT_2: ok
// @stdout: LN_2: ok
// @stdout: int_max: ok

namespace MathConstants;

import math;

function main() -> i32 {
    const e: f64 = math::E;
    assert(e > 2.71, "E should be > 2.71");
    assert(e < 2.72, "E should be < 2.72");
    println("E: ok");

    const s: f64 = math::SQRT_2;
    assert(s > 1.41, "SQRT_2 should be > 1.41");
    assert(s < 1.42, "SQRT_2 should be < 1.42");
    println("SQRT_2: ok");

    const l: f64 = math::LN_2;
    assert(l > 0.69, "LN_2 should be > 0.69");
    assert(l < 0.70, "LN_2 should be < 0.70");
    println("LN_2: ok");

    const i_max: i32 = math::I32_MAX;
    assert(i_max == 2147483647, "I32_MAX should be 2147483647");
    println("int_max: ok");

    return 0;
}
