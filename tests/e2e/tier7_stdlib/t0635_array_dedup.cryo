// @test: stdlib_array_dedup
// @expect: compile_success
// @mode: stdlib
// @description: Array dedup removes consecutive duplicates
// @tags: stdlib, array
// @stdout: sorted: ok
// @stdout: dedup: ok

namespace ArrayDedup;

function main() -> i32 {
    mut arr: Array<i64> = Array<i64>::new();
    arr.push(3);
    arr.push(1);
    arr.push(2);
    arr.push(1);
    arr.push(3);

    arr.sort();
    assert(arr.is_sorted(), "should be sorted");
    println("sorted: ok");

    arr.dedup();
    assert(arr.len() == 3, "should have 3 unique elements after dedup");
    const v0: Option<i64> = arr.get(0);
    const v1: Option<i64> = arr.get(1);
    const v2: Option<i64> = arr.get(2);
    assert(v0.unwrap() == 1, "first should be 1");
    assert(v1.unwrap() == 2, "second should be 2");
    assert(v2.unwrap() == 3, "third should be 3");
    println("dedup: ok");

    return 0;
}
