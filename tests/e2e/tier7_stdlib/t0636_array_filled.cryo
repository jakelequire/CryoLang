// @test: stdlib_array_filled
// @expect: compile_success
// @mode: stdlib
// @description: Array::filled creates n copies of a value
// @tags: stdlib, array
// @stdout: filled: ok
// @stdout: values: ok

namespace ArrayFilled;

function main() -> i32 {
    const arr: Array<i64> = Array<i64>::filled(5, 42);
    assert(arr.len() == 5, "filled array should have len 5");
    println("filled: ok");

    const v0: Option<i64> = arr.get(0);
    const v4: Option<i64> = arr.get(4);
    assert(v0.unwrap() == 42, "first should be 42");
    assert(v4.unwrap() == 42, "last should be 42");
    println("values: ok");

    return 0;
}
