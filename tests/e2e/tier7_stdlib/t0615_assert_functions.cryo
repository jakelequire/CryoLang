// @test: stdlib_assert_functions
// @expect: compile_success
// @mode: stdlib
// @description: Prelude assertion functions
// @tags: stdlib, assert
// @stdout: assert: ok
// @stdout: assert_eq: ok
// @stdout: assert_ne: ok

namespace AssertFunctions;

function main() -> i32 {
    assert(true, "true should be true");
    assert(1 + 1 == 2, "1 + 1 should equal 2");
    println("assert: ok");

    assert_eq<i64>(10, 10, "10 should equal 10");
    assert_eq<boolean>(true, true, "true should equal true");
    println("assert_eq: ok");

    assert_ne<i64>(10, 20, "10 should not equal 20");
    assert_ne<boolean>(true, false, "true should not equal false");
    println("assert_ne: ok");

    return 0;
}
