// @test: stdlib_string_lines
// @expect: compile_success
// @mode: stdlib
// @description: String::lines splits by newline
// @tags: stdlib, string, array
// @stdout: line count: ok
// @stdout: first
// @stdout: second

namespace StringLines;

function main() -> i32 {
    const s: String = String::from_cstr("first\nsecond\nthird");
    const lines: Array<String> = s.lines();

    assert(lines.len() == 3, "should have 3 lines");
    println("line count: ok");

    const l0: Option<String> = lines.get(0);
    const line0: String = l0.unwrap();
    println(line0.as_cstr());

    const l1: Option<String> = lines.get(1);
    const line1: String = l1.unwrap();
    println(line1.as_cstr());

    return 0;
}
