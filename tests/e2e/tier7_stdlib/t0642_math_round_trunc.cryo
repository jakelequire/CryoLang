// @test: stdlib_math_round_trunc
// @expect: compile_success
// @mode: stdlib
// @description: Math round, trunc, and fract
// @tags: stdlib, math
// @stdout: round: ok
// @stdout: trunc: ok
// @stdout: fract: ok

namespace MathRoundTrunc;

import math;

function main() -> i32 {
    const r: f64 = math::round(3.7);
    assert(r == 4.0, "round(3.7) should be 4.0");
    const r2: f64 = math::round(3.2);
    assert(r2 == 3.0, "round(3.2) should be 3.0");
    println("round: ok");

    const t: f64 = math::trunc(3.9);
    assert(t == 3.0, "trunc(3.9) should be 3.0");
    const t2: f64 = math::trunc(-3.9);
    assert(t2 == -3.0, "trunc(-3.9) should be -3.0");
    println("trunc: ok");

    const f: f64 = math::fract(3.75);
    assert(f > 0.74, "fract(3.75) should be ~0.75");
    assert(f < 0.76, "fract(3.75) should be ~0.75");
    println("fract: ok");

    return 0;
}
