// @test: stdlib_math_trig
// @expect: compile_success
// @mode: stdlib
// @description: Trigonometric functions and PI constant
// @tags: stdlib, math
// @stdout: pi: ok
// @stdout: sin: ok
// @stdout: cos: ok

namespace MathTrig;

import math;

function main() -> i32 {
    const pi: f64 = math::PI;
    assert(pi > 3.14, "PI should be > 3.14");
    assert(pi < 3.15, "PI should be < 3.15");
    println("pi: ok");

    const s: f64 = math::sin(0.0);
    assert(s == 0.0, "sin(0) should be 0");
    println("sin: ok");

    const c: f64 = math::cos(0.0);
    assert(c == 1.0, "cos(0) should be 1");
    println("cos: ok");

    return 0;
}
