// @test: stdlib_string_split
// @expect: compile_success
// @mode: stdlib
// @description: String split and trim operations
// @tags: stdlib, string, array
// @stdout: hello
// @stdout: world
// @stdout: split count: ok
// @stdout: trim: ok

namespace StringSplit;

function main() -> i32 {
    const s: String = String::from_cstr("hello,world");
    const parts: Array<String> = s.split(",");

    assert(parts.len() == 2, "split should produce 2 parts");

    const first: Option<String> = parts.get(0);
    const p0: String = first.unwrap();
    println(p0.as_cstr());

    const second: Option<String> = parts.get(1);
    const p1: String = second.unwrap();
    println(p1.as_cstr());

    println("split count: ok");

    const padded: String = String::from_cstr("  trimmed  ");
    const trimmed: String = padded.trim();
    assert(trimmed.len() == 7, "trimmed len should be 7");
    println("trim: ok");

    return 0;
}
