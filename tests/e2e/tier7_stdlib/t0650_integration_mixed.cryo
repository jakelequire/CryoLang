// @test: stdlib_integration_mixed
// @expect: compile_success
// @mode: stdlib
// @description: Integration test using multiple stdlib types together
// @tags: stdlib, integration, string, array, option
// @stdout: array of strings: ok
// @stdout: search: ok
// @stdout: option chain: ok
// @stdout: all done

namespace IntegrationMixed;

function main() -> i32 {
    mut names: Array<String> = Array<String>::new();
    names.push(String::from_cstr("alice"));
    names.push(String::from_cstr("bob"));
    names.push(String::from_cstr("charlie"));
    assert(names.len() == 3, "should have 3 names");
    println("array of strings: ok");

    const second: Option<String> = names.get(1);
    assert(second.is_some(), "get(1) should be Some");
    const name: String = second.unwrap();
    assert(name.contains("bob"), "second name should be bob");
    assert(name.len() == 3, "bob should have len 3");
    println("search: ok");

    const missing: Option<String> = names.get(10);
    assert(missing.is_none(), "get(10) should be None");
    const fallback: String = missing.unwrap_or(String::from_cstr("unknown"));
    assert(fallback.contains("unknown"), "fallback should be unknown");
    println("option chain: ok");

    println("all done");
    return 0;
}
