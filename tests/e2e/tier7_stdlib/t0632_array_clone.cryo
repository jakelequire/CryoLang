// @test: stdlib_array_clone
// @expect: compile_success
// @mode: stdlib
// @description: Array clone creates an independent copy
// @tags: stdlib, array
// @stdout: clone len: ok
// @stdout: clone values: ok
// @stdout: independent: ok

namespace ArrayClone;

function main() -> i32 {
    mut arr: Array<i64> = Array<i64>::new();
    arr.push(10);
    arr.push(20);
    arr.push(30);

    mut cloned: Array<i64> = arr.clone();
    assert(cloned.len() == 3, "cloned len should be 3");
    println("clone len: ok");

    const v0: Option<i64> = cloned.get(0);
    const v1: Option<i64> = cloned.get(1);
    const v2: Option<i64> = cloned.get(2);
    assert(v0.unwrap() == 10, "cloned[0] should be 10");
    assert(v1.unwrap() == 20, "cloned[1] should be 20");
    assert(v2.unwrap() == 30, "cloned[2] should be 30");
    println("clone values: ok");

    cloned.push(40);
    assert(cloned.len() == 4, "cloned len should be 4 after push");
    assert(arr.len() == 3, "original len should still be 3");
    println("independent: ok");

    return 0;
}
