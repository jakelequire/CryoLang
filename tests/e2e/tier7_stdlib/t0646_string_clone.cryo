// @test: stdlib_string_clone
// @expect: compile_success
// @mode: stdlib
// @description: String::clone creates an independent copy
// @tags: stdlib, string
// @stdout: clone: ok
// @stdout: hello world
// @stdout: independent: ok

namespace StringClone;

function main() -> i32 {
    const s: String = String::from_cstr("hello world");
    const cloned: String = s.clone();

    assert(cloned.len() == s.len(), "cloned len should match");
    println("clone: ok");

    println(cloned.as_cstr());

    assert(cloned.contains("hello"), "clone should contain hello");
    assert(cloned.contains("world"), "clone should contain world");
    println("independent: ok");

    return 0;
}
