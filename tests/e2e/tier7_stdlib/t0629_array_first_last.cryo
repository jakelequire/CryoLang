// @test: stdlib_array_first_last
// @expect: compile_success
// @mode: stdlib
// @description: Array first and last accessors
// @tags: stdlib, array, option
// @stdout: first: ok
// @stdout: last: ok
// @stdout: empty: ok

namespace ArrayFirstLast;

function main() -> i32 {
    mut arr: Array<i64> = Array<i64>::new();
    arr.push(100);
    arr.push(200);
    arr.push(300);

    const f: Option<i64> = arr.first();
    assert(f.is_some(), "first should be Some");
    assert(f.unwrap() == 100, "first should be 100");
    println("first: ok");

    const l: Option<i64> = arr.last();
    assert(l.is_some(), "last should be Some");
    assert(l.unwrap() == 300, "last should be 300");
    println("last: ok");

    mut empty: Array<i64> = Array<i64>::new();
    const ef: Option<i64> = empty.first();
    assert(ef.is_none(), "first of empty should be None");
    const el: Option<i64> = empty.last();
    assert(el.is_none(), "last of empty should be None");
    println("empty: ok");

    return 0;
}
