// @test: stdlib_math_pow_exp
// @expect: compile_success
// @mode: stdlib
// @description: Math pow, exp, and ln functions
// @tags: stdlib, math
// @stdout: pow: ok
// @stdout: exp: ok
// @stdout: ln: ok

namespace MathPowExp;

import math;

function main() -> i32 {
    const p: f64 = math::pow(2.0, 10.0);
    assert(p == 1024.0, "2^10 should be 1024");
    println("pow: ok");

    const e: f64 = math::exp(0.0);
    assert(e == 1.0, "exp(0) should be 1");
    println("exp: ok");

    const l: f64 = math::ln(1.0);
    assert(l == 0.0, "ln(1) should be 0");
    println("ln: ok");

    return 0;
}
