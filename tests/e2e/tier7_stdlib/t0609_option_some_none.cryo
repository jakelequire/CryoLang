// @test: stdlib_option_some_none
// @expect: compile_success
// @mode: stdlib
// @description: Option Some and None basics
// @tags: stdlib, option
// @stdout: is_some: ok
// @stdout: is_none: ok
// @stdout: unwrap: ok

namespace OptionSomeNone;

function main() -> i32 {
    const some_val: Option<i64> = some<i64>(42);
    assert(some_val.is_some(), "Some should be some");
    assert(!some_val.is_none(), "Some should not be none");
    println("is_some: ok");

    const none_val: Option<i64> = none<i64>();
    assert(none_val.is_none(), "None should be none");
    assert(!none_val.is_some(), "None should not be some");
    println("is_none: ok");

    const val: i64 = some_val.unwrap();
    assert(val == 42, "unwrap should return 42");
    println("unwrap: ok");

    return 0;
}
