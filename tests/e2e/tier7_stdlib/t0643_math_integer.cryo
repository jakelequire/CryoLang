// @test: stdlib_math_integer
// @expect: compile_success
// @mode: stdlib
// @description: Math integer functions: gcd, lcm, is_power_of_two
// @tags: stdlib, math
// @stdout: gcd: ok
// @stdout: lcm: ok
// @stdout: power_of_two: ok

namespace MathInteger;

import math;

function main() -> i32 {
    const g: u64 = math::gcd(12, 8);
    assert(g == 4, "gcd(12, 8) should be 4");
    const g2: u64 = math::gcd(17, 13);
    assert(g2 == 1, "gcd(17, 13) should be 1 (coprime)");
    println("gcd: ok");

    const l: u64 = math::lcm(4, 6);
    assert(l == 12, "lcm(4, 6) should be 12");
    println("lcm: ok");

    assert(math::is_power_of_two(8), "8 should be power of two");
    assert(math::is_power_of_two(1), "1 should be power of two");
    assert(!math::is_power_of_two(6), "6 should not be power of two");
    println("power_of_two: ok");

    return 0;
}
