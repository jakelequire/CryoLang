// @test: stdlib_hashmap_basic
// @expect: compile_success
// @mode: stdlib
// @description: HashMap construction, insert, get, contains_key
// @tags: stdlib, hashmap, collections
// @stdout: insert: ok
// @stdout: get: ok
// @stdout: contains_key: ok

namespace HashMapBasic;

import collections::hashmap;

function main() -> i32 {
    mut map: HashMap<string, i64> = HashMap<string, i64>::new();

    const key: string = "count";
    const key_hash: u64 = hash_str(key);
    map.insert(key, 42, key_hash);
    println("insert: ok");

    const result: Option<i64> = map.get(key, key_hash);
    assert(result.is_some(), "get should return Some");
    const val: i64 = result.unwrap();
    assert(val == 42, "get should return 42");
    println("get: ok");

    assert(map.contains_key(key, key_hash), "should contain key");
    assert(!map.contains_key("missing", hash_str("missing")), "should not contain missing key");
    println("contains_key: ok");

    return 0;
}
