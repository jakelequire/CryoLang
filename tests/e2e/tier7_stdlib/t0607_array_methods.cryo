// @test: stdlib_array_methods
// @expect: compile_success
// @mode: stdlib
// @description: Array pop, contains, clear
// @tags: stdlib, array
// @stdout: contains: ok
// @stdout: pop: ok
// @stdout: clear: ok

namespace ArrayMethods;

function main() -> i32 {
    mut arr: Array<i64> = Array<i64>::new();
    arr.push(10);
    arr.push(20);
    arr.push(30);

    assert(arr.contains(20), "should contain 20");
    assert(!arr.contains(99), "should not contain 99");
    println("contains: ok");

    const popped: Option<i64> = arr.pop();
    assert(popped.is_some(), "pop should return Some");
    const pop_val: i64 = popped.unwrap();
    assert(pop_val == 30, "popped value should be 30");
    assert(arr.len() == 2, "len should be 2 after pop");
    println("pop: ok");

    arr.clear();
    assert(arr.is_empty(), "array should be empty after clear");
    assert(arr.len() == 0, "len should be 0 after clear");
    println("clear: ok");

    return 0;
}
