// @test: stdlib_array_basic
// @expect: compile_success
// @mode: stdlib
// @description: Array construction, push, len, get
// @tags: stdlib, array
// @stdout: empty: ok
// @stdout: push: ok
// @stdout: len: ok
// @stdout: get: ok

namespace ArrayBasic;

function main() -> i32 {
    mut arr: Array<i64> = Array<i64>::new();
    assert(arr.is_empty(), "new array should be empty");
    println("empty: ok");

    arr.push(10);
    arr.push(20);
    arr.push(30);
    assert(!arr.is_empty(), "array should not be empty after push");
    println("push: ok");

    assert(arr.len() == 3, "len should be 3");
    println("len: ok");

    const opt: Option<i64> = arr.get(0);
    assert(opt.is_some(), "get(0) should be Some");
    const val: i64 = opt.unwrap();
    assert(val == 10, "get(0) should be 10");
    println("get: ok");

    return 0;
}
