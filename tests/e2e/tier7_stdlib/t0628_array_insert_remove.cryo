// @test: stdlib_array_insert_remove
// @expect: compile_success
// @mode: stdlib
// @description: Array insert and remove at index
// @tags: stdlib, array
// @stdout: insert: ok
// @stdout: remove: ok
// @stdout: final: ok

namespace ArrayInsertRemove;

function main() -> i32 {
    mut arr: Array<i64> = Array<i64>::new();
    arr.push(10);
    arr.push(30);

    arr.insert(1, 20);
    assert(arr.len() == 3, "len should be 3 after insert");
    const mid: Option<i64> = arr.get(1);
    assert(mid.unwrap() == 20, "inserted value should be at index 1");
    println("insert: ok");

    const removed: i64 = arr.remove(1);
    assert(removed == 20, "removed value should be 20");
    assert(arr.len() == 2, "len should be 2 after remove");
    println("remove: ok");

    const first: Option<i64> = arr.get(0);
    const last: Option<i64> = arr.get(1);
    assert(first.unwrap() == 10, "first should be 10");
    assert(last.unwrap() == 30, "last should be 30");
    println("final: ok");

    return 0;
}
