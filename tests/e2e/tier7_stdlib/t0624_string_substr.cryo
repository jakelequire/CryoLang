// @test: stdlib_string_substr
// @expect: compile_success
// @mode: stdlib
// @description: String::substr extraction
// @tags: stdlib, string
// @stdout: world
// @stdout: substr: ok
// @stdout: hel
// @stdout: prefix: ok

namespace StringSubstr;

function main() -> i32 {
    const s: String = String::from_cstr("hello world");

    const sub: String = s.substr(6, 5);
    println(sub.as_cstr());
    assert(sub.len() == 5, "substr should have len 5");
    println("substr: ok");

    const prefix: String = s.substr(0, 3);
    println(prefix.as_cstr());
    assert(prefix.len() == 3, "prefix should have len 3");
    println("prefix: ok");

    return 0;
}
