// @test: stdlib_math_classify
// @expect: compile_success
// @mode: stdlib
// @description: Math classification functions
// @tags: stdlib, math
// @stdout: is_nan: ok
// @stdout: is_infinite: ok
// @stdout: is_finite: ok

namespace MathClassify;

import math;

function main() -> i32 {
    const nan: f64 = math::NAN;
    assert(math::is_nan(nan), "NAN should be nan");
    assert(!math::is_nan(1.0), "1.0 should not be nan");
    println("is_nan: ok");

    const inf: f64 = math::INFINITY;
    assert(math::is_infinite(inf), "INFINITY should be infinite");
    assert(!math::is_infinite(1.0), "1.0 should not be infinite");
    println("is_infinite: ok");

    assert(math::is_finite(1.0), "1.0 should be finite");
    assert(!math::is_finite(inf), "INFINITY should not be finite");
    assert(!math::is_finite(nan), "NAN should not be finite");
    println("is_finite: ok");

    return 0;
}
