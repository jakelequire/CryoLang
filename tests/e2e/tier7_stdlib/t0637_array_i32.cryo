// @test: stdlib_array_i32
// @expect: compile_success
// @mode: stdlib
// @description: Array with i32 element type
// @tags: stdlib, array, generics
// @stdout: push: ok
// @stdout: get: ok
// @stdout: sort: ok

namespace ArrayI32;

function main() -> i32 {
    mut arr: Array<i32> = Array<i32>::new();
    arr.push(50);
    arr.push(10);
    arr.push(30);
    assert(arr.len() == 3, "len should be 3");
    println("push: ok");

    const v: Option<i32> = arr.get(0);
    assert(v.is_some(), "get(0) should be Some");
    assert(v.unwrap() == 50, "get(0) should be 50");
    println("get: ok");

    arr.sort();
    const first: Option<i32> = arr.get(0);
    assert(first.unwrap() == 10, "first after sort should be 10");
    println("sort: ok");

    return 0;
}
