// @test: stdlib_array_resize
// @expect: compile_success
// @mode: stdlib
// @description: Array resize and truncate
// @tags: stdlib, array
// @stdout: resize grow: ok
// @stdout: truncate: ok

namespace ArrayResize;

function main() -> i32 {
    mut arr: Array<i64> = Array<i64>::new();
    arr.push(1);
    arr.push(2);

    arr.resize(5, 0);
    assert(arr.len() == 5, "len should be 5 after resize");
    const v: Option<i64> = arr.get(3);
    assert(v.unwrap() == 0, "new elements should be 0");
    println("resize grow: ok");

    arr.truncate(2);
    assert(arr.len() == 2, "len should be 2 after truncate");
    const f: Option<i64> = arr.get(0);
    assert(f.unwrap() == 1, "first element should still be 1");
    println("truncate: ok");

    return 0;
}
