// @test: stdlib_option_or
// @expect: compile_success
// @mode: stdlib
// @description: Option::or returns the first Some value
// @tags: stdlib, option
// @stdout: some or some: ok
// @stdout: some or none: ok
// @stdout: none or some: ok
// @stdout: none or none: ok

namespace OptionOr;

function main() -> i32 {
    const a: Option<i64> = some<i64>(1);
    const b: Option<i64> = some<i64>(2);
    const n: Option<i64> = none<i64>();
    const n2: Option<i64> = none<i64>();

    const r1: Option<i64> = a.or(b);
    assert(r1.is_some(), "Some.or(Some) should be Some");
    assert(r1.unwrap() == 1, "Some(1).or(Some(2)) should be 1");
    println("some or some: ok");

    const r2: Option<i64> = a.or(n);
    assert(r2.is_some(), "Some.or(None) should be Some");
    assert(r2.unwrap() == 1, "Some(1).or(None) should be 1");
    println("some or none: ok");

    const r3: Option<i64> = n.or(b);
    assert(r3.is_some(), "None.or(Some) should be Some");
    assert(r3.unwrap() == 2, "None.or(Some(2)) should be 2");
    println("none or some: ok");

    const r4: Option<i64> = n.or(n2);
    assert(r4.is_none(), "None.or(None) should be None");
    println("none or none: ok");

    return 0;
}
