// @test: early_return
// @expect: compile_success
// @mode: raw
// @stdout: negative
// @stdout: zero
// @stdout: positive
// @tags: control_flow, return

namespace EarlyReturn;

function classify(n: int) -> void {
    if (n < 0) {
        printf("negative\n");
        return;
    }
    if (n == 0) {
        printf("zero\n");
        return;
    }
    printf("positive\n");
}

function main() -> int {
    classify(-5);
    classify(0);
    classify(10);
    return 0;
}
