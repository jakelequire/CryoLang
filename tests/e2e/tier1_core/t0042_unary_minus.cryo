// @test: unary_minus
// @expect: compile_success
// @mode: raw
// @stdout: -10
// @stdout: 10
// @stdout: -42
// @tags: operators, unary, negation

namespace UnaryMinus;

function negate(x: int) -> int {
    return -x;
}

function main() -> int {
    const a: int = 10;
    printf("%d\n", -a);
    printf("%d\n", negate(-10));
    const b: int = 42;
    printf("%d\n", -b);
    return 0;
}
