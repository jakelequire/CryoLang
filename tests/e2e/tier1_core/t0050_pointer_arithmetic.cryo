// @test: pointer_arithmetic
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: 20
// @stdout: 30
// @tags: pointers, arithmetic, stdlib_bug
// @description: RC8 - Pointer arithmetic (ptr + offset, ptr - ptr) for stack allocator patterns

namespace PtrArith;

function main() -> int {
    const buf: u8* = malloc(256);
    mut offset: u64 = 0;

    // Store integers at different offsets
    const p1: int* = buf + offset;
    *p1 = 10;
    offset = offset + sizeof(int);

    const p2: int* = buf + offset;
    *p2 = 20;
    offset = offset + sizeof(int);

    const p3: int* = buf + offset;
    *p3 = 30;

    printf("%d\n", *p1);
    printf("%d\n", *p2);
    printf("%d\n", *p3);

    free(buf);
    return 0;
}
