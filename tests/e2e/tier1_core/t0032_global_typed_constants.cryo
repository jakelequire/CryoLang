// @test: global_typed_constants
// @expect: compile_success
// @mode: raw
// @stdout: 1000000000
// @stdout: 255
// @tags: constants, types

namespace GlobalTypedConst;

const NANOS_PER_SEC: u64 = 1000000000;
const MAX_BYTE: u8 = 255;

function main() -> int {
    printf("%lu\n", NANOS_PER_SEC);
    printf("%d\n", MAX_BYTE);
    return 0;
}
