// @test: char_arithmetic
// @expect: compile_success
// @mode: raw
// @stdout: 7
// @stdout: 1
// @stdout: 0
// @tags: types, char, arithmetic

namespace CharArith;

function char_to_digit(c: char) -> int {
    return c - '0';
}

function is_digit(c: char) -> int {
    if (c >= '0' && c <= '9') {
        return 1;
    }
    return 0;
}

function main() -> int {
    printf("%d\n", char_to_digit('7'));
    printf("%d\n", is_digit('5'));
    printf("%d\n", is_digit('x'));
    return 0;
}
