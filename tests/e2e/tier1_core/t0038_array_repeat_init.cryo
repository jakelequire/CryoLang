// @test: array_repeat_init
// @expect: compile_success
// @mode: raw
// @stdout: 0
// @stdout: 0
// @stdout: 0
// @stdout: 99
// @tags: arrays, initialization, repeat

namespace ArrRepeatInit;

function main() -> int {
    mut arr: int[5] = [0; 5];
    printf("%d\n", arr[0]);
    printf("%d\n", arr[2]);
    printf("%d\n", arr[4]);
    arr[3] = 99;
    printf("%d\n", arr[3]);
    return 0;
}
