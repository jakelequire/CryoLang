// @test: recursion
// @expect: compile_success
// @mode: raw
// @stdout: 55
// @tags: functions, recursion

namespace Recursion;

function fibonacci(n: int) -> int {
    if (n <= 1) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

function main() -> int {
    const result: int = fibonacci(10);
    printf("%d\n", result);
    return 0;
}
