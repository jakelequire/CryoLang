// @test: pointer_arithmetic_arrays
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: 20
// @stdout: 30
// @tags: pointers, indexing

namespace PtrArith;

function main() -> int {
    mut arr: int[3] = [10, 20, 30];
    const ptr: int* = &arr[0];
    printf("%d\n", ptr[0]);
    printf("%d\n", ptr[1]);
    printf("%d\n", ptr[2]);
    return 0;
}
