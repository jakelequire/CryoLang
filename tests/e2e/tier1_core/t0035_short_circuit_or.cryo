// @test: short_circuit_or
// @expect: compile_success
// @mode: raw
// @stdout: at_least_one
// @stdout: at_least_one
// @stdout: neither
// @tags: logical_ops, control_flow

namespace ShortCircuitOr;

function check(a: int, b: int) -> void {
    if (a > 0 || b > 0) {
        printf("at_least_one\n");
    } else {
        printf("neither\n");
    }
}

function main() -> int {
    check(1, -1);
    check(-1, 1);
    check(-1, -1);
    return 0;
}
