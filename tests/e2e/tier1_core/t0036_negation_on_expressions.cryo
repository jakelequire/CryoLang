namespace NegExpr;

function is_positive(n: int) -> boolean {
    return n > 0;
}

function main() -> int {
    if (!is_positive(-5)) {
        printf("yes\n");
    }
    if (!(3 < 1)) {
        printf("yes\n");
    }
    const val: boolean = false;
    if (!val) {
        printf("yes\n");
    }
    return 0;
}
