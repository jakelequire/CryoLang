// @test: break_continue
// @expect: compile_success
// @mode: raw
// @stdout: 1
// @stdout: 3
// @stdout: 5
// @tags: control_flow, loops

namespace BreakCont;

function main() -> int {
    mut i: int = 0;
    while (i < 10) {
        i = i + 1;
        if (i % 2 == 0) {
            continue;
        }
        if (i > 5) {
            break;
        }
        printf("%d\n", i);
    }
    return 0;
}
