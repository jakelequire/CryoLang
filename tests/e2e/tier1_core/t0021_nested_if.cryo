// @test: nested_if
// @expect: compile_success
// @mode: raw
// @stdout: medium
// @tags: control_flow, if_else

namespace NestedIf;

function main() -> int {
    const x: int = 50;
    if (x > 100) {
        printf("large\n");
    } else if (x > 10) {
        printf("medium\n");
    } else {
        printf("small\n");
    }
    return 0;
}
