// @test: function_multiple_params
// @expect: compile_success
// @mode: raw
// @stdout: 60
// @tags: functions

namespace FuncParams;

function multiply_add(a: int, b: int, c: int) -> int {
    return a * b + c;
}

function main() -> int {
    const result: int = multiply_add(5, 10, 10);
    printf("%d\n", result);
    return 0;
}
