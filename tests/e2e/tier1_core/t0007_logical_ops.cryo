// @test: logical_ops
// @expect: compile_success
// @mode: raw
// @stdout: 1
// @stdout: 1
// @stdout: 0
// @tags: logical, operators
// @xfail: Logical operators with bool cause compiler crash

namespace LogOps;

function main() -> int {
    const a: bool = true;
    const b: bool = false;
    printf("%d\n", a && a);
    printf("%d\n", a || b);
    printf("%d\n", !a);
    return 0;
}
