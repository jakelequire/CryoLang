// @test: mixed_width_arithmetic
// @expect: compile_success
// @mode: raw
// @stdout: 300
// @stdout: 1000
// @tags: types, arithmetic, casting

namespace MixedWidthArith;

function main() -> int {
    const a: u8 = 100;
    const b: u8 = 200;
    const sum: u32 = (a as u32) + (b as u32);
    printf("%u\n", sum);

    const c: u16 = 500;
    const d: u64 = (c as u64) * 2;
    printf("%lu\n", d);
    return 0;
}
