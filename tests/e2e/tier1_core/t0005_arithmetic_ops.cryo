// @expect: compile_success
// @mode: raw
// @stdout: 15
// @stdout: 5
// @stdout: 50
// @stdout: 2
// @tags: arithmetic, operators

namespace ArithOps;

function main() -> int {
    const a: int = 10;
    const b: int = 5;
    printf("%d\n", a + b);
    printf("%d\n", a - b);
    printf("%d\n", a * b);
    printf("%d\n", a / b);
    return 0;
}
