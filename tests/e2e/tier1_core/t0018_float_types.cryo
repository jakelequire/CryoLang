// @mode: raw
// @stdout_contains: 3.14
// @stdout_contains: 2.71
// @tags: types, float
// @xfail: Float types not resolved in raw mode

namespace FloatTypes;

function main() -> int {
    const a: f32 = 3.14;
    const b: f64 = 2.718;
    printf("%.2f\n", a);
    printf("%.2f\n", b);
    return 0;
}
