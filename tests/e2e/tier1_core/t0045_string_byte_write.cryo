// @test: string_byte_write
// @expect: compile_success
// @mode: raw
// @stdout: ABC
// @tags: strings, indexing, mutation

namespace StringByteWrite;

function main() -> int {
    mut buf: u8[4] = [0; 4];
    buf[0] = 65;
    buf[1] = 66;
    buf[2] = 67;
    buf[3] = 0;
    printf("%s\n", &buf[0] as string);
    return 0;
}
