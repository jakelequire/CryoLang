// @expect: compile_success
// @mode: raw
// @stdout: 1
// @stdout: 0
// @stdout: 1
// @stdout: 1
// @tags: comparison, operators

namespace CompOps;

function main() -> int {
    const a: int = 10;
    const b: int = 5;
    printf("%d\n", a > b);
    printf("%d\n", a < b);
    printf("%d\n", a != b);
    printf("%d\n", a >= b);
    return 0;
}
