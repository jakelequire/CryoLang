// @test: char_escape_sequences
// @expect: compile_success
// @mode: raw
// @stdout: 0
// @stdout: 10
// @stdout: 9
// @stdout: 65
// @tags: types, char, escape

namespace CharEscape;

function main() -> int {
    const null_char: char = '\0';
    const newline: char = '\n';
    const tab: char = '\t';
    const letter: char = 'A';
    printf("%d\n", null_char);
    printf("%d\n", newline);
    printf("%d\n", tab);
    printf("%d\n", letter);
    return 0;
}
