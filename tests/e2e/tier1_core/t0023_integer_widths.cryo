// @test: integer_widths
// @expect: compile_success
// @mode: raw
// @stdout: 127
// @stdout: 32000
// @stdout: 100000
// @tags: types, integers

namespace IntWidths;

function main() -> int {
    const a: i8 = 127;
    const b: i16 = 32000;
    const c: i32 = 100000;
    printf("%d\n", a);
    printf("%d\n", b);
    printf("%d\n", c);
    return 0;
}
