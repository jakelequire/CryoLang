// @test: ternary_expression
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: 5
// @stdout: 1
// @tags: expressions, ternary, conditional

namespace TernaryExpr;

function max(a: int, b: int) -> int {
    return a > b ? a : b;
}

function main() -> int {
    printf("%d\n", max(10, 5));
    printf("%d\n", max(3, 5));
    const x: int = 1;
    const result: int = x > 0 ? 1 : 0;
    printf("%d\n", result);
    return 0;
}
