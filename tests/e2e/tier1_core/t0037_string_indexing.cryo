// @test: string_indexing
// @expect: compile_success
// @mode: raw
// @stdout: 72
// @stdout: 101
// @stdout: 111
// @tags: strings, indexing

namespace StringIdx;

function main() -> int {
    const s: string = "Hello";
    const p: u8* = s as u8*;
    printf("%d\n", p[0]);
    printf("%d\n", p[1]);
    printf("%d\n", p[4]);
    return 0;
}
