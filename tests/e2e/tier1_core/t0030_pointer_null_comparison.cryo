// @test: pointer_null_comparison
// @expect: compile_success
// @mode: raw
// @stdout: not_null
// @stdout: is_null
// @tags: pointers, null, comparison

namespace PtrNullCmp;

function check(p: int*) -> void {
    if (p != null) {
        printf("not_null\n");
    } else {
        printf("is_null\n");
    }
}

function main() -> int {
    mut x: int = 42;
    const p: int* = &x;
    const q: int* = null;
    check(p);
    check(q);
    return 0;
}
