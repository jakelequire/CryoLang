// @test: for_loop_continue
// @expect: compile_success
// @mode: raw
// @stdout: 1
// @stdout: 3
// @stdout: 5
// @stdout: 7
// @stdout: 9
// @tags: control_flow, loops, continue

namespace ForContinue;

function main() -> int {
    for (mut i: int = 0; i < 10; i++) {
        if (i % 2 == 0) {
            continue;
        }
        printf("%d\n", i);
    }
    return 0;
}
