// @test: loop_keyword
// @expect: compile_success
// @mode: raw
// @stdout: 0
// @stdout: 1
// @stdout: 2
// @tags: control_flow, loops

namespace LoopKw;

function main() -> int {
    mut i: int = 0;
    loop {
        if (i >= 3) {
            break;
        }
        printf("%d\n", i);
        i = i + 1;
    }
    return 0;
}
