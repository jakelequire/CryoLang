// @test: pointer_comparison_ordering
// @expect: compile_success
// @mode: raw
// @stdout: less
// @tags: pointers, comparison, stdlib_bug
// @description: RC8 - Pointer ordering comparisons (<, >, <=, >=) not supported

namespace PtrCompareOrder;

function main() -> int {
    const buf: u8* = malloc(64);
    const a: u8* = buf;
    const b: u8* = buf + 32;

    if (a < b) {
        printf("less\n");
    } else {
        printf("not_less\n");
    }

    free(buf);
    return 0;
}
