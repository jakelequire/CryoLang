// @test: alignof
// @expect: compile_success
// @mode: raw
// @stdout: Point: (1, 2)
// @stdout: alignof(Point): 4
// @tags: alignof, struct

namespace AlignOfTest;

type struct Point {
    x: int;
    y: int;

    static new(_x: int, _y: int) -> Point {
        return Point { x: _x, y: _y };
    }
}

function main() -> i32 {
    const p: Point = Point::new(1, 2);
    printf("Point: (%d, %d)\n", p.x, p.y);

    printf("alignof(Point): %d\n", alignof(Point));

    return 0;
}
