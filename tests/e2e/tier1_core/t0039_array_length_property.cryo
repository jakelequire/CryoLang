// @test: array_length_property
// @expect: compile_success
// @mode: raw
// @stdout: 3
// @stdout: 5
// @tags: arrays, length, property

namespace ArrLenProp;

function sum(arr: int*, len: int) -> int {
    mut total: int = 0;
    for (mut i: int = 0; i < len; i++) {
        total = total + arr[i];
    }
    return total;
}

function main() -> int {
    const a: int[3] = [10, 20, 30];
    printf("%d\n", a.length);
    const b: int[5] = [1, 2, 3, 4, 5];
    printf("%d\n", b.length);
    return 0;
}
