// @test: bitwise_shift
// @expect: compile_success
// @mode: raw
// @stdout: 8
// @stdout: 2
// @stdout: 240
// @stdout: 15
// @tags: bitwise, operators, shift

namespace BitwiseShift;

function main() -> int {
    const a: int = 1;
    printf("%d\n", a << 3);
    printf("%d\n", a << 3 >> 2);

    const b: int = 0xF;
    printf("%d\n", b << 4);
    printf("%d\n", 240 >> 4);
    return 0;
}
