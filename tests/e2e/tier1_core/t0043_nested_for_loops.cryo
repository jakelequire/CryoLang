// @test: nested_for_loops
// @expect: compile_success
// @mode: raw
// @stdout: 0,0
// @stdout: 0,1
// @stdout: 1,0
// @stdout: 1,1
// @stdout: 2,0
// @stdout: 2,1
// @tags: control_flow, loops, nested

namespace NestedForLoops;

function main() -> int {
    for (mut i: int = 0; i < 3; i++) {
        for (mut j: int = 0; j < 2; j++) {
            printf("%d,%d\n", i, j);
        }
    }
    return 0;
}
