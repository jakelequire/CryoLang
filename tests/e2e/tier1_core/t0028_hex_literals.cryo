// @test: hex_literals
// @expect: compile_success
// @mode: raw
// @stdout: 255
// @stdout: 256
// @stdout: 65535
// @stdout: 10
// @tags: literals, hex

namespace HexLiterals;

function main() -> int {
    const a: int = 0xFF;
    const b: int = 0x100;
    const c: int = 0xFFFF;
    const d: int = 0xA;
    printf("%d\n", a);
    printf("%d\n", b);
    printf("%d\n", c);
    printf("%d\n", d);
    return 0;
}
