// @test: bitwise_xor
// @expect: compile_success
// @mode: raw
// @stdout: 6
// @stdout: 0
// @stdout: 15
// @tags: bitwise, operators, xor

namespace BitwiseXor;

function main() -> int {
    const a: int = 5;
    const b: int = 3;
    printf("%d\n", a ^ b);
    printf("%d\n", a ^ a);
    printf("%d\n", 0 ^ 15);
    return 0;
}
