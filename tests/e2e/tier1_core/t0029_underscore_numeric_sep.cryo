// @test: underscore_numeric_sep
// @expect: compile_success
// @mode: raw
// @stdout: 1000000
// @stdout: 1000000000
// @stdout: 1000
// @tags: literals, numeric, underscore

namespace UnderscoreNumSep;

function main() -> int {
    const a: int = 1_000_000;
    const b: i64 = 1_000_000_000;
    const c: int = 1_000;
    printf("%d\n", a);
    printf("%ld\n", b);
    printf("%d\n", c);
    return 0;
}
