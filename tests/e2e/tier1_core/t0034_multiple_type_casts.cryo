// @test: multiple_type_casts
// @expect: compile_success
// @mode: raw
// @stdout: 42
// @stdout: 65
// @stdout: 7
// @tags: types, casting

namespace MultTypeCasts;

function main() -> int {
    const a: i64 = 42;
    const b: i32 = a as i32;
    printf("%d\n", b);

    const c: u8 = 65;
    const d: u32 = c as u32;
    printf("%u\n", d);

    const e: i64 = 7;
    const f: i32 = e as i32;
    printf("%d\n", f);
    return 0;
}
