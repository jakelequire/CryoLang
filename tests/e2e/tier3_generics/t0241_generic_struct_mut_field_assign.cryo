// @test: generic_struct_mut_field_assign
// @expect: compile_success
// @mode: raw
// @stdout: len=0 cap=4
// @stdout: len=3 cap=4
// @tags: generics, structs, mutable, assignment

namespace GenStructMutAssign;

type struct Vec<T> {
    data: T*;
    len: int;
    cap: int;

    static new() -> Vec<T> {
        const cap: int = 4;
        const ptr: T* = malloc(sizeof(T) * cap);
        return Vec { data: ptr, len: 0, cap: cap };
    }

    push(mut &this, item: T) -> void {
        this.data[this.len] = item;
        this.len = this.len + 1;
    }

    get(&this, idx: int) -> T {
        return this.data[idx];
    }

    info(&this) -> void {
        printf("len=%d cap=%d\n", this.len, this.cap);
    }

    drop(mut &this) -> void {
        free(this.data);
    }
}

function main() -> int {
    mut v: Vec<int> = Vec<int>::new();
    v.info();
    v.push(10);
    v.push(20);
    v.push(30);
    v.info();
    v.drop();
    return 0;
}
