// @test: generic_func_multi_types
// @expect: compile_success
// @mode: raw
// @stdout: 5
// @stdout: 3
// @tags: generics, functions, monomorphization

namespace GenFuncMulti;

function min<T>(a: T, b: T) -> T {
    if (a < b) {
        return a;
    }
    return b;
}

function main() -> int {
    const a: int = min<int>(5, 10);
    const b: i32 = min<i32>(3, 7);
    printf("%d\n", a);
    printf("%d\n", b);
    return 0;
}
