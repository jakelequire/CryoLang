// @test: generic_overload_three_variants
// @expect: compile_success
// @mode: raw
// @stdout: 0
// @stdout: 10
// @stdout: 30
// @tags: generics, structs, overload
//
// Tests a generic struct with THREE overloaded static methods (0, 1, 2 params).
// Stresses the overload resolution with more than two variants.

namespace GenOverloadThree;

type struct Vec2<T> {
    x: T;
    y: T;

    static make() -> Vec2<T> {
        return Vec2 { x: 0, y: 0 };
    }

    static make(v: T) -> Vec2<T> {
        return Vec2 { x: v, y: v };
    }

    static make(a: T, b: T) -> Vec2<T> {
        return Vec2 { x: a, y: b };
    }

    sum(&this) -> T {
        return this.x + this.y;
    }
}

function main() -> int {
    const zero: Vec2<int> = Vec2<int>::make();
    printf("%d\n", zero.sum());

    const same: Vec2<int> = Vec2<int>::make(5);
    printf("%d\n", same.sum());

    const diff: Vec2<int> = Vec2<int>::make(10, 20);
    printf("%d\n", diff.sum());

    return 0;
}
