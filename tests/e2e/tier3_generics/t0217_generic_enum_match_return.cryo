// @test: generic_enum_match_return
// @expect: compile_success
// @mode: raw
// @stdout: 42
// @stdout: -1
// @tags: generics, enums, match, return

namespace GenEnumMatchReturn;

enum Maybe<T> {
    Just(T);
    Nothing;
}

implement enum Maybe<T> {
    unwrap_or(&this, default_val: T) -> T {
        match (&this) {
            Maybe::Just(v) => { return v; }
            Maybe::Nothing => { return default_val; }
            _ => { return default_val; }
        }
    }

    is_just(&this) -> int {
        match (&this) {
            Maybe::Just(_) => { return 1; }
            Maybe::Nothing => { return 0; }
            _ => { return 0; }
        }
    }
}

function main() -> int {
    const a: Maybe<int> = Maybe::Just(42);
    const b: Maybe<int> = Maybe::Nothing;
    printf("%d\n", a.unwrap_or(0));
    printf("%d\n", b.unwrap_or(-1));
    return 0;
}
