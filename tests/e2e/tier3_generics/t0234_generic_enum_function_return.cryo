// @test: generic_enum_function_return
// @expect: compile_success
// @mode: raw
// @stdout: ok:42
// @stdout: err:1
// @tags: generics, enums, implement, return
//
// Tests that a generic enum (Result-like) can be returned from a function.
// This exercises the codegen path where the enum variant constructor returns
// a struct type that must match the function's return type.

namespace GenEnumFnReturn;

enum Result<T, E> {
    Ok(T);
    Err(E);
}

implement enum Result<T, E> {
    is_ok(&this) -> int {
        match (&this) {
            Result::Ok(_) => { return 1; }
            Result::Err(_) => { return 0; }
            _ => { return 0; }
        }
    }
}

function make_ok(value: int) -> Result<int, int> {
    return Result::Ok(value);
}

function make_err(code: int) -> Result<int, int> {
    return Result::Err(code);
}

function main() -> int {
    const good: Result<int, int> = make_ok(42);
    const bad: Result<int, int> = make_err(1);

    match (good) {
        Result::Ok(v) => { printf("ok:%d\n", v); }
        Result::Err(e) => { printf("err:%d\n", e); }
        _ => {}
    }
    match (bad) {
        Result::Ok(v) => { printf("ok:%d\n", v); }
        Result::Err(e) => { printf("err:%d\n", e); }
        _ => {}
    }

    return 0;
}
