// @test: type_alias_generic_match
// @expect: compile_success
// @mode: raw
// @stdout: allocated 128 bytes
// @stdout: alloc failed: out of memory
// @tags: generics, types, alias, pointers, match, stdlib_bug
// @description: Isolates E0613 - match expression on variable with generic ptr alias type from function

namespace TypeAliasGenMatch;

type struct AllocError {
    reason: string;

    static new(reason: string) -> AllocError {
        return AllocError { reason: reason };
    }
}

enum Result<T, E> {
    Ok(T);
    Err(E);
}

type AllocResult = Result<void*, AllocError>;

function try_alloc(size: u64) -> AllocResult {
    const ptr: void* = malloc(size);
    if (ptr == null) {
        return Result::Err(AllocError::new("out of memory"));
    }
    return Result::Ok(ptr);
}

function main() -> int {
    const result: AllocResult = try_alloc(128);
    match (result) {
        Result::Ok(ptr) => {
            printf("allocated 128 bytes\n");
            free(ptr);
        }
        Result::Err(e) => {
            printf("alloc failed: %s\n", e.reason);
        }
        _ => {}
    }

    // Simulate failure path
    const err: AllocResult = Result::Err(AllocError::new("out of memory"));
    match (err) {
        Result::Ok(ptr) => {
            printf("unexpected success\n");
        }
        Result::Err(e) => {
            printf("alloc failed: %s\n", e.reason);
        }
        _ => {}
    }
    return 0;
}
