// @test: generic_enum_fn_returning_generic
// @expect: compile_success
// @mode: raw
// @stdout: 42
// @stdout: 99
// @tags: generics, enums, function_type, implement
// @description: Function type parameter whose return type is a generic type (e.g. () -> Maybe<T>)

namespace GenEnumFnRetGeneric;

enum Maybe<T> {
    Just(T);
    Nothing;
}

implement enum Maybe<T> {
    unwrap_or(&this, def: T) -> T {
        match (&this) {
            Maybe::Just(v) => { return v; }
            Maybe::Nothing => { return def; }
        }
    }

    or_else(&this, f: () -> Maybe<T>) -> Maybe<T> {
        match (&this) {
            Maybe::Just(_) => { return this; }
            Maybe::Nothing => { return f(); }
        }
    }
}

function fallback() -> Maybe<int> {
    return Maybe::Just(99);
}

function main() -> int {
    const a: Maybe<int> = Maybe::Just(42);
    const b: Maybe<int> = Maybe::Nothing;

    // a is Just(42), so or_else should return a (42)
    const r1: Maybe<int> = a.or_else(fallback);
    printf("%d\n", r1.unwrap_or(0));

    // b is Nothing, so or_else should call fallback() and return Just(99)
    const r2: Maybe<int> = b.or_else(fallback);
    printf("%d\n", r2.unwrap_or(0));

    return 0;
}
