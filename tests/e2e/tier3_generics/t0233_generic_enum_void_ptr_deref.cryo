// @test: generic_enum_void_ptr_deref
// @expect: compile_success
// @mode: raw
// @stdout: 42
// @tags: generics, enums, void_pointer

namespace GenEnumVoidDeref;

enum Wrapper<T> {
    Some(T);
    None;
}

function wrap<T>(val: T) -> Wrapper<T> {
    return Wrapper::Some(val);
}

function main() -> int {
    const x: int = 42;
    const p: void* = &x;
    const w: Wrapper<void*> = wrap<void*>(p);

    match (w) {
        Wrapper::Some(val) => {
            const ip: int* = val;
            printf("%d\n", *ip);
        }
        Wrapper::None => { printf("none\n"); }
        _ => { printf("error\n"); }
    }
    return 0;
}
