// @test: type_alias_generic_var_init
// @expect: compile_success
// @mode: raw
// @stdout: 42
// @tags: generics, types, alias, pointers, stdlib_bug
// @description: Isolates E0634 - variable with generic alias type initialized from function return

namespace TypeAliasGenVarInit;

enum Result<T, E> {
    Ok(T);
    Err(E);
}

type PtrResult = Result<void*, string>;

function try_alloc(size: u64) -> PtrResult {
    const ptr: void* = malloc(size);
    if (ptr == null) {
        return Result::Err("allocation failed");
    }
    return Result::Ok(ptr);
}

function main() -> int {
    const result: PtrResult = try_alloc(64);
    match (result) {
        Result::Ok(ptr) => {
            const ip: int* = ptr;
            *ip = 42;
            printf("%d\n", *ip);
            free(ptr);
        }
        Result::Err(msg) => {
            printf("error: %s\n", msg);
        }
        _ => {}
    }
    return 0;
}
