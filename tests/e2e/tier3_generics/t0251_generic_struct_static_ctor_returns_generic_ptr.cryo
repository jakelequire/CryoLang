// @test: generic_struct_static_ctor_returns_generic_ptr
// @expect: compile_success
// @mode: raw
// @stdout: 42
// @stdout: 99
// @tags: generics, structs, static, pointer, constructor
// @description: Static constructor on generic struct returning GenericStruct<T>* called from another generic struct's method

namespace GenStructStaticCtorPtr;

type struct Node<T> {
    value: T;
    next: Node<T>*;

    static new(val: T) -> Node<T>* {
        const n: Node<T>* = malloc(sizeof(Node<T>));
        n.value = val;
        n.next = null;
        return n;
    }
}

type struct Stack<T> {
    top: Node<T>*;

    static new() -> Stack<T> {
        return Stack { top: null };
    }

    push(mut &this, val: T) -> void {
        const node: Node<T>* = Node<T>::new(val);
        node.next = this.top;
        this.top = node;
    }

    peek(&this) -> T {
        return this.top.value;
    }
}

function main() -> int {
    mut s: Stack<int> = Stack<int>::new();
    s.push(42);
    printf("%d\n", s.peek());
    s.push(99);
    printf("%d\n", s.peek());
    return 0;
}
