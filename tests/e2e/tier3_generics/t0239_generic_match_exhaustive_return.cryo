// @test: generic_match_exhaustive_return
// @expect: compile_success
// @mode: raw
// @stdout: 42
// @stdout: -1
// @stdout: 100
// @stdout: 0
// @tags: generics, enums, match, return, exhaustive

namespace GenMatchExhaust;

enum Result<T, E> {
    Ok(T);
    Err(E);
}

implement enum Result<T, E> {
    unwrap_or(&this, default: T) -> T {
        match (&this) {
            Result::Ok(v) => { return v; }
            Result::Err(_) => { return default; }
            _ => { return default; }
        }
    }

    is_ok(&this) -> int {
        match (&this) {
            Result::Ok(_) => { return 1; }
            Result::Err(_) => { return 0; }
            _ => { return 0; }
        }
    }
}

function safe_divide(a: int, b: int) -> Result<int, string> {
    if (b == 0) {
        return Result::Err("division by zero");
    }
    return Result::Ok(a / b);
}

function main() -> int {
    const r1: Result<int, string> = safe_divide(84, 2);
    const r2: Result<int, string> = safe_divide(10, 0);

    printf("%d\n", r1.unwrap_or(-1));
    printf("%d\n", r2.unwrap_or(-1));

    const r3: Result<int, string> = Result::Ok(100);
    printf("%d\n", r3.unwrap_or(0));
    printf("%d\n", r2.is_ok());
    return 0;
}
