// @test: generic_struct_two_params
// @expect: compile_success
// @mode: raw
// @stdout: 1
// @stdout: 2
// @tags: generics, structs
// @xfail: Multi-param generic struct field access not resolved

namespace GenStructTwoParams;

type struct KV<K, V> {
    key: K;
    val: V;

    static new(k: K, v: V) -> KV<K, V> {
        return KV { key: k, val: v };
    }
}

function main() -> int {
    const entry: KV<int, int> = KV<int, int>::new(1, 2);
    printf("%d\n", entry.key);
    printf("%d\n", entry.val);
    return 0;
}
