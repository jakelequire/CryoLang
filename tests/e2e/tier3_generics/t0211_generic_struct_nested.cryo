// @test: generic_struct_nested
// @expect: compile_success
// @mode: raw
// @stdout: 5
// @stdout: 10
// @tags: generics, structs, nested
// @xfail: Method calls on nested generic struct fields not supported

namespace GenStructNested;

type struct Inner<T> {
    value: T;

    static new(v: T) -> Inner<T> {
        return Inner { value: v };
    }

    get(&this) -> T {
        return this.value;
    }
}

type struct Outer<T> {
    inner: Inner<T>;

    static new(v: T) -> Outer<T> {
        return Outer { inner: Inner<T>::new(v) };
    }
}

function main() -> int {
    const a: Outer<int> = Outer<int>::new(5);
    const b: Outer<int> = Outer<int>::new(10);
    printf("%d\n", a.inner.get());
    printf("%d\n", b.inner.get());
    return 0;
}
