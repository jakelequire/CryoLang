// @test: generic_ptr_index_member_assign
// @expect: compile_success
// @mode: raw
// @stdout: 0:0
// @stdout: 1:99
// @stdout: 0:0
// @tags: generics, pointers, arrays, member_access, assignment

namespace GenPtrIdxAssign;

type struct Slot<T> {
    state: int;
    value: T;

    static new(s: int, v: T) -> Slot<T> {
        return Slot<T> { state: s, value: v };
    }
}

type struct Table<T> {
    entries: Slot<T>*;
    count: int;

    static new(d: Slot<T>*, n: int) -> Table<T> {
        return Table<T> { entries: d, count: n };
    }

    set(mut &this, index: int, val: T) -> void {
        this.entries[index].value = val;
        this.entries[index].state = 1;
    }

    get_state(&this, index: int) -> int {
        return this.entries[index].state;
    }

    get_value(&this, index: int) -> T {
        return this.entries[index].value;
    }
}

function main() -> int {
    mut slots: Slot<int>[3] = [
        Slot::new(0, 0),
        Slot::new(0, 0),
        Slot::new(0, 0)
    ];
    mut t: Table<int> = Table::new(&slots[0], 3);
    t.set(1, 99);
    printf("%d:%d\n", t.get_state(0), t.get_value(0));
    printf("%d:%d\n", t.get_state(1), t.get_value(1));
    printf("%d:%d\n", t.get_state(2), t.get_value(2));
    return 0;
}
