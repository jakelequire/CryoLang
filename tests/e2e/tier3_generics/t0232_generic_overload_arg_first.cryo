// @test: generic_overload_arg_first
// @expect: compile_success
// @mode: raw
// @stdout: 50
// @stdout: 0
// @tags: generics, structs, overload
//
// Tests calling the parameterized overload FIRST, then the no-arg overload.
// This exercises the reverse order from t0231 to ensure overload resolution
// works regardless of call order.

namespace GenOverloadArgFirst;

type struct Stack<T> {
    size: int;
    top: T;

    static new() -> Stack<T> {
        return Stack { size: 0, top: 0 };
    }

    static new(initial: T) -> Stack<T> {
        return Stack { size: 1, top: initial };
    }

    get_size(&this) -> int {
        return this.size;
    }

    get_top(&this) -> T {
        return this.top;
    }
}

function main() -> int {
    // Call with-arg first
    const full: Stack<int> = Stack<int>::new(50);
    printf("%d\n", full.get_top());

    // Then call no-arg
    const empty: Stack<int> = Stack<int>::new();
    printf("%d\n", empty.get_size());

    return 0;
}
