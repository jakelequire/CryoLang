// @test: generic_enum_two_params
// @expect: compile_success
// @mode: raw
// @stdout: ok
// @tags: generics, enums
// @xfail: Two-param generic enums may not work in raw mode

namespace GenEnumTwoParams;

enum Res<T, E> {
    Ok(T);
    Err(E);
}

function main() -> int {
    const r: Res<int, int> = Res::Ok(42);
    match (r) {
        Res::Ok(_) => { printf("ok\n"); },
        Res::Err(_) => { printf("err\n"); },
    }
    return 0;
}
