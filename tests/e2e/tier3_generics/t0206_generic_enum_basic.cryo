// @test: generic_enum_basic
// @expect: compile_success
// @mode: raw
// @stdout: has_value
// @stdout: empty
// @tags: generics, enums
// @xfail: Generic enum instantiation may not work in raw mode

namespace GenEnumBasic;

enum Maybe<T> {
    Just(T);
    Empty;
}

function main() -> int {
    const a: Maybe<int> = Maybe::Just(42);
    const b: Maybe<int> = Maybe::Empty;

    match (a) {
        Maybe::Just(_) => { printf("has_value\n"); },
        Maybe::Empty => { printf("empty\n"); },
    }
    match (b) {
        Maybe::Just(_) => { printf("has_value\n"); },
        Maybe::Empty => { printf("empty\n"); },
    }
    return 0;
}
