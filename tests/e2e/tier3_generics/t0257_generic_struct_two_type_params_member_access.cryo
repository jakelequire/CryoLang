// @test: generic_struct_two_type_params_member_access
// @expect: compile_success
// @mode: raw
// @stdout: key=hello val=42
// @stdout: key=world val=99
// @tags: generics, structs, member_access, multi_param, stdlib_bug
// @description: RC1 - Member access on generic struct with two type params (HashMap<K,V> pattern) through pointer

namespace GenStructTwoParams;

type struct KVEntry<K, V> {
    key: K;
    value: V;
    hash: u64;
    state: u8;
}

type struct SimpleTable<K, V> {
    entries: KVEntry<K, V>*;
    cap: u64;
    len: u64;

    static new(capacity: u64) -> SimpleTable<K, V> {
        const e: KVEntry<K, V>* = calloc(capacity, sizeof(KVEntry<K, V>));
        return SimpleTable { entries: e, cap: capacity, len: 0 };
    }

    put(mut &this, idx: u64, k: K, v: V) -> void {
        this.entries[idx].key = k;
        this.entries[idx].value = v;
        this.entries[idx].state = 1;
        this.len = this.len + 1;
    }

    get_key(&this, idx: u64) -> K {
        return this.entries[idx].key;
    }

    get_value(&this, idx: u64) -> V {
        return this.entries[idx].value;
    }

    is_occupied(&this, idx: u64) -> boolean {
        return this.entries[idx].state == 1;
    }

    drop(mut &this) -> void {
        free(this.entries);
    }
}

function main() -> int {
    mut t: SimpleTable<string, int> = SimpleTable<string, int>::new(8);
    t.put(0, "hello", 42);
    t.put(1, "world", 99);

    printf("key=%s val=%d\n", t.get_key(0), t.get_value(0));
    printf("key=%s val=%d\n", t.get_key(1), t.get_value(1));

    t.drop();
    return 0;
}
