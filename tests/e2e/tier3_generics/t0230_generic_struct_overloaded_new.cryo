// @test: generic_struct_overloaded_new
// @expect: compile_success
// @mode: raw
// @stdout: 16
// @stdout: 0
// @stdout: 64
// @stdout: 0
// @tags: generics, structs, overload
//
// Tests that a generic struct with overloaded static `new` constructors
// (no-arg and with-arg) correctly resolves both overloads.
// This is the pattern used by stdlib Array<T>::new() vs Array<T>::new(capacity).

namespace GenOverloadNew;

type struct Container<T> {
    capacity: int;
    len: int;
    value: T;

    static new() -> Container<T> {
        return Container { capacity: 16, len: 0, value: 0 };
    }

    static new(cap: int) -> Container<T> {
        return Container { capacity: cap, len: 0, value: 0 };
    }

    get_capacity(&this) -> int {
        return this.capacity;
    }

    get_len(&this) -> int {
        return this.len;
    }
}

function main() -> int {
    // Call no-arg overload
    const a: Container<int> = Container<int>::new();
    printf("%d\n", a.get_capacity());
    printf("%d\n", a.get_len());

    // Call with-arg overload
    const b: Container<int> = Container<int>::new(64);
    printf("%d\n", b.get_capacity());
    printf("%d\n", b.get_len());

    return 0;
}
