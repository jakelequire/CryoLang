// @test: generic_struct_member_access_state_field
// @expect: compile_success
// @mode: raw
// @stdout: occupied
// @stdout: empty
// @tags: generics, structs, member_access, stdlib_bug
// @description: RC1 - Member access on fields of monomorphized generic structs (e.g. entry.state on HashMapEntry<K,V>)

namespace GenStructMemberState;

const BUCKET_EMPTY: u8 = 0;
const BUCKET_OCCUPIED: u8 = 1;

type struct Entry<K, V> {
    key: K;
    value: V;
    state: u8;

    static new(k: K, v: V, s: u8) -> Entry<K, V> {
        return Entry { key: k, value: v, state: s };
    }

    is_occupied(&this) -> boolean {
        return this.state == BUCKET_OCCUPIED;
    }

    is_empty(&this) -> boolean {
        return this.state == BUCKET_EMPTY;
    }
}

function main() -> int {
    const e1: Entry<int, int> = Entry<int, int>::new(10, 20, BUCKET_OCCUPIED);
    const e2: Entry<int, int> = Entry<int, int>::new(0, 0, BUCKET_EMPTY);

    if (e1.is_occupied()) {
        printf("occupied\n");
    }
    if (e2.is_empty()) {
        printf("empty\n");
    }

    return 0;
}
