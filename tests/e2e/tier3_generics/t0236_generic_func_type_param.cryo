// @test: generic_func_type_param
// @expect: compile_success
// @mode: raw
// @stdout: 42
// @tags: generics, enums, function_types, implement_blocks

namespace GenFuncTypeParam;

enum Maybe<T> {
    Just(T);
    Nothing;
}

implement Maybe<T> {
    or_fallback(&this, f: () -> Maybe<T>) -> Maybe<T> {
        match (&this) {
            Maybe::Just(_) => { return this; }
            Maybe::Nothing => { return f(); }
        }
        return this;
    }
}

function fallback() -> Maybe<int> {
    return Maybe::Just(42);
}

function main() -> int {
    const x: Maybe<int> = Maybe::Nothing;
    const result: Maybe<int> = x.or_fallback(fallback);

    match (result) {
        Maybe::Just(v) => { printf("%d\n", v); }
        Maybe::Nothing => { printf("nothing\n"); }
        _ => { printf("error\n"); }
    }
    return 0;
}
