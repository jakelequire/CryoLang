// @test: mixed_generic_nesting
// @expect: compile_success
// @mode: raw
// @stdout: found:42
// @stdout: inner_empty
// @stdout: outer_error
// @tags: generics, enums, nesting

namespace MixedGenNest;

enum Maybe<T> {
    Just(T);
    Nothing;
}

enum Outcome<T, E> {
    Ok(T);
    Err(E);
}

function describe(o: Outcome<Maybe<int>, string>) -> void {
    match (o) {
        Outcome::Ok(inner) => {
            match (inner) {
                Maybe::Just(v) => {
                    printf("found:%d\n", v);
                }
                Maybe::Nothing => {
                    printf("inner_empty\n");
                }
                _ => {
                    printf("unknown\n");
                }
            }
        }
        Outcome::Err(e) => {
            printf("outer_error\n");
        }
        _ => {
            printf("unknown\n");
        }
    }
}

function main() -> int {
    const a: Outcome<Maybe<int>, string> = Outcome::Ok(Maybe::Just(42));
    const b: Outcome<Maybe<int>, string> = Outcome::Ok(Maybe::Nothing);
    const c: Outcome<Maybe<int>, string> = Outcome::Err("fail");
    describe(a);
    describe(b);
    describe(c);
    return 0;
}
