// @test: generic_overload_multi_instantiation
// @expect: compile_success
// @mode: raw
// @stdout: 0
// @stdout: 42
// @stdout: 0
// @stdout: 99
// @tags: generics, structs, overload
//
// Tests that overloaded constructors work across multiple instantiations
// of the same generic type (e.g., Container<int> and Container<i64>).
// Each instantiation should independently resolve overloads correctly.

namespace GenOverloadMultiInst;

type struct Holder<T> {
    value: T;
    flag: int;

    static new() -> Holder<T> {
        return Holder { value: 0, flag: 0 };
    }

    static new(v: T) -> Holder<T> {
        return Holder { value: v, flag: 1 };
    }

    get_value(&this) -> T {
        return this.value;
    }

    get_flag(&this) -> int {
        return this.flag;
    }
}

function main() -> int {
    // Instantiation 1: Holder<int> with both overloads
    const a: Holder<int> = Holder<int>::new();
    printf("%d\n", a.get_flag());

    const b: Holder<int> = Holder<int>::new(42);
    printf("%d\n", b.get_value());

    // Instantiation 2: Holder<i64> with both overloads
    const c: Holder<i64> = Holder<i64>::new();
    printf("%d\n", c.get_flag());

    const d: Holder<i64> = Holder<i64>::new(99);
    printf("%d\n", d.get_value());

    return 0;
}
