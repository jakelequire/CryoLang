// @test: generic_struct_module_const
// @expect: compile_success
// @mode: raw
// @stdout: 8
// @stdout: 16
// @tags: generics, structs, constants

namespace GenStructModConst;

const INITIAL_CAP: int = 8;

type struct Pool<T> {
    capacity: int;
    count: int;

    static new() -> Pool<T> {
        return Pool<T> { capacity: INITIAL_CAP, count: 0 };
    }

    get_capacity(&this) -> int {
        return this.capacity;
    }

    double_capacity(mut &this) -> void {
        this.capacity = this.capacity * 2;
    }
}

function main() -> int {
    mut p: Pool<int> = Pool::new();
    printf("%d\n", p.get_capacity());
    p.double_capacity();
    printf("%d\n", p.get_capacity());
    return 0;
}
