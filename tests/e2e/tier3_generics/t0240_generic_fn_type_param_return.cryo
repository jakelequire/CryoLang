// @test: generic_fn_type_param_return
// @expect: compile_success
// @mode: raw
// @stdout: 99
// @stdout: 42
// @tags: generics, enums, function_types, implement

namespace GenFnTypeReturn;

enum Maybe<T> {
    Just(T);
    Nothing;
}

implement enum Maybe<T> {
    map<U>(&this, f: (T) -> U) -> Maybe<U> {
        match (&this) {
            Maybe::Just(v) => { return Maybe::Just(f(v)); }
            Maybe::Nothing => { return Maybe::Nothing; }
            _ => { return Maybe::Nothing; }
        }
    }

    unwrap_or(&this, default: T) -> T {
        match (&this) {
            Maybe::Just(v) => { return v; }
            Maybe::Nothing => { return default; }
            _ => { return default; }
        }
    }
}

function double(x: int) -> int {
    return x * 2;
}

function main() -> int {
    const a: Maybe<int> = Maybe::Just(99);
    printf("%d\n", a.unwrap_or(0));

    const b: Maybe<int> = Maybe::Just(21);
    const c: Maybe<int> = b.map(double);
    printf("%d\n", c.unwrap_or(0));
    return 0;
}
