// @test: generic_struct_module_const_access
// @expect: compile_success
// @mode: raw
// @stdout: cap=8
// @stdout: inserted
// @tags: generics, structs, constants, stdlib_bug
// @description: RC2 - Module-level constants used inside generic struct methods (e.g. MIN_CAPACITY, BUCKET_EMPTY in HashMap)

namespace GenStructModuleConst;

const DEFAULT_CAPACITY: u64 = 8;
const BUCKET_EMPTY: u8 = 0;
const BUCKET_OCCUPIED: u8 = 1;

type struct Bucket<V> {
    value: V;
    state: u8;
}

type struct SimpleMap<V> {
    buckets: Bucket<V>*;
    cap: u64;
    len: u64;

    static new() -> SimpleMap<V> {
        const c: u64 = DEFAULT_CAPACITY;
        const b: Bucket<V>* = calloc(c, sizeof(Bucket<V>));
        return SimpleMap { buckets: b, cap: c, len: 0 };
    }

    insert(mut &this, index: u64, val: V) -> void {
        if (index < this.cap) {
            this.buckets[index].value = val;
            this.buckets[index].state = BUCKET_OCCUPIED;
            this.len = this.len + 1;
        }
    }

    get(&this, index: u64) -> V {
        return this.buckets[index].value;
    }

    is_occupied(&this, index: u64) -> boolean {
        return this.buckets[index].state == BUCKET_OCCUPIED;
    }

    drop(mut &this) -> void {
        free(this.buckets);
    }
}

function main() -> int {
    mut m: SimpleMap<int> = SimpleMap<int>::new();
    printf("cap=%llu\n", m.cap);

    m.insert(3, 42);
    if (m.is_occupied(3)) {
        printf("inserted\n");
    }

    m.drop();
    return 0;
}
