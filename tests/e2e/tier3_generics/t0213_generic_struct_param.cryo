// @test: generic_struct_param
// @expect: compile_success
// @mode: raw
// @stdout: 77
// @tags: generics, structs, functions

namespace GenStructParam;

type struct Wrap<T> {
    value: T;

    static new(v: T) -> Wrap<T> {
        return Wrap { value: v };
    }

    get(&this) -> T {
        return this.value;
    }
}

function extract(w: Wrap<int>) -> int {
    return w.get();
}

function main() -> int {
    const w: Wrap<int> = Wrap<int>::new(77);
    printf("%d\n", extract(w));
    return 0;
}
