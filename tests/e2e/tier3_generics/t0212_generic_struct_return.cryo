// @test: generic_struct_return
// @expect: compile_success
// @mode: raw
// @stdout: 100
// @tags: generics, structs, functions

namespace GenStructReturn;

type struct Wrap<T> {
    value: T;

    static new(v: T) -> Wrap<T> {
        return Wrap { value: v };
    }

    get(&this) -> T {
        return this.value;
    }
}

function make_wrap(n: int) -> Wrap<int> {
    return Wrap<int>::new(n);
}

function main() -> int {
    const w: Wrap<int> = make_wrap(100);
    printf("%d\n", w.get());
    return 0;
}
