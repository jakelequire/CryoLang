// @test: generic_enum_fn_param
// @expect: compile_success
// @mode: raw
// @stdout: 20
// @stdout: -1
// @tags: generics, enums, function_type, map

namespace GenEnumFnParam;

enum Maybe<T> {
    Just(T);
    Nothing;
}

implement enum Maybe<T> {
    map_int(&this, f: (T) -> int) -> int {
        match (&this) {
            Maybe::Just(v) => { return f(v); }
            Maybe::Nothing => { return -1; }
            _ => { return -1; }
        }
    }
}

function dub(n: int) -> int {
    return n * 2;
}

function main() -> int {
    const a: Maybe<int> = Maybe::Just(10);
    const b: Maybe<int> = Maybe::Nothing;
    printf("%d\n", a.map_int(dub));
    printf("%d\n", b.map_int(dub));
    return 0;
}
