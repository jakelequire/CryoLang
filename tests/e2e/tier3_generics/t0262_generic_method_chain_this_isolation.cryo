// @test: generic_method_chain_this_isolation
// @expect: compile_success
// @mode: raw
// @stdout: 3
// @stdout: hello
// @stdout: world
// @stdout: !
// @tags: generics, structs, methods, method_chain, this_isolation, stdlib_root_cause
// @description: RC8 - Multiple methods on a generic struct must have isolated 'this' references. The compiler must not leak %this alloca from one method's LLVM function into another. This tests that each method gets its own this parameter without cross-function IR reference corruption.

namespace GenMethodThisIsolation;

type struct Buffer<T> {
    ptr: T*;
    len: u64;
    cap: u64;

    static new() -> Buffer<T> {
        return Buffer<T> {
            ptr: malloc(sizeof(T) * 8),
            len: 0,
            cap: 8
        };
    }

    push(mut &this, value: T) -> void {
        this.ptr[this.len] = value;
        this.len = this.len + 1;
    }

    length(&this) -> u64 {
        return this.len;
    }

    get(&this, index: u64) -> T {
        return this.ptr[index];
    }

    /// A method that calls other methods on this - tests this isolation
    fill_and_count(mut &this, a: T, b: T, c: T) -> u64 {
        this.push(a);
        this.push(b);
        this.push(c);
        return this.length();
    }
}

function main() -> int {
    mut buf: Buffer<string> = Buffer<string>::new();
    const count: u64 = buf.fill_and_count("hello", "world", "!");
    printf("%llu\n", count);
    printf("%s\n", buf.get(0));
    printf("%s\n", buf.get(1));
    printf("%s\n", buf.get(2));
    return 0;
}
