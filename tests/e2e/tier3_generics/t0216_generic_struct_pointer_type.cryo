// @test: generic_struct_pointer_type
// @expect: compile_success
// @mode: raw
// @stdout: 42
// @stdout: 100
// @tags: generics, pointers, structs

namespace GenStructPtr;

type struct Node<T> {
    value: T;
    next: int;

    static new(v: T) -> Node<T> {
        return Node<T> { value: v, next: 0 };
    }

    get_value(&this) -> T {
        return this.value;
    }
}

function main() -> int {
    mut n1: Node<int> = Node::new(42);
    const p: Node<int>* = &n1;
    printf("%d\n", p.get_value());

    mut n2: Node<int> = Node::new(100);
    const p2: Node<int>* = &n2;
    printf("%d\n", p2.get_value());
    return 0;
}
