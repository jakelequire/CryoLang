// @test: generic_enum_unwrap_err
// @expect: compile_success
// @mode: raw
// @stdout: err=42
// @tags: generics, enums, implement, stdlib_bug
// @description: RC7 - unwrap_err method on Result-like generic enum (method calling another method in same impl block)

namespace GenEnumUnwrapErr;

enum Result<T, E> {
    Ok(T);
    Err(E);
}

implement enum Result<T, E> {
    is_ok(&this) -> boolean {
        match (&this) {
            Result::Ok(_) => { return true; }
            Result::Err(_) => { return false; }
        }
    }

    unwrap(&this, msg: string) -> T {
        match (&this) {
            Result::Ok(v) => { return v; }
            Result::Err(_) => {
                printf("panic: %s\n", msg);
                return 0;
            }
        }
    }

    unwrap_err(&this, msg: string) -> E {
        match (&this) {
            Result::Ok(_) => {
                printf("panic: %s\n", msg);
                return 0;
            }
            Result::Err(e) => { return e; }
        }
    }
}

function main() -> int {
    const r: Result<int, int> = Result::Err(42);
    const e: int = r.unwrap_err("expected err");
    printf("err=%d\n", e);
    return 0;
}
