// @test: generic_struct_array_member
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: 20
// @tags: generics, arrays, structs, member_access

namespace GenStructArrMember;

type struct Entry<T> {
    key: int;
    value: T;

    static new(k: int, v: T) -> Entry<T> {
        return Entry<T> { key: k, value: v };
    }
}

type struct Container<T> {
    data: Entry<T>*;
    size: int;

    static new(d: Entry<T>*, n: int) -> Container<T> {
        return Container<T> { data: d, size: n };
    }

    get_value(&this, index: int) -> T {
        return this.data[index].value;
    }
}

function main() -> int {
    mut entries: Entry<int>[2] = [
        Entry<int>::new(1, 10),
        Entry<int>::new(2, 20)
    ];
    const c: Container<int> = Container<int>::new(&entries[0], 2);
    printf("%d\n", c.get_value(0));
    printf("%d\n", c.get_value(1));
    return 0;
}
