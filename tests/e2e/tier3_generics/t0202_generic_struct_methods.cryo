// @test: generic_struct_methods
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: 20
// @tags: generics, structs, methods

namespace GenStructMethods;

type struct Wrapper<T> {
    value: T;

    static new(v: T) -> Wrapper<T> {
        return Wrapper { value: v };
    }

    get(&this) -> T {
        return this.value;
    }
}

function main() -> int {
    const a: Wrapper<int> = Wrapper<int>::new(10);
    const b: Wrapper<int> = Wrapper<int>::new(20);
    printf("%d\n", a.get());
    printf("%d\n", b.get());
    return 0;
}
