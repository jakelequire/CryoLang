// @test: generic_struct_multi_inst
// @expect: compile_success
// @mode: raw
// @stdout: 42
// @stdout: 7
// @tags: generics, structs, instantiation

namespace GenStructMultiInst;

type struct Holder<T> {
    value: T;

    static of(v: T) -> Holder<T> {
        return Holder { value: v };
    }

    get(&this) -> T {
        return this.value;
    }
}

function main() -> int {
    const a: Holder<int> = Holder<int>::of(42);
    const b: Holder<i16> = Holder<i16>::of(7);
    printf("%d\n", a.get());
    printf("%d\n", b.get());
    return 0;
}
