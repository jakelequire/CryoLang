// @test: generic_member_access_after_array_subscript
// @expect: compile_success
// @mode: raw
// @stdout: occupied
// @stdout: key=42
// @stdout: empty
// @tags: generics, structs, member_access, array_subscript, stdlib_root_cause
// @description: RC4 - Accessing a field on a generic struct obtained via array subscript (e.g., this.entries[i].state). The compiler must correctly infer the type of entries[i] as the concrete monomorphized Entry<K,V> and allow field access on it.

namespace GenMemberAfterSubscript;

const BUCKET_EMPTY: u8 = 0;
const BUCKET_OCCUPIED: u8 = 1;

type struct Entry<K, V> {
    key: K;
    value: V;
    state: u8;
}

type struct Map<K, V> {
    entries: Entry<K, V>*;
    cap: u64;

    static new(capacity: u64) -> Map<K, V> {
        const entries: Entry<K, V>* = calloc(capacity, sizeof(Entry<K, V>));
        return Map<K, V> {
            entries: entries,
            cap: capacity
        };
    }

    /// Sets an entry - accesses entries[index].field
    set(mut &this, index: u64, key: K, value: V) -> void {
        this.entries[index].key = key;
        this.entries[index].value = value;
        this.entries[index].state = BUCKET_OCCUPIED;
    }

    /// Reads fields from entries[index] - the pattern that fails
    is_occupied(&this, index: u64) -> boolean {
        return this.entries[index].state == BUCKET_OCCUPIED;
    }

    get_key(&this, index: u64) -> K {
        return this.entries[index].key;
    }

    is_empty(&this, index: u64) -> boolean {
        return this.entries[index].state == BUCKET_EMPTY;
    }
}

function main() -> int {
    mut m: Map<int, int> = Map<int, int>::new(8);

    m.set(0, 42, 100);

    if (m.is_occupied(0)) {
        printf("occupied\n");
    }
    printf("key=%d\n", m.get_key(0));

    if (m.is_empty(1)) {
        printf("empty\n");
    }

    return 0;
}
