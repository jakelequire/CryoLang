// @test: generic_struct_returns_enum
// @expect: compile_success
// @mode: raw
// @stdout: got:42
// @stdout: empty
// @tags: generics, structs, enums

namespace GenStructRetEnum;

enum Maybe<T> {
    Just(T);
    Nothing;
}

type struct Container<T> {
    data: T;
    valid: int;

    static new(v: T) -> Container<T> {
        return Container { data: v, valid: 1 };
    }

    static empty(v: T) -> Container<T> {
        return Container { data: v, valid: 0 };
    }

    get(&this) -> Maybe<T> {
        if (this.valid == 1) {
            return Maybe::Just(this.data);
        }
        return Maybe::Nothing;
    }
}

function main() -> int {
    const a: Container<int> = Container<int>::new(42);
    const b: Container<int> = Container<int>::empty(0);

    match (a.get()) {
        Maybe::Just(v) => { printf("got:%d\n", v); }
        Maybe::Nothing => { printf("empty\n"); }
        _ => { printf("error\n"); }
    }

    match (b.get()) {
        Maybe::Just(v) => { printf("got:%d\n", v); }
        Maybe::Nothing => { printf("empty\n"); }
        _ => { printf("error\n"); }
    }
    return 0;
}
