// @test: generic_enum_nested
// @expect: compile_success
// @mode: raw
// @stdout: inner:42
// @stdout: outer_empty
// @stdout: all_empty
// @tags: generics, enums, nested

namespace GenEnumNested;

enum Maybe<T> {
    Just(T);
    Nothing;
}

implement enum Maybe<T> {
    is_just(&this) -> int {
        match (&this) {
            Maybe::Just(_) => { return 1; }
            Maybe::Nothing => { return 0; }
            _ => { return 0; }
        }
    }
}

function describe(outer: Maybe<Maybe<int>>) -> void {
    match (outer) {
        Maybe::Just(inner) => {
            match (inner) {
                Maybe::Just(v) => {
                    printf("inner:%d\n", v);
                }
                Maybe::Nothing => {
                    printf("outer_empty\n");
                }
                _ => {
                    printf("outer_empty\n");
                }
            }
        }
        Maybe::Nothing => {
            printf("all_empty\n");
        }
        _ => {
            printf("all_empty\n");
        }
    }
}

function main() -> int {
    const a: Maybe<Maybe<int>> = Maybe::Just(Maybe::Just(42));
    const b: Maybe<Maybe<int>> = Maybe::Just(Maybe::Nothing);
    const c: Maybe<Maybe<int>> = Maybe::Nothing;
    describe(a);
    describe(b);
    describe(c);
    return 0;
}
