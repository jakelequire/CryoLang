// @test: generic_enum_two_methods
// @expect: compile_success
// @mode: raw
// @stdout: just:42
// @stdout: nothing
// @stdout: 1
// @stdout: 0
// @tags: generics, enums, implement, methods

namespace GenEnumTwoMethods;

enum Maybe<T> {
    Just(T);
    Nothing;
}

implement enum Maybe<T> {
    describe(&this) -> void {
        match (&this) {
            Maybe::Just(v) => {
                printf("just:%d\n", v);
            }
            Maybe::Nothing => {
                printf("nothing\n");
            }
        }
    }

    has_value(&this) -> int {
        match (&this) {
            Maybe::Just(_) => { return 1; }
            Maybe::Nothing => { return 0; }
            _ => { return -1; }
        }
    }
}

function main() -> int {
    const a: Maybe<int> = Maybe::Just(42);
    const b: Maybe<int> = Maybe::Nothing;
    a.describe();
    b.describe();
    printf("%d\n", a.has_value());
    printf("%d\n", b.has_value());
    return 0;
}
