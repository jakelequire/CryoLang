// @test: generic_type_alias
// @expect: compile_success
// @mode: raw
// @stdout: has_value:42
// @stdout: is_error:oops
// @tags: generics, types, alias

namespace GenTypeAlias;

enum Res<T, E> {
    Ok(T);
    Err(E);
}

type IntResult = Res<int, string>;

function describe(r: IntResult) -> void {
    match (r) {
        Res::Ok(v) => {
            printf("has_value:%d\n", v);
        }
        Res::Err(e) => {
            printf("is_error:%s\n", e);
        }
        _ => {
            printf("unknown\n");
        }
    }
}

function main() -> int {
    const a: IntResult = Res::Ok(42);
    const b: IntResult = Res::Err("oops");
    describe(a);
    describe(b);
    return 0;
}
