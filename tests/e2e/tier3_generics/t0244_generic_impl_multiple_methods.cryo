// @test: generic_impl_multiple_methods
// @expect: compile_success
// @mode: raw
// @stdout: 1
// @stdout: 0
// @stdout: 42
// @stdout: 99
// @stdout: has_value
// @tags: generics, enums, implement, multiple_methods

namespace GenImplMulti;

enum Option<T> {
    Some(T);
    None;
}

implement enum Option<T> {
    is_some(&this) -> int {
        match (&this) {
            Option::Some(_) => { return 1; }
            Option::None => { return 0; }
            _ => { return 0; }
        }
    }

    is_none(&this) -> int {
        match (&this) {
            Option::None => { return 1; }
            _ => { return 0; }
        }
    }

    unwrap(&this) -> T {
        match (&this) {
            Option::Some(v) => { return v; }
            _ => { return 0; }
        }
    }

    unwrap_or(&this, default: T) -> T {
        match (&this) {
            Option::Some(v) => { return v; }
            Option::None => { return default; }
            _ => { return default; }
        }
    }

    expect(&this, msg: string) -> T {
        match (&this) {
            Option::Some(v) => { return v; }
            _ => {
                printf("panic: %s\n", msg);
                return 0;
            }
        }
    }

    describe(&this) -> void {
        if (this.is_some() == 1) {
            printf("has_value\n");
        } else {
            printf("no_value\n");
        }
    }
}

function main() -> int {
    const a: Option<int> = Option::Some(42);
    const b: Option<int> = Option::None;

    printf("%d\n", a.is_some());
    printf("%d\n", b.is_some());
    printf("%d\n", a.unwrap_or(0));
    printf("%d\n", b.unwrap_or(99));
    a.describe();
    return 0;
}
