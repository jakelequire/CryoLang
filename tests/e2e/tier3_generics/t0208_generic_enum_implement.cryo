// @test: generic_enum_implement
// @expect: compile_success
// @mode: raw
// @stdout: 1
// @stdout: 0
// @tags: generics, enums, implement

namespace GenEnumImpl;

enum Maybe<T> {
    Just(T);
    Empty;
}

implement enum Maybe<T> {
    is_just(&this) -> int {
        match (&this) {
            Maybe::Just(_) => { return 1; }
            Maybe::Empty => { return 0; }
        }
    }
}

function main() -> int {
    const a: Maybe<int> = Maybe::Just(10);
    const b: Maybe<int> = Maybe::Empty;
    printf("%d\n", a.is_just());
    printf("%d\n", b.is_just());
    return 0;
}
