// @test: generic_enum_variant_in_monomorphized_body
// @expect: compile_success
// @mode: raw
// @stdout: has_value=1
// @stdout: has_value=0
// @tags: generics, enums, variant_resolution, stdlib_bug
// @description: RC6 - Generic enum variant (Option_X::None) inside monomorphized method body

namespace GenEnumVariantMono;

enum Maybe<T> {
    Some(T);
    None;
}

implement enum Maybe<T> {
    is_some(&this) -> boolean {
        match (&this) {
            Maybe::Some(_) => { return true; }
            Maybe::None => { return false; }
        }
    }

    take(mut &this) -> Maybe<T> {
        match (&this) {
            Maybe::Some(v) => {
                // Replace this with None - the key pattern being tested
                this = Maybe::None;
                return Maybe::Some(v);
            }
            Maybe::None => {
                return Maybe::None;
            }
        }
    }

    ok_or(&this, err: boolean) -> boolean {
        match (&this) {
            Maybe::Some(_) => { return true; }
            Maybe::None => { return err; }
        }
    }
}

function main() -> int {
    const a: Maybe<int> = Maybe::Some(42);
    const b: Maybe<int> = Maybe::None;

    printf("has_value=%d\n", a.is_some());
    printf("has_value=%d\n", b.is_some());

    return 0;
}
