// @test: generic_impl_match_ref_this
// @expect: compile_success
// @mode: raw
// @stdout: has:42
// @stdout: empty
// @stdout: 42
// @stdout: -1
// @tags: generics, enums, implement, match, address_of_this

namespace GenImplMatchRefThis;

enum Option<T> {
    Some(T);
    None;
}

implement enum Option<T> {
    is_some(&this) -> int {
        match (&this) {
            Option::Some(_) => { return 1; }
            Option::None => { return 0; }
            _ => { return 0; }
        }
    }

    is_none(&this) -> int {
        match (&this) {
            Option::None => { return 1; }
            _ => { return 0; }
        }
    }

    unwrap_or(&this, default: T) -> T {
        match (&this) {
            Option::Some(v) => { return v; }
            Option::None => { return default; }
            _ => { return default; }
        }
    }

    describe(&this) -> void {
        match (&this) {
            Option::Some(v) => { printf("has:%d\n", v); }
            Option::None => { printf("empty\n"); }
            _ => { printf("unknown\n"); }
        }
    }
}

function main() -> int {
    const a: Option<int> = Option::Some(42);
    const b: Option<int> = Option::None;

    a.describe();
    b.describe();

    printf("%d\n", a.unwrap_or(0));
    printf("%d\n", b.unwrap_or(-1));
    return 0;
}
