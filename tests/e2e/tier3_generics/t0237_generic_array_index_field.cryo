// @test: generic_array_index_field
// @expect: compile_success
// @mode: raw
// @stdout: key=1 val=100
// @stdout: key=2 val=200
// @tags: generics, arrays, indexing, member_access

namespace GenArrIdxField;

type struct Entry<V> {
    key: int;
    value: V;
    occupied: int;
}

type struct Map<V> {
    entries: Entry<V>*;
    cap: int;
    len: int;

    static new(cap: int) -> Map<V> {
        const ptr: Entry<V>* = calloc(cap, sizeof(Entry<V>));
        return Map { entries: ptr, cap: cap, len: 0 };
    }

    put(mut &this, key: int, value: V) -> void {
        mut i: int = 0;
        while (i < this.cap) {
            if (this.entries[i].occupied == 0) {
                this.entries[i].key = key;
                this.entries[i].value = value;
                this.entries[i].occupied = 1;
                this.len = this.len + 1;
                return;
            }
            i = i + 1;
        }
    }

    get(&this, key: int) -> V {
        mut i: int = 0;
        while (i < this.cap) {
            if (this.entries[i].occupied == 1) {
                if (this.entries[i].key == key) {
                    return this.entries[i].value;
                }
            }
            i = i + 1;
        }
        return this.entries[0].value;
    }

    dump(&this) -> void {
        mut i: int = 0;
        while (i < this.cap) {
            if (this.entries[i].occupied == 1) {
                printf("key=%d val=%d\n", this.entries[i].key, this.entries[i].value);
            }
            i = i + 1;
        }
    }

    drop(mut &this) -> void {
        free(this.entries);
    }
}

function main() -> int {
    mut m: Map<int> = Map<int>::new(8);
    m.put(1, 100);
    m.put(2, 200);
    m.dump();
    m.drop();
    return 0;
}
