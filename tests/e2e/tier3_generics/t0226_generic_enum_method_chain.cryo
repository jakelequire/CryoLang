// @test: generic_enum_method_chain
// @expect: compile_success
// @mode: raw
// @stdout: 1
// @stdout: 0
// @stdout: 42
// @stdout: -1
// @tags: generics, enums, implement, methods

namespace GenEnumChain;

enum Maybe<T> {
    Just(T);
    Nothing;
}

implement enum Maybe<T> {
    is_just(&this) -> int {
        match (&this) {
            Maybe::Just(_) => { return 1; }
            Maybe::Nothing => { return 0; }
        }
    }

    is_nothing(&this) -> int {
        match (&this) {
            Maybe::Just(_) => { return 0; }
            Maybe::Nothing => { return 1; }
        }
    }

    unwrap_or(&this, fallback: T) -> T {
        match (&this) {
            Maybe::Just(v) => { return v; }
            Maybe::Nothing => { return fallback; }
        }
    }

    map_or(&this, fallback: int, f: int) -> int {
        match (&this) {
            Maybe::Just(_) => { return f; }
            Maybe::Nothing => { return fallback; }
        }
    }
}

function main() -> int {
    const a: Maybe<int> = Maybe::Just(42);
    const b: Maybe<int> = Maybe::Nothing;

    printf("%d\n", a.is_just());
    printf("%d\n", a.is_nothing());
    printf("%d\n", a.unwrap_or(0));
    printf("%d\n", b.unwrap_or(-1));
    return 0;
}
