// @test: generic_enum_result_pattern
// @expect: compile_success
// @mode: raw
// @stdout: ok:42
// @stdout: err:1
// @tags: generics, enums, implement

namespace GenEnumResult;

enum Outcome<T, E> {
    Ok(T);
    Err(E);
}

implement enum Outcome<T, E> {
    is_ok(&this) -> int {
        match (&this) {
            Outcome::Ok(_) => { return 1; }
            Outcome::Err(_) => { return 0; }
        }
    }

    is_err(&this) -> int {
        match (&this) {
            Outcome::Ok(_) => { return 0; }
            Outcome::Err(_) => { return 1; }
        }
    }
}

function main() -> int {
    const good: Outcome<int, int> = Outcome::Ok(42);
    const bad: Outcome<int, int> = Outcome::Err(1);

    match (good) {
        Outcome::Ok(v) => { printf("ok:%d\n", v); }
        Outcome::Err(e) => { printf("err:%d\n", e); }
    }
    match (bad) {
        Outcome::Ok(v) => { printf("ok:%d\n", v); }
        Outcome::Err(e) => { printf("err:%d\n", e); }
    }
    return 0;
}
