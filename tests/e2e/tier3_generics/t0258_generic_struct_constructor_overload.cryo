// @test: generic_struct_constructor_overload
// @expect: compile_success
// @mode: raw
// @stdout: 0
// @stdout: 0
// @stdout: 0
// @stdout: 0
// @stdout: 8
// @stdout: 100
// @tags: generics, structs, constructors, overload, stdlib_root_cause
// @description: RC1 - Generic struct with overloaded static new() constructors (zero-arg and one-arg). The stdlib Array<T> defines both new() and new(capacity: u64). During monomorphization the compiler must preserve both overloads and emit calls with the correct number of arguments.

namespace GenStructCtorOverload;

type struct Container<T> {
    ptr: T*;
    len: u64;
    cap: u64;

    /// Zero-argument constructor
    static new() -> Container<T> {
        return Container<T> {
            ptr: null,
            len: 0,
            cap: 0
        };
    }

    /// One-argument constructor (overload)
    static new(capacity: u64) -> Container<T> {
        return Container<T> {
            ptr: malloc(sizeof(T) * capacity),
            len: 0,
            cap: capacity
        };
    }

    length(&this) -> u64 {
        return this.len;
    }

    capacity(&this) -> u64 {
        return this.cap;
    }
}

function main() -> int {
    // Call zero-arg constructor
    const a: Container<int> = Container<int>::new();
    printf("%llu\n", a.length());
    printf("%llu\n", a.capacity());

    // Call zero-arg constructor with different type param
    const b: Container<u8> = Container<u8>::new();
    printf("%llu\n", b.length());
    printf("%llu\n", b.capacity());

    // Call one-arg constructor
    const c: Container<int> = Container<int>::new(8);
    printf("%llu\n", c.capacity());

    // Call one-arg constructor with different capacity
    const d: Container<u8> = Container<u8>::new(100);
    printf("%llu\n", d.capacity());

    return 0;
}
