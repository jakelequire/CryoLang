// @test: generic_struct_ptr_field_member_access
// @expect: compile_success
// @mode: raw
// @stdout: data_ptr_ok
// @stdout: val=42
// @tags: generics, structs, pointers, member_access, stdlib_bug
// @description: RC1 - Access field through pointer to monomorphized generic struct (e.g. entry.key where entry is Entry<K,V>*)

namespace GenStructPtrField;

type struct Entry<T> {
    value: T;
    next: Entry<T>*;

    static new(val: T) -> Entry<T>* {
        const e: Entry<T>* = malloc(sizeof(Entry<T>));
        e.value = val;
        e.next = null;
        return e;
    }
}

type struct Container<T> {
    data: Entry<T>*;
    len: int;

    static new() -> Container<T> {
        return Container { data: null, len: 0 };
    }

    push(mut &this, val: T) -> void {
        const e: Entry<T>* = Entry<T>::new(val);
        e.next = this.data;
        this.data = e;
        this.len = this.len + 1;
    }

    peek(&this) -> T {
        return this.data.value;
    }

    drop(mut &this) -> void {
        mut cur: Entry<T>* = this.data;
        while (cur != null) {
            const next: Entry<T>* = cur.next;
            free(cur);
            cur = next;
        }
    }
}

function main() -> int {
    mut c: Container<int> = Container<int>::new();
    c.push(42);

    if (c.data != null) {
        printf("data_ptr_ok\n");
    }
    printf("val=%d\n", c.peek());

    c.drop();
    return 0;
}
