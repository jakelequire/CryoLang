// @test: generic_struct_while_loop
// @expect: compile_success
// @mode: raw
// @stdout: 3
// @stdout: 10
// @stdout: 20
// @stdout: 30
// @tags: generics, structs, while, mutation

namespace GenStructWhile;

type struct Stack<T> {
    data: T*;
    count: int;
    capacity: int;

    get(&this, index: int) -> T {
        return this.data[index];
    }

    size(&this) -> int {
        return this.count;
    }
}

function print_all(s: Stack<int>) -> void {
    printf("%d\n", s.size());
    mut i: int = 0;
    while (i < s.count) {
        printf("%d\n", s.get(i));
        i = i + 1;
    }
}

function main() -> int {
    mut arr: int[3] = [10, 20, 30];
    const s: Stack<int> = Stack<int> { data: &arr[0], count: 3, capacity: 3 };
    print_all(s);
    return 0;
}
