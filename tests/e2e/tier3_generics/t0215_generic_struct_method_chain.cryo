// @test: generic_struct_method_chain
// @expect: compile_success
// @mode: raw
// @stdout: 3
// @stdout: 7
// @tags: generics, structs, methods

namespace GenStructChain;

type struct Counter<T> {
    value: T;
    count: int;

    static new(v: T) -> Counter<T> {
        return Counter { value: v, count: 0 };
    }

    get_value(&this) -> T {
        return this.value;
    }

    get_count(&this) -> int {
        return this.count;
    }

    inc(mut &this) -> void {
        this.count = this.count + 1;
    }
}

function main() -> int {
    mut c: Counter<int> = Counter<int>::new(7);
    c.inc();
    c.inc();
    c.inc();
    printf("%d\n", c.get_count());
    printf("%d\n", c.get_value());
    return 0;
}
