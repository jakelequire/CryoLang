// @test: generic_struct_i64
// @expect: compile_success
// @mode: raw
// @stdout: 1000000
// @tags: generics, structs, types

namespace GenStructI64;

type struct Holder<T> {
    value: T;

    static new(v: T) -> Holder<T> {
        return Holder { value: v };
    }

    get(&this) -> T {
        return this.value;
    }
}

function main() -> int {
    const h: Holder<i64> = Holder<i64>::new(1000000);
    printf("%ld\n", h.get());
    return 0;
}
