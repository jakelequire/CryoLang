// @test: generic_enum_method_local_var
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @tags: generics, enums, implement_blocks, methods

namespace GenEnumMethodLocal;

enum Maybe<T> {
    Just(T);
    Nothing;
}

implement Maybe<T> {
    replace(mut &this, value: T) -> Maybe<T> {
        const old: Maybe<T> = this;
        this = Maybe::Just(value);
        return old;
    }
}

function main() -> int {
    mut x: Maybe<int> = Maybe::Just(10);
    const prev: Maybe<int> = x.replace(42);

    match (prev) {
        Maybe::Just(v) => { printf("%d\n", v); }
        Maybe::Nothing => { printf("nothing\n"); }
        _ => { printf("error\n"); }
    }
    return 0;
}
