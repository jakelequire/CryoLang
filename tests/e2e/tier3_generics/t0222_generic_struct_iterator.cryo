// @test: generic_struct_iterator
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: 20
// @stdout: 30
// @tags: generics, structs, iterator, methods

namespace GenStructIter;

type struct Node<T> {
    value: T;

    static new(v: T) -> Node<T> {
        return Node<T> { value: v };
    }

    get(&this) -> T {
        return this.value;
    }
}

type struct NodeIter<T> {
    data: Node<T>*;
    pos: int;
    len: int;

    static new(d: Node<T>*, n: int) -> NodeIter<T> {
        return NodeIter<T> { data: d, pos: 0, len: n };
    }

    has_next(&this) -> int {
        if (this.pos < this.len) {
            return 1;
        }
        return 0;
    }

    next(mut &this) -> T {
        const idx: int = this.pos;
        this.pos = this.pos + 1;
        return this.data[idx].value;
    }
}

function main() -> int {
    mut nodes: Node<int>[3] = [
        Node<int>::new(10),
        Node<int>::new(20),
        Node<int>::new(30)
    ];
    mut it: NodeIter<int> = NodeIter<int>::new(&nodes[0], 3);
    while (it.has_next()) {
        printf("%d\n", it.next());
    }
    return 0;
}
