// @test: type_alias_generic_nested
// @expect: compile_success
// @mode: raw
// @stdout: has_value
// @stdout: empty
// @tags: generics, types, alias, pointers, stdlib_bug
// @description: Isolates type alias of generic wrapping another generic (Option containing ptr alias)

namespace TypeAliasGenNested;

enum Option<T> {
    Some(T);
    None;
}

enum Result<T, E> {
    Ok(T);
    Err(E);
}

type MaybePtr = Option<void*>;

function check(m: MaybePtr) -> void {
    match (m) {
        Option::Some(p) => {
            printf("has_value\n");
        }
        Option::None => {
            printf("empty\n");
        }
        _ => {}
    }
}

function main() -> int {
    const data: int = 42;
    const a: MaybePtr = Option::Some(&data);
    check(a);

    const b: MaybePtr = Option::None;
    check(b);
    return 0;
}
