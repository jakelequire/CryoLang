// @test: generic_enum_unwrap
// @expect: compile_success
// @mode: raw
// @stdout: 42
// @tags: generics, enums, match
// @xfail: Generic enum payload extraction may not work in raw mode

namespace GenEnumUnwrap;

enum Maybe<T> {
    Just(T);
    Empty;
}

function unwrap_maybe(m: Maybe<int>) -> int {
    match (m) {
        Maybe::Just(v) => { return v; },
        Maybe::Empty => { return -1; },
    }
}

function main() -> int {
    const a: Maybe<int> = Maybe::Just(42);
    printf("%d\n", unwrap_maybe(a));
    return 0;
}
