// @test: generic_overload_noarg_first
// @expect: compile_success
// @mode: raw
// @stdout: 0
// @stdout: 100
// @tags: generics, structs, overload
//
// Tests that calling the no-arg overload FIRST (before the parameterized one)
// resolves correctly. The codegen registers overloads in declaration order;
// this verifies the first-declared no-arg variant is found.

namespace GenOverloadNoargFirst;

type struct Stack<T> {
    size: int;
    top: T;

    static new() -> Stack<T> {
        return Stack { size: 0, top: 0 };
    }

    static new(initial: T) -> Stack<T> {
        return Stack { size: 1, top: initial };
    }

    get_size(&this) -> int {
        return this.size;
    }

    get_top(&this) -> T {
        return this.top;
    }
}

function main() -> int {
    // Call no-arg first
    const empty: Stack<int> = Stack<int>::new();
    printf("%d\n", empty.get_size());

    // Then call with-arg
    const full: Stack<int> = Stack<int>::new(100);
    printf("%d\n", full.get_top());

    return 0;
}
