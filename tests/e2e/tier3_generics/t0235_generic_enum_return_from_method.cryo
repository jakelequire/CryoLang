// @test: generic_enum_return_from_method
// @expect: compile_success
// @mode: raw
// @stdout: 1
// @stdout: 0
// @tags: generics, enums, implement, return
//
// Tests returning a generic enum from a struct method.
// Combines generic struct + generic enum return, exercising
// the path where TypeMapper and GenericCodegen may create
// different LLVM named struct types for the same enum.

namespace GenEnumRetMethod;

enum Maybe<T> {
    Some(T);
    None;
}

implement enum Maybe<T> {
    is_some(&this) -> int {
        match (&this) {
            Maybe::Some(_) => { return 1; }
            Maybe::None => { return 0; }
            _ => { return 0; }
        }
    }
}

type struct Parser<T> {
    value: T;

    static new(v: T) -> Parser<T> {
        return Parser { value: v };
    }

    try_get(&this) -> Maybe<T> {
        return Maybe::Some(this.value);
    }

    try_empty(&this) -> Maybe<T> {
        return Maybe::None;
    }
}

function main() -> int {
    const p: Parser<int> = Parser<int>::new(42);
    const got: Maybe<int> = p.try_get();
    const empty: Maybe<int> = p.try_empty();
    printf("%d\n", got.is_some());
    printf("%d\n", empty.is_some());
    return 0;
}
