// @test: type_alias_generic_ptr_param
// @expect: compile_success
// @mode: raw
// @stdout: got_ptr
// @stdout: got_error
// @tags: generics, types, alias, pointers, stdlib_bug
// @description: Isolates type alias of generic with pointer type parameter (like Result<void*, AllocError>)

namespace TypeAliasGenPtrParam;

enum Outcome<T, E> {
    Ok(T);
    Err(E);
}

type PtrOutcome = Outcome<void*, int>;

function main() -> int {
    const data: int = 42;
    const ptr: void* = &data;
    const ok: PtrOutcome = Outcome::Ok(ptr);
    match (ok) {
        Outcome::Ok(p) => {
            printf("got_ptr\n");
        }
        Outcome::Err(e) => {
            printf("error:%d\n", e);
        }
        _ => {}
    }

    const err: PtrOutcome = Outcome::Err(99);
    match (err) {
        Outcome::Ok(p) => {
            printf("got_ptr\n");
        }
        Outcome::Err(e) => {
            printf("got_error\n");
        }
        _ => {}
    }
    return 0;
}
