// @test: generic_nested_array_field
// @expect: compile_success
// @mode: raw
// @stdout: found:hello
// @stdout: found:world
// @stdout: not_found
// @tags: generics, structs, arrays, member_access, indexing, nested

namespace GenNestedArrField;

const EMPTY: int = 0;
const OCCUPIED: int = 1;
const DELETED: int = 2;

type struct Bucket<K, V> {
    key: K;
    value: V;
    state: int;
}

type struct SimpleMap<K, V> {
    entries: Bucket<K, V>*;
    cap: int;

    static new(cap: int) -> SimpleMap<K, V> {
        const ptr: Bucket<K, V>* = calloc(cap, sizeof(Bucket<K, V>));
        return SimpleMap { entries: ptr, cap: cap };
    }

    set(mut &this, idx: int, key: K, value: V) -> void {
        this.entries[idx].key = key;
        this.entries[idx].value = value;
        this.entries[idx].state = OCCUPIED;
    }

    find(&this, key: int) -> string {
        mut i: int = 0;
        while (i < this.cap) {
            if (this.entries[i].state == OCCUPIED) {
                if (this.entries[i].key == key) {
                    return this.entries[i].value;
                }
            }
            i = i + 1;
        }
        return "not_found";
    }

    drop(mut &this) -> void {
        free(this.entries);
    }
}

function main() -> int {
    mut m: SimpleMap<int, string> = SimpleMap<int, string>::new(4);
    m.set(0, 1, "hello");
    m.set(1, 2, "world");

    printf("found:%s\n", m.find(1));
    printf("found:%s\n", m.find(2));
    printf("%s\n", m.find(3));
    m.drop();
    return 0;
}
