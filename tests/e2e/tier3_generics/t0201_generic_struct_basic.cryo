// @test: generic_struct_basic
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: 20
// @tags: generics, structs

namespace GenStructBasic;

type struct Pair<T> {
    first: T;
    second: T;

    static new(a: T, b: T) -> Pair<T> {
        return Pair { first: a, second: b };
    }
}

function main() -> int {
    const p: Pair<int> = Pair<int>::new(10, 20);
    printf("%d\n", p.first);
    printf("%d\n", p.second);
    return 0;
}
