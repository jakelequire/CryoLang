// @test: generic_type_alias_method
// @expect: compile_success
// @mode: raw
// @stdout: 42
// @stdout: error
// @tags: generics, enums, type_alias

namespace GenTypeAlias;

enum Result<T, E> {
    Ok(T);
    Err(E);
}

implement enum Result<T, E> {
    unwrap_or(&this, default: T) -> T {
        match (&this) {
            Result::Ok(v) => { return v; }
            Result::Err(_) => { return default; }
            _ => { return default; }
        }
    }

    is_ok(&this) -> int {
        match (&this) {
            Result::Ok(_) => { return 1; }
            _ => { return 0; }
        }
    }
}

type IntResult = Result<int, string>;

function parse_int(s: string) -> IntResult {
    if (s == "42") {
        return Result::Ok(42);
    }
    return Result::Err("parse error");
}

function main() -> int {
    const r1: IntResult = parse_int("42");
    printf("%d\n", r1.unwrap_or(0));

    const r2: IntResult = parse_int("abc");
    if (r2.is_ok() == 0) {
        printf("error\n");
    }
    return 0;
}
