// @test: type_alias_generic_fn_sig
// @expect: compile_success
// @mode: raw
// @stdout: value:100
// @stdout: err:bad input
// @tags: generics, types, alias, stdlib_bug
// @description: Isolates generic type alias used in function parameter and return positions

namespace TypeAliasGenFnSig;

enum Result<T, E> {
    Ok(T);
    Err(E);
}

type IntResult = Result<int, string>;

function parse(input: int) -> IntResult {
    if (input > 0) {
        return Result::Ok(input);
    }
    return Result::Err("bad input");
}

function describe(r: IntResult) -> void {
    match (r) {
        Result::Ok(v) => {
            printf("value:%d\n", v);
        }
        Result::Err(e) => {
            printf("err:%s\n", e);
        }
        _ => {}
    }
}

function main() -> int {
    const a: IntResult = parse(100);
    describe(a);
    const b: IntResult = parse(-1);
    describe(b);
    return 0;
}
