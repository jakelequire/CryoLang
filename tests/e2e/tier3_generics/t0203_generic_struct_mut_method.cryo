// @test: generic_struct_mut_method
// @expect: compile_success
// @mode: raw
// @stdout: 10
// @stdout: 99
// @tags: generics, structs, mutation

namespace GenStructMut;

type struct Box<T> {
    value: T;

    static new(v: T) -> Box<T> {
        return Box { value: v };
    }

    get(&this) -> T {
        return this.value;
    }

    set(mut &this, v: T) -> void {
        this.value = v;
    }
}

function main() -> int {
    mut b: Box<int> = Box<int>::new(10);
    printf("%d\n", b.get());
    b.set(99);
    printf("%d\n", b.get());
    return 0;
}
