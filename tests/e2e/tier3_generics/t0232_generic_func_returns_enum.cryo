// @test: generic_func_returns_enum
// @expect: compile_success
// @mode: raw
// @stdout: has:10
// @stdout: has:99
// @tags: generics, functions, enums

namespace GenFuncRetEnum;

enum Maybe<T> {
    Just(T);
    Nothing;
}

function make<T>(v: T) -> Maybe<T> {
    return Maybe::Just(v);
}

function main() -> int {
    const a: Maybe<int> = make<int>(10);
    const b: Maybe<int> = make<int>(99);

    match (a) {
        Maybe::Just(v) => { printf("has:%d\n", v); }
        Maybe::Nothing => { printf("empty\n"); }
        _ => { printf("error\n"); }
    }

    match (b) {
        Maybe::Just(v) => { printf("has:%d\n", v); }
        Maybe::Nothing => { printf("empty\n"); }
        _ => { printf("error\n"); }
    }
    return 0;
}
