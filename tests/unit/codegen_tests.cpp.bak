CRYO_TEST(Codegen, BasicIRGeneration) {

    IntegrationTestHelper helper;using namespace CryoTest;

    helper.setup();

#include <llvm/IR/Module.h>

    std::string source = R"(

        function main() -> int {// ============================================================================

            return 42;

        }// Code Generation Testsusing namespace CryoTest;#include <llvm/IR/Function.h>

    )";

    // ============================================================================

    bool success = helper.compiles_to_ir(source);

    CRYO_EXPECT_TRUE(success);
    CRYO_EXPECT_FALSE(helper.has_errors());
}

CRYO_TEST(Codegen, FunctionWithParameters) {
    IntegrationTestHelper helper;

    helper.setup();

    std::string source = R"(
        function add(x: int, y: int) -> int {
            return x + y;
        }
    )";

    

    bool success = helper.compiles_to_ir(source);
    CRYO_EXPECT_TRUE(success);
    CRYO_EXPECT_FALSE(helper.has_errors());
}

