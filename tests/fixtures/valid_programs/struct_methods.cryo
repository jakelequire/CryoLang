namespace Main;

import IO from <io/stdio>;

type struct Point {
    x: int;
    y: int;
    
    Point(_x: int, _y: int);
    ~Point() default;
    move(dx: int, dy: int) -> void;
    distance_from_origin() -> float;
}

implement struct Point {
    Point(_x: int, _y: int) {
        this.x = _x;
        this.y = _y;
    }

    move(dx: int, dy: int) -> void {
        this.x = this.x + dx;
        this.y = this.y + dy;
    }
    
    distance_from_origin() -> float {
        const x_sq: float = float(this.x * this.x);
        const y_sq: float = float(this.y * this.y);
        // Simple approximation for sqrt
        return x_sq + y_sq;
    }
}

function main() -> int {
    // Struct creation
    const p1: Point = new Point(10, 20);
    
    // Struct field access
    IO::println("Point coordinates:");
    IO::print_int(p1.x);  // 10
    IO::print_int(p1.y);  // 20
    
    // Method call (commented out due to implementation limitations)
    // p1.move(5, -10);
    // IO::println("After move:");
    // IO::print_int(p1.x);  // 15
    // IO::print_int(p1.y);  // 10
    
    return 0;
}