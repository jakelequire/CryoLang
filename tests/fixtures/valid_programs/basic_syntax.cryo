namespace Main;

import IO from <io/stdio>;
import <core/types>;

// Basic variable declarations and assignments
function test_basic_variables() -> void {
    const x: int = 42;
    mut y: int = 10;
    y = y + 5;
    const flag: boolean = true;
    const pi: float = 3.14;
    const name: string = "CryoLang";
    const letter: char = 'A';
    return;
}

// Basic arithmetic operations
function test_arithmetic() -> void {
    const a: int = 10;
    const b: int = 5;
    const sum: int = a + b;
    const diff: int = a - b;
    const product: int = a * b;
    const quotient: int = a / b;
    const remainder: int = a % b;
    return;
}

// Basic function calls
function add(x: int, y: int) -> int {
    return x + y;
}

function test_function_calls() -> void {
    const result: int = add(5, 3);
    return;
}

function main() -> int {
    test_basic_variables();
    test_arithmetic();
    test_function_calls();
    return 0;
}