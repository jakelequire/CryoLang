namespace Main;

import IO from <io/stdio>;
import <core/types>;

enum Color {
    RED,
    GREEN,
    BLUE,
    YELLOW
}

enum Shape {
    Circle(float),
    Rectangle(float, float),
    Triangle(float, float, float)
}

function test_basic_enum() -> void {
    const my_color: Color = Color::RED;
    const is_red: boolean = my_color == Color::RED;
    return;
}

function test_complex_enum() -> void {
    const circle: Shape = Shape::Circle(5.0);
    match circle {
        Shape::Circle(radius) => {
            const area: float = 3.14 * radius * radius;
        },
        Shape::Rectangle(width, height) => {
            const area: float = width * height;
        },
        Shape::Triangle(a, b, c) => {
            const s: float = (a + b + c) / 2.0;
        }
    }
    return;
}

function main() -> int {
    test_basic_enum();
    test_complex_enum();
    return 0;
}