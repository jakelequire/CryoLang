namespace Main;

import IO from <io/stdio>;

enum Color {
    RED,
    GREEN,
    BLUE
}

enum StatusCode {
    SUCCESS,
    ERROR,
    PENDING
}

enum Shape {
    Circle(float),
    Rectangle(float, float),
    Triangle(float, float, float)
}

function main() -> int {
    // Simple enums
    const primary_color: Color = Color::RED;
    const status: StatusCode = StatusCode::SUCCESS;
    
    // Enum comparisons
    const is_red: boolean = primary_color == Color::RED;
    const is_success: boolean = status == StatusCode::SUCCESS;
    
    IO::println("Enum Test Results:");
    IO::print_bool(is_red);     // true
    IO::print_bool(is_success); // true
    
    // Complex enum with data
    const circle: Shape = Shape::Circle(5.0);
    
    // Switch statement with enums
    switch (primary_color) {
        case Color::RED:
            IO::println("Color is RED");
            break;
        case Color::GREEN:
            IO::println("Color is GREEN");
            break;
        case Color::BLUE:
            IO::println("Color is BLUE");
            break;
        default:
            IO::println("Unknown color");
            break;
    }
    
    return 0;
}