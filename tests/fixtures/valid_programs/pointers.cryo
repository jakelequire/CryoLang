namespace Main;

import IO from <io/stdio>;
import <core/types>;

// Basic pointer operations
function test_address_of_and_dereference() -> void {
    mut x: int = 42;
    mut ptr: int* = &x;    // Address-of operator
    const val: int = *ptr; // Dereference operator
    
    IO::printf("Original value: %d\n", x);
    IO::printf("Value through pointer: %d\n", val);
    
    *ptr = 84; // Modify through pointer
    IO::printf("Modified value: %d\n", x);
    return;
}

// Array pointer arithmetic  
function test_array_pointer_arithmetic() -> void {
    mut arr: int[] = [10, 20, 30, 40, 50];
    mut ptr: int* = &arr[0];
    
    IO::printf("Array traversal via pointer arithmetic:\n");
    for (mut i: int = 0; i < 5; i++) {
        IO::printf("  arr[%d] = %d\n", i, *(ptr + i));
    }
    
    // Pointer increment/decrement
    ++ptr; // Move to arr[1]  
    IO::printf("After increment: %d\n", *ptr);
    
    ptr = ptr + 2; // Move to arr[3]
    IO::printf("After adding 2: %d\n", *ptr);
    
    --ptr; // Move back to arr[2]
    IO::printf("After decrement: %d\n", *ptr);
    return;
}

// Multiple levels of indirection
function test_pointer_to_pointer() -> void {
    mut value: int = 123;
    mut ptr: int* = &value;
    mut ptr_to_ptr: int** = &ptr;
    
    const indirect_value: int = **ptr_to_ptr;
    IO::printf("Value through double indirection: %d\n", indirect_value);
    
    **ptr_to_ptr = 456; // Modify through double pointer
    IO::printf("Modified value: %d\n", value);
    return;
}

// Pointer comparisons
function test_pointer_comparisons() -> void {
    mut arr: int[] = [1, 2, 3, 4, 5];
    mut ptr1: int* = &arr[1];
    mut ptr2: int* = &arr[3];
    
    if (ptr1 < ptr2) {
        IO::printf("ptr1 comes before ptr2 in memory\n");
    }
    
    const distance: int = ptr2 - ptr1; // Pointer difference
    IO::printf("Distance between pointers: %d elements\n", distance);
    return;
}

function main() -> int {
    IO::printf("=== Pointer Operations Test Suite ===\n");
    
    test_address_of_and_dereference();
    test_array_pointer_arithmetic();
    test_pointer_to_pointer();
    test_pointer_comparisons();
    
    IO::printf("All pointer tests completed.\n");
    return 0;
}