namespace Main;

import IO from <io/stdio>;
import <core/types>;

// Basic struct declaration and usage
type struct Point {
    x: int;
    y: int;
    
    Point(x_val: int, y_val: int);
    distance_from_origin() -> float;
}

implement Point {
    Point(x_val: int, y_val: int) {
        this.x = x_val;
        this.y = y_val;
    }
    
    distance_from_origin() -> float {
        const x_squared: float = float(this.x * this.x);
        const y_squared: float = float(this.y * this.y);
        // Simplified sqrt calculation for testing
        return x_squared + y_squared; // Not actual sqrt, just for testing
    }
}

// Struct with mixed data types
type struct GameEntity {
    id: int;
    health: float;
    active: boolean;
    name: string;
    
    GameEntity(entity_id: int, entity_name: string);
    take_damage(amount: float) -> void;
    is_alive() -> boolean;
}

implement GameEntity {
    GameEntity(entity_id: int, entity_name: string) {
        this.id = entity_id;
        this.name = entity_name;
        this.health = 100.0;
        this.active = true;
    }
    
    take_damage(amount: float) -> void {
        this.health = this.health - amount;
        if (this.health <= 0.0) {
            this.active = false;
            this.health = 0.0;
        }
    }
    
    is_alive() -> boolean {
        return this.active && this.health > 0.0;
    }
}

function test_basic_struct_operations() -> void {
    IO::printf("=== Basic Struct Operations ===\n");
    
    const p1: Point = Point(3, 4);
    const p2: Point = Point(10, 20);
    
    IO::printf("Point 1: (%d, %d)\n", p1.x, p1.y);
    IO::printf("Point 2: (%d, %d)\n", p2.x, p2.y);
    
    const sum_x: int = p1.x + p2.x;
    const sum_y: int = p1.y + p2.y;
    IO::printf("Sum: (%d, %d)\n", sum_x, sum_y);
    
    const distance1: float = p1.distance_from_origin();
    IO::printf("Distance from origin (approx): %f\n", distance1);
    return;
}

function test_struct_with_methods() -> void {
    IO::printf("\n=== Struct Methods Test ===\n");
    
    mut entity: GameEntity = GameEntity(1001, "Player");
    
    IO::printf("Entity %d (%s) health: %f\n", entity.id, entity.name, entity.health);
    IO::printf("Is alive: %s\n", entity.is_alive() ? "true" : "false");
    
    entity.take_damage(30.0);
    IO::printf("After taking 30 damage: %f health\n", entity.health);
    
    entity.take_damage(80.0);  // This should "kill" the entity
    IO::printf("After taking 80 more damage: %f health\n", entity.health);
    IO::printf("Is alive: %s\n", entity.is_alive() ? "true" : "false");
    return;
}

function test_struct_arrays() -> void {
    IO::printf("\n=== Struct Arrays Test ===\n");
    
    mut points: Point[] = [
        Point(1, 2),
        Point(3, 4),
        Point(5, 6)
    ];
    
    for (mut i: int = 0; i < 3; i++) {
        IO::printf("Point[%d]: (%d, %d)\n", i, points[i].x, points[i].y);
    }
    
    // Modify struct in array
    points[1].x = 10;
    points[1].y = 20;
    IO::printf("Modified Point[1]: (%d, %d)\n", points[1].x, points[1].y);
    return;
}

function main() -> int {
    test_basic_struct_operations();
    test_struct_with_methods();
    test_struct_arrays();
    
    IO::printf("\nAll struct tests completed successfully.\n");
    return 0;
}