namespace Main;

import IO from <io/stdio>;

trait Drawable {
    draw(self: &Drawable) -> void;
}

trait Colored {
    get_color(self: &Colored) -> string;
}

// Multiple inheritance example
trait Shape : Drawable, Colored {
    area(self: &Shape) -> float;
}

function main() -> int {
    IO::println("Trait definition test - compilation only");
    // Note: Trait implementation testing would require more complex setup
    
    return 0;
}