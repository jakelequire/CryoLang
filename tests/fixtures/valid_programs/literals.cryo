namespace Main;

import IO from <io/stdio>;

function main() -> int {
    // String literals and operations
    const greeting: string = "Hello, World!";
    const name: string = "Cryo";
    
    // Character literal
    const first_char: char = 'H';
    
    // Different integer types
    const small_int: i32 = 42;
    const big_int: i64 = 1234567890123456789;
    const hex_value: i64 = 0xFF;
    const binary_value: i32 = 0b1010;
    
    // Float literals
    const pi: float = 3.14;
    const scientific: float = 1.23e-4;
    
    // Boolean literals
    const flag: boolean = true;
    const not_flag: boolean = false;
    
    IO::println("Literal Tests:");
    IO::println(greeting);
    IO::print_int(small_int);
    IO::print_int(big_int);
    IO::print_int(hex_value);
    IO::print_float(pi);
    IO::print_bool(flag);
    
    return 0;
}