namespace Main;

import IO from <io/stdio>;
import <core/types>;

type struct GenericStruct<T> {
    value: T;
    GenericStruct(val: T) {
        this.value = val;
    }
    ~GenericStruct() default;
    get_value() -> T {
        return this.value;
    }
}

function generic_function<T>(item: T) -> T {
    return item;
}

function main() -> int {
    // Generic struct instantiation
    const int_instance: GenericStruct<int> = new GenericStruct<int>(42);
    const string_instance: GenericStruct<string> = new GenericStruct<string>("hello");
    
    IO::println("Generic Struct Test:");
    // Note: Method calls may not be fully implemented yet
    // IO::print_int(int_instance.get_value());
    // IO::println(string_instance.get_value());
    
    return 0;
}