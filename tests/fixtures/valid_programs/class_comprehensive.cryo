namespace Main;

import IO from <io/stdio>;
import <core/types>;

// Basic class with public and private members
type class BankAccount {
private:
    balance: float;
    account_number: int;
    
public:
    owner: string;
    
    BankAccount(number: int, initial_balance: float, owner_name: string) {
        this.account_number = number;
        this.balance = initial_balance;
        this.owner = owner_name;
    }
    
    ~BankAccount() default;
    
    deposit(amount: float) -> void {
        if (amount > 0.0) {
            this.balance = this.balance + amount;
        }
    }
    
    withdraw(amount: float) -> boolean {
        if (amount > 0.0 && amount <= this.balance) {
            this.balance = this.balance - amount;
            return true;
        }
        return false;
    }
    
    get_balance() -> float {
        return this.balance;
    }
    
    get_account_number() -> int {
        return this.account_number;
    }
    
    transfer_to(other_account: BankAccount*, amount: float) -> boolean {
        if (this.withdraw(amount)) {
            other_account.deposit(amount);
            return true;
        }
        return false;
    }
}

// Class demonstrating inheritance-like composition
type class Vehicle {
protected:
    speed: float;
    fuel: float;
    
public:
    make: string;
    model: string;
    
    Vehicle(vehicle_make: string, vehicle_model: string) {
        this.make = vehicle_make;
        this.model = vehicle_model;
        this.speed = 0.0;
        this.fuel = 100.0;
    }
    
    ~Vehicle() default;
    
    accelerate(amount: float) -> void {
        if (this.fuel > 0.0) {
            this.speed = this.speed + amount;
            this.fuel = this.fuel - (amount * 0.1);  // Consume fuel
        }
    }
    
    brake(amount: float) -> void {
        this.speed = this.speed - amount;
        if (this.speed < 0.0) {
            this.speed = 0.0;
        }
    }
    
    get_speed() -> float {
        return this.speed;
    }
    
    get_fuel() -> float {
        return this.fuel;
    }
    
    refuel() -> void {
        this.fuel = 100.0;
    }
}

// Class with static-like behavior using methods
type class MathUtils {
private:
    pi_value: float;
    
public:
    MathUtils() {
        this.pi_value = 3.14159;
    }
    
    circle_area(radius: float) -> float {
        return this.pi_value * radius * radius;
    }
    
    rectangle_area(width: float, height: float) -> float {
        return width * height;
    }
    
    max_of_three(a: int, b: int, c: int) -> int {
        mut max_val: int = a;
        if (b > max_val) {
            max_val = b;
        }
        if (c > max_val) {
            max_val = c;
        }
        return max_val;
    }
}

function test_bank_account_operations() -> void {
    IO::printf("=== Bank Account Class Test ===\n");
    
    mut account1: BankAccount = BankAccount(12345, 1000.0, "Alice");
    mut account2: BankAccount = BankAccount(67890, 500.0, "Bob");
    
    IO::printf("Account 1 (%s): $%.2f\n", account1.owner, account1.get_balance());
    IO::printf("Account 2 (%s): $%.2f\n", account2.owner, account2.get_balance());
    
    // Test deposits
    account1.deposit(200.0);
    IO::printf("After $200 deposit to account 1: $%.2f\n", account1.get_balance());
    
    // Test withdrawals
    const withdraw_success: boolean = account2.withdraw(100.0);
    IO::printf("Withdrawal from account 2: %s, Balance: $%.2f\n", 
               withdraw_success ? "Success" : "Failed", account2.get_balance());
    
    // Test transfer
    const transfer_success: boolean = account1.transfer_to(&account2, 300.0);
    IO::printf("Transfer $300 from account 1 to 2: %s\n", 
               transfer_success ? "Success" : "Failed");
    IO::printf("Account 1 balance: $%.2f\n", account1.get_balance());
    IO::printf("Account 2 balance: $%.2f\n", account2.get_balance());
    return;
}

function test_vehicle_class() -> void {
    IO::printf("\n=== Vehicle Class Test ===\n");
    
    mut car: Vehicle = Vehicle("Toyota", "Camry");
    
    IO::printf("Vehicle: %s %s\n", car.make, car.model);
    IO::printf("Initial speed: %.2f, Fuel: %.2f\n", car.get_speed(), car.get_fuel());
    
    // Test acceleration
    car.accelerate(30.0);
    IO::printf("After accelerating: Speed=%.2f, Fuel=%.2f\n", 
               car.get_speed(), car.get_fuel());
    
    car.accelerate(20.0);
    IO::printf("After more acceleration: Speed=%.2f, Fuel=%.2f\n", 
               car.get_speed(), car.get_fuel());
    
    // Test braking
    car.brake(15.0);
    IO::printf("After braking: Speed=%.2f, Fuel=%.2f\n", 
               car.get_speed(), car.get_fuel());
    
    // Test refueling
    car.refuel();
    IO::printf("After refueling: Speed=%.2f, Fuel=%.2f\n", 
               car.get_speed(), car.get_fuel());
    return;
}

function test_utility_class() -> void {
    IO::printf("\n=== Utility Class Test ===\n");
    
    const math: MathUtils = MathUtils();
    
    const circle_area: float = math.circle_area(5.0);
    IO::printf("Circle area (radius 5): %.2f\n", circle_area);
    
    const rect_area: float = math.rectangle_area(4.0, 6.0);
    IO::printf("Rectangle area (4x6): %.2f\n", rect_area);
    
    const max_val: int = math.max_of_three(15, 8, 23);
    IO::printf("Max of (15, 8, 23): %d\n", max_val);
    return;
}

function test_class_arrays_and_pointers() -> void {
    IO::printf("\n=== Class Arrays and Pointers Test ===\n");
    
    mut accounts: BankAccount[] = [
        BankAccount(1001, 500.0, "Charlie"),
        BankAccount(1002, 750.0, "Diana"),
        BankAccount(1003, 1200.0, "Eve")
    ];
    
    // Test array access
    for (mut i: int = 0; i < 3; i++) {
        IO::printf("Account %d: %s has $%.2f\n", 
                   accounts[i].get_account_number(),
                   accounts[i].owner, 
                   accounts[i].get_balance());
    }
    
    // Test pointer operations
    mut account_ptr: BankAccount* = &accounts[1];
    account_ptr.deposit(250.0);
    IO::printf("After pointer deposit: %s has $%.2f\n",
               account_ptr.owner, account_ptr.get_balance());
    
    // Verify the change was made to the original
    IO::printf("Original array element: %s has $%.2f\n",
               accounts[1].owner, accounts[1].get_balance());
    return;
}

function main() -> int {
    test_bank_account_operations();
    test_vehicle_class();
    test_utility_class();
    test_class_arrays_and_pointers();
    
    IO::printf("\nAll class tests completed successfully.\n");
    return 0;
}