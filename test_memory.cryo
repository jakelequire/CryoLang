namespace TestMemory;

import <core/intrinsics>;
import <core/memory>;



function main() -> int {
    const str: string = "Hello, CryoLang!";
    // Test if we can at least use the full qualified name first
    const str_ptr: string* = std::Intrinsics::__malloc__(sizeof(string));
    *str_ptr = str;
    
    const box: Box<string> = Box<string>(str_ptr);

    return 0;
}

