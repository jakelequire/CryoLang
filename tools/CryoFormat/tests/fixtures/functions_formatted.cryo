// Test fixture for function declarations
function main() -> int {
    return 0;
}

function add(a: int, b: int) -> int {
    return a + b;
}

function greet(name: string) -> void {
    print("Hello " + name);
}

function complex(x: int, y: string, z: boolean) -> int {
    if (z) {
        return x + 1;
    } else {
        return x - 1;
    }
}