{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CryoLang",
  "scopeName": "source.cryo",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#identifiers"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.cryo",
          "begin": "//",
          "end": "$",
          "patterns": [
            {
              "name": "constant.character.escape.cryo",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "comment.block.cryo",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "include": "#comments"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cryo",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cryo",
              "match": "\\\\[\"'\\\\nrt0]"
            },
            {
              "name": "constant.character.escape.cryo",
              "match": "\\\\x[0-9a-fA-F]{2}"
            },
            {
              "name": "constant.character.escape.cryo",
              "match": "\\\\u[0-9a-fA-F]{4}"
            }
          ]
        },
        {
          "name": "string.quoted.single.cryo",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.cryo",
              "match": "\\\\[\"'\\\\nrt0]"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.cryo",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.cryo",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.octal.cryo",
          "match": "\\b0[oO][0-7]+\\b"
        },
        {
          "name": "constant.numeric.float.cryo",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?[fF]?\\b"
        },
        {
          "name": "constant.numeric.integer.cryo",
          "match": "\\b[0-9]+[uUlL]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cryo",
          "match": "\\b(if|else|for|while|loop|break|continue|return|match|case|default|try|catch|finally|throw)\\b"
        },
        {
          "name": "keyword.declaration.cryo",
          "match": "\\b(function|var|mut|const|let|type|class|struct|enum|interface|namespace|import|export|extern|public|private|protected|static|virtual|override|abstract)\\b"
        },
        {
          "name": "keyword.operator.cryo",
          "match": "\\b(and|or|not|in|is|as|sizeof|typeof|new|delete)\\b"
        },
        {
          "name": "constant.language.cryo",
          "match": "\\b(true|false|null|this|super)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.cryo",
          "match": "\\b(int|i8|i16|i32|i64|uint|u8|u16|u32|u64|float|f32|f64|double|bool|char|string|void)\\b"
        },
        {
          "name": "storage.type.cryo",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.cryo",
          "match": "(=|\\+=|-=|\\*=|/=|%=|\\|=|&=|\\^=|<<=|>>=)"
        },
        {
          "name": "keyword.operator.comparison.cryo",
          "match": "(==|!=|<|<=|>|>=)"
        },
        {
          "name": "keyword.operator.arithmetic.cryo",
          "match": "(\\+|\\-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.logical.cryo",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.bitwise.cryo",
          "match": "(&|\\||\\^|~|<<|>>)"
        },
        {
          "name": "keyword.operator.increment.cryo",
          "match": "(\\+\\+|\\-\\-)"
        },
        {
          "name": "keyword.operator.access.cryo",
          "match": "(\\.|->|::)"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.function.cryo",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        },
        {
          "name": "variable.other.cryo",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.cryo",
          "match": "[,;]"
        },
        {
          "name": "punctuation.definition.parameters.begin.cryo",
          "match": "\\("
        },
        {
          "name": "punctuation.definition.parameters.end.cryo",
          "match": "\\)"
        },
        {
          "name": "punctuation.definition.block.begin.cryo",
          "match": "\\{"
        },
        {
          "name": "punctuation.definition.block.end.cryo",
          "match": "\\}"
        },
        {
          "name": "punctuation.definition.array.begin.cryo",
          "match": "\\["
        },
        {
          "name": "punctuation.definition.array.end.cryo",
          "match": "\\]"
        }
      ]
    }
  }
}