{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Cryo",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#enums"
        },
        {
            "include": "#scope-resolution"
        },
        {
            "include": "#types"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#identifiers"
        }
    ],
    "repository": {
        "enums": {
            "patterns": [
                {
                    "name": "meta.enum.cryo",
                    "begin": "\\b(enum)\\s+([A-Z][a-zA-Z0-9_]*)\\s*\\{",
                    "end": "\\}",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.declaration.cryo"
                        },
                        "2": {
                            "name": "entity.name.type.cryo"
                        }
                    },
                    "patterns": [
                        {
                            "name": "entity.name.function.cryo",
                            "match": "\\b[A-Z][a-zA-Z0-9_]*\\b(?=\\s*\\()"
                        },
                        {
                            "name": "entity.name.type.variant.cryo",
                            "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
                        },
                        {
                            "include": "#comments"
                        },
                        {
                            "include": "#types"
                        }
                    ]
                }
            ]
        },
        "scope-resolution": {
            "patterns": [
                {
                    "name": "meta.scope-resolution.cryo",
                    "match": "([A-Za-z_][A-Za-z0-9_]*)(::)([A-Za-z_][A-Za-z0-9_]*)(?=\\s*\\()",
                    "captures": {
                        "1": {
                            "name": "entity.name.type.cryo"
                        },
                        "2": {
                            "name": "punctuation.accessor.cryo"
                        },
                        "3": {
                            "name": "entity.name.function.cryo"
                        }
                    }
                },
                {
                    "name": "meta.scope-resolution.cryo",
                    "match": "([A-Za-z_][A-Za-z0-9_]*)(::)([A-Za-z_][A-Za-z0-9_]*)",
                    "captures": {
                        "1": {
                            "name": "entity.name.type.cryo"
                        },
                        "2": {
                            "name": "punctuation.accessor.cryo"
                        },
                        "3": {
                            "name": "entity.name.type.variant.cryo"
                        }
                    }
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.cryo",
                    "match": "\\b(if|else|while|for|switch|loop|break|continue|return|match|case|default|new|delete)\\b"
                },
                {
                    "name": "keyword.declaration.cryo",
                    "match": "\\b(function|public|private|intrinsic|static|volatile|const|unsigned|mut|let|struct|class|extern|enum|impl|trait|module|import|export|namespace|type|implement)\\b"
                },
                {
                    "name": "keyword.other.cryo",
                    "match": "\\b(this|super|null|undefined|true|false)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "entity.name.type.cryo",
                    "match": "\\b(int|float|double|string|char|boolean|void|i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|uint8|uint16|uint32|uint64|ptr|const_ptr)\\b"
                },
                {
                    "name": "entity.name.type.cryo",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b(?!\\s*::)"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "meta.function.cryo",
                    "begin": "\\b(function|fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.declaration.function.cryo"
                        },
                        "2": {
                            "name": "entity.name.function.cryo"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#parameters"
                        }
                    ]
                },
                {
                    "name": "entity.name.function.call.cryo",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
                }
            ]
        },
        "parameters": {
            "patterns": [
                {
                    "name": "variable.parameter.cryo",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                },
                {
                    "include": "#types"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.cryo",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.cryo",
                            "match": "\\\\(n|r|t|\\\\|\"|'|0|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4})"
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.cryo",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.cryo",
                            "match": "\\\\(n|r|t|\\\\|\"|'|0|x[0-9a-fA-F]{2})"
                        }
                    ]
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.cryo",
                    "begin": "//",
                    "end": "$",
                    "patterns": [
                        {
                            "name": "markup.bold.comment.cryo",
                            "match": "\\b(TODO|FIXME|NOTE|HACK|XXX)\\b"
                        }
                    ]
                },
                {
                    "name": "comment.block.cryo",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "patterns": [
                        {
                            "name": "markup.bold.comment.cryo",
                            "match": "\\b(TODO|FIXME|NOTE|HACK|XXX)\\b"
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.cryo",
                    "match": "\\b0[xX][0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.binary.cryo",
                    "match": "\\b0[bB][01]+\\b"
                },
                {
                    "name": "constant.numeric.octal.cryo",
                    "match": "\\b0[oO][0-7]+\\b"
                },
                {
                    "name": "constant.numeric.float.cryo",
                    "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?[fFdD]?\\b"
                },
                {
                    "name": "constant.numeric.integer.cryo",
                    "match": "\\b\\d+([eE][+-]?\\d+)?[ulUL]*\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.cryo",
                    "match": "(=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=)"
                },
                {
                    "name": "keyword.operator.comparison.cryo",
                    "match": "(==|!=|<|<=|>|>=)"
                },
                {
                    "name": "keyword.operator.logical.cryo",
                    "match": "(&&|\\|\\||!)"
                },
                {
                    "name": "keyword.operator.arithmetic.cryo",
                    "match": "(\\+|-|\\*|/|%)"
                },
                {
                    "name": "keyword.operator.bitwise.cryo",
                    "match": "(&|\\||\\^|~|<<|>>)"
                },
                {
                    "name": "keyword.operator.arrow.cryo",
                    "match": "(-&gt;|=&gt;)"
                },
                {
                    "name": "punctuation.accessor.cryo",
                    "match": "::"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "variable.other.constant.cryo",
                    "match": "\\b[A-Z][A-Z0-9_]*\\b"
                },
                {
                    "name": "entity.name.function.cryo",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b(?=\\s*\\()"
                },
                {
                    "name": "entity.name.type.variant.cryo",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b(?=\\s*[,})]|$)"
                },
                {
                    "name": "variable.other.cryo",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    },
    "scopeName": "source.cryo"
}