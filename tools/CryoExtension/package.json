{
    "name": "cryo-language-support",
    "displayName": "Cryo Language Support",
    "description": "Language support for Cryo programming language",
    	"version": "0.1.3",
    "publisher": "cryolang",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "activationEvents": [
        "onLanguage:cryo"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "cryo",
                "aliases": [
                    "Cryo",
                    "cryo"
                ],
                "extensions": [
                    ".cryo"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "cryo",
                "scopeName": "source.cryo",
                "path": "./syntaxes/cryo.tmLanguage.json"
            }
        ],
        "commands": [
            {
                "command": "cryo.restartLanguageServer",
                "title": "Restart Language Server",
                "category": "Cryo"
            },
            {
                "command": "cryo.shutdownLanguageServer", 
                "title": "Shutdown Language Server",
                "category": "Cryo"
            },
            {
                "command": "cryo.stopLanguageClient",
                "title": "Stop Language Client (Dev Build)",
                "category": "Cryo"
            },
            {
                "command": "cryo.disableExtension",
                "title": "Disable Extension (Nuclear Option)",
                "category": "Cryo"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "16.x",
        "@types/vscode": "^1.74.0",
        "typescript": "^4.9.4"
    },
    "dependencies": {
        "vscode-languageclient": "^8.1.0"
    }
}