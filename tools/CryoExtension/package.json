{
  "name": "cryo-language-support",
  "displayName": "CryoLang Language Support",
  "description": "Language support for CryoLang programming language",
  "version": "0.1.0",
  "publisher": "cryolang",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "cryolang",
    "cryo",
    "programming",
    "language",
    "compiler"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cryo",
        "aliases": [
          "CryoLang",
          "cryo"
        ],
        "extensions": [
          ".cryo"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cryo",
        "scopeName": "source.cryo",
        "path": "./syntaxes/cryo.tmGrammar.json"
      }
    ],
    "commands": [
      {
        "command": "cryo.restartLanguageServer",
        "title": "Restart CryoLang Language Server",
        "category": "CryoLang"
      },
      {
        "command": "cryo.shutdownLanguageServer",
        "title": "Shutdown CryoLang Language Server",
        "category": "CryoLang"
      },
      {
        "command": "cryo.disableLanguageServer",
        "title": "Disable CryoLang Language Server",
        "category": "CryoLang"
      },
      {
        "command": "cryo.enableLanguageServer",
        "title": "Enable CryoLang Language Server",
        "category": "CryoLang"
      },
      {
        "command": "cryo.openLogFile",
        "title": "Open CryoLang Language Server Log",
        "category": "CryoLang"
      },
      {
        "command": "cryo.killAllProcesses",
        "title": "Kill All CryoLSP Processes",
        "category": "CryoLang"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "CryoLang Configuration",
      "properties": {
        "cryo.languageServer.path": {
          "type": "string",
          "default": "",
          "description": "Path to the CryoLSP language server executable. If empty, searches in workspace and PATH."
        },
        "cryo.languageServer.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging for the language server"
        },

        "cryo.languageServer.autoRestart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically restart the language server if it crashes or stops unexpectedly"
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage:cryo"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.4",
    "@vscode/test-electron": "^2.2.0",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cryolang/cryo.git"
  },
  "bugs": {
    "url": "https://github.com/cryolang/cryo/issues"
  },
  "homepage": "https://github.com/cryolang/cryo#readme",
  "license": "MIT"
}