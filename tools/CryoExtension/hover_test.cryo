// Test file for Cryo LSP hover functionality
namespace TestHover;

// Function with documentation
function add_numbers(x: int, y: int) -> int {
    // This function adds two integers together
    const result: int = x + y;
    return result;
}

// Variable with type annotation
const PI: float = 3.14159;

// Struct for testing
struct Point {
    x: int,
    y: int,
    
    function distance() -> float {
        // Calculate distance from origin
        return PI * 2.0;
    }
}

// Test function with complex types
