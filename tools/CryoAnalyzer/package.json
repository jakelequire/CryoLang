{
  "name": "cryo-analyzer",
  "displayName": "CryoLang",
  "description": "Language support for the Cryo programming language",
  "version": "1.0.0",
  "publisher": "cryolang",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:cryo"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cryo",
        "aliases": [
          "Cryo",
          "cryo",
          "CryoLang"
        ],
        "extensions": [
          ".cryo"
        ],
        "configuration": "./language/language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cryo",
        "scopeName": "source.cryo",
        "path": "./syntaxes/cryo.tmGrammar.json"
      }
    ],
    "configuration": {
      "title": "CryoLang",
      "properties": {
        "cryo.languageServer.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable the CryoLSP language server"
        },
        "cryo.languageServer.path": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "description": "Absolute path to the CryoLSP binary (e.g. C:\\Programming\\apps\\CryoLang\\bin\\cryolsp.exe). Set this in User settings so it applies across all workspaces. Leave empty for auto-detection."
        },
        "cryo.languageServer.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging for the language server"
        },
        "cryo.languageServer.logFile": {
          "type": "string",
          "default": "",
          "description": "Path to a log file for LSP server output"
        }
      }
    },
    "commands": [
      {
        "command": "cryo.restartLanguageServer",
        "title": "Cryo: Restart Language Server"
      },
      {
        "command": "cryo.shutdownLanguageServer",
        "title": "Cryo: Shutdown Language Server"
      },
      {
        "command": "cryo.showOutputChannel",
        "title": "Cryo: Show Output"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.mjs",
    "check-types": "tsc --noEmit",
    "watch": "node esbuild.mjs --watch",
    "package": "npm run check-types && node esbuild.mjs --production",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0"
  }
}
