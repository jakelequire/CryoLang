{
  "name": "@cryolang/wasm-compiler",
  "version": "0.1.0", 
  "description": "CryoLang WebAssembly compiler for web applications",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "wasm/",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:wasm": "make -f ../wasm.makefile.config wasm-release",
    "dev": "rollup -c --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "type-check": "tsc --noEmit",
    "prepare": "npm run build:wasm && npm run build",
    "serve": "serve dist -s -p 8080"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/emscripten": "^1.39.10",
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rollup": "^4.12.0",
    "serve": "^14.2.1",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "monaco-editor": "^0.45.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./wasm": "./wasm/cryo-compiler.js"
  },
  "keywords": [
    "cryolang",
    "compiler", 
    "webassembly",
    "wasm",
    "programming-language",
    "playground"
  ],
  "author": "CryoLang Team",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jakelequire/CryoLang.git",
    "directory": "web-package"
  },
  "browser": {
    "fs": false,
    "path": false
  }
}