namespace Main;


/**
 * This is a documentation comment for the function below.
 */
function doc_function() -> void {
    return;
}

/// This is a single-line documentation comment for the function below.
/// But it can still be chained to the next line.
function single_line_doc() -> void {
    return;
}

// This is a regular comment, this should not be treated as documentation.
function regular_comment() -> void {
    return;
}

function function_param_names(something: int, another_thing: string) -> void {
    return;
}

type struct MyStruct {
    field1: int;
    field2: string;
}

type struct StructWithMethods {
    value: int;

    get_value() -> int {
        return this.value;
    }
}

function main() -> int {
    const x: int = 42;

    // const wrong_type: int = "this should cause a type error";

    const constant_value: int = 100;
    constant_value = 200; // This should cause a reassignment error

    function_param_names(x, "hello");

    const my_struct: MyStruct = MyStruct ({ field1: 10, field2: "test" });
    
    return 0;
}
