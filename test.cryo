namespace Testing;

function main() -> int {
    // Test primitive constructor syntax for integer types
    const int_32: i32 = 42;
    const int_64: i64 = i64(int_32);
    
    // Test with other integer primitive constructors
    const small_int: i8 = i8(5);
    const big_uint: u64 = u64(100);
    const regular_int: int = int(int_32);
    
    return 0;
}