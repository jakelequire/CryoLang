namespace Main;

// ❌
// ✅

import IO from <io/stdio>


type struct Config {
    verbose: boolean;
    output: string;
    count: int;
}

type class CircleClass {
public:
    center: float;
    radius: float;
    foo: string;
    bar: i32;

    CircleClass(center: float, radius: float) {
        this.center = center;
        this.radius = radius;
    }

    area() -> float {
        return 3.14 * this.radius * this.radius;
    }


private:
    diameter() -> float {
        return 2.0 * this.radius;
    }
}

function test_object_errors() -> void {
    mut circle: CircleClass = new CircleClass(0.0, 5.0);
    const area: float = circle.area(); // Correct method call
    const diameter: float = circle.diameter(); // Accessing private method should error

    return;
}

function main() -> int {
    IO::println("Hello, world!");
    test_object_errors();

    mut config: Config = Config({
        verbose: true,
        output: "result.txt",
        count: 10
    });

    const simple_type_mismatch: int = "this should error"; // Direct string to int assignment
    const type_mismatch: int = config.output; // This should cause a type mismatch error

    const deref_error: int = *config; // Attempting to dereference a non-pointer type
    if (deref_error > 0) {
        // Do something...
    }
    const invalid_field_access: string = config.non_existent_field; // Accessing a non-existent field
    const invalid_operation: int = config.verbose + 5; // Invalid operation between boolean and int
    const invalid_address_of: int = &config.count; // Taking address of a non-pointer type
    const zero_initializer: Config = new Config(); // Missing field initializers
    const similar_field_names: boolean = config.outpu; // Misspelled field name

    // const unfinished_expression: int = (5 + ; // Incomplete expression

    return 0;
}
