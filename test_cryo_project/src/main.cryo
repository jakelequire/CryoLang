namespace Main;

import IO from <io/stdio>


type struct Person {
    name: string;
    age: int;
    Person(_name: string, _age: int) {
        this.name = _name;
        this.age = _age;
    }
}

function fibonacci(n: int) -> int {
    if (n <= 0) {
        return 0;
    } else if (n == 1) {
        return 1;
    } else {
        return fibonacci(n - 1) + fibonacci(n - 2);
    }
}

function test_fibonacci(limit: int) -> void {
    IO::println("Testing Fibonacci function:");

    for (mut i: int = 0; i <= limit; i++) {
        const fib_result: int = fibonacci(i);
        IO::print_int(fib_result);
    }
    
    return;
}

function main() -> int {
    IO::println("Hello, world!");
    test_fibonacci(15);

    const person: Person = new Person("Alice", 30);
    const person_age: int = person.age;
    IO::printf("Person's age: %d\n", person_age);

    return 0;
}
