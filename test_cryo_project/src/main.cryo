namespace Main;

import IO from <io/stdio>


// +!+==========================================================================+!+ //
//                                                                                  // 
//                    Object Orientation: Classes & Structs                         //
//                                                                                  // 
// +!+==========================================================================+!+ //


// Unlike structs, classes require explicit access modifiers
// Similar to C++, we can define public/private/protected sections in blocks
type class TestClass {
public:
    some_public_field: int;

    TestClass(initilizer: int) {
        this.some_public_field = initilizer;
    }

    get_public_field() -> int {
        return this.some_public_field;
    }

    // Static methods in a Struct or Class drops the implicit `this` parameter
    // This can be called without an instance of the class using the scope resolution operator `::`
    static static_class_method() -> int {
        return 100;
    }

private:
    some_private_method() -> void {
        IO::println("This is a private method.");
        return;
    }
}

// Structws are similar to classes but structs have all members public by default
// However, we can still define private methods in structs
type struct TestStruct {
    struct_field: int;

    TestStruct(initializer: int) {
        this.struct_field = initializer;
    }

    get_struct_field() -> int {
        return this.struct_field;
    }

    // Static methods in a Struct or Class drops the implicit `this` parameter
    // This can be called without an instance of the class using the scope resolution operator `::`
    static static_struct_method() -> int {
        return 42;
    }

// TODO: Enable visibility modifiers for structs
// private:
//     hidden_struct_method() -> boolean {
//         return true;
//     }
}

// Both Classes and Structs should enforce access modifiers correctly
// The only different between them is that Classes require explicit access modifiers
// while Structs have all members public by default
function test_access_modifiers() -> void {
    mut test_obj: TestClass = new TestClass(42);                // Create instance of TestClass
    const public_value: int = test_obj.get_public_field();      // Valid access to public method
    test_obj.some_private_method();                             // Invalid access to private method

    mut test_struct: TestStruct = new TestStruct(100);          // Create instance of TestStruct
    const struct_value: int = test_struct.get_struct_field();   // Valid access to struct method
    if (test_struct.hidden_struct_method()) {                   // Invalid access to private struct method
        IO::println("Accessed hidden struct method.");
    }

    return;
}

// Syntactically, Classes and Structs can be instantiated in two ways:
// 1. Using the `new` keyword which allocates the object on the HEAP
// 2. Without the `new` keyword which allocates the object on the STACK
// However, when instantiating without the `new` keyword, all fields must be explicitly initialized
// Failing to do so should result in a compilation error.
function test_object_instantiation() -> void {

    // Valid instantiation with `new` keyword (HEAP-ALLOCATED)
    mut obj1: TestClass = new TestClass(10);
    // Valid instantiation of struct with `new` keyword (HEAP-ALLOCATED)
    mut struct_obj: TestStruct = new TestStruct(15);

    // Invalid instantiation without `new` keyword WITHOUT explicit instantiation with `TestClass({some_public_field: 10});`
    mut obj2: TestClass = TestClass(20);
    // Invalid instantiation without `new` keyword WITHOUT explicit instantiation with `TestStruct({struct_field: 25});`
    mut struct_obj2: TestStruct = TestStruct(25);

    // Valid instantiation without `new` keyword WITH explicit field initialization (STACK-ALLOCATED)
    mut obj3: TestClass = TestClass({some_public_field: 30});
    mut struct_obj3: TestStruct = TestStruct({struct_field: 35});


    return;
}


// +!+==========================================================================+!+ //
//                                                                                  // 
//                      Primitive Data Types & Type Checking                        //
//                                                                                  // 
// +!+==========================================================================+!+ //

function test_basic_data_type() -> void {
    mut num: int = 10;                      // Valid assignments
    const float_num: float = 20.5;          // Valid assignments
    const is_valid: boolean = true;         // Valid assignments
    const text: string = "Hello, Cryo!";    // Valid assignments

    const invalid_assign: int = "This should cause a type error";   // Invalid assignment
    const sum: int = num + float_num;                               // Invalid operation between int and float
    num = "Another type error";                                     // Invalid assignment
    text = 100;                                                     // Invalid const modification

    return;
}

function test_undefined_symbols() -> void {
    // Using undefined symbols should result in compilation error.
    const undefined_function_call: int = non_existent_function();
    const undefined_variable: int = some_undefined_variable;
    const undefined_struct: NonExistentStruct = NonExistentStruct({field: 10});
    const undefined_class: NonExistentClass = new NonExistentClass();
}


// +!+==========================================================================+!+ //
//                                                                                  // 
//                  Pointers, References, and Memory Management                     //
//                                                                                  // 
// +!+==========================================================================+!+ //

// In Cryo, the following rules apply for pointers and references:
// 1. You can take the address of MUTABLE variables using the `&` operator to create references
// 2. You can dereference pointers using the `*` operator to access the value
// 3. You CANNOT take the address of constant values, literals, or const variables
// 4. You CANNOT dereference pointers to constant values (const data)
// 5. You can take the address of STACK-ALLOCATED objects and structs (if mutable)
// 6. You CANNOT take the address of HEAP-ALLOCATED objects created with `new`
// 7. You CANNOT take the address of literals directly
function test_pointers_and_references() -> void {
    // === BASIC POINTER TESTS ===
    mut mutable_number: int = 42;                       // Valid: Mutable integer
    const const_number: int = 100;                      // Valid: Const integer
    
    mut valid_ptr: &int = &mutable_number;              // Valid: Taking address of mutable variable
    mut invalid_ptr: &int = &const_number;              // Invalid: Cannot take address of const variable
    mut literal_ptr: &int = &42;                        // Invalid: Cannot take address of literal
    
    const dereferenced_valid: int = *valid_ptr;         // Valid: Dereferencing pointer to mutable data
    const dereferenced_invalid: int = *invalid_ptr;     // Invalid: Dereferencing pointer to const data (if it existed)

    // === STRING POINTER TESTS ===
    mut mutable_str: string = "Hello";                  // Valid: Mutable string
    const const_str: string = "World";                  // Valid: Const string
    
    mut valid_str_ptr: &string = &mutable_str;          // Valid: Taking address of mutable string
    mut invalid_str_ptr: &string = &const_str;          // Invalid: Cannot take address of const string
    mut literal_str_ptr: &string = &"Literal";          // Invalid: Cannot take address of string literal
    
    const dereferenced_str: string = *valid_str_ptr;    // Valid: Dereferencing pointer to mutable string

    // === OBJECT POINTER TESTS ===
    // STACK-ALLOCATED objects
    mut local_mutable_obj: TestClass = TestClass({some_public_field: 10});      // Valid: Mutable STACK object
    const local_const_obj: TestClass = TestClass({some_public_field: 20});      // Valid: Const STACK object
    
    mut valid_obj_ptr: &TestClass = &local_mutable_obj;                         // Valid: Address of mutable STACK object
    mut invalid_obj_ptr: &TestClass = &local_const_obj;                         // Invalid: Address of const STACK object
    
    // HEAP-ALLOCATED objects
    mut heap_obj: TestClass = new TestClass(30);                                // Valid: HEAP object
    const const_heap_obj: TestClass = new TestClass(40);                        // Valid: Const HEAP object
    
    mut invalid_heap_ptr1: &TestClass = &heap_obj;                              // Invalid: Cannot take address of HEAP object
    mut invalid_heap_ptr2: &TestClass = &const_heap_obj;                        // Invalid: Cannot take address of HEAP object (double invalid)

    // TODO: Compiler is unable to parse double indirection tests `**` AND `&(&)` needs fixing in the compiler.
    // === DOUBLE INDIRECTION TESTS ===
    // mut ptr_to_ptr: &(&int) = &valid_ptr;                                       // Valid: Pointer to pointer
    // mut invalid_ptr_to_ptr: &(&int) = &invalid_ptr;                             // Invalid: Pointer to invalid pointer
    //
    // const double_deref: int = **ptr_to_ptr;                                     // Valid: Double dereference
    // const invalid_double_deref: int = **invalid_ptr_to_ptr;                     // Invalid: Double dereference through invalid pointer

    // === FUNCTION PARAMETER TESTS ===
    test_pointer_parameter(valid_ptr);                                          // Valid: Passing valid pointer
    test_pointer_parameter(invalid_ptr);                                        // Invalid: Passing invalid pointer
    test_pointer_parameter(&50);                                                // Invalid: Passing address of literal

    return;
}

// Helper function to test pointer parameters
function test_pointer_parameter(_ptr: &int) -> void {
    const value: int = *_ptr;                            // This should only work with valid pointers
    return;
}


// +!+==========================================================================+!+ //
//                                                                                  // 
//                          Generics and Template Errors                           //
//                                                                                  // 
// +!+==========================================================================+!+ //

type struct GenericTestStruct<T> {
    value: T;
    
    GenericTestStruct(val: T) {
        this.value = val;
    }
}

function test_generic_errors() -> void {
    // Valid generic instantiations
    const valid_int_generic: GenericTestStruct<int> = new GenericTestStruct<int>(42);
    const valid_string_generic: GenericTestStruct<string> = new GenericTestStruct<string>("test");

    // Invalid generic instantiations
    const missing_type_param: GenericTestStruct = new GenericTestStruct(10);           // Invalid: Missing type parameter
    const wrong_type_arg: GenericTestStruct<int> = new GenericTestStruct<int>("str");  // Invalid: Wrong type for constructor
    const undefined_generic: UndefinedGeneric<int> = new UndefinedGeneric<int>(5);     // Invalid: Undefined generic type
    const invalid_type_param: GenericTestStruct<NonExistentType> = new GenericTestStruct<NonExistentType>(1); // Invalid: Non-existent type parameter

    return;
}

// +!+==========================================================================+!+ //
//                                                                                  // 
//                      Function Signature and Parameter Errors                    //
//                                                                                  // 
// +!+==========================================================================+!+ //

function test_function_signature_errors() -> void {
    // Valid function calls
    valid_function_with_params(10, "test");
    const result: int = valid_function_with_return();

    // Invalid function calls - wrong number of parameters
    valid_function_with_params(10);                        // Invalid: Too few parameters
    valid_function_with_params(10, "test", 42);            // Invalid: Too many parameters
    
    // Invalid function calls - wrong parameter types
    valid_function_with_params("string", 42);              // Invalid: Wrong type order
    valid_function_with_params(10.5, "test");              // Invalid: float instead of int
    
    // Invalid function calls - using return value incorrectly
    const wrong_type: string = valid_function_with_return();  // Invalid: Expecting int, got string
    valid_function_with_params(valid_function_with_return(), "test"); // Valid: Using return value as parameter
    
    // Invalid function calls - undefined functions
    undefined_function();                                   // Invalid: Function doesn't exist
    const undefined_result: int = another_undefined_func(5); // Invalid: Function doesn't exist

    // Invalid function calls - void function return value usage
    const void_result: int = void_function();               // Invalid: Cannot use void return value

    return;
}

function valid_function_with_params(a: int, b: string) -> void {
    return;
}

function valid_function_with_return() -> int {
    return 42;
}

function void_function() -> void {
    return;
}

// +!+==========================================================================+!+ //
//                                                                                  // 
//                        Array and Indexing Errors                                //
//                                                                                  // 
// +!+==========================================================================+!+ //

function test_array_errors() -> void {
    const valid_array: int[] = [1, 2, 3, 4, 5];
    const mixed_type_array: int[] = [1, "string", 3];      // Invalid: Mixed types in array literal
    const empty_array: int[] = [];                         // Valid: Empty array

    // Valid array access
    const first_element: int = valid_array[0];
    const variable_index: int = 2;
    const third_element: int = valid_array[variable_index];

    // Invalid array access
    const negative_index: int = valid_array[-1];           // Invalid: Negative index
    const string_index: int = valid_array["invalid"];      // Invalid: String as index
    const float_index: int = valid_array[1.5];             // Invalid: Float as index
    const out_of_bounds: int = valid_array[100];           // Runtime error: Out of bounds (if bounds checking enabled)

    // Invalid array operations
    const add_arrays: int[] = valid_array + [6, 7, 8];     // Invalid: Array addition not defined
    const multiply_array: int[] = valid_array * 2;         // Invalid: Array multiplication not defined

    // 2D Array errors
    const matrix: int[][] = [[1, 2], [3, 4, 5], [6]];     // Valid: Jagged 2D array
    const invalid_2d_access: int = matrix[0][5];           // Runtime error: Out of bounds in second dimension
    const wrong_dimension: int = matrix[0];                // Invalid: Expecting int, got int[]

    return;
}

// +!+==========================================================================+!+ //
//                                                                                  // 
//                        Enum and Match Expression Errors                         //
//                                                                                  // 
// +!+==========================================================================+!+ //

enum TestEnum {
    VARIANT_A,
    VARIANT_B(int),
    VARIANT_C(string, boolean)
}

function test_enum_errors() -> void {
    // Valid enum usage
    const valid_enum: TestEnum = TestEnum::VARIANT_A;
    const enum_with_data: TestEnum = TestEnum::VARIANT_B(42);

    // Invalid enum usage
    const undefined_variant: TestEnum = TestEnum::NONEXISTENT;         // Invalid: Undefined enum variant
    const wrong_data_type: TestEnum = TestEnum::VARIANT_B("string");   // Invalid: Wrong data type for variant
    const missing_data: TestEnum = TestEnum::VARIANT_B();              // Invalid: Missing required data
    const extra_data: TestEnum = TestEnum::VARIANT_A(10);              // Invalid: Extra data for simple variant

    // Match expression errors
    match valid_enum {
        TestEnum::VARIANT_A => {
            const a_result: int = 1;
        },
        TestEnum::VARIANT_B(value) => {
            const b_result: int = value;
        }
        // Invalid: Missing VARIANT_C case - should be exhaustiveness error
    }

    match valid_enum {
        TestEnum::VARIANT_A => {
            const a_result: int = 1;
        },
        TestEnum::NONEXISTENT => {                          // Invalid: Undefined variant in match
            const invalid_result: int = 0;
        },
        TestEnum::VARIANT_B(value) => {
            const b_result: int = value;
        },
        TestEnum::VARIANT_C(text, flag) => {
            const c_result: string = text;
        }
    }

    return;
}

// +!+==========================================================================+!+ //
//                                                                                  // 
//                        Control Flow and Scope Errors                            //
//                                                                                  // 
// +!+==========================================================================+!+ //

function test_control_flow_errors() -> void {
    // Valid control flow
    const condition: boolean = true;
    if (condition) {
        const inner_var: int = 10;
    }

    // Invalid scope access
    const scope_error: int = inner_var;                     // Invalid: Variable out of scope

    // Loop variable scope errors
    for (mut i: int = 0; i < 10; i++) {
        const loop_var: int = i * 2;
    }
    const after_loop: int = i;                              // Invalid: Loop variable out of scope
    const loop_var_outside: int = loop_var;                // Invalid: Loop-scoped variable out of scope


    if (condition) {
        break;                                              // Invalid: Break in if statement
        continue;                                           // Invalid: Continue in if statement
    }

    // Invalid condition types
    if (42) {                                               // Invalid: Integer as boolean condition
        const num_condition: int = 1;
    }

    if ("string") {                                         // Invalid: String as boolean condition
        const str_condition: int = 1;
    }

    while (10 > 5 > 2) {                                    // Invalid: Chained comparisons (if not supported)
        break;
    }

    return;
}

// +!+==========================================================================+!+ //
//                                                                                  // 
//                          Operator and Expression Errors                         //
//                                                                                  // 
// +!+==========================================================================+!+ //

function test_operator_errors() -> void {
    const a: int = 10;
    const b: int = 20;
    const str1: string = "hello";
    const str2: string = "world";
    const flag: boolean = true;

    // Valid operations
    const add_result: int = a + b;
    const bool_and: boolean = flag && true;
    const comparison: boolean = a < b;

    // Invalid arithmetic operations
    const add_int_string: int = a + str1;                   // Invalid: Cannot add int and string
    const subtract_strings: string = str1 - str2;          // Invalid: Cannot subtract strings
    const multiply_booleans: boolean = flag * true;        // Invalid: Cannot multiply booleans
    const divide_by_string: int = a / str1;                // Invalid: Cannot divide by string

    // Invalid logical operations
    const logical_int: boolean = a && b;                    // Invalid: Logical AND on integers
    const logical_string: boolean = str1 || str2;          // Invalid: Logical OR on strings
    const not_int: boolean = !a;                           // Invalid: Logical NOT on integer

    // Invalid assignment operations
    const immutable_var: int = 10;
    immutable_var = 20;                                     // Invalid: Cannot modify const variable
    
    mut mutable_var: int = 10;
    mutable_var = "string";                                 // Invalid: Type mismatch in assignment

    // Invalid comparison operations
    const compare_int_string: boolean = a == str1;         // Invalid: Cannot compare int and string
    const compare_different_types: boolean = flag < a;     // Invalid: Cannot compare boolean and int

    // Invalid increment/decrement (if these operators exist)
    const const_increment: int = immutable_var++;          // Invalid: Cannot increment const variable
    const string_increment: string = str1++;               // Invalid: Cannot increment string

    return;
}

// +!+==========================================================================+!+ //
//                                                                                  // 
//                            Import and Namespace Errors                          //
//                                                                                  // 
// +!+==========================================================================+!+ //

// These would be file-level errors, but including here for completeness
function test_import_errors() -> void {
    // These would typically be caught at the import level, not in function scope
    // But including usage errors here:

    // Invalid namespace access
    const invalid_io: string = NonExistentNamespace::some_function();  // Invalid: Undefined namespace
    const invalid_function: void = IO::nonexistent_function();         // Invalid: Undefined function in valid namespace

    // Invalid type usage from imports
    const invalid_imported_type: UndefinedImportedType = new UndefinedImportedType(); // Invalid: Type not imported/doesn't exist

    return;
}

// +!+==========================================================================+!+ //
//                                                                                  // 
//                              Memory Safety Errors                               //
//                                                                                  // 
// +!+==========================================================================+!+ //

function test_memory_safety_errors() -> void {
    // Dangling pointer scenarios
    mut dangling_ptr: &int = null;
    {
        mut local_var: int = 42;
        dangling_ptr = &local_var;                          // Potentially invalid: Pointer to local variable
    }
    // dangling_ptr now points to deallocated stack memory
    const dangling_value: int = *dangling_ptr;              // Invalid: Use after scope ends

    // Double free scenarios (if manual memory management)
    mut heap_obj: TestClass = new TestClass(10);
    // free(heap_obj);  // If explicit free exists
    // free(heap_obj);  // Invalid: Double free

    // Null pointer dereference
    mut null_ptr: &int = null;
    const null_deref: int = *null_ptr;                      // Invalid: Null pointer dereference

    // Use after move (if move semantics exist)
    mut original_obj: TestClass = new TestClass(5);
    mut moved_obj: TestClass = original_obj;                // If this is a move
    const use_after_move: int = original_obj.get_public_field(); // Invalid: Use after move

    return;
}

function main() -> int {
    test_access_modifiers();
    test_object_instantiation();
    test_basic_data_type();
    test_undefined_symbols();
    test_pointers_and_references();
    test_generic_errors();
    test_function_signature_errors();
    test_array_errors();
    test_enum_errors();
    test_control_flow_errors();
    test_operator_errors();
    test_import_errors();
    test_memory_safety_errors();

    return 0;
}
