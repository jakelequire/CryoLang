// tokens.def - Token definitions
// Usage: Include this file with appropriate macro definitions

//===----------------------------------------------------------------------===//
// Special/Meta Tokens
//===----------------------------------------------------------------------===//

TOK(UNKNOWN) // Unknown/invalid character
TOK(EOF)     // End of file
TOK(EOD)     // End of directive (preprocessor)
TOK(COMMENT) // Comments (if preserved)
TOK(DOC_COMMENT_BLOCK) // /** */ style documentation comments
TOK(DOC_COMMENT_LINE)  // /// style documentation comments

//===----------------------------------------------------------------------===//
// Identifiers and Literals
//===----------------------------------------------------------------------===//

TOK(IDENTIFIER)         // Variable/function names
TOK(NUMERIC_CONSTANT)   // 123, 3.14, 0xFF, 1e10
TOK(CHAR_CONSTANT)      // 'a', '\n', '\xFF'
TOK(STRING_LITERAL)     // "hello world"
TOK(RAW_STRING_LITERAL) // r"raw string"
TOK(BOOLEAN_LITERAL)    // true, false (if not keywords)

//===----------------------------------------------------------------------===//
// Keywords - Control Flow
//===----------------------------------------------------------------------===//

KEYWORD(IF)
KEYWORD(ELSE)
KEYWORD(ELIF) // else if
KEYWORD(SWITCH)
KEYWORD(CASE)
KEYWORD(DEFAULT)
KEYWORD(MATCH) // Pattern matching
KEYWORD(WHILE)
KEYWORD(FOR)
KEYWORD(DO)
KEYWORD(BREAK)
KEYWORD(CONTINUE)
KEYWORD(RETURN)
KEYWORD(GOTO)
KEYWORD(TRY)
KEYWORD(CATCH)
KEYWORD(FINALLY)
KEYWORD(THROW)
KEYWORD(RAISE) // Alternative to throw
KEYWORD(YIELD) // Generator support

//===----------------------------------------------------------------------===//
// Keywords - Declarations
//===----------------------------------------------------------------------===//

KEYWORD(VAR)       // Variable declaration
KEYWORD(LET)       // Immutable binding
KEYWORD(CONST)     // Constant
KEYWORD(STATIC)    // Static storage
KEYWORD(EXTERN)    // External linkage
KEYWORD(AUTO)      // Type inference
KEYWORD(UNSIGNED)  // Unsigned type modifier
KEYWORD(FUNCTION)  // Alternative function keyword
KEYWORD(CLASS)     // Class definition
KEYWORD(STRUCT)    // Structure
KEYWORD(UNION)     // Union type
KEYWORD(ENUM)      // Enumeration
KEYWORD(INTERFACE) // Interface definition
KEYWORD(TRAIT)     // Trait definition
KEYWORD(TYPE)      // Type alias
KEYWORD(NAMESPACE) // Namespace
KEYWORD(MODULE)    // Module definition
KEYWORD(IMPORT)    // Import statement
KEYWORD(EXPORT)    // Export statement
KEYWORD(FROM)      // Import from
KEYWORD(AS)        // Import/cast as
KEYWORD(IMPLEMENT) // Implementation block
KEYWORD(INTRINSIC) // Intrinsic function declaration
KEYWORD(WHERE)     // Where clause for trait bounds

//===----------------------------------------------------------------------===//
// Keywords - Type System
//===----------------------------------------------------------------------===//

KEYWORD(VOID)
KEYWORD(BOOLEAN)
KEYWORD(INT)
KEYWORD(I8)
KEYWORD(I16)
KEYWORD(I32)
KEYWORD(I64)
KEYWORD(UINT)
KEYWORD(UINT8)
KEYWORD(UINT16)
KEYWORD(UINT32)
KEYWORD(UINT64)
KEYWORD(FLOAT)
KEYWORD(F32)
KEYWORD(F64)
KEYWORD(DOUBLE)
KEYWORD(CHAR)
KEYWORD(STRING)
KEYWORD(ARRAY)
KEYWORD(LIST)
KEYWORD(MAP)
KEYWORD(DICT)
KEYWORD(SET)
KEYWORD(TUPLE)
KEYWORD(OPTIONAL) // Optional/nullable types
KEYWORD(ANY)      // Any type
KEYWORD(GENERIC)  // Generic type parameter

//===----------------------------------------------------------------------===//
// Keywords - Access Control & Modifiers
//===----------------------------------------------------------------------===//

KEYWORD(PUBLIC)
KEYWORD(PRIVATE)
KEYWORD(PROTECTED)
KEYWORD(INTERNAL)
KEYWORD(READONLY)
KEYWORD(MUTABLE)
KEYWORD(VIRTUAL)
KEYWORD(OVERRIDE)
KEYWORD(ABSTRACT)
KEYWORD(FINAL)
KEYWORD(INLINE)
KEYWORD(ASYNC)
KEYWORD(AWAIT)
KEYWORD(UNSAFE) // Unsafe operations

//===----------------------------------------------------------------------===//
// Keywords - Memory & Ownership (Rust-like)
//===----------------------------------------------------------------------===//

KEYWORD(REF)  // Reference
KEYWORD(MUT)  // Mutable

//===----------------------------------------------------------------------===//
// Keywords - Special Values
//===----------------------------------------------------------------------===//

KEYWORD(TRUE)
KEYWORD(FALSE)
KEYWORD(NULL)
KEYWORD(NIL)         // Alternative to null
KEYWORD(NONE)        // Optional none value
KEYWORD(SOME)        // Optional some value
KEYWORD(SUPER)       // Parent/super class
KEYWORD(THIS)        // Object instance
KEYWORD(THIS_TYPE)   // Current type (trait/class)
KEYWORD(CONSTRUCTOR) // Constructor method

//===----------------------------------------------------------------------===//
// Keywords - Operators as Keywords
//===----------------------------------------------------------------------===//

KEYWORD(IN)      // Membership test
KEYWORD(TYPEOF)  // Type query
KEYWORD(SIZEOF)  // Size query
KEYWORD(ALIGNOF) // Alignment query
KEYWORD(NEW)     // Object creation
KEYWORD(DELETE)  // Object destruction
KEYWORD(WITH)    // Context manager

//===----------------------------------------------------------------------===//
// Punctuators - Grouping
//===----------------------------------------------------------------------===//

PUNCTUATOR(L_PAREN, "(")
PUNCTUATOR(R_PAREN, ")")
PUNCTUATOR(L_BRACE, "{")
PUNCTUATOR(R_BRACE, "}")
PUNCTUATOR(L_SQUARE, "[")
PUNCTUATOR(R_SQUARE, "]")
PUNCTUATOR(L_ANGLE, "<")
PUNCTUATOR(R_ANGLE, ">")

//===----------------------------------------------------------------------===//
// Punctuators - Basic Operations
//===----------------------------------------------------------------------===//

PUNCTUATOR(PLUS, "+")
PUNCTUATOR(MINUS, "-")
PUNCTUATOR(STAR, "*")
PUNCTUATOR(SLASH, "/")
PUNCTUATOR(PERCENT, "%")
PUNCTUATOR(CARET, "^")
PUNCTUATOR(AMP, "&")
PUNCTUATOR(PIPE, "|")
PUNCTUATOR(TILDE, "~")
PUNCTUATOR(EXCLAIM, "!")
PUNCTUATOR(QUESTION, "?")
PUNCTUATOR(COLON, ":")
PUNCTUATOR(SEMICOLON, ";")
PUNCTUATOR(COMMA, ",")
PUNCTUATOR(PERIOD, ".")
PUNCTUATOR(AT, "@")
PUNCTUATOR(HASH, "#")
PUNCTUATOR(DOLLAR, "$")
PUNCTUATOR(BACKSLASH, "\\")

//===----------------------------------------------------------------------===//
// Punctuators - Assignment
//===----------------------------------------------------------------------===//

PUNCTUATOR(EQUAL, "=")
PUNCTUATOR(PLUSEQUAL, "+=")
PUNCTUATOR(MINUSEQUAL, "-=")
PUNCTUATOR(STAREQUAL, "*=")
PUNCTUATOR(SLASHEQUAL, "/=")
PUNCTUATOR(PERCENTEQUAL, "%=")
PUNCTUATOR(CARETEQUAL, "^=")
PUNCTUATOR(AMPEQUAL, "&=")
PUNCTUATOR(PIPEEQUAL, "|=")

//===----------------------------------------------------------------------===//
// Punctuators - Comparison
//===----------------------------------------------------------------------===//

PUNCTUATOR(EQUALEQUAL, "==")
PUNCTUATOR(EXCLAIMEQUAL, "!=")
PUNCTUATOR(LESSEQUAL, "<=")
PUNCTUATOR(GREATEREQUAL, ">=")
PUNCTUATOR(SPACESHIP, "<=>")

//===----------------------------------------------------------------------===//
// Punctuators - Logical
//===----------------------------------------------------------------------===//

PUNCTUATOR(AMPAMP, "&&")
PUNCTUATOR(PIPEPIPE, "||")
PUNCTUATOR(QUESTION2, "??")

//===----------------------------------------------------------------------===//
// Punctuators - Bitwise & Shift
//===----------------------------------------------------------------------===//

PUNCTUATOR(LESSLESS, "<<")
PUNCTUATOR(GREATERGREATER, ">>")
PUNCTUATOR(LESSLESSEQUAL, "<<=")
PUNCTUATOR(GREATERGREATEREQUAL, ">>=")

//===----------------------------------------------------------------------===//
// Punctuators - Increment/Decrement
//===----------------------------------------------------------------------===//

PUNCTUATOR(PLUSPLUS, "++")
PUNCTUATOR(MINUSMINUS, "--")

//===----------------------------------------------------------------------===//
// Punctuators - Arrow & Access
//===----------------------------------------------------------------------===//

PUNCTUATOR(ARROW, "->")
PUNCTUATOR(ARROWSTAR, "->*")
PUNCTUATOR(PERIODSTAR, ".*")
PUNCTUATOR(COLONCOLON, "::")
PUNCTUATOR(ELLIPSIS, "...")
PUNCTUATOR(FATARROW, "=>")

//===----------------------------------------------------------------------===//
// Punctuators - Special
//===----------------------------------------------------------------------===//

PUNCTUATOR(QUESTIONDOT, "?.")
PUNCTUATOR(PIPEGT, "|>")
PUNCTUATOR(LTPIPE, "<|")
PUNCTUATOR(DOLLARBRACE, "${")
PUNCTUATOR(HASHHASH, "##")

//===----------------------------------------------------------------------===//
// Preprocessor Directives
//===----------------------------------------------------------------------===//

DIRECTIVE(PRAGMA)

//===----------------------------------------------------------------------===//
// Attributes/Annotations
//===----------------------------------------------------------------------===//

ATTRIBUTE(DEPRECATED)
ATTRIBUTE(INLINE)
ATTRIBUTE(NOINLINE)
ATTRIBUTE(PURE)
ATTRIBUTE(CONST)
ATTRIBUTE(NORETURN)
ATTRIBUTE(PACKED)
ATTRIBUTE(ALIGNED)
ATTRIBUTE(SECTION)
ATTRIBUTE(WEAK)
ATTRIBUTE(CONSTRUCTOR)
ATTRIBUTE(DESTRUCTOR)