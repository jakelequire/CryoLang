import <io/stdio>;




function main() -> int {
    // Test basic integer printing
    std::IO::print_int(42);
    std::IO::printf("\n");
    
    // Test floating point printing
    std::IO::print_float(3.14);
    std::IO::printf("\n");
    
    // Test boolean printing  
    std::IO::print_bool(true);
    std::IO::printf("\n");
    std::IO::print_bool(false);
    std::IO::printf("\n");

    const char_str: string = from_char('A');
    std::IO::printf(char_str);
    
    return 0;
}
