// ❌ ✅
namespace FunctionErrorTest;

import IO from <io/stdio>;

function test_function_signature_errors() -> void {
    // Valid function calls
    valid_function_with_params(10, "test");           // ✅ Valid
    const result: int = valid_function_with_return(); // ✅ Valid

    // Invalid function calls - wrong number of parameters
    valid_function_with_params(10);             // ❌ [E0216_TOO_FEW_ARGS] Too few parameters
    valid_function_with_params(10, "test", 42); // ❌ [E0215_TOO_MANY_ARGS] Too many parameters
    
    // Invalid function calls - wrong parameter types
    valid_function_with_params("string", 42);  // ❌ [E0200_TYPE_MISMATCH] Wrong type order
    valid_function_with_params(10.5, "test");  // ❌ [E0200_TYPE_MISMATCH] Wrong type order

    // Invalid function calls - using return value incorrectly
    const wrong_type: string = valid_function_with_return();           // ❌ [E0200_TYPE_MISMATCH] Expecting int, got string
    valid_function_with_params(valid_function_with_return(), "test");  // ✅ Valid: Using return value as parameter
    
    // Invalid function calls - undefined functions
    undefined_function();                                    // ❌ [E0202_UNDEFINED_FUNCTION] Function doesn't exist
    const undefined_result: int = another_undefined_func(5); // ❌ [E0202_UNDEFINED_FUNCTION] Function doesn't exist

    // Invalid function calls - void function return value usage
    const void_result: int = void_function(); // ❌ [E0200_TYPE_MISMATCH] Cannot use void return value

    return;
}

function valid_function_with_params(a: int, b: string) -> void {
    return;
}

function valid_function_with_return() -> int {
    return 42;
}

function void_function() -> void {
    return;
}


function main() -> int {
    test_function_signature_errors();

    return 0;
}
