// Total Errors: 8
// ❌ ✅
namespace PrimitiveErrorTest;

import IO from <io/stdio>;


function test_basic_data_type() -> void {
    mut num: int = 10;                      // ✅ Valid assignments
    const float_num: float = 20.5;          // ✅ Valid assignments
    const is_valid: boolean = true;         // ✅ Valid assignments
    const text: string = "Hello, Cryo!";    // ✅ Valid assignments

    const invalid_assign: int = "This should cause a type error";  // ❌ [E0200_TYPE_MISMATCH] Invalid assignment
    const sum: int = num + text;                                   // ❌ [E0200_TYPE_MISMATCH] Invalid operation between int and string
    num = "Another type error";                                    // ❌ [E0232_INVALID_ASSIGNMENT_TARGET] Invalid assignment
    text = 100;                                                    // ❌ [E0232_INVALID_ASSIGNMENT_TARGET] Invalid const modification

    return;
}

function test_undefined_symbols() -> void {
    // Using undefined symbols should result in compilation error.
    const undefined_function_call: int = non_existent_function();               // ❌ [E0202_UNDEFINED_FUNCTION] Undefined function
    const undefined_variable: int = some_undefined_variable;                    // ❌ [E0201_UNDEFINED_VARIABLE] Undefined variable
    const undefined_struct: NonExistentStruct = NonExistentStruct({field: 10}); // ❌ [E0203_UNDEFINED_TYPE] Undefined struct
    const undefined_class: NonExistentClass = new NonExistentClass();           // ❌ [E0203_UNDEFINED_TYPE] Undefined class
}

function main() -> int {
    test_basic_data_type();
    test_undefined_symbols();
    
    return 0;
}