namespace Main;

function main() -> int {
    const a: int = 10;
    const b: int = 20;
    
    // Simple ternary
    const max_value: int = a > b ? a : b;
    
    // Nested ternary
    const result: int = a > 15 ? (b > 25 ? b : a) : 5;
    
    // Boolean ternary
    const is_positive: boolean = max_value > 0 ? true : false;
    
    return 0;
}
