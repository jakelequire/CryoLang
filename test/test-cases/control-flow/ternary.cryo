namespace Main;

// Test ternary operator expressions
function ternary_test() -> void {
    const a: int = 10;
    const b: int = 20;
    
    //  Simple ternary
    const max_value: int = a > b ? a : b;
    
    //  Nested ternary
    const result: int = a > 15 ? (b > 25 ? b : a) : 5;
    
    //  Boolean ternary
    const is_positive: boolean = max_value > 0 ? true : false;
    
    return;
}

// Test ternary with different data types
function test_ternary_types() -> void {
    const score: int = 85;
    
    // String ternary
    const grade_message: string = score >= 90 ? "Excellent" : "Good";
    
    // Character ternary
    const grade_letter: char = score >= 90 ? 'A' : 'B';
    
    // Float ternary
    const bonus: float = score >= 95 ? 10.5 : 5.0;
    
    // Boolean ternary
    const passed: boolean = score >= 60 ? true : false;
    
    return;
}

// Test complex ternary expressions
function test_complex_ternary() -> void {
    const x: int = 15;
    const y: int = 25;
    const z: int = 35;
    
    // Ternary with arithmetic expressions
    const max_of_sums: int = (x + y) > (y + z) ? (x + y) : (y + z);
    
    // Ternary with function calls (when available)
    // const result: int = x > y ? add(x, 10) : add(y, 5);
    
    // Chained ternary for multiple conditions
    const category: string = x > 30 ? "High" : (x > 15 ? "Medium" : "Low");
    
    return;
}