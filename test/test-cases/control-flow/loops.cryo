namespace Main;

// Test while loops
function test_while_loops() -> void {
    //  Basic while loop
    mut counter: int = 0;
    while (counter < 5) {
        counter = counter + 1;
    }
    
    // While loop with complex condition
    mut x: int = 100;
    mut y: int = 1;
    while (x > 10 && y < 50) {
        x = x - 5;
        y = y * 2;
    }
    
    return;
}

// Test for loops with manual increment
function test_for_loops_manual() -> void {
    //  Basic for loop
    for (mut i: int = 0; i < 10; i = i + 1) {
        if (i == 3) {
            continue;
        }
        if (i == 7) {
            break;
        }
        const value: int = i * 2;
    }
    
    // For loop with different step
    for (mut j: int = 0; j < 20; j = j + 2) {
        const even_value: int = j;
    }
    
    // Countdown for loop
    for (mut k: int = 10; k > 0; k = k - 1) {
        const countdown: int = k;
    }
    
    return;
}

// Test for loops with increment/decrement operators
function test_for_loops_operators() -> void {
    // For loop with postfix increment operator
    for (mut j: int = 0; j < 5; j++) {
        const square: int = j * j;
    }
    
    // For loop with prefix increment operator  
    for (mut j: int = 0; j < 5; ++j) {
        const square: int = j * j;
    }

    // For loop with prefix decrement operator
    for (mut k: int = 5; k > 0; --k) {
        const cube: int = k * k * k;
    }
    
    // For loop with postfix decrement operator
    for (mut k: int = 5; k > 0; k--) {
        const cube: int = k * k * k;
    }
    
    return;
}

// Test nested loops
function test_nested_loops() -> void {
    for (mut i: int = 0; i < 3; i = i + 1) {
        for (mut j: int = 0; j < 3; j = j + 1) {
            if (i == j) {
                continue;
            }
            const product: int = i * j;
        }
    }
    
    return;
}

// Test break and continue
function test_loop_control() -> void {
    // Test continue
    for (mut i: int = 0; i < 10; i++) {
        if (i % 2 == 0) {
            continue; // Skip even numbers
        }
        const odd_number: int = i;
    }
    
    // Test break
    mut found: boolean = false;
    for (mut i: int = 0; i < 100; i++) {
        if (i == 42) {
            found = true;
            break; // Exit loop early
        }
    }
    
    return;
}