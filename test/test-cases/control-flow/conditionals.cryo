namespace Main;

// Test if-else statements
function test_if_else() -> void {
    //  If-else statement
    const condition: boolean = true;
    if (condition) {
        const success_result: int = 42;
    } else {
        const failure_result: int = 0;
    }
    
    // If without else
    const x: int = 10;
    if (x > 5) {
        const is_greater: boolean = true;
    }
    
    return;
}

// Test nested if-else
function test_nested_if_else() -> void {
    const x: int = 10;
    if (x > 5) {
        if (x > 15) {
            const big: boolean = true;
        } else {
            const medium: boolean = true;
        }
    }
    
    return;
}

// Test complex boolean conditions
function test_complex_conditions() -> void {
    const a: int = 10;
    const b: int = 20;
    const flag: boolean = true;
    
    // AND condition
    if (a > 5 && b < 30) {
        const both_true: boolean = true;
    }
    
    // OR condition
    if (a < 5 || b > 15) {
        const one_true: boolean = true;
    }
    
    // Mixed conditions
    if ((a > 5 && b < 30) || flag) {
        const complex_result: boolean = true;
    }
    
    return;
}

// Test chained if-else (else if pattern)
function test_chained_if_else() -> void {
    const score: int = 85;
    
    if (score >= 90) {
        const grade_a: char = 'A';
    } else {
        if (score >= 80) {
            const grade_b: char = 'B';
        } else {
            if (score >= 70) {
                const grade_c: char = 'C';
            } else {
                const grade_f: char = 'F';
            }
        }
    }
    
    return;
}