namespace Main;

// Test function parameters with different types
function func_param(a: int, b: float, c: string, d: boolean, e: char) -> void {
    const local_var: int = a + 10;
    const flag: boolean = d && true;
    const message: string = "Hello, " + c;
    const char_at: char = message[7];
    
    return;
}

// Function with multiple parameters and return value
function complex_calculation(x: int, y: int, multiplier: float) -> float {
    const base_result: int = x + y;
    const final_result: float = base_result * multiplier;
    return final_result;
}

// Function with string parameters
function string_operations(prefix: string, suffix: string) -> string {
    const result: string = prefix + " " + suffix;
    return result;
}

// Function with array parameter
function array_sum(numbers: int[]) -> int {
    // Note: This is a placeholder - actual array iteration would require loops
    const first_two: int = numbers[0] + numbers[1];
    return first_two;
}