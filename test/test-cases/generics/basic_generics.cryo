namespace Main;

// Generic struct with single type parameter and method  
type struct GenericStruct<T> {
    value: T;
    get_value() -> T {
        return this.value;
    }
}

// Simple generic struct
type struct SimpleGeneric<T> {
    data: T;
}

// Generic struct with multiple type parameters
type struct Pair<T, U> {
    first: T;
    second: U;
}

// Generic struct with array types
type struct Container<T> {
    items: T[];
    count: int;
}

// Generic struct with nested generic types
type struct Wrapper<T> {
    inner: SimpleGeneric<int>;
    metadata: T; 
}

// Generic struct with constraints (conceptual - may not be implemented yet)
type struct NumericContainer<T> {
    value: T;
    doubled: T;
}

// Test basic generic usage
function test_basic_generics() -> void {
    const generic_instance: GenericStruct<string> = new GenericStruct<string>("Test");
    const val: string = generic_instance.get_value();

    const simple_pair: SimpleGeneric<int> = new SimpleGeneric<int>(42);
    const int_data: int = simple_pair.data;
    
    const float_simple: SimpleGeneric<float> = new SimpleGeneric<float>(3.14);
    const float_data: float = float_simple.data;

    return;
}

// Test multiple type parameters
function test_multiple_type_params() -> void {
    const pair_instance: Pair<int, string> = new Pair<int, string>(1, "One");
    const first_val: int = pair_instance.first;
    const second_val: string = pair_instance.second;
    
    const float_bool_pair: Pair<float, boolean> = new Pair<float, boolean>(3.14, true);
    const float_val: float = float_bool_pair.first;
    const bool_val: boolean = float_bool_pair.second;

    return;
}

// Test generic arrays
function test_generic_arrays() -> void {
    const int_container: Container<int> = new Container<int>([1, 2, 3], 3);
    const int_items: int[] = int_container.items;
    const item_count: int = int_container.count;
    
    const string_container: Container<string> = new Container<string>(["a", "b"], 2);
    const string_items: string[] = string_container.items;

    return;
}

// Test nested generics
function test_nested_generics() -> void {
    const wrapper_int: Wrapper<string> = new Wrapper<string>(
        new SimpleGeneric<int>(42),
        "metadata"
    );
    
    const inner_data: int = wrapper_int.inner.data;
    const meta: string = wrapper_int.metadata;

    return;
}

// Test generics with different primitive types
function test_generic_primitives() -> void {
    const int_generic: SimpleGeneric<int> = new SimpleGeneric<int>(100);
    const float_generic: SimpleGeneric<float> = new SimpleGeneric<float>(2.718);
    const bool_generic: SimpleGeneric<boolean> = new SimpleGeneric<boolean>(true);
    const char_generic: SimpleGeneric<char> = new SimpleGeneric<char>('X');
    const string_generic: SimpleGeneric<string> = new SimpleGeneric<string>("Hello");

    return;
}