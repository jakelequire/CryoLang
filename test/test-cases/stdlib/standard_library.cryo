namespace Main;

// =============================================================================
// CRYO STANDARD LIBRARY TEST - Design and Validation
// =============================================================================
// This file demonstrates the planned standard library functions and collections
// that should be built into the CryoLang compiler. These are parsed and type-checked
// but not yet executed until LLVM code generation is implemented.

function test_io_functions() -> void {
    // Basic I/O functions
    print("Hello, ");
    println("World!");
    
    // String input (when we add it)
    // const input: string = read_line();
    
    // File operations
    const content: string = read_file("example.txt");
    const success: boolean = write_file("output.txt", "Hello from CryoLang!");
    
    // Check if file exists
    const exists: boolean = file_exists("test.txt");
    
    return;
}

function test_string_functions() -> void {
    const text: string = "Hello, CryoLang!";
    
    // String length and manipulation
    const len: int = length(text);
    const upper: string = to_upper(text);
    const lower: string = to_lower(text);
    
    // String slicing and searching
    const substr: string = substring(text, 0, 5);  // "Hello"
    const index: int = find(text, "Cryo");         // 7
    const contains: boolean = contains(text, "Lang");
    
    // String splitting and joining
    const words: string[] = split(text, " ");
    const joined: string = join(words, "-");
    
    return;
}

function test_array_functions() -> void {
    mut numbers: int[] = [1, 2, 3, 4, 5];
    
    // Array length and manipulation
    const len: int = length(numbers);
    push(numbers, 6);           // Mutates array
    const popped: int = pop(numbers);  // Returns and removes last element
    
    // Array operations
    const sum: int = sum(numbers);
    const max: int = max(numbers);
    const min: int = min(numbers);
    
    // Functional operations (when we add lambdas)
    // const doubled: int[] = map(numbers, |x| x * 2);
    // const evens: int[] = filter(numbers, |x| x % 2 == 0);
    
    return;
}

function test_collections() -> void {
    // HashMap - key-value pairs
    mut scores: HashMap<string, int> = new HashMap<string, int>();
    insert(scores, "Alice", 100);
    insert(scores, "Bob", 85);
    
    const alice_score: int = get(scores, "Alice");
    const has_charlie: boolean = contains_key(scores, "Charlie");
    
    // HashSet - unique values
    mut unique_numbers: HashSet<int> = new HashSet<int>();
    insert(unique_numbers, 1);
    insert(unique_numbers, 2);
    insert(unique_numbers, 1);  // Duplicate, ignored
    
    const set_size: int = size(unique_numbers);  // Should be 2
    
    return;
}

function test_math_functions() -> void {
    const x: float = 3.14159;
    const y: float = 2.71828;
    
    // Basic math
    const abs_val: float = abs(-5.5);
    const power: float = pow(x, 2.0);
    const sqrt_val: float = sqrt(16.0);
    
    // Trigonometry  
    const sin_val: float = sin(x);
    const cos_val: float = cos(x);
    const tan_val: float = tan(x);
    
    // Logarithms
    const log_val: float = log(y);      // Natural log
    const log10_val: float = log10(100.0);  // Base 10
    
    // Rounding
    const rounded: float = round(3.7);   // 4.0
    const floored: int = floor(3.7);     // 3
    const ceiled: int = ceil(3.2);       // 4
    
    return;
}

function test_type_conversion() -> void {
    // String conversions
    const int_str: string = to_string(42);
    const float_str: string = to_string(3.14);
    const bool_str: string = to_string(true);
    
    // Parse from strings
    const parsed_int: int = parse_int("123");
    const parsed_float: float = parse_float("3.14");
    const parsed_bool: boolean = parse_bool("true");
    
    // Type casting
    const int_to_float: float = to_float(42);
    const float_to_int: int = to_int(3.99);  // Truncation
    
    return;
}

function test_random_functions() -> void {
    // Random number generation
    const rand_int: int = random_int(1, 100);        // Random int between 1-100
    const rand_float: float = random_float(0.0, 1.0); // Random float between 0-1
    const rand_bool: boolean = random_bool();         // Random true/false
    
    // Set random seed for reproducibility
    set_random_seed(12345);
    
    return;
}

function test_time_functions() -> void {
    // Get current time/date
    const timestamp: int = current_time_millis();
    const date_str: string = current_date();      // "2025-09-22"
    const time_str: string = current_time();      // "14:30:45"
    
    // Sleep/delay
    sleep_millis(1000);  // Sleep for 1 second
    
    return;
}

function test_error_handling() -> void {
    // Built-in error handling (when we implement Result<T, E> type)
    const file_result: Result<string, string> = try_read_file("might_not_exist.txt");
    
    match file_result {
        Result::Ok(content) => {
            println("File content: " + content);
        },
        Result::Err(error) => {
            println("Error reading file: " + error);
        }
    }
    
    return;
}

function main(argc: int, argv: string[]) -> int {
    println("=== CryoLang Standard Library Test ===");
    
    test_io_functions();
    test_string_functions();
    test_array_functions();
    test_collections();
    test_math_functions();
    test_type_conversion();
    test_random_functions();
    test_time_functions();
    test_error_handling();
    
    println("=== All standard library functions type-checked successfully! ===");
    return 0;
}