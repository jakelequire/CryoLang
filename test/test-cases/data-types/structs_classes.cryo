namespace Main;

// Test struct declarations
type struct Point {
    x: int;
    y: int;
    move(dx: int, dy: int) -> void;
}

type struct Rectangle {
    width: float;
    height: float;
    area() -> float;
    perimeter() -> float;
}

// Test class declarations
type class Circle {
public:
    center: Point;
    radius: float;

    area() -> float {
        return 3.14 * radius * radius;
    }
    
    circumference() -> float {
        return 2.0 * 3.14 * radius;
    }
}

type class Person {
public:
    name: string;
    age: int;
    
private:
    id: int;

    get_info() -> string {
        return name + " is " + "years old"; // Note: int to string conversion needed
    }
}

// Implement struct methods
implement struct Point {
    move(dx: int, dy: int) -> void {
        this.x = this.x + dx;
        this.y = this.y + dy;
    }
}

implement struct Rectangle {
    area() -> float {
        return this.width * this.height;
    }
    
    perimeter() -> float {
        return 2.0 * (this.width + this.height);
    }
}

// Test struct and class usage
function test_structs_and_classes() -> void {
    const p: Point = new Point(10, 20);
    p.move(5, -5);
    
    const rect: Rectangle = new Rectangle(10.0, 20.0);
    const rect_area: float = rect.area();
    const rect_perimeter: float = rect.perimeter();
    
    const c: Circle = new Circle(p, 15.0);
    const area: float = c.area();
    const circumference: float = c.circumference();
    
    const person: Person = new Person("Alice", 30, 12345);
    const info: string = person.get_info();

    return;
}