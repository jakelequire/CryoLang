namespace Main;

// Test basic data type declarations
function test_basic_types() -> void {
    // Integer types
    const number: int = 42;
    const hex_value: int = 0xFF;
    const negative: int = -10;
    
    // Float types
    const pi: float = 3.14;
    const scientific: float = 2.5e10;
    const negative_float: float = -1.5;
    
    // Boolean types
    const flag: boolean = true;
    const disabled: boolean = false;
    
    // Character types
    const char_value: char = 'A';
    const digit_char: char = '5';
    const symbol_char: char = '@';
    
    // String types
    const greeting: string = "Hello, World!";
    const empty_string: string = "";
    const multiword: string = "CryoLang Compiler";
    
    return;
}

// Test type operations and conversions
function test_type_operations() -> void {
    // Integer operations
    const a: int = 10;
    const b: int = 20;
    const sum: int = a + b;
    const product: int = a * b;
    const difference: int = b - a;
    const quotient: int = b / a;
    
    // Float operations
    const x: float = 10.5;
    const y: float = 3.2;
    const float_sum: float = x + y;
    const float_product: float = x * y;
    
    // String operations
    const first_name: string = "John";
    const last_name: string = "Doe";
    const full_name: string = first_name + " " + last_name;
    
    // Boolean operations
    const condition1: boolean = true;
    const condition2: boolean = false;
    const and_result: boolean = condition1 && condition2;
    const or_result: boolean = condition1 || condition2;
    const not_result: boolean = !condition1;
    
    return;
}

// Test type comparisons
function test_type_comparisons() -> void {
    // Integer comparisons
    const num1: int = 10;
    const num2: int = 20;
    const equal: boolean = num1 == num2;
    const not_equal: boolean = num1 != num2;
    const less_than: boolean = num1 < num2;
    const greater_than: boolean = num1 > num2;
    const less_equal: boolean = num1 <= num2;
    const greater_equal: boolean = num1 >= num2;
    
    // Float comparisons
    const f1: float = 3.14;
    const f2: float = 2.71;
    const float_equal: boolean = f1 == f2;
    const float_greater: boolean = f1 > f2;
    
    // String comparisons
    const str1: string = "apple";
    const str2: string = "banana";
    const string_equal: boolean = str1 == str2;
    
    // Boolean comparisons
    const bool1: boolean = true;
    const bool2: boolean = false;
    const bool_equal: boolean = bool1 == bool2;
    
    return;
}