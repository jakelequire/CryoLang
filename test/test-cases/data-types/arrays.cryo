namespace Main;

// Test array declarations and literals
function test_arrays() -> void {
    //  Array literal - integers
    const numbers: int[] = [1, 2, 3, 4, 5];
    
    //  Array literal - strings  
    const names: string[] = ["Alice", "Bob", "Charlie"];
    
    //  Array literal - floats
    const temperatures: float[] = [20.5, 25.0, 30.2];
    
    //  Array literal - booleans
    const flags: boolean[] = [true, false, true];
    
    //  Array literal - characters
    const letters: char[] = ['a', 'b', 'c'];
    
    //  Empty array
    const empty: int[] = [];
    
    return;
}

// Test array access and indexing
function test_array_access() -> void {
    const numbers: int[] = [10, 20, 30, 40, 50];
    const names: string[] = ["Alice", "Bob", "Charlie"];
    
    //  Array access with literal index
    const first_number: int = numbers[0];
    const second_name: string = names[1];
    const last_number: int = numbers[4];
    
    //  Array access with variable index
    const index: int = 2;
    const third_number: int = numbers[index];
    
    // String character access
    const greeting: string = "Hello, world!";
    const char_at: char = greeting[7];
    
    return;
}

// Test multi-dimensional arrays
function test_multidimensional_arrays() -> void {
    //  2D array (matrix)
    const matrix: int[][] = [[1, 2], [3, 4], [5, 6]];
    const element: int = matrix[1][0]; // Should be 3
    
    // 2D string array
    const word_grid: string[][] = [["Hello", "World"], ["Foo", "Bar"]];
    const word: string = word_grid[0][1]; // Should be "World"
    
    // 3D array
    const cube: int[][][] = [[[1, 2], [3, 4]], [[5, 6], [7, 8]]];
    const deep_element: int = cube[1][0][1]; // Should be 6
    
    return;
}

// Test array operations
function array_operations() -> void {
    //  Mixed expressions with arrays
    const values: int[] = [10, 20, 30];
    const sum: int = values[0] + values[1];
    const doubled: int = values[2] * 2;
    
    // Array elements in calculations
    const coordinates: float[] = [1.5, 2.5, 3.0];
    const distance: float = coordinates[0] + coordinates[1];
    
    // Array of results
    const results: int[] = [values[0] * 2, values[1] + 5, values[2] - 1];
    
    return;
}

// Test string array operations
function string_array() -> void {
    const words: string[] = ["Hello", "World"];
    const greeting: string = words[0] + ", " + words[1] + "!";
    
    const another_greeting: string = "Hello, world!";
    const char_at: char = another_greeting[7];

    return;
}