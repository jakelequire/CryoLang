namespace Main;

/// This is a test
/**
 * This is a multi-line comment
 */
function test_pointers_and_references() -> void {
    mut x: int = 10; // No `&` or `*`, just a normal variable which is the owner of the value
    mut y: int = 20;
    
    // Reference to x
    mut ref_x: &int = &x;
    // Reference to y
    mut ref_y: &int = &y; // `&` prefix indicates a reference type
    
    // Pointer to x
    mut ptr_x: int * = &x; // The POSTFIX of `*` indicates a pointer type, the prefix of `*` is dereference operator
    // Pointer to y
    mut ptr_y: int * = &y;
    
    // Dereference pointer and modify value
    *ptr_x = *ptr_x + 5; // x should now be 15
    *ptr_y = *ptr_y + 10; // y should now be 30
    
    // Modify original variables through references
    x = *ref_x + 2; // x should now be 17
    y = *ref_y + 3; // y should now be 33
    
    return;
}

// Test pointer arithmetic and operations
function test_pointer_operations() -> void {
    mut value: int = 42;
    mut ptr: int * = &value;
    
    // Basic pointer operations
    const original: int = *ptr;
    *ptr = original * 2;
    
    // Reference vs pointer comparison
    mut ref_val: &int = &value;
    const ref_result: int = *ref_val;
    const ptr_result: int = *ptr;
    
    return;
}

// Test references with different types
function test_references_types() -> void {
    mut int_val: int = 100;
    mut float_val: float = 3.14;
    mut bool_val: boolean = true;
    mut string_val: string = "Hello";
    
    // References to different types
    mut int_ref: &int = &int_val;
    mut float_ref: &float = &float_val;
    mut bool_ref: &boolean = &bool_val;
    mut string_ref: &string = &string_val;
    
    // Dereferencing different types
    const deref_int: int = *int_ref;
    const deref_float: float = *float_ref;
    const deref_bool: boolean = *bool_ref;
    const deref_string: string = *string_ref;
    
    return;
}

// Test pointers with arrays
function test_array_pointers() -> void {
    mut numbers: int[] = [1, 2, 3, 4, 5];
    
    // Pointer to array (note: syntax may vary)
    mut array_ptr: int[] * = &numbers;
    
    // Access array elements through pointer
    const first_element: int = (*array_ptr)[0];
    const second_element: int = (*array_ptr)[1];
    
    return;
}

// Test memory safety patterns
function test_memory_safety() -> void {
    mut original: int = 50;
    
    {
        mut local_ptr: int * = &original;
        *local_ptr = 75;
    }
    // local_ptr goes out of scope, but original is still valid
    
    const final_value: int = original; // Should be 75
    
    return;
}