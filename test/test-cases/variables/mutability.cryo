namespace Main;

// Test variable mutability
function test_mutability() -> void {
    mut count: int = 0;
    count = count + 1;
    return;
}

// Test const vs mut variables
function test_const_vs_mut() -> void {
    // Constant variables - cannot be reassigned
    const pi: float = 3.14159;
    const app_name: string = "CryoLang";
    const max_users: int = 1000;
    
    // Mutable variables - can be reassigned
    mut current_users: int = 0;
    mut is_running: boolean = true;
    mut progress: float = 0.0;
    
    // Only mutable variables can be modified
    current_users = current_users + 1;
    is_running = false;
    progress = 0.5;
    
    return;
}

// Test mutability with complex types
function test_mutability_complex() -> void {
    // Mutable array
    mut numbers: int[] = [1, 2, 3];
    // Note: Array element modification would be: numbers[0] = 10; (when supported)
    
    // Const array - cannot reassign the whole array
    const fixed_values: int[] = [10, 20, 30];
    
    return;
}