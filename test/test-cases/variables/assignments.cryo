namespace Main;

// Test variable assignments
function test_assignment() -> void {
    mut x: int = 10;
    x = x + 5;
    return;
}

// Test different assignment patterns
function test_various_assignments() -> void {
    // Basic assignments
    mut counter: int = 0;
    mut name: string = "CryoLang";
    mut active: boolean = true;
    mut temperature: float = 25.5;
    mut grade: char = 'A';
    
    // Reassignments
    counter = counter * 2;
    name = name + " Compiler";
    active = !active;
    temperature = temperature + 5.0;
    grade = 'B';
    
    return;
}

// Test compound assignments with expressions
function test_complex_assignments() -> void {
    mut result: int = 0;
    const base: int = 10;
    const multiplier: int = 3;
    
    result = (base + 5) * multiplier;
    result = result - (base / 2);
    
    return;
}