namespace Main;

// Test variable scoping rules
function test_scope() -> void {
    {
        const inner_var: int = 20;
        //  inner_var is accessible here
    }
    //  inner_var is not accessible here
    return;
}

// Test nested scoping
function test_nested_scope() -> void {
    const outer_var: int = 100;
    
    {
        const middle_var: string = "Middle";
        const outer_copy: int = outer_var; // Can access outer scope
        
        {
            const inner_var: boolean = true;
            const middle_copy: string = middle_var; // Can access middle scope
            const outer_copy_inner: int = outer_var; // Can access outer scope
            
            // All three variables accessible here
        }
        
        // Only outer_var and middle_var accessible here
    }
    
    // Only outer_var accessible here
    return;
}

// Test function scope vs block scope
function test_function_vs_block_scope() -> void {
    const function_var: int = 42;
    
    if (true) {
        const block_var: string = "Block scoped";
        const function_access: int = function_var; // Can access function scope
    }
    
    // block_var is not accessible here
    // function_var is still accessible
    
    return;
}