namespace Main;

// Simple test to verify built-in functions are available
function test_builtins() -> void {
    const x: int = 42;
    const name: string = "Cryo";
    const pi: float = 3.14159;
    const message: string = "Testing built-ins";
    
    // Test built-in I/O functions
    println("Hello from CryoLang!");
    print(name);
    
    // Test math functions  
    const sq: float = sqrt(16.0);
    const power: float = pow(2.0, 3.0);
    const abs_val: float = abs(-10.5);
    
    // Test string functions
    const len: int = length(name);
    const upper: string = to_upper(name);
    const lower: string = to_lower(name);
    
    // Test type conversions
    const x_str: string = to_string(x);
    const pi_str: string = to_string(pi);
    const parsed: int = parse_int("123");
    
    // Test system functions
    const time: int = current_time_millis();
    const date: string = current_date();
    
    return;
}

function main(argc: int, argv: string[]) -> int {
    test_builtins();
    return 0;
}