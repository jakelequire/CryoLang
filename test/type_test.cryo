namespace TypeTest;

// Function with type annotations
function add_numbers(x: int, y: int) -> int {
    return x + y;
}

function main() -> int {
    // Test basic types
    const num: int = 42;
    const text: string = "Hello";
    const flag: boolean = true;
    const pi: float = 3.14;
    
    // Test type inference and function calls
    const result: int = add_numbers(10, 20);
    
    // Test type errors (these should be caught)
    // const bad_assign: int = "string";  // Type error
    // const bad_call: int = add_numbers(1.0, 2.0);  // Type error
    
    return 0;
}