namespace ImplErrorTest;

import IO from <io/stdio>;

type struct ImplTestStruct {
    value: int;

    ImplTestStruct(val: int);

    valid_method() -> int;
    invalid_method() -> int;
    another_invalid_method() -> void;
    static static_impl_method() -> int;
}

implement ImplTestStruct {
    valid_method() -> int {
        return this.value;  // Valid usage of 'this'
    }

    invalid_method() -> int {
        const invalid_access: int = this.non_existent_field;  // Invalid: 'this' accessing undefined field
        return invalid_access;
    }

    another_invalid_method() -> void {
        this = new ImplTestStruct(10);  // Invalid: Attempting to assign to 'this'
    }

    static static_impl_method() -> int {
        // Invalid: 'this' cannot be used in static methods
        const invalid_static_access: int = this.value;
        return invalid_static_access;
    }
}


function main() -> int {
    const test_struct_instance: ImplTestStruct = new ImplTestStruct(10);

    return 0;
}