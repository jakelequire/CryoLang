namespace ImplErrorTest;

import IO from <io/stdio>;

// In this test, we are only creating a struct definition and its implementation.
// In Cryo, the implementation block must match the struct definition exactly.
// The implementation of the struct/class methods can either be inlined in the struct/class definition,
// or provided in a separate implementation block using the `implement` keyword.
// The implementation must either be inline or in an `implement` block, but not both.

type struct Point2D {
    x: int;
    y: int;

    Point2D(_x: int, _y: int);
    move(dx: int, dy: int) -> void;
}

implement struct Point2D {
    Point2D(_x: int, _y: int) {
        this.x = _x;
        this.y = _y;
    }

    move(dx: int, dy: int) -> void {
        this.x = this.x + dx;
        this.y = this.y + dy;
    }
}


function main() -> int {
    const point: Point2D = new Point2D(0, 0);

    IO::printf("Initial Point coordinates: (%d, %d)\n", point.x, point.y);
    
    point.move(5, 10);

    IO::printf("Point coordinates: (%d, %d)\n", point.x, point.y);

    return 0;
}
