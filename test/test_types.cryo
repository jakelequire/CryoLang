namespace TestTypes;

// Basic type annotations
function test_basic_types() -> void {
    const x: int = 42;
    const y: float = 3.14;
    const message: string = "Hello, CryoLang!";
    const flag: boolean = true;
    const ch: char = 'A';
    
    return;
}

// Type inference with auto
function test_auto_inference() -> void {
    const auto_int = 100;        // Should infer int
    const auto_float = 2.718;    // Should infer float  
    const auto_string = "World"; // Should infer string
    const auto_bool = false;     // Should infer boolean
    
    return;
}

// Array types
function test_arrays() -> void {
    const numbers: int[] = [1, 2, 3, 4, 5];
    const words: string[] = ["hello", "world"];
    const flags: boolean[3] = [true, false, true];
    
    return;
}

// Function types and parameters
function add(a: int, b: int) -> int {
    return a + b;
}

function greet(name: string, count: int) -> string {
    return "Hello " + name;
}

// Optional/nullable types (if implemented)
function test_optionals() -> void {
    const maybe_value: int? = 42;
    const empty_value: string? = null;
    
    return;
}

// Mixed type operations
function test_operations() -> void {
    const a: int = 10;
    const b: int = 20;
    const sum: int = a + b;
    
    const x: float = 1.5;
    const y: float = 2.5;
    const product: float = x * y;
    
    const isEqual: boolean = (a == 10);
    const isGreater: boolean = (b > a);
    
    return;
}

// Main function to test everything
public function main() -> int {
    test_basic_types();
    test_auto_inference();
    test_arrays();
    test_operations();
    
    const result: int = add(5, 10);
    const greeting: string = greet("CryoLang", 1);
    
    return 0;
}