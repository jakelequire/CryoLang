}

// Simple enum for testing
enum Direction {
    NORTH,
    SOUTH,
    EAST,
    WEST
}

// Enum with single variant (edge case)
enum SingleVariant {
    OnlyOne(string)
}

function test_enums() -> void {
    // Test C-style enum usage with scope resolution
    const my_color: Color = Color::RED;
    const status: StatusCode = StatusCode::SUCCESS;
    const heading: Direction = Direction::NORTH;
    
    // Test enum in expressions
    const is_red: boolean = my_color == Color::RED;
    const is_success: boolean = status == StatusCode::SUCCESS;
    
    // Test different enum variants
    const another_color: Color = Color::BLUE;
    const failed_status: StatusCode = StatusCode::ERROR;

    const circle: Shape = Shape::Circle(5.0);
    const rect: Shape = Shape::Rectangle(10.0, 20.0);
    match circle {
        Shape::Circle(radius) => {
            const area: float = 3.14 * radius * radius;
            std::IO::printf("Area of Circle:");
            std::IO::print_float(area);
        },
        Shape::Rectangle(width, height) => {
            const area: float = width * height;
            std::IO::printf("Area of Rectangle:");
            std::IO::print_float(area);
        },
        Shape::Triangle(a, b, c) => {
            const s: float = (a + b + c) / 2.0;
            std::IO::printf("Semi-perimeter of Triangle:");
            std::IO::print_float(s);
        }
    }

    return;
}

function test_pointers_and_references() -> void {
    std::IO::printf("Testing Pointers and References:");
    mut x: int = 10; // No `&` or `*`, just a normal variable which is the owner of the value
    mut y: int = 20;
    std::IO::printf("Initial values:");
    std::IO::print_int(x);
    std::IO::print_int(y);

    // Reference to x
    mut ref_x: &int = &x;
    // Reference to y
    mut ref_y: &int = &y; // `&` prefix indicates a reference type

    std::IO::printf("Reference values:");
    std::IO::print_int(*ref_x);
    std::IO::print_int(*ref_y);

    // Pointer to x
    mut ptr_x: int * = &x; // The POSTFIX of `*` indicates a pointer type, the prefix of `*` is dereference operator
    // Pointer to y
    mut ptr_y: int * = &y;

    std::IO::printf("Pointer values:");
    std::IO::print_int(*ptr_x);
    std::IO::print_int(*ptr_y);

    // Dereference pointer and modify value
    *ptr_x = *ptr_x + 5; // x should now be 15
    *ptr_y = *ptr_y + 10; // y should now be 30

    std::IO::printf("Values after modifying through pointers:");
    std::IO::print_int(x);
    std::IO::print_int(y);

    // Modify original variables through references
    x = *ref_x + 2; // x should now be 17
    y = *ref_y + 3; // y should now be 33

    std::IO::printf("Values after modifying through references:");
    std::IO::print_int(x);
    std::IO::print_int(y);

    return;
}

type struct Point {
    x: int;
    y: int;
    
    Point(_x: int, y: int);
    move(dx: int, dy: int) -> void;

}

implement struct Point {
    Point(_x: int, _y: int) {
        this.x = _x;
        this.y = _y;
    }

    move(dx: int, dy: int) -> void {
        this.x = this.x + dx;
        this.y = this.y + dy;
    }
}

function test_structs() -> void {
    std::IO::printf("Testing Structs:");
    const p: Point = new Point(10, 20);
    std::IO::printf("Initial Point coordinates:");
    std::IO::print_int(p.x); // Should print 10
    std::IO::print_int(p.y); // Should print 20
    p.move(5, -10);

    std::IO::printf("Point coordinates after move:");
    std::IO::print_int(p.x); // Should print 15
    std::IO::print_int(p.y); // Should print 10

    return;
}


type class CircleClass {
public:
    center: float;
    radius: float;
    foo: string;
    bar: i32;

    CircleClass(center: float, radius: float) {
        this.center = center;
        this.radius = radius;
    }

    area() -> float {
        return 3.14 * this.radius * this.radius;
    }
private:
    diameter() -> float {
        return 2.0 * this.radius;
    }
}

function test_classes() -> void {
    std::IO::printf("Testing Classes:");
    const circle: CircleClass = new CircleClass(0.0, 10.0);

    const area: float = circle.area();
    std::IO::printf("Area of Circle:");
    std::IO::print_float(area); // Should print 314.0

    return;
}

type struct GenericStruct<T> {
    value: T;
    GenericStruct(val: T) {
        this.value = val;
    }
    get_value() -> T {
        return this.value;
    }
}

type struct Pair<T, U> {
    first: T;
    second: U;
}

type struct SingleStruct {
    name: string;
}

type struct AnotherStruct {
    id: int;
    description: string;
}

function test_generic_structs() -> void {
    std::IO::printf("Testing Generic Structs:");

    const int_instance: GenericStruct<int> = new GenericStruct<int>(42);
    const float_instance: GenericStruct<float> = new GenericStruct<float>(3.14);
    const string_instance: GenericStruct<string> = new GenericStruct<string>("Hello");

    std::IO::printf("Integer GenericStruct value:");
    std::IO::print_int(int_instance.get_value()); // Should print 42

    std::IO::printf("Float GenericStruct value:");
    std::IO::print_float(float_instance.get_value()); // Should print 3.14

    std::IO::printf("String GenericStruct value:");
    std::IO::printf(string_instance.get_value()); // Should print "Hello"

    const pair_instance: Pair<int, string> = Pair<int, string>({first: 1, second: "One"});
    std::IO::printf("Pair values:");
    std::IO::print_int(pair_instance.first); // Should print 1
    std::IO::printf(pair_instance.second); // Should print "One"


    const single_instance: SingleStruct = SingleStruct({name: "Single"});
    std::IO::printf("SingleStruct name:");
    std::IO::printf(single_instance.name); // Should print "Single"

    const another_instance: AnotherStruct = AnotherStruct({id: 100, description: "Another"});
    std::IO::printf("AnotherStruct values:");
    std::IO::print_int(another_instance.id); // Should print 100
    std::IO::printf(another_instance.description); // Should print "Another"

    return;
}

function test_switch() -> void {
    std::IO::printf("Testing Switch Statement:");
    const value: int = 2;
    mut result: string = "";

    switch (value) {
        case 1:
            result = "One";
            break;
        case 2:
            result = "Two";
            break;
        case 3:
            result = "Three";
            break;
        default:
            result = "Other";
    }

    std::IO::printf("<int> Switch result:");
    std::IO::printf(result); // Should print "Two"

    const str_value: string = "hello";
    mut str_result: string = "";

    switch (str_value) {
        case "hi":
            str_result = "Greeting";
            break;
        case "hello":
            str_result = "Salutation";
            break;
        case "bye":
            str_result = "Farewell";
            break;
        default:
            str_result = "Unknown";
            break;
    }

    std::IO::printf("<string> Switch result:");
    std::IO::printf(str_result); // Should print "Salutation"

    const char_value: char = 'A';
    mut char_result: string = "";
    switch (char_value) {
        case 'A':
            char_result = "Letter A";
            break;
        case 'B':
            char_result = "Letter B";
            break;
        case 'C':
            char_result = "Letter C";
            break;
        default:
            char_result = "Other Letter";
            break;
    }

    std::IO::printf("<char> Switch result:");
    std::IO::printf(char_result); // Should print "Letter A"

    const enum_value: Color = Color::GREEN;
    mut enum_result: string = "";
    switch (enum_value) {
        case Color::RED:
            enum_result = "Red Color";
            break;
        case Color::GREEN:
            enum_result = "Green Color";
            break;
        case Color::BLUE:
            enum_result = "Blue Color";
            break;
        default:
            enum_result = "Other Color";
            break;
    }

    std::IO::printf("<enum> Switch result:");
    std::IO::printf(enum_result); // Should print "Green Color"

    return;
}

trait Foo {
    do_something(self: &Foo) -> void;
}

trait Bar : Foo {
    do_another_thing(self: &Bar) -> void;
}

function generic_function<T>(item: T) -> T {
    return item;
}


