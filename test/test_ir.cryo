function test_control_flow() -> void {
    std::IO::printf("Testing Control Flow:");
    //  If-else statement
    const condition: boolean = true;
    mut result: int = 0;
    if (condition) {
        result = 42;
    } else {
        result = 10;
    }
    
    //  Nested if-else
    const x: int = 10;
    if (x > 5) {
        if (x > 15) {
            const big: boolean = true;
        } else {
            const medium: boolean = true;
        }
    }
    
    //  While loop
    mut counter: int = 0;
    while (counter < 5) {
        counter = counter + 1;
    }
    
    //  For loop
    for (mut i: int = 0; i < 10; i = i + 1) {
        if (i == 3) {
            continue;
        }
        if (i == 7) {
            break;
        }
        const value: int = i * 2;
        std::IO::printf("For loop value:");
        std::IO::print_int(value);
    }
    
    // For loop with increment operator 
    for (mut j: int = 0; j < 5; j++) {
        const square: int = j * j;
        std::IO::print_int(square);
    }

    // For loop with decrement operator
    for (mut k: int = 5; k > 0; k--) {
        const cube: int = k * k * k;
        std::IO::print_int(cube);
    }
    
    return;
}

function test_nested_loops() -> void {
    std::IO::printf("Testing Nested Loops:");
    for (mut i: int = 0; i < 3; i++) {
        for (mut j: int = 0; j < 3; j++) {
            if (i == j) {
                continue;
            }
            const product: int = i * j;
            std::IO::print_int(product);
        }
    }
}

function fibonacci(n: int) -> int {
    if (n <= 0) {
        return 0;
    } else if (n == 1) {
        return 1;
    } else {
        return fibonacci(n - 1) + fibonacci(n - 2);
    }
}

function test_fibonacci(limit: int) -> void {
    std::IO::printf("Testing Fibonacci function:");

    for (mut i: int = 0; i <= limit; i++) {
        const fib_result: int = fibonacci(i);
        std::IO::print_int(fib_result);
    }
    
    return;
}

function ternary_test() -> void {
    std::IO::printf("Testing Ternary Operator:");
    const a: int = 10;
    const b: int = 20;
    
    //  Simple ternary
    const max_value: int = a > b ? a : b;
    std::IO::print_int(max_value); // Should print 20
    
    //  Nested ternary
    const result: int = a > 15 ? (b > 25 ? b : a) : 5;
    std::IO::print_int(result); // Should print 5

    //  Boolean ternary
    const is_positive: boolean = max_value > 0 ? true : false;
    std::IO::print_bool(is_positive); // Should print true
}

function test_arrays() -> void {
    std::IO::printf("Testing Arrays:");
    
    //  Array literal - integers
    const numbers: int[] = [1, 2, 3, 4, 5];
    
    //  Array literal - strings  
    const names: string[] = ["Alice", "Bob", "Charlie"];
    
    //  Empty array
    const empty: int[] = [];
    
    //  Array access
    const first_number: int = numbers[0];
    std::IO::printf("Accessing first number in the array:");
    std::IO::print_int(first_number); // Should print 1

    const second_name: string = names[1];
    std::IO::printf("Accessing second name in the array:");
    std::IO::printf(second_name); // Should print "Bob"

    //  Array access with variable index
    const index: int = 2;
    const third_number: int = numbers[index];
    std::IO::printf("Accessing third number in the array:");
    std::IO::print_int(third_number); // Should print 3

    // `.length` isn't implemented yet, so we'll hardcode the length for now
    std::IO::printf("Iterating over the array:");
    for (mut i: int = 0; i < 4; i++) {
        std::IO::print_int(numbers[i]); // Should print 1, 2, 3, 4
    }
    
    //  Nested arrays (2D array) - commented out for now due to issues
    const matrix: int[][] = [[1, 2], [3, 4], [5, 6]];
    const element: int = matrix[1][0]; // Should be 3
    std::IO::printf("Accessing element from 2D array:");
    std::IO::print_int(element); // Should print 3

    return;
}

