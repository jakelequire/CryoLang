namespace Main;

// Temporarily commented out to avoid crashes during incremental testing
function func_param(a: int, b: float, c: string, d: boolean, e: char) -> void {
    Std::Runtime::println("Testing Function Parameters:");
    const local_var: int = a + 10;
    const flag: boolean = true;

    Std::Runtime::print_bool(flag);
    Std::Runtime::print_int(local_var);
    Std::Runtime::print_float(b);
    Std::Runtime::print_char(e);
    
    return;
}

function add(a: int, b: int) -> int {
    return a + b;
}

function multiply(x: int, y: int) -> int {
    return x * y;
}

function test_assignment() -> void {
    Std::Runtime::println("Testing Assignment:");
    mut x: int = 10;
    x = x + 5;
    Std::Runtime::print_int(x);
    return;
}

function test_scope() -> void {
    {
        const inner_var: int = 20;
        //  inner_var is accessible here
    }
    //  inner_var is not accessible here - this would cause a scope error:
    // const test_inner: int* = &inner_var; // Correctly caught scope error!
    return;
}


function test_control_flow() -> void {
    Std::Runtime::println("Testing Control Flow:");
    //  If-else statement
    const condition: boolean = true;
    mut result: int = 0;
    if (condition) {
        result = 42;
    } else {
        result = 10;
    }
    
    //  Nested if-else
    const x: int = 10;
    if (x > 5) {
        if (x > 15) {
            const big: boolean = true;
        } else {
            const medium: boolean = true;
        }
    }
    
    //  While loop
    mut counter: int = 0;
    while (counter < 5) {
        counter = counter + 1;
    }
    
    //  For loop
    for (mut i: int = 0; i < 10; i = i + 1) {
        if (i == 3) {
            continue;
        }
        if (i == 7) {
            break;
        }
        const value: int = i * 2;
        Std::Runtime::print_int(value);
    }
    
    // For loop with increment operator 
    for (mut j: int = 0; j < 5; j++) {
        const square: int = j * j;
        Std::Runtime::print_int(square);
    }

    // For loop with decrement operator
    for (mut k: int = 5; k > 0; k--) {
        const cube: int = k * k * k;
        Std::Runtime::print_int(cube);
    }
    
    return;
}

function test_nested_loops() -> void {
    Std::Runtime::println("Testing Nested Loops:");
    for (mut i: int = 0; i < 3; i++) {
        for (mut j: int = 0; j < 3; j++) {
            if (i == j) {
                continue;
            }
            const product: int = i * j;
            Std::Runtime::print_int(product);
        }
    }
}

function fibonacci(n: int) -> int {
    if (n <= 0) {
        return 0;
    } else if (n == 1) {
        return 1;
    } else {
        return fibonacci(n - 1) + fibonacci(n - 2);
    }
}

function test_fibonacci(limit: int) -> void {
    Std::Runtime::println("Testing Fibonacci function:");

    for (mut i: int = 0; i <= limit; i++) {
        const fib_result: int = fibonacci(i);
        Std::Runtime::print_int(fib_result);
    }
    
    return;
}

function ternary_test() -> void {
    Std::Runtime::println("Testing Ternary Operator:");
    const a: int = 10;
    const b: int = 20;
    
    //  Simple ternary
    const max_value: int = a > b ? a : b;
    Std::Runtime::print_int(max_value); // Should print 20
    
    //  Nested ternary
    const result: int = a > 15 ? (b > 25 ? b : a) : 5;
    Std::Runtime::print_int(result); // Should print 5

    //  Boolean ternary
    const is_positive: boolean = max_value > 0 ? true : false;
    Std::Runtime::print_bool(is_positive); // Should print true
}

function test_arrays() -> void {
    Std::Runtime::println("Testing Arrays:");
    
    //  Array literal - integers
    const numbers: int[] = [1, 2, 3, 4, 5];
    
    //  Array literal - strings  
    const names: string[] = ["Alice", "Bob", "Charlie"];
    
    //  Empty array
    const empty: int[] = [];
    
    //  Array access
    const first_number: int = numbers[0];
    Std::Runtime::print_int(first_number); // Should print 1
    
    const second_name: string = names[1];
    Std::Runtime::println(second_name); // Should print "Bob"

    //  Array access with variable index
    const index: int = 2;
    const third_number: int = numbers[index];
    Std::Runtime::print_int(third_number); // Should print 3

    // `.length` isn't implemented yet, so we'll hardcode the length for now
    for (mut i: int = 0; i < 4; i++) {
        Std::Runtime::print_int(numbers[i]); // Print each number in the array
    }
    
    //  Nested arrays (2D array) - commented out for now due to issues
    const matrix: int[][] = [[1, 2], [3, 4], [5, 6]];
    const element: int = matrix[1][0]; // Should be 3
    Std::Runtime::print_int(element); // Should print 3
    
    return;
}


function main() -> int {
    const x: int = 10;
    const y: int = 20;
    const result: int = x + y;

    Std::Runtime::println("Testing x+y:");
    Std::Runtime::print_int(result);
    Std::Runtime::println("New Line");

    func_param(5, 3.14, "World", true, 'A');

    test_assignment();
    test_nested_loops();
    test_fibonacci(12);
    ternary_test();
    test_arrays();

    return result;
}
