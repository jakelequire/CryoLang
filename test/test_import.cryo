namespace Main;

// The `test_import.cryo` file has the namespace `CryoTest` and defines a simple function.
// When importing, resolving symbols can be accessed via the namespace.
import "./test_file.cryo";     // To import from another file, using "./" or "../" for relative paths
// import "./test_import.cryo" as CryoTest; // ( The `as` keyword is not implemented yet. )
// ^ This is what it looks like under the hood when importing from another file.
// So when accessing symbols, you would use `CryoTest::test_import_function()`.
// If it's the same namespace, you can omit the namespace prefix. (only if the file is within the same directory, similar to Go)
// If it's the same namespace, it is treated as one single compilation unit.

// Importing from the standard library
// The standard library is located in the `stdlib/` directory at the root of the project.
import <core/intrinsics>;       // To import from the standard library, using <> for absolute paths
// import <core/intrinsics> as Std::Intrinsics;




function main() -> int {
    const result: int = CryoTest::test_import_function();
    Std::Runtime::print_int(result);
    return result;
}

