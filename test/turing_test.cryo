namespace Main;

import IO from <io/stdio>;
import <strings/strings>;

// Tape cell - stores a symbol
type struct Cell {
    symbol: char;
    Cell(s: char) {
        this.symbol = s;
    }
}

// Turing Machine state
type struct TuringMachine {
    tape: Cell[];
    head_position: int;
    current_state: int;
    halt_state: int;
    
    TuringMachine(tape_size: int) {
        // Initialize tape with blank symbols
        this.tape = [];
        for (mut i: int = 0; i < tape_size; i++) {
            // We'll manually populate since array methods aren't complete
        }
        this.head_position = 0;
        this.current_state = 0;
        this.halt_state = -1;
    }
    
    read() -> char {
        return this.tape[this.head_position].symbol;
    }
    
    write(symbol: char) -> void {
        this.tape[this.head_position].symbol = symbol;
    }
    
    move_left() -> void {
        if (this.head_position > 0) {
            this.head_position = this.head_position - 1;
        }
    }
    
    move_right() -> void {
        this.head_position = this.head_position + 1;
    }
    
    step() -> boolean {
        if (this.current_state == this.halt_state) {
            return false;
        }
        
        const current_symbol: char = this.read();
        
        // Simple transition rules: flip 0s to 1s, move right, halt on blank
        if (current_symbol == '0') {
            this.write('1');
            this.move_right();
            this.current_state = 0;
        } else if (current_symbol == '1') {
            this.move_right();
            this.current_state = 0;
        } else {
            // Blank symbol - halt
            this.current_state = this.halt_state;
            return false;
        }
        
        return true;
    }
    
    run() -> void {
        mut running: boolean = true;
        mut steps: int = 0;
        
        while (running) {
            running = this.step();
            steps = steps + 1;
            
            if (steps > 100) {
                break;
            }
        }
    }
}

function main() -> int {
    IO::println("Basic Turing Machine");
    
    const tm: TuringMachine = new TuringMachine(10);
    
    // Initialize tape manually with 0s
    tm.tape[0] = new Cell('0');
    tm.tape[1] = new Cell('0');
    tm.tape[2] = new Cell('0');
    tm.tape[3] = new Cell(' ');
    tm.tape[4] = new Cell(' ');
    
    tm.run();
    
    IO::println("Tape after execution:");
    for (mut i: int = 0; i < 5; i++) {
        IO::print_char(tm.tape[i].symbol);
    }

    IO::println("");
    
    return 0;
}
