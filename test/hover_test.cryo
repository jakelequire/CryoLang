// Sample CryoLang file for testing LSP hover functionality

/// This is a main function that demonstrates various language features
/// @param argc The number of command line arguments
/// @param argv Array of command line argument strings
/// @returns Exit code (0 for success)
function main(argc: int, argv: string[]) -> int {
    // Variable declarations with different types
    let name: string = "CryoLang";
    let version: float = 1.0;
    let isDebug: boolean = true;
    let count: uint32 = 42;
    
    /// This function calculates the factorial of a number
    /// @param n The number to calculate factorial for
    /// @returns The factorial result
    function factorial(n: int) -> int {
        if (n <= 1) {
            return 1;
        }
        return n * factorial(n - 1);
    }
    
    // Test hover on variables
    let result = factorial(count);
    
    // Test hover on built-in types
    let testBool: bool = false;
    let testChar: char = 'A';
    let testDouble: double = 3.14159;
    
    // Test hover on function calls
    print_info(name, version);
    
    return 0;
}

