namespace ThisKWErrorTest;

import IO from <io/stdio>;

type class ThisTestClass {
    value: int;

    ThisTestClass(val: int) {
        this.value = val;
    }

    valid_method() -> int {
        return this.value;  // Valid usage of 'this'
    }

    invalid_method() -> int {
        const invalid_access: int = this.non_existent_field;  // Invalid: 'this' accessing undefined field
        return invalid_access;
    }

    another_invalid_method() -> void {
        this = new ThisTestClass(10);  // Invalid: Attempting to assign to 'this'
    }

    static static_class_method() -> int {
        // Invalid: 'this' cannot be used in static methods
        const invalid_static_access: int = this.value;
        return invalid_static_access;
    }
}

type struct ThisTestStruct {
    value: int;

    ThisTestStruct(val: int) {
        this.value = val;
    }

    valid_struct_method() -> int {
        return this.value;  // Valid usage of 'this'
    }

    invalid_struct_method() -> int {
        const invalid_access: int = this.non_existent_field;  // Invalid: 'this' accessing undefined field
        return invalid_access;
    }

    static static_struct_method() -> int {
        // Invalid: 'this' cannot be used in static methods
        const invalid_static_access: int = this.value;
        return invalid_static_access;
    }
}

function main() -> int {
    const test_class_instance = new ThisTestClass(5);
    const test_struct_instance = new ThisTestStruct(10);

    return 0;
}
