namespace ErrorTest;

function add_numbers(x: int, y: int) -> int {
    return x + y;
}

function main() -> int {
    // This should cause a type error - string assigned to int
    const bad_assign: int = "this is a string";
    
    // This should cause a type error - float arguments to int parameters
    const bad_call: int = add_numbers(1.5, 2.7);
    
    return 0;
}