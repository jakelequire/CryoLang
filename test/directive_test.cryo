#[test(name = "directive_system_test", category = "directives")]

namespace DirectiveTest;

import IO from <io/stdio>;

function test_basic_directives() -> void {
    const valid_assignment: int = 42;                    // ✅ Valid assignment
    
    #[expect_error("E0200_TYPE_MISMATCH")]
    const invalid_assignment: int = "this should fail";  // ❌ Should trigger E0200_TYPE_MISMATCH
    
    return;
}

function main() -> int {
    test_basic_directives();
    return 0;
}
