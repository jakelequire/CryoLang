type struct Point {
    x: int;
    y: int;
    move(dx: int, dy: int) -> void;
}

type class Circle {
public:
    center: Point;
    radius: float;

    // Circle(center: Point, radius: float) {
    //     this.center = center;
    //     this.radius = radius;
    // }

    area() -> float {
        return 3.14 * radius * radius;
    }
private:
    diameter() -> float {
        return 2.0 * radius;
    }
}

implement struct Point {
    move(dx: int, dy: int) -> void {
        this.x = this.x + dx;
        this.y = this.y + dy;
    }
}

// Generic struct with single type parameter and method  
type struct GenericStruct<T> {
    value: T;
    get_value() -> T {
        return this.value;
    }
}

// Simple generic struct
type struct SimpleGeneric<T> {
    data: T;
}

// Generic struct with multiple type parameters
type struct Pair<T, U> {
    first: T;
    second: U;
}

// Generic struct with array types
type struct Container<T> {
    items: T[];
    count: int;
}

// Generic struct with nested generic types
type struct Wrapper<T> {
    inner: SimpleGeneric<int>;
    metadata: T; 
}

function test_structs_and_classes() -> void {
    const p: Point = new Point(10, 20);
    p.move(5, -5);
    
    const c: Circle = new Circle(p, 15.0);
    const area: float = c.area();

    const generic_instance: GenericStruct<string> = new GenericStruct<string>("Test");
    const val: string = generic_instance.get_value();

    const simple_pair: SimpleGeneric<int> = new SimpleGeneric<int>(42);
    const pair_instance: Pair<int, string> = new Pair<int, string>(1, "One");

    return;
}

// ============================================================================
// ENUM TESTS - Both C-style and Rust-style
// ============================================================================

// C-style enum (simple values)
enum Color {
    RED,
    GREEN,
    BLUE,
    YELLOW
}

// C-style enum with explicit syntax  
enum StatusCode {
    SUCCESS,
    ERROR,
    PENDING,
    CANCELLED
}

// Rust-style enum with associated data
enum Shape {
    Circle(float),
    Rectangle(float, float),
    Triangle(float, float, float)
}

// Complex Rust-style enum with concrete types for now
enum Result {
    Ok(int),
    Err(string)
}

// Mixed enum (some simple, some complex - should default to complex)
enum Message {
    Quit,
    Move(int, int),
    Write(string),
    ChangeColor(int, int, int)
}

// Simple enum for testing
enum Direction {
    NORTH,
    SOUTH,
    EAST,
    WEST
}

// Enum with single variant (edge case)
enum SingleVariant {
    OnlyOne(string)
}

function test_enums() -> void {
    // Test C-style enum usage with scope resolution
    const my_color: Color = Color::RED;
    const status: StatusCode = StatusCode::SUCCESS;
    const heading: Direction = Direction::NORTH;
    
    // Test enum in expressions
    const is_red: boolean = my_color == Color::RED;
    const is_success: boolean = status == StatusCode::SUCCESS;
    
    // Test different enum variants
    const another_color: Color = Color::BLUE;
    const failed_status: StatusCode = StatusCode::ERROR;

    const circle: Shape = Shape::Circle(5.0);
    const rect: Shape = Shape::Rectangle(10.0, 20.0);
    match circle {
        Shape::Circle(radius) => {
            const area: float = 3.14 * radius * radius;
        },
        Shape::Rectangle(width, height) => {
            const area: float = width * height;
        },
        Shape::Triangle(a, b, c) => {
            const s: float = (a + b + c) / 2.0;
            const area: float = sqrt(s * (s - a) * (s - b) * (s - c));
        }
    }

    return;
}

/// This is a test
/**
 * This is a multi-line comment
 */
function test_pointers_and_references() -> void {
    mut x: int = 10; // No `&` or `*`, just a normal variable which is the owner of the value
    mut y: int = 20;
    
    // Reference to x
    mut ref_x: &int = &x;
    // Reference to y
    mut ref_y: &int = &y; // `&` prefix indicates a reference type
    
    // Pointer to x
    mut ptr_x: int * = &x; // The POSTFIX of `*` indicates a pointer type, the prefix of `*` is dereference operator
    // Pointer to y
    mut ptr_y: int * = &y;
    
    // Dereference pointer and modify value
    *ptr_x = *ptr_x + 5; // x should now be 15
    *ptr_y = *ptr_y + 10; // y should now be 30
    
    // Modify original variables through references
    x = *ref_x + 2; // x should now be 17
    y = *ref_y + 3; // y should now be 33
    
    return;
}

function main(argc: int, argv: string[]) -> int {
    const greeting: string = "Hello, World!";
    const number: int = 42;
    const flag: boolean = true;
    const pi: float = 3.14;
    const hex_value: int = 0xFF;
    const char_value: char = 'A';

    const result: int = add(multiply(4, 5), 10);
    print_result(result);

    test_fn();
    test_assignment();
    test_scope();
    test_mutability();
    test_control_flow();
    test_nested_loops();
    ternary_test();
    test_enums();

    return 0;
}
