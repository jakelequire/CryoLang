namespace TuringTest;

import IO from <io/stdio>;

// Turing Machine States
enum TuringState {
    START,
    SCAN_RIGHT,
    SCAN_LEFT,
    ACCEPT,
    REJECT
}

// Tape symbols
enum Symbol {
    ZERO,      // '0'
    ONE,       // '1' 
    BLANK,     // 'B' (blank)
    MARKED_ZERO, // 'X' (marked 0)
    MARKED_ONE   // 'Y' (marked 1)
}

// Turing Machine Tape
type class TuringTape {
public:
    tape: Symbol*;
    head_position: i32;
    tape_size: i32;

    TuringTape(size: i32) {
        this.tape_size = size;
        this.head_position = 0;
        
        // Initialize tape with blanks
        // Note: Using array literal syntax that the compiler supports
        mut temp_tape: Symbol[];
        for (mut i: i32 = 0; i < size; i++) {
            temp_tape.push(Symbol::BLANK);
        }
        this.tape = temp_tape.get();
    }

    ~TuringTape() default;

    read() -> Symbol {
        if (this.head_position < 0 || this.head_position >= this.tape_size) {
            return Symbol::BLANK;
        }
        return this.tape[this.head_position];
    }

    write(symbol: Symbol) -> void {
        if (this.head_position >= 0 && this.head_position < this.tape_size) {
            this.tape[this.head_position] = symbol;
        }
        return;
    }

    move_left() -> void {
        this.head_position = this.head_position - 1;
        return;
    }

    move_right() -> void {
        this.head_position = this.head_position + 1;
        return;
    }

    print_tape() -> void {
        IO::println("Tape contents:");
        for (mut i: i32 = 0; i < this.tape_size; i++) {
            if (i == this.head_position) {
                IO::print_char('[');
            }
            
            const current_symbol: Symbol = this.tape[i];
            if (current_symbol == Symbol::ZERO) {
                IO::print_char('0');
            } else if (current_symbol == Symbol::ONE) {
                IO::print_char('1');
            } else if (current_symbol == Symbol::MARKED_ZERO) {
                IO::print_char('X');
            } else if (current_symbol == Symbol::MARKED_ONE) {
                IO::print_char('Y');
            } else {
                IO::print_char('_');
            }
            
            if (i == this.head_position) {
                IO::print_char(']');
            } else {
                IO::print_char(' ');
            }
        }
        IO::println("");
        return;
    }
}

// Turing Machine that recognizes equal 0s and 1s
type class TuringMachine {
public:
    tape: TuringTape*;
    state: TuringState;
    steps: i32;

    TuringMachine(input_tape: TuringTape*) {
        this.tape = input_tape;
        this.state = TuringState::START;
        this.steps = 0;
    }

    ~TuringMachine() default;

    run() -> boolean {
        const max_steps: i32 = 1000;  // Prevent infinite loops
        
        while (this.steps < max_steps) {
            this.steps = this.steps + 1;
            
            IO::print_int(this.steps);
            IO::println(": Current state and tape:");
            this.print_state();
            this.tape.print_tape();
            
            if (this.state == TuringState::ACCEPT) {
                IO::println("ACCEPTED: String has equal 0s and 1s!");
                return true;
            }
            
            if (this.state == TuringState::REJECT) {
                IO::println("REJECTED: String does not have equal 0s and 1s!");
                return false;
            }
            
            this.step();
        }
        
        IO::println("TIMEOUT: Machine exceeded maximum steps");
        return false;
    }

private:
    step() -> void {
        const current_symbol: Symbol = this.tape.read();
        
        if (this.state == TuringState::START) {
            this.handle_start_state(current_symbol);
        } else if (this.state == TuringState::SCAN_RIGHT) {
            this.handle_scan_right_state(current_symbol);
        } else if (this.state == TuringState::SCAN_LEFT) {
            this.handle_scan_left_state(current_symbol);
        }
        return;
    }

    handle_start_state(symbol: Symbol) -> void {
        if (symbol == Symbol::ZERO) {
            // Mark the 0 and look for a 1 to match
            this.tape.write(Symbol::MARKED_ZERO);
            this.tape.move_right();
            this.state = TuringState::SCAN_RIGHT;
        } else if (symbol == Symbol::ONE) {
            // Mark the 1 and look for a 0 to match
            this.tape.write(Symbol::MARKED_ONE);
            this.tape.move_right();
            this.state = TuringState::SCAN_RIGHT;
        } else if (symbol == Symbol::BLANK) {
            // Empty string - equal 0s and 1s (both zero)
            this.state = TuringState::ACCEPT;
        } else {
            this.state = TuringState::REJECT;
        }
        return;
    }

    handle_scan_right_state(symbol: Symbol) -> void {
        if (symbol == Symbol::ZERO || symbol == Symbol::ONE) {
            // Keep scanning right
            this.tape.move_right();
        } else if (symbol == Symbol::BLANK) {
            // Reached end, go back to start
            this.tape.move_left();
            this.state = TuringState::SCAN_LEFT;
        } else {
            // Found a match, mark it and go back
            if (symbol == Symbol::ZERO) {
                this.tape.write(Symbol::MARKED_ZERO);
            } else if (symbol == Symbol::ONE) {
                this.tape.write(Symbol::MARKED_ONE);
            }
            this.tape.move_left();
            this.state = TuringState::SCAN_LEFT;
        }
        return;
    }

    handle_scan_left_state(symbol: Symbol) -> void {
        if (symbol == Symbol::MARKED_ZERO || symbol == Symbol::MARKED_ONE) {
            // Keep scanning left past marked symbols
            this.tape.move_left();
        } else if (symbol == Symbol::ZERO || symbol == Symbol::ONE) {
            // Found start of unmarked section
            this.state = TuringState::START;
        } else {
            // Reached beginning - check if all symbols are marked
            this.tape.move_right();
            this.check_completion();
        }
        return;
    }

    check_completion() -> void {
        // Scan the entire tape to see if all symbols are marked
        mut all_marked: boolean = true;
        const original_position: i32 = this.tape.head_position;
        
        this.tape.head_position = 0;
        
        while (this.tape.head_position < this.tape.tape_size) {
            const current: Symbol = this.tape.read();
            if (current == Symbol::ZERO || current == Symbol::ONE) {
                all_marked = false;
                break;
            }
            if (current == Symbol::BLANK) {
                break;  // Reached end of input
            }
            this.tape.move_right();
        }
        
        this.tape.head_position = original_position;
        
        if (all_marked) {
            this.state = TuringState::ACCEPT;
        } else {
            this.state = TuringState::REJECT;
        }
        return;
    }

    print_state() -> void {
        if (this.state == TuringState::START) {
            IO::println("State: START");
        } else if (this.state == TuringState::SCAN_RIGHT) {
            IO::println("State: SCAN_RIGHT");
        } else if (this.state == TuringState::SCAN_LEFT) {
            IO::println("State: SCAN_LEFT");
        } else if (this.state == TuringState::ACCEPT) {
            IO::println("State: ACCEPT");
        } else if (this.state == TuringState::REJECT) {
            IO::println("State: REJECT");
        }
        return;
    }
}

function setup_test_tape(input: string) -> TuringTape* {
    const tape: TuringTape* = new TuringTape(20); // HEAP allocated tape of size 20
    
    // Manually set up a test pattern
    // Test case: "0011" (should accept - equal 0s and 1s)
    tape.tape[0] = Symbol::ZERO;
    tape.tape[1] = Symbol::ZERO;
    tape.tape[2] = Symbol::ONE;
    tape.tape[3] = Symbol::ONE;
    // Rest are BLANK by default
    
    return tape;
}

function run_turing_test() -> void {
    IO::println("=== Turing Machine Test ===");
    IO::println("Testing string '0011' (should accept)");
    
    const test_tape: TuringTape* = setup_test_tape("0011");
    const machine: TuringMachine* = new TuringMachine(test_tape); // HEAP allocated machine
    
    IO::println("Initial tape:");
    test_tape.print_tape();
    IO::println("");
    
    const result: boolean = machine.run();
    
    IO::println("");
    IO::println("Final result:");
    if (result) {
        IO::println("✓ Test PASSED");
    } else {
        IO::println("✗ Test FAILED");
    }
    
    IO::print_int(machine.steps);
    IO::println(" total steps executed");
    
    return;
}

function main() -> int {
    IO::println("CryoLang Turing Machine Implementation");
    IO::println("Recognizes strings with equal numbers of 0s and 1s");
    IO::println("");
    
    run_turing_test();
    
    return 0;
}
