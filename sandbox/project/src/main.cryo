namespace Main;

import IO from <io/stdio>;
import <net/types>;

function main() -> int {
    IO::println("=== Minimal HTTP Server Test ===\n");
    const ip: IpAddr = new IpAddr(u8(127), u8(0), u8(0), u8(1));

    // Start server on localhost:8080
    const addr: SocketAddr = new SocketAddr(
        ip,
        u16(8080)
    );

    return 0;
}