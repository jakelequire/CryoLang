namespace TestLSP;

import <io/stdio>;

// Test primitive types and keywords
function test_primitive_types() -> void {
    const number: i32 = 42;
    const text: string = "Hello";
    const flag: boolean = true;
    const decimal: f64 = 3.14;
    
    if (flag) {
        println("Testing LSP hover functionality");
    }
    
    return;
}

type struct TestStruct {
    id: u32;
    name: string;
    active: bool;
    
    TestStruct(id: u32, name: string) {
        this.id = id;
        this.name = name;
        this.active = true;
    }
}

function main() -> int {
    const test: TestStruct = TestStruct(1, "test");
    test_primitive_types();
    return 0;
}
