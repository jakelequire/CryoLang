namespace MathTesting;

import IO from <io/stdio>;

type class Math {
public:
    static abs(x: int) -> int {
        return x < 0 ? -x : x;
    }

    static abs(x: float) -> float {
        return x < 0.0 ? -x : x;
    }
}

function main() -> int {
    const a: int = -10;
    IO::println("Absolute value of ", a, " is ", Math::abs(a));
    
    return 0;
}
