function do_something_with_point(p: Point *) -> void {
    IO::printf("Inside do_something_with_point - Point at %p with coordinates (%d, %d)\n", p, p.x, p.y);
    // Perform some operations on the point
    p.x += 10;
    p.y += 20;
    IO::printf("Modified Point coordinates to (%d, %d)\n", p.x, p.y);
    return;
}


function test_destructor_calls() -> void {
    IO::printf("=== Destructor Call Tests ===\n");

    {
        mut p1: Point* = new Point(5, 10);
        IO::printf("Created Point p1 at %p\n", p1);
        do_something_with_point(p1);
        IO::printf("Point p1 after modification: (%d, %d) | Should be (15, 30)\n", p1.x, p1.y);
        // p1 goes out of scope here, destructor should be called
    }
    IO::printf("Exited scope for p1\n");

    {
        mut p2: Point = Point(15, 20);
        IO::printf("Created Point p2 at %p\n", &p2);
        do_something_with_point(&p2);
        IO::printf("Point p2 after modification: (%d, %d) | Should be (25, 40)\n", p2.x, p2.y);
        // p2 goes out of scope here, destructor should be called
    }
    IO::printf("Exited scope for p2\n");
}


function test_array() -> void {
    IO::printf("=== Array Literal Initialization Tests ===\n");

    // Test array literal initialization
    IO::printf("About to create array...\n");
    mut int_array: Array<int> = [10, 20, 30, 40, 50];
    IO::printf("Array created successfully\n");
    
    // Debug: Check array length first
    IO::printf("Checking array length...\n");
    mut length_val: u64 = int_array.length;
    IO::printf("Array length: %d | Should be 5\n", length_val);
    
    // Simple test - just try to print one element first
    IO::printf("Testing first element access...\n");
    IO::printf("int_array[0] = %d | Should be 10\n", int_array[0]);

    IO::printf("Array elements:\n");
    for (mut i: u64 = 0; i < int_array.length; i++) {
        IO::printf("Loop iteration %d\n", i);
        IO::printf("int_array[%d] = %d\n", i, int_array[i]);
    }

    return;
}

function main() -> int {
    simple_array_test();
    pointer_arithmetic();
    bit_shifting();
    heap_allocation_tests();
    memory_layout_tests();
    implicit_new_tests();
    test_destructor_calls();
    test_array();
    
    return 0;
}
