{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Cryo",
  "scopeName": "source.cryo",
  "fileTypes": ["cryo"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#directives" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#function-declaration" },
    { "include": "#function-call" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.cryo",
          "match": "///.*$"
        },
        {
          "name": "comment.line.double-slash.cryo",
          "match": "//.*$"
        },
        {
          "name": "comment.block.documentation.cryo",
          "begin": "/\\*\\*",
          "end": "\\*/",
          "captures": {
            "0": { "name": "punctuation.definition.comment.cryo" }
          }
        },
        {
          "name": "comment.block.cryo",
          "begin": "/\\*",
          "end": "\\*/",
          "captures": {
            "0": { "name": "punctuation.definition.comment.cryo" }
          }
        }
      ]
    },

    "directives": {
      "patterns": [
        {
          "name": "meta.directive.cryo",
          "begin": "(#)(\\[)",
          "end": "\\]",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.directive.cryo" },
            "2": { "name": "punctuation.section.bracket.begin.cryo" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.bracket.end.cryo" }
          },
          "patterns": [
            {
              "name": "entity.other.attribute-name.cryo",
              "match": "\\b(deprecated|inline|noinline|pure|const|noreturn|packed|aligned|section|weak|constructor|destructor)\\b"
            },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#identifiers" },
            {
              "name": "punctuation.separator.comma.cryo",
              "match": ","
            }
          ]
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.raw.cryo",
          "begin": "r\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.cryo" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.cryo" }
          }
        },
        {
          "name": "string.quoted.double.cryo",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.cryo" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.cryo" }
          },
          "patterns": [
            { "include": "#escape-sequences" }
          ]
        }
      ]
    },

    "characters": {
      "patterns": [
        {
          "name": "string.quoted.single.cryo",
          "match": "'(?:[^'\\\\]|\\\\(?:[nrtab0fv\\\\'\"]|x[0-9a-fA-F]{2}|[0-7]{1,3}))'",
          "captures": {
            "0": { "name": "string.quoted.single.cryo" }
          }
        }
      ]
    },

    "escape-sequences": {
      "patterns": [
        {
          "name": "constant.character.escape.cryo",
          "match": "\\\\(?:[nrtab0fv\\\\'\"]|x[0-9a-fA-F]{2}|[0-7]{1,3})"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.cryo",
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*(?:u8|u16|u32|u64|i8|i16|i32|i64|usize|isize)?\\b"
        },
        {
          "name": "constant.numeric.binary.cryo",
          "match": "\\b0[bB][01][01_]*(?:u8|u16|u32|u64|i8|i16|i32|i64|usize|isize)?\\b"
        },
        {
          "name": "constant.numeric.octal.cryo",
          "match": "\\b0[oO][0-7][0-7_]*(?:u8|u16|u32|u64|i8|i16|i32|i64|usize|isize)?\\b"
        },
        {
          "name": "constant.numeric.float.cryo",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*(?:[eE][+-]?[0-9]+)?(?:f32|f64)?\\b"
        },
        {
          "name": "constant.numeric.float.exponent.cryo",
          "match": "\\b[0-9][0-9_]*[eE][+-]?[0-9]+(?:f32|f64)?\\b"
        },
        {
          "name": "constant.numeric.integer.cryo",
          "match": "\\b[0-9][0-9_]*(?:u8|u16|u32|u64|i8|i16|i32|i64|f32|f64|usize|isize)?\\b"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.cryo",
          "match": "\\b(if|else|elif|switch|case|default|match|while|for|loop|do|break|continue|return|yield)\\b"
        },
        {
          "name": "keyword.declaration.cryo",
          "match": "\\b(function|class|struct|enum|trait|type|namespace|module|import|export|from|as|implement|intrinsic|where|extern)\\b"
        },
        {
          "name": "storage.modifier.cryo",
          "match": "\\b(const|mut|static|public|private|protected|virtual|override|inline|async|await|unsafe|mutable)\\b"
        },
        {
          "name": "keyword.operator.cryo",
          "match": "\\b(new|delete|sizeof|alignof|typeof|in|as)\\b"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.cryo",
          "match": "\\b(void|boolean|char|string|int|i8|i16|i32|i64|i128|uint|u8|u16|u32|u64|u128|float|f32|f64|double|usize|isize|never)\\b"
        },
        {
          "comment": "Generic type instantiation: Identifier<...>",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\s*(<)",
          "captures": {
            "1": { "name": "entity.name.type.cryo" },
            "2": { "name": "punctuation.definition.generic.begin.cryo" }
          }
        },
        {
          "comment": "PascalCase identifiers as types",
          "name": "entity.name.type.cryo",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b"
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.cryo",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.cryo",
          "match": "\\b(null)\\b"
        },
        {
          "name": "variable.language.this.cryo",
          "match": "\\b(this)\\b"
        },
        {
          "comment": "SCREAMING_SNAKE_CASE constants",
          "name": "constant.other.caps.cryo",
          "match": "\\b([A-Z][A-Z0-9_]{2,})\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.cryo",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.scope.cryo",
          "match": "::"
        },
        {
          "name": "keyword.operator.pipe.cryo",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.null-coalescing.cryo",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.optional-chain.cryo",
          "match": "\\?\\."
        },
        {
          "name": "keyword.operator.range.cryo",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.spread.cryo",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.spaceship.cryo",
          "match": "<=>"
        },
        {
          "name": "keyword.operator.comparison.cryo",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.cryo",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.compound.cryo",
          "match": "\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>="
        },
        {
          "name": "keyword.operator.assignment.cryo",
          "match": "="
        },
        {
          "name": "keyword.operator.increment-decrement.cryo",
          "match": "\\+\\+|--"
        },
        {
          "name": "keyword.operator.bitwise.shift.cryo",
          "match": "<<|>>"
        },
        {
          "name": "keyword.operator.bitwise.cryo",
          "match": "&|\\||\\^|~"
        },
        {
          "name": "keyword.operator.arithmetic.cryo",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.ternary.cryo",
          "match": "\\?"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.cryo",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.cryo",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.cryo",
          "match": ":"
        },
        {
          "name": "punctuation.section.braces.begin.cryo",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.braces.end.cryo",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.parens.begin.cryo",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.cryo",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.cryo",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.cryo",
          "match": "\\]"
        },
        {
          "name": "punctuation.accessor.dot.cryo",
          "match": "\\."
        }
      ]
    },

    "function-declaration": {
      "patterns": [
        {
          "comment": "Function declaration: function name(...)",
          "match": "\\b(function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=(<|\\())",
          "captures": {
            "1": { "name": "keyword.declaration.cryo" },
            "2": { "name": "entity.name.function.cryo" }
          }
        },
        {
          "comment": "Intrinsic function declaration",
          "match": "\\b(intrinsic)\\s+(function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.declaration.cryo" },
            "2": { "name": "keyword.declaration.cryo" },
            "3": { "name": "entity.name.function.cryo" }
          }
        },
        {
          "comment": "Extern function declaration",
          "match": "\\b(extern)\\s+(function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.declaration.cryo" },
            "2": { "name": "keyword.declaration.cryo" },
            "3": { "name": "entity.name.function.cryo" }
          }
        },
        {
          "comment": "Method declaration inside struct/class/implement (identifier followed by ( or <)",
          "match": "^\\s*(?:(?:public|private|protected)\\s+)?(?:(?:static|virtual|override)\\s+)*([a-z_][a-zA-Z0-9_]*)\\s*(?=(<[^>]*>)?\\s*\\()",
          "captures": {
            "1": { "name": "entity.name.function.cryo" }
          }
        }
      ]
    },

    "function-call": {
      "patterns": [
        {
          "comment": "Scoped function call: Type::method(...)",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\s*(::)\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=(<[^>]*>)?\\s*\\()",
          "captures": {
            "1": { "name": "entity.name.type.cryo" },
            "2": { "name": "keyword.operator.scope.cryo" },
            "3": { "name": "entity.name.function.cryo" }
          }
        },
        {
          "comment": "Enum variant with data: Type::Variant(...)",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\s*(::)\\s*([A-Z][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.type.cryo" },
            "2": { "name": "keyword.operator.scope.cryo" },
            "3": { "name": "variable.other.enummember.cryo" }
          }
        },
        {
          "comment": "Enum variant without data: Type::Variant",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\s*(::)\\s*([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.type.cryo" },
            "2": { "name": "keyword.operator.scope.cryo" },
            "3": { "name": "variable.other.enummember.cryo" }
          }
        },
        {
          "comment": "Free function call: name(...)",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.cryo" }
          }
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "comment": "Self-reference parameter: &this, mut &this",
          "match": "\\b(mut)\\s*(&)(this)\\b",
          "captures": {
            "1": { "name": "storage.modifier.cryo" },
            "2": { "name": "keyword.operator.reference.cryo" },
            "3": { "name": "variable.language.this.cryo" }
          }
        },
        {
          "comment": "Immutable self-reference parameter: &this",
          "match": "(&)(this)\\b",
          "captures": {
            "1": { "name": "keyword.operator.reference.cryo" },
            "2": { "name": "variable.language.this.cryo" }
          }
        },
        {
          "name": "variable.other.cryo",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
