namespace TestRuntime;

import IO from <io/stdio>;
import Runtime from <runtime/runtime>;

function foo_fn() -> void {
    const x: int = 42;
    return; 
}

function main() -> int {
    IO::printf("Testing runtime function call...\n");
    foo_fn();

    IO::printf("Before alloca call\n");
    const _ptr: void * = Runtime::cryo_alloc(i64(128));
    IO::printf("Allocated 128 bytes at %p\n", _ptr);
    Runtime::cryo_free(_ptr);

    return 55;
}
