namespace TestRuntime;

import IO from <io/stdio>;
import Runtime from <runtime/runtime>;

function foo_fn() -> void {
    const x: int = 42;
    return; 
}

function test_multiple_allocations() -> void {
    const p1: void* = Runtime::cryo_alloc(u64(32));
    const p2: void* = Runtime::cryo_alloc(u64(64));
    const p3: void* = Runtime::cryo_alloc(u64(128));

    Runtime::cryo_assert(p1 != null, "Allocation 1 failed");
    Runtime::cryo_assert(p2 != null, "Allocation 2 failed");
    Runtime::cryo_assert(p3 != null, "Allocation 3 failed");

    Runtime::cryo_free(p1);
    Runtime::cryo_free(p2);
    Runtime::cryo_free(p3);
}

function test_reuse() -> void {
    const p1: void* = cryo_alloc(u64(64));
    cryo_free(p1);
    
    const p2: void* = cryo_alloc(u64(64));
    // Should reuse same block
    cryo_free(p2);
}

type struct MyStruct {
    a: int;
    b: int;
}

function main() -> int {
    IO::printf("Testing runtime function call...\n");
    foo_fn();
    test_multiple_allocations();
    test_reuse();

    IO::printf("Before alloca call\n");
    const _ptr: void * = Runtime::cryo_alloc(i64(128));
    IO::printf("Allocated 128 bytes at %p\n", _ptr);
    Runtime::cryo_free(_ptr);

    IO::printf("Testing struct allocation...\n");
    IO::printf("Size of MyStruct: %d\n", sizeof(MyStruct));
    const struct_ptr: MyStruct * = Runtime::cryo_alloc(sizeof(MyStruct));
    struct_ptr.a = 10;
    struct_ptr.b = 20;
    IO::printf("Allocated MyStruct at %p with values: a=%d, b=%d\n", struct_ptr, struct_ptr.a, struct_ptr.b);

    return 55;
}
