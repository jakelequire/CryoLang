namespace TestRuntime;

import IO from <io/stdio>;
import Runtime from <runtime/runtime>;

function foo_fn() -> void {
    const x: int = 42;
    return; 
}

function main() -> int {
    IO::printf("Testing runtime function call...\n");
    foo_fn();

    const foo: void* = Runtime::cryo_alloc(u64(55));

    return 55;
}
