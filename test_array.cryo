namespace TestArray;


function main() -> int {
    const arr_literal: int[] = [1, 2, 3, 4, 5]; // This is NOT the as `Array<int>`. It's a built-in array literal.
    // Array literals have limited functionality compared to Array<T>, e.g., no methods.
    const arr_str_literal: string[] = ["hello", "world"]; // Array literal of strings


    const arr: Array<int> = [1, 2, 3, 4, 5]; // This is the `Array<int>` type. This works due to implicit conversion from literal to Array<T> from the compiler.
    const arr_len: int = arr.size(); // Array<T> has a size() method.

    return 0;
}