#=======================================================================
# CryoLang Test Framework Configuration
# Self-contained testing infrastructure (no third-party dependencies)
#=======================================================================

# Test directories
TEST_DIR := tests
TEST_UNIT_DIR := $(TEST_DIR)/unit
TEST_INTEGRATION_DIR := $(TEST_DIR)/integration
TEST_E2E_DIR := $(TEST_DIR)/e2e
TEST_FIXTURES_DIR := $(TEST_DIR)/fixtures
TEST_INCLUDE_DIR := $(TEST_DIR)/include
TEST_BIN_DIR := bin/tests

# Ensure BIN_DIR is properly defined for tests
ifndef BIN_DIR
BIN_DIR := bin
endif

# Test source files
TEST_UNIT_SOURCES := $(wildcard $(TEST_UNIT_DIR)/*.cpp)
TEST_INTEGRATION_SOURCES := $(wildcard $(TEST_INTEGRATION_DIR)/*.cpp)
TEST_MAIN_SOURCE := $(TEST_DIR)/test_main.cpp
TEST_UTILS_SOURCE := $(TEST_DIR)/test_utils.cpp

# Test object files
TEST_UNIT_OBJECTS := $(TEST_UNIT_SOURCES:$(TEST_UNIT_DIR)/%.cpp=$(BIN_DIR)/.o/tests/unit/%.o)
TEST_INTEGRATION_OBJECTS := $(TEST_INTEGRATION_SOURCES:$(TEST_INTEGRATION_DIR)/%.cpp=$(BIN_DIR)/.o/tests/integration/%.o)
TEST_MAIN_OBJECT := $(BIN_DIR)/.o/tests/test_main.o
TEST_UTILS_OBJECT := $(BIN_DIR)/.o/tests/test_utils.o

# Test executable (single unified binary)
TEST_ALL_EXECUTABLE := $(TEST_BIN_DIR)/cryo_tests$(BIN_SUFFIX)

# E2E test source files and objects
TEST_E2E_SOURCES := $(wildcard $(TEST_E2E_DIR)/*.cpp)
TEST_E2E_OBJECTS := $(TEST_E2E_SOURCES:$(TEST_E2E_DIR)/%.cpp=$(BIN_DIR)/.o/tests/e2e/%.o)

# All test objects combined
TEST_ALL_OBJECTS := $(TEST_UNIT_OBJECTS) $(TEST_INTEGRATION_OBJECTS) $(TEST_E2E_OBJECTS) $(TEST_MAIN_OBJECT) $(TEST_UTILS_OBJECT)

# Link against the main compiler library instead of individual objects
COMPILER_LIB := $(BIN_DIR)/libcryo-compiler.a

# Test-specific compiler flags (no external dependencies)
TEST_CXXFLAGS := $(CXXFLAGS) -I$(TEST_DIR) -DCRYO_TESTING
TEST_LDFLAGS := $(LDFLAGS)

# Coverage flags (optional)
ifdef ENABLE_COVERAGE
	TEST_CXXFLAGS += --coverage -fprofile-arcs -ftest-coverage
	TEST_LDFLAGS += --coverage -lgcov
endif

# Sanitizer flags (optional)
ifdef ENABLE_ASAN
	TEST_CXXFLAGS += -fsanitize=address -fno-omit-frame-pointer
	TEST_LDFLAGS += -fsanitize=address
endif

ifdef ENABLE_TSAN
	TEST_CXXFLAGS += -fsanitize=thread
	TEST_LDFLAGS += -fsanitize=thread
endif

ifdef ENABLE_UBSAN
	TEST_CXXFLAGS += -fsanitize=undefined
	TEST_LDFLAGS += -fsanitize=undefined
endif

# Test runner configuration
TEST_TIMEOUT := 30
TEST_VERBOSITY := 2
TEST_OUTPUT_FORMAT := xml
TEST_RESULTS_DIR := $(TEST_BIN_DIR)/results

# Parallel test execution
TEST_PARALLEL_JOBS := $(shell nproc 2>/dev/null || echo 4)

# Benchmark configuration
BENCHMARK_ITERATIONS := 100
BENCHMARK_TIME_UNIT := ms

# Test data paths
TEST_VALID_PROGRAMS := $(wildcard $(TEST_FIXTURES_DIR)/valid_programs/*.cryo)
TEST_INVALID_PROGRAMS := $(wildcard $(TEST_FIXTURES_DIR)/invalid_programs/*.cryo)
TEST_LANGUAGE_FEATURES := $(wildcard $(TEST_E2E_DIR)/language_features/*.cryo)
TEST_REGRESSION_CASES := $(wildcard $(TEST_E2E_DIR)/regression/*.cryo)

# Test utilities
TEST_RUNNER := $(TEST_BIN_DIR)/test_runner$(BIN_SUFFIX)
TEST_REPORT_GENERATOR := $(TEST_BIN_DIR)/generate_report$(BIN_SUFFIX)

# Color output for test results
COLOR_RESET := \033[0m
COLOR_RED := \033[31m
COLOR_GREEN := \033[32m
COLOR_YELLOW := \033[33m
COLOR_BLUE := \033[34m
COLOR_MAGENTA := \033[35m
COLOR_CYAN := \033[36m
COLOR_WHITE := \033[37m

# Test status indicators
TEST_PASS := $(COLOR_GREEN)✓ PASS$(COLOR_RESET)
TEST_FAIL := $(COLOR_RED)✗ FAIL$(COLOR_RESET)
TEST_SKIP := $(COLOR_YELLOW)⚠ SKIP$(COLOR_RESET)
TEST_RUN := $(COLOR_BLUE)▶ RUN$(COLOR_RESET)

# Test categories for selective running
TEST_CATEGORIES := unit integration e2e performance memory safety

# Memory leak detection
VALGRIND_OPTS := --leak-check=full --show-leak-kinds=all --track-origins=yes
VALGRIND_SUPPRESSIONS := $(TEST_DIR)/valgrind.supp

# Test environment
export CRYO_TEST_MODE := 1
export CRYO_TEST_DATA_DIR := $(TEST_FIXTURES_DIR)
export CRYO_COMPILER_PATH := $(BIN_DIR)/cryo$(EXE_SUFFIX)

#=======================================================================
# Self-Contained Test Framework Targets
#=======================================================================

# Test directories setup
.PHONY: test-dirs
ifeq ($(OS), Windows_NT)
test-dirs:
	@if not exist "$(TEST_BIN_DIR)" mkdir "$(TEST_BIN_DIR)"
	@if not exist "$(BIN_DIR)\.o\tests\unit" mkdir "$(BIN_DIR)\.o\tests\unit"
	@if not exist "$(BIN_DIR)\.o\tests\integration" mkdir "$(BIN_DIR)\.o\tests\integration"
	@if not exist "$(BIN_DIR)\.o\tests\e2e" mkdir "$(BIN_DIR)\.o\tests\e2e"
else
test-dirs:
	@$(MKDIR) $(TEST_BIN_DIR)
	@$(MKDIR) $(BIN_DIR)/.o/tests/unit
	@$(MKDIR) $(BIN_DIR)/.o/tests/integration
	@$(MKDIR) $(BIN_DIR)/.o/tests/e2e
endif

# Object file rules for tests
$(BIN_DIR)/.o/tests/unit/%.o: $(TEST_UNIT_DIR)/%.cpp | test-dirs
	@echo "Compiling unit test: $<"
	@$(CXX) $(TEST_CXXFLAGS) -c $< -o $@

$(BIN_DIR)/.o/tests/integration/%.o: $(TEST_INTEGRATION_DIR)/%.cpp | test-dirs  
	@echo "Compiling integration test: $<"
	@$(CXX) $(TEST_CXXFLAGS) -c $< -o $@

$(TEST_MAIN_OBJECT): $(TEST_MAIN_SOURCE) | test-dirs
	@echo "Compiling test main..."
	@$(CXX) $(TEST_CXXFLAGS) -c $< -o $@

$(TEST_UTILS_OBJECT): $(TEST_UTILS_SOURCE) | test-dirs
	@echo "Compiling test utils..."
	@$(CXX) $(TEST_CXXFLAGS) -c $< -o $@

# E2E test compilation rule (missing from above)
$(BIN_DIR)/.o/tests/e2e/%.o: $(TEST_E2E_DIR)/%.cpp | test-dirs
	@echo "Compiling E2E test: $<"
	@$(CXX) $(TEST_CXXFLAGS) -c $< -o $@

# Build the unified test executable
$(TEST_ALL_EXECUTABLE): $(TEST_ALL_OBJECTS) $(COMPILER_LIB) | test-dirs
	@echo "Linking test executable..."
	@$(CXX) $(TEST_ALL_OBJECTS) $(COMPILER_LIB) $(TEST_LDFLAGS) -o $@

# Test information
.PHONY: test-info
test-info:
	@echo "CryoLang Test Framework:"
	@echo "  Unit tests:      $(words $(TEST_UNIT_SOURCES))"
	@echo "  Integration:     $(words $(TEST_INTEGRATION_SOURCES))"
	@echo "  E2E tests:       $(words $(wildcard $(TEST_E2E_DIR)/*.cpp))"
	@echo "  Test fixtures:   $(words $(TEST_VALID_PROGRAMS))"
	@echo "  Framework:       Self-Contained C++ (no dependencies)"