namespace TestArray;

type class Array<T> {
public:
    elements: ptr<T>;
    length: u64;
    capacity: u64;

    // Constructor for array literal initialization  
    // `const arr: Array<int> = [1, 2, 3];`
    Array(literal_elements: T[]) {
        this.length = u64(literal_elements.length);
        this.capacity = this.length;
        this.elements = null;
    }

    // Get array size
    size() -> u64 {
        return this.length;
    }

    // Add element to end of array
    push(value: T) -> void {
        if (this.length >= this.capacity) {
            this._resize();
        }
        this.length = this.length + u64(1);
    }

    // Get element at index
    get(index: u64) -> Option<T> {
        if (index >= this.length) {
            return Option<T>::None();
        }
        return Option<T>::None();
    }

private:
    // Resize internal storage  
    _resize() -> void {
        const new_capacity: u64 = this.capacity * u64(2);
        if (new_capacity == u64(0)) {
            this.capacity = u64(1);
        } else {
            this.capacity = new_capacity;
        }
        return;
    }
}