@RUNTIME_VERSION_MAJOR = constant i32 1
@RUNTIME_VERSION_MINOR = constant i32 0
@RUNTIME_VERSION_PATCH = constant i32 0
@DEFAULT_HEAP_SIZE = constant i64 67108864
@DEFAULT_STACK_SIZE = constant i64 1048576
@SMALL_OBJECT_THRESHOLD = constant i64 256
@LARGE_OBJECT_THRESHOLD = constant i64 65536
@MAX_SMALL_OBJECT_SIZE = constant i64 256
@MIN_ALLOCATION_SIZE = constant i64 16
@ALLOCATION_ALIGNMENT = constant i64 16
@GUARD_PAGE_SIZE = constant i64 4096
@MEMORY_POOL_COUNT = constant i32 32
@MEMORY_POISON_PATTERN = constant i8 -35
@BLOCK_MAGIC = constant i32 -559038737
@MAX_THREADS = constant i32 256
@THREAD_STACK_SIZE = constant i64 2097152
@WORK_QUEUE_SIZE = constant i32 1024
@MEMORY_PRESSURE_THRESHOLD = constant double 0x3FEB333340000000
@MEMORY_WARNING_THRESHOLD = constant double 0x3FEE666660000000
@DEFRAG_THRESHOLD = constant double 0x3FD3333340000000
@ENABLE_RUNTIME_PROFILING = constant i1 true
@ENABLE_MEMORY_TRACKING = constant i1 true
@ENABLE_TYPE_CHECKING = constant i1 true
@MAX_STACK_TRACE_DEPTH = constant i32 128

@g_cryo_runtime = global %CryoRuntime zeroinitializer

