%"Array<u64>" = type { ptr, i64, i64 }
%ThreadManager = type { ptr, i32, i32, i64 }
%Mutex = type { i1, i64, ptr }
%StackTrace = type { ptr, i32, i32 }
%ExceptionManager = type { ptr, ptr, ptr }
