  %argv2 = alloca ptr, align 8
  %init_result = alloca i32, align 4
  %user_result = alloca i32, align 4
  store i32 %argc, ptr %argc1, align 4
  store ptr %argv, ptr %argv2, align 8
  %printf.result = call i32 (ptr, ...) @printf(ptr @.str.299)
  %call.result = call i32 @"std::Runtime::cryo_runtime_initialize"()
  store i32 %call.result, ptr %init_result, align 4
  %init_result.load = load i32, ptr %init_result, align 4
  %ne = icmp ne i32 %init_result.load, 0
  br i1 %ne, label %if.then, label %if.end

if.then:                                          ; preds = %entry
  %init_result.load3 = load i32, ptr %init_result, align 4
  %init_result.load4 = load i32, ptr %init_result, align 4
  %printf.result5 = call i32 (ptr, ...) @printf(ptr @.str.300, i32 %init_result.load4)
  ret i32 1

if.end:                                           ; preds = %entry
  %init_result.load6 = load i32, ptr %init_result, align 4
  %eq = icmp eq i32 %init_result.load6, 0
  br i1 %eq, label %if.then7, label %if.else

if.then7:                                         ; preds = %if.end
  %printf.result9 = call i32 (ptr, ...) @printf(ptr @.str.301)
  br label %if.end8

if.end8:                                          ; preds = %if.then7
  %printf.result13 = call i32 (ptr, ...) @printf(ptr @.str.303)
  %printf.result14 = call i32 (ptr, ...) @printf(ptr @.str.304)
  store i32 0, ptr %user_result, align 4
  %argc.load = load i32, ptr %argc1, align 4
  %argv.load = load ptr, ptr %argv2, align 8
  %call.result15 = call i32 @_user_main_(i32 %argc.load, ptr %argv.load)
  store i32 %call.result15, ptr %user_result, align 4
  %printf.result16 = call i32 (ptr, ...) @printf(ptr @.str.305)
  %user_result.load = load i32, ptr %user_result, align 4
  %user_result.load17 = load i32, ptr %user_result, align 4
  %printf.result18 = call i32 (ptr, ...) @printf(ptr @.str.306, i32 %user_result.load17)
  call void @"std::Runtime::cryo_runtime_shutdown"()
  %user_result.load19 = load i32, ptr %user_result, align 4
  ret i32 %user_result.load19

if.else:                                          ; preds = %if.end
  %init_result.load10 = load i32, ptr %init_result, align 4
  %init_result.load11 = load i32, ptr %init_result, align 4
  %printf.result12 = call i32 (ptr, ...) @printf(ptr @.str.302, i32 %init_result.load11)
  ret i32 1
}

attributes #0 = { nounwind }
