namespace Main;

function test_string_methods() -> void {
    const str1: string = "Hello";
    const str2: string = "World!";
    
    // Test string methods
    str1.test_method();
    str2.test_method();
    
    // Test string length
    const len1: u64 = str1.length();
    const len2: u64 = str2.length();
    
    return;
}

function main() -> int {
    test_string_methods();
    return 0;
}