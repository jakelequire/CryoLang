// As conversion for reference types
trait AsRef<T, R> {
    as_ref(self: &T) -> &R;
}

trait AsMut<T, R> {
    as_mut(self: &mut T) -> &mut R;
}

//===================================================================
// ARITHMETIC TRAITS
//===================================================================

trait Add<T> {
    add(self: T, rhs: T) -> T;
}

trait Sub<T> {
    sub(self: T, rhs: T) -> T;
}

trait Mul<T> {
    mul(self: T, rhs: T) -> T;
}

trait Div<T> {
    div(self: T, rhs: T) -> T;
}

trait Rem<T> {
    rem(self: T, rhs: T) -> T;
}

//===================================================================
// BITWISE OPERATION TRAITS
//===================================================================

trait BitAnd<T> {
    bitand(self: T, rhs: T) -> T;
}

trait BitOr<T> {
    bitor(self: T, rhs: T) -> T;
}

trait BitXor<T> {
    bitxor(self: T, rhs: T) -> T;
}

trait Not<T> {
    not(self: T) -> T;
}

trait Shl<T> {
    shl(self: T, rhs: u32) -> T;
}

trait Shr<T> {
    shr(self: T, rhs: u32) -> T;
}

//===================================================================
// UTILITY FUNCTIONS
//===================================================================


// Swap two values
function swap<T>(a: &mut T, b: &mut T) -> void {
    const temp: T = *a;
    *a = *b;
    *b = temp;
}

// Take ownership of value, leaving default in its place
function take<T>(value: &mut T) -> T where T: Default {
    const taken: T = *value;
    *value = T::get_default();
    return taken;
}

// Replace value with new one, returning old value
function replace<T>(dest: &mut T, src: T) -> T {
    const old: T = *dest;
    *dest = src;
    return old;
}