namespace std::core::Types;

//===================================================================
// CORE TYPE DEFINITIONS AND TRAITS
// Fundamental type system definitions for CryoLang
// Provides common interfaces and type utilities
//===================================================================

//===================================================================
// PRIMITIVE TYPE ALIASES
//===================================================================

import <core/intrinsics>;

type i1;        // Compiler defined
type i8;        // Compiler defined 
type i16;       // Compiler defined
type i32;       // Compiler defined
type i64;       // Compiler defined
type int = i64; // Default integer type (alias for i64)

// Unsigned integer types  
type u8  = uint8;
type u16 = uint16;
type u32 = uint32;
type u64 = uint64;

// Floating point types
type f32 = float;
type f64 = double;

// Pointer types
type ptr<T> = T*;
type const_ptr<T> = const T*;


implement string {
    length() -> u64 {
        std::Intrinsics::__printf__("[DEBUG] In string::length method\n");
        std::Intrinsics::__printf__("String value: %s\n", this);
        std::Intrinsics::__printf__("\n");
        std::Intrinsics::__printf__(this);
        std::Intrinsics::__printf__("\n");

        const __str__: string = this;
        std::Intrinsics::__printf__(__str__);

        return std::Intrinsics::__strlen__(this);
    }

    // char_at(index: u64) -> char {
    //     // For now, let's skip bounds checking to get basic functionality working
    //     return this[index];
    // }
}




//===================================================================
// Error type for Result
//===================================================================

type struct Error {
    code: int;
    message: string;
    Error(code: int, message: string) {
        this.code = code;
        this.message = message;
    }
}

type struct ConversionError {
    message: string;
    ConversionError(message: string) {
        this.message = message;
    }
}

enum INTERNAL_ERROR {
    Unknown,
    InvalidInput,
    NotFound,
    PermissionDenied,
    ConnectionFailed,
    Timeout,
    OutOfMemory
}


//===================================================================
// OPTION TYPE
//===================================================================

enum Option<T> {
    Some(T),
    None
}

implement enum Option<T> {

    is_some() -> boolean {
        match this {
            Option::Some(_) => return true,
            Option::None => return false
        }
    }

    is_none() -> boolean {
        match this {
            Option::Some(_) => return false,
            Option::None => return true
        }
    }

    unwrap() -> T {
        match this {
            Option::Some(_) => {
                // For now, return a default since we can't extract the value
                // This is a limitation of the current type system
                std::Intrinsics::__panic__("unwrap not fully implemented");
            }
            Option::None => {
                std::Intrinsics::__printf__("Called unwrap on None value\n");
                std::Intrinsics::__panic__("unwrap called on None value");
            }
        }
    }

    unwrap_or(default_value: T) -> T {
        match this {
            Option::Some(_) => {
                // For now, return default_value since we can't extract the actual value
                return default_value;
            }
            Option::None => return default_value
        }
    }
}

//===================================================================
// RESULT TYPE
//===================================================================

enum Result<T, E> {
    Ok(T),
    Err(E)
}

implement enum Result<T, E> {
    
    ok() -> boolean {
        match this {
            Result::Ok(_) => return true,
            Result::Err(_) => return false
        }
    }

    err() -> boolean {
        match this {
            Result::Ok(_) => return false,
            Result::Err(_) => return true
        }
    }

    unwrap() -> T {
        match this {
            Result::Ok(_) => {
                // For now, we can't extract the value due to type system limitations
                std::Intrinsics::__panic__("unwrap not fully implemented for Result");
            }
            Result::Err(_) => {
                std::Intrinsics::__printf__("Called unwrap on Err value\n");
                std::Intrinsics::__panic__("unwrap called on Err value");
            }
        }
    }

    unwrap_or(default_value: T) -> T {
        match this {
            Result::Ok(_) => {
                // For now, return default_value since we can't extract the actual value
                return default_value;
            }
            Result::Err(_) => return default_value
        }
    }

    expect(message: string) -> T {
        match this {
            Result::Ok(_) => {
                // For now, we can't extract the value due to type system limitations
                std::Intrinsics::__panic__("expect not fully implemented for Result");
            }
            Result::Err(_) => {
                std::Intrinsics::__printf__(message);
                std::Intrinsics::__panic__("expect called on Err value");
            }
        }
    }
}
//===================================================================
// COMMON TRAIT INTERFACES
//===================================================================

// Clone trait for copyable types
trait Clone<T> {
    clone(self: T) -> T;
}

implement trait Clone<T> {
    clone(self: T) -> T {
        // Implement a default shallow copy using 'this'
        return this;
    }
}

// Copy trait for trivially copyable types (marker trait)
trait Copy<T> : Clone<T> {
    // No additional methods - just marks types as trivially copyable
}

// Default trait for types with default values
trait Default<T> {
    get_default() -> T;
}

// Display trait for string representation
trait Display<T> {
    to_string() -> string;
}

// Debug trait for debugging representation
trait Debug<T> {
    debug_string() -> string;
}

// Equality comparison
trait Eq<T> {
    eq(other: T) -> boolean;
    ne(other: T) -> boolean;
}

// Ordering comparison
trait Ord<T> {
    cmp(self: T, other: T) -> Ordering;
    lt(self: T, other: T) -> boolean;
    le(self: T, other: T) -> boolean;
    gt(self: T, other: T) -> boolean;
    ge(self: T, other: T) -> boolean;
}

// // Ordering enum for comparison results
enum Ordering {
    Less,
    Equal,
    Greater
}

// Hash trait for hashable types
trait Hash<T> {
    hash(self: T) -> u64;
}

//===================================================================
// ITERATOR TRAIT
//===================================================================

trait Iterator<T> {
    next(self: &mut Iterator) -> Option<T>;
    size_hint(self: &Iterator) -> (u64, Option<u64>);
}

// Collect trait for converting iterators to collections
trait Collect<T, C> {
    collect(iter: &mut Iterator<T>) -> C;
}

//===================================================================
// INDEX TRAIT
//===================================================================

trait Index<T, I> {
    index(self: &T, index: I) -> &T::Output;
}

trait IndexMut<T, I> : Index<T, I> {
    index_mut(self: &mut T, index: I) -> &mut T::Output;
}

//===================================================================
// CONVERSION TRAITS
//===================================================================

// Infallible conversion
trait From<T, F> {
    from(self: F) -> T;
}

// Fallible conversion  
trait TryFrom<T, F> {
    try_from(self: F) -> Result<T, This::Error>;
}

// Into conversion (reciprocal of From)
trait Into<T, I> {
    into(self: T) -> I;
}

// Try into conversion (reciprocal of TryFrom)
trait TryInto<T, I> {
    try_into(self: T) -> Result<I, This::Error>;
}

