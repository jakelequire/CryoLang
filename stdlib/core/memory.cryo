namespace std::Memory;

import <core/intrinsics>;
import <core/types>;

//===================================================================
// MEMORY MANAGEMENT CORE
// Advanced RAII-based manual memory management for CryoLang
// Provides safe, efficient memory operations without garbage collection
//===================================================================

//===================================================================
// ALLOCATION RESULT TYPES
//===================================================================

enum AllocError {
    OutOfMemory,
    InvalidSize,
    AlignmentError,
    Corrupted
}

type AllocResult<T> = Result<T*, AllocError>;

//===================================================================
// SMART POINTER TYPES
//===================================================================

// Unique ownership - automatically frees on destruction
type class Box<T> {
private:
    _ptr: T*;
    
public:
    // Constructor - takes ownership of raw pointer
    Box(raw_ptr: T*) {
        this._ptr = raw_ptr;
    }

    // Move constructor 
    Box(other: Box<T>) {
        this._ptr = other._ptr;
        other._ptr = null; // Transfer ownership
    }
    
    // Destructor - automatically called when Box goes out of scope
    ~Box() {
        if (this._ptr != null) {
            std::Intrinsics::__free__(this._ptr);
            this._ptr = null;
        }
    }
    
    // Get the raw pointer (borrow)
    get() -> T* {
        return this._ptr;
    }
    
    // Release ownership and return raw pointer
    release() -> T* {
        const result: T* = this._ptr;
        this._ptr = null;
        return result;
    }
    
    // Check if the Box owns a valid pointer
    is_valid() -> boolean {
        return this._ptr != null;
    }
}

// Reference counting for shared ownership
type class Rc<T> {
private:
    _ptr: T*;
    _ref_count: u64*;
    
public:
    // Constructor
    Rc(raw_ptr: T*) {
        this._ptr = raw_ptr;
        this._ref_count = std::Intrinsics::__malloc__(sizeof(u64));
        *this._ref_count = u64(1);
    }
    
    // Copy constructor - increment reference count
    Rc(other: Rc<T>) {
        this._ptr = other._ptr;
        this._ref_count = other._ref_count;
        if (this._ref_count != null) {
            *this._ref_count = *this._ref_count + u64(1);
        }
    }
    
    // Destructor - decrement and possibly free
    ~Rc() {
        if (this._ref_count != null && *this._ref_count > u64(0)) {
            *this._ref_count = *this._ref_count - u64(1);
            if (*this._ref_count == u64(0)) {
                std::Intrinsics::__free__(this._ptr);
                std::Intrinsics::__free__(this._ref_count);
            }
        }
    }
    
    // Get the raw pointer (borrow)
    get() -> T* {
        return this._ptr;
    }
    
    // Get current reference count
    ref_count() -> u64 {
        return this._ref_count != null ? *this._ref_count : u64(0);
    }
}

//===================================================================
// ALLOCATOR INTERFACE
//===================================================================

trait Allocator {
    allocate(size: u64, align: u64) -> AllocResult<void>;
    deallocate(_ptr: void*, size: u64, align: u64) -> void;
    reallocate(_ptr: void*, old_size: u64, new_size: u64, align: u64) -> AllocResult<void>;
}

//===================================================================
// SYSTEM ALLOCATOR (Default malloc/free wrapper)
//===================================================================

type class SystemAllocator {
public:
    allocate(size: u64, align: u64) -> AllocResult<void> {
        if (size == u64(0)) {
            return Result::Err(AllocError::InvalidSize);
        }
        
        const _ptr: void* = std::Intrinsics::__malloc__(size);
        if (_ptr == null) {
            return Result::Err(AllocError::OutOfMemory);
        }
        
        return Result::Ok(_ptr);
    }
    
    deallocate(_ptr: void*, size: u64, align: u64) -> void {
        if (_ptr != null) {
            std::Intrinsics::__free__(_ptr);
        }
        return;
    }
    
    reallocate(_ptr: void*, old_size: u64, new_size: u64, align: u64) -> AllocResult<void> {
        if (new_size == u64(0)) {
            this.deallocate(_ptr, old_size, align);
            return Result::Err(AllocError::InvalidSize);
        }
        
        const new_ptr: void* = std::Intrinsics::__realloc__(_ptr, new_size);
        if (new_ptr == null) {
            return Result::Err(AllocError::OutOfMemory);
        }
        
        return Result::Ok(new_ptr);
    }
}

