//===================================================================
// HTTP RESPONSE TYPE
//===================================================================

// HTTP response message structure
type class Response {
private:
    version: Version;
    status_code: StatusCode;
    reason_phrase: string;
    headers: HeaderMap;
    body: string;

public:
    Response() {
        this.version = Version::HTTP_1_1;
        this.status_code = StatusCode::OK;
        this.reason_phrase = "OK";
        this.headers = HeaderMap();
        this.body = "";
        return;
    }
    
    Response(code: StatusCode) {
        this.version = Version::HTTP_1_1;
        this.status_code = code;
        this.reason_phrase = "";
        this.headers = HeaderMap();
        this.body = "";
        return;
    }
    
    // Get HTTP version
    get_version() -> Version {
        return this.version;
    }
    
    // Set HTTP version
    set_version(new_version: Version) -> void {
        this.version = new_version;
        return;
    }
    
    // Get status code
    get_status_code() -> StatusCode {
        return this.status_code;
    }
    
    // Set status code
    set_status_code(code: StatusCode) -> void {
        this.status_code = code;
        return;
    }
    
    // Get reason phrase
    get_reason_phrase() -> string {
        return this.reason_phrase;
    }
    
    // Set reason phrase
    set_reason_phrase(phrase: string) -> void {
        this.reason_phrase = phrase;
        return;
    }
    
    // Get headers
    get_headers() -> HeaderMap {
        return this.headers;
    }
    
    // Set header
    set_header(name: string, value: string) -> void {
        this.headers.set_header(name, value);
        return;
    }
    
    // Get header value
    get_header(name: string) -> string {
        return this.headers.get_header(name);
    }
    
    // Get response body
    get_body() -> string {
        return this.body;
    }
    
    // Set response body
    set_body(new_body: string) -> void {
        this.body = new_body;
        return;
    }
}

//===================================================================
// HTTP UTILITY FUNCTIONS
//===================================================================

// Convert status code enum to numeric value
function status_code_to_int(code: StatusCode) -> i32 {
    // This would use the explicit enum values
    return i32(200); // Placeholder
}

// Convert method enum to string
function method_to_string(method: Method) -> string {
    if (method == Method::GET) return "GET";
    if (method == Method::POST) return "POST";
    if (method == Method::PUT) return "PUT";
    if (method == Method::DELETE) return "DELETE";
    if (method == Method::HEAD) return "HEAD";
    if (method == Method::OPTIONS) return "OPTIONS";
    if (method == Method::PATCH) return "PATCH";
    if (method == Method::TRACE) return "TRACE";
    if (method == Method::CONNECT) return "CONNECT";
    return "UNKNOWN";
}

// Convert version enum to string
function version_to_string(version: Version) -> string {
    if (version == Version::HTTP_1_0) return "HTTP/1.0";
    if (version == Version::HTTP_1_1) return "HTTP/1.1";
    if (version == Version::HTTP_2_0) return "HTTP/2.0";
    return "HTTP/1.1";
}