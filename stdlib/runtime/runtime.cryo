//===================================================================
// MAIN RUNTIME FUNCTION
//===================================================================

extern function _user_main_() -> int;

function main() -> int {
    std::Intrinsics::__printf__("[DEBUG::RUNTIME] Starting CryoLang Runtime System\n");
    g_runtime_manager = new RuntimeManager();

    // Initialize runtime
    const init_result: RuntimeError = g_runtime_manager.initialize();
    if (init_result != RuntimeError::SUCCESS) {
        std::Intrinsics::__printf__("[DEBUG::RUNTIME] Runtime initialization failed: %d\n", init_result);
        return 1;
    }
    
    std::Intrinsics::__printf__("[DEBUG::RUNTIME] Runtime initialized, calling user main\n");
    
    // Call user main function
    mut user_result: int = 0;
    user_result = _user_main_();
    
    std::Intrinsics::__printf__("[DEBUG::RUNTIME] User main returned: %d\n", user_result);
    
    // Shutdown runtime
    g_runtime_manager.shutdown();
    
    std::Intrinsics::__printf__("[DEBUG::RUNTIME] Runtime shutdown complete\n");
    return user_result;
}

