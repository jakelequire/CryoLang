// ============================================================================
// AtomicPtr
// ============================================================================

/// An atomic pointer.
type struct AtomicPtr<T> {
    value: T*;

    // Method signatures
    AtomicPtr(value: T*);
    load(&this, order: Ordering) -> T*;
    store(mut &this, value: T*, order: Ordering) -> void;
    swap(mut &this, value: T*, order: Ordering) -> T*;
    compare_exchange(mut &this, current: T*, new: T*, success: Ordering, failure: Ordering) -> CompareExchangeResult<T*>;
}

implement struct AtomicPtr<T> {
    AtomicPtr(value: T*) {
        this.value = value;
    }

    load(&this, order: Ordering) -> T* {
        return atomic_load_ptr(&this.value, order);
    }

    store(mut &this, value: T*, order: Ordering) -> void {
        atomic_store_ptr(&this.value, value, order);
    }

    swap(mut &this, value: T*, order: Ordering) -> T* {
        return atomic_swap_ptr(&this.value, value, order);
    }

    compare_exchange(mut &this, current: T*, new: T*, success: Ordering, failure: Ordering) -> CompareExchangeResult<T*> {
        return atomic_cmpxchg_ptr(&this.value, current, new, success, failure);
    }
}

// ============================================================================
// Compare Exchange Result
// ============================================================================

/// Result of a compare-exchange operation.
type struct CompareExchangeResult<T> {
    success: boolean;
    value: T;
}

// ============================================================================
// Fence Operations
// ============================================================================

/// A memory fence with the specified ordering.
function fence(order: Ordering) -> void {
    atomic_fence(order);
}

/// A compiler fence (prevents reordering by the compiler).
function compiler_fence(order: Ordering) -> void {
    atomic_compiler_fence(order);
}

// ============================================================================
// Intrinsics
// ============================================================================

intrinsic function atomic_load_u8(ptr: u8*, order: Ordering) -> u8;
intrinsic function atomic_store_u8(ptr: u8*, value: u8, order: Ordering) -> void;
intrinsic function atomic_swap_u8(ptr: u8*, value: u8, order: Ordering) -> u8;
intrinsic function atomic_cmpxchg_u8(ptr: u8*, current: u8, new: u8, success: Ordering, failure: Ordering) -> CompareExchangeResult<u8>;
intrinsic function atomic_fetch_and_u8(ptr: u8*, value: u8, order: Ordering) -> u8;
intrinsic function atomic_fetch_or_u8(ptr: u8*, value: u8, order: Ordering) -> u8;
intrinsic function atomic_fetch_xor_u8(ptr: u8*, value: u8, order: Ordering) -> u8;
intrinsic function atomic_fetch_nand_u8(ptr: u8*, value: u8, order: Ordering) -> u8;

intrinsic function atomic_load_i32(ptr: i32*, order: Ordering) -> i32;
intrinsic function atomic_store_i32(ptr: i32*, value: i32, order: Ordering) -> void;
intrinsic function atomic_swap_i32(ptr: i32*, value: i32, order: Ordering) -> i32;
intrinsic function atomic_cmpxchg_i32(ptr: i32*, current: i32, new: i32, success: Ordering, failure: Ordering) -> CompareExchangeResult<i32>;
intrinsic function atomic_fetch_add_i32(ptr: i32*, value: i32, order: Ordering) -> i32;
intrinsic function atomic_fetch_sub_i32(ptr: i32*, value: i32, order: Ordering) -> i32;
intrinsic function atomic_fetch_and_i32(ptr: i32*, value: i32, order: Ordering) -> i32;
intrinsic function atomic_fetch_or_i32(ptr: i32*, value: i32, order: Ordering) -> i32;
intrinsic function atomic_fetch_xor_i32(ptr: i32*, value: i32, order: Ordering) -> i32;
intrinsic function atomic_fetch_max_i32(ptr: i32*, value: i32, order: Ordering) -> i32;
intrinsic function atomic_fetch_min_i32(ptr: i32*, value: i32, order: Ordering) -> i32;

intrinsic function atomic_load_u32(ptr: u32*, order: Ordering) -> u32;
intrinsic function atomic_store_u32(ptr: u32*, value: u32, order: Ordering) -> void;
intrinsic function atomic_swap_u32(ptr: u32*, value: u32, order: Ordering) -> u32;
intrinsic function atomic_cmpxchg_u32(ptr: u32*, current: u32, new: u32, success: Ordering, failure: Ordering) -> CompareExchangeResult<u32>;
intrinsic function atomic_fetch_add_u32(ptr: u32*, value: u32, order: Ordering) -> u32;
intrinsic function atomic_fetch_sub_u32(ptr: u32*, value: u32, order: Ordering) -> u32;
intrinsic function atomic_fetch_and_u32(ptr: u32*, value: u32, order: Ordering) -> u32;
intrinsic function atomic_fetch_or_u32(ptr: u32*, value: u32, order: Ordering) -> u32;
intrinsic function atomic_fetch_xor_u32(ptr: u32*, value: u32, order: Ordering) -> u32;

intrinsic function atomic_load_i64(ptr: i64*, order: Ordering) -> i64;
intrinsic function atomic_store_i64(ptr: i64*, value: i64, order: Ordering) -> void;
intrinsic function atomic_swap_i64(ptr: i64*, value: i64, order: Ordering) -> i64;
intrinsic function atomic_cmpxchg_i64(ptr: i64*, current: i64, new: i64, success: Ordering, failure: Ordering) -> CompareExchangeResult<i64>;
intrinsic function atomic_fetch_add_i64(ptr: i64*, value: i64, order: Ordering) -> i64;
intrinsic function atomic_fetch_sub_i64(ptr: i64*, value: i64, order: Ordering) -> i64;

intrinsic function atomic_load_u64(ptr: u64*, order: Ordering) -> u64;
intrinsic function atomic_store_u64(ptr: u64*, value: u64, order: Ordering) -> void;
intrinsic function atomic_swap_u64(ptr: u64*, value: u64, order: Ordering) -> u64;
intrinsic function atomic_cmpxchg_u64(ptr: u64*, current: u64, new: u64, success: Ordering, failure: Ordering) -> CompareExchangeResult<u64>;
intrinsic function atomic_fetch_add_u64(ptr: u64*, value: u64, order: Ordering) -> u64;
intrinsic function atomic_fetch_sub_u64(ptr: u64*, value: u64, order: Ordering) -> u64;

intrinsic function atomic_load_ptr<T>(ptr: T**, order: Ordering) -> T*;
intrinsic function atomic_store_ptr<T>(ptr: T**, value: T*, order: Ordering) -> void;
intrinsic function atomic_swap_ptr<T>(ptr: T**, value: T*, order: Ordering) -> T*;
intrinsic function atomic_cmpxchg_ptr<T>(ptr: T**, current: T*, new: T*, success: Ordering, failure: Ordering) -> CompareExchangeResult<T*>;

intrinsic function atomic_fence(order: Ordering) -> void;
intrinsic function atomic_compiler_fence(order: Ordering) -> void;
