///! Atomic Operations
///!
///! Atomic types for lock-free concurrent programming.

namespace std::sync::atomic;

import core::intrinsics;

// ============================================================================
// Memory Ordering
// ============================================================================

/// Memory ordering for atomic operations.
enum Ordering {
    /// No ordering constraints.
    Relaxed;
    /// Acquire ordering for loads.
    Acquire;
    /// Release ordering for stores.
    Release;
    /// Both acquire and release.
    AcqRel;
    /// Sequentially consistent.
    SeqCst;
}

// ============================================================================
// AtomicBool
// ============================================================================

/// An atomic boolean type.
type struct AtomicBool {
    value: u8;

    // Method signatures
    AtomicBool(value: boolean);
    load(&this, order: Ordering) -> boolean;
    store(mut &this, value: boolean, order: Ordering) -> void;
    swap(mut &this, value: boolean, order: Ordering) -> boolean;
    compare_exchange(mut &this, current: boolean, new: boolean, success: Ordering, failure: Ordering) -> CompareExchangeResult<boolean>;
    fetch_and(mut &this, value: boolean, order: Ordering) -> boolean;
    fetch_or(mut &this, value: boolean, order: Ordering) -> boolean;
    fetch_xor(mut &this, value: boolean, order: Ordering) -> boolean;
    fetch_nand(mut &this, value: boolean, order: Ordering) -> boolean;
}

implement struct AtomicBool {
    /// Creates a new AtomicBool.
    AtomicBool(value: boolean) {
        this.value = value ? 1 : 0;
    }

    /// Loads the value.
    load(&this, order: Ordering) -> boolean {
        return atomic_load_u8(&this.value, order) != 0;
    }

    /// Stores a value.
    store(mut &this, value: boolean, order: Ordering) -> void {
        atomic_store_u8(&this.value, value ? 1 : 0, order);
    }

    /// Swaps the value, returning the old value.
    swap(mut &this, value: boolean, order: Ordering) -> boolean {
        return atomic_swap_u8(&this.value, value ? 1 : 0, order) != 0;
    }

    /// Compares and exchanges the value.
    compare_exchange(mut &this, current: boolean, new: boolean, success: Ordering, failure: Ordering) -> CompareExchangeResult<boolean> {
        const current_val: u8 = current ? 1 : 0;
        const new_val: u8 = new ? 1 : 0;
        const result: CompareExchangeResult<u8> = atomic_cmpxchg_u8(&this.value, current_val, new_val, success, failure);
        return CompareExchangeResult {
            success: result.success,
            value: result.value != 0
        };
    }

    /// Fetches the value and applies bitwise AND.
    fetch_and(mut &this, value: boolean, order: Ordering) -> boolean {
        return atomic_fetch_and_u8(&this.value, value ? 1 : 0, order) != 0;
    }

    /// Fetches the value and applies bitwise OR.
    fetch_or(mut &this, value: boolean, order: Ordering) -> boolean {
        return atomic_fetch_or_u8(&this.value, value ? 1 : 0, order) != 0;
    }

    /// Fetches the value and applies bitwise XOR.
    fetch_xor(mut &this, value: boolean, order: Ordering) -> boolean {
        return atomic_fetch_xor_u8(&this.value, value ? 1 : 0, order) != 0;
    }

    /// Fetches the value and applies bitwise NAND.
    fetch_nand(mut &this, value: boolean, order: Ordering) -> boolean {
        return atomic_fetch_nand_u8(&this.value, value ? 1 : 0, order) != 0;
    }
}

// ============================================================================
// AtomicI32
// ============================================================================

/// An atomic 32-bit signed integer.
type struct AtomicI32 {
    value: i32;

    // Method signatures
    AtomicI32(value: i32);
    load(&this, order: Ordering) -> i32;
    store(mut &this, value: i32, order: Ordering) -> void;
    swap(mut &this, value: i32, order: Ordering) -> i32;
    compare_exchange(mut &this, current: i32, new: i32, success: Ordering, failure: Ordering) -> CompareExchangeResult<i32>;
    fetch_add(mut &this, value: i32, order: Ordering) -> i32;
    fetch_sub(mut &this, value: i32, order: Ordering) -> i32;
    fetch_and(mut &this, value: i32, order: Ordering) -> i32;
    fetch_or(mut &this, value: i32, order: Ordering) -> i32;
    fetch_xor(mut &this, value: i32, order: Ordering) -> i32;
    fetch_max(mut &this, value: i32, order: Ordering) -> i32;
    fetch_min(mut &this, value: i32, order: Ordering) -> i32;
}

implement struct AtomicI32 {
    AtomicI32(value: i32) {
        this.value = value;
    }

    load(&this, order: Ordering) -> i32 {
        return atomic_load_i32(&this.value, order);
    }

    store(mut &this, value: i32, order: Ordering) -> void {
        atomic_store_i32(&this.value, value, order);
    }

    swap(mut &this, value: i32, order: Ordering) -> i32 {
        return atomic_swap_i32(&this.value, value, order);
    }

    compare_exchange(mut &this, current: i32, new: i32, success: Ordering, failure: Ordering) -> CompareExchangeResult<i32> {
        return atomic_cmpxchg_i32(&this.value, current, new, success, failure);
    }

    fetch_add(mut &this, value: i32, order: Ordering) -> i32 {
        return atomic_fetch_add_i32(&this.value, value, order);
    }

    fetch_sub(mut &this, value: i32, order: Ordering) -> i32 {
        return atomic_fetch_sub_i32(&this.value, value, order);
    }

    fetch_and(mut &this, value: i32, order: Ordering) -> i32 {
        return atomic_fetch_and_i32(&this.value, value, order);
    }

    fetch_or(mut &this, value: i32, order: Ordering) -> i32 {
        return atomic_fetch_or_i32(&this.value, value, order);
    }

    fetch_xor(mut &this, value: i32, order: Ordering) -> i32 {
        return atomic_fetch_xor_i32(&this.value, value, order);
    }

    fetch_max(mut &this, value: i32, order: Ordering) -> i32 {
        return atomic_fetch_max_i32(&this.value, value, order);
    }

    fetch_min(mut &this, value: i32, order: Ordering) -> i32 {
        return atomic_fetch_min_i32(&this.value, value, order);
    }
}

