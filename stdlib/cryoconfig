# CryoLang Standard Library Configuration
#
# This configuration builds the CryoLang standard library from individual
# modules. The compiler will automatically discover all .cryo files in the
# source directory and its subdirectories.
#
# The stdlib target type is special:
# - Compiles all .cryo files in source_dir recursively
# - Uses --stdlib-mode compilation flag automatically
# - Does not require an entry_point (no main function needed)
# - Outputs a combined library suitable for linking with user programs
# - Handles module discovery and dependency resolution automatically

[project]
project_name = "cryo-stdlib"
output_dir = "_bin/stdlib"
target_type = "stdlib"
source_dir = "."
# No entry_point needed for stdlib compilation

[compiler]
debug = false
optimize = true
stdlib_mode = true
no_std = true
args = ["--emit-llvm", "-c"]

[dependencies]
# Standard library has no external dependencies