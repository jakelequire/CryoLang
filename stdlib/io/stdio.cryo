namespace std::IO;

import <core/types>;
import <core/syscall>;
import <strings/strings>;

// Simplified printf without variadic parameters for now
function printf(format: string) -> i64 {
    const length: i64 = std::String::strlen(format);
    const result: i64 = std::Syscall::IO::write(1, format, length);
    if (result < 0) {
        return -1; // Indicate an error occurred
    }
    return result;
}
