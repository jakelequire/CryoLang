///! Cursor - In-Memory I/O
///!
///! A Cursor wraps an in-memory buffer and provides Read/Write/Seek operations.

namespace std::io::cursor;

import core::intrinsics;
import core::option;
import core::mem;
import alloc::global;
import collections::array;
import io::error;
import io::reader;
import io::writer;

// ============================================================================
// Cursor
// ============================================================================

/// A cursor wrapping an in-memory buffer.
/// Implements Read, Write, and Seek.
type struct Cursor<T> {
    inner: T;
    pos: u64;

    // Method signatures
    Cursor(inner: T) -> Cursor<T>;
    get_ref(&this) -> T*;
    get_mut(mut &this) -> T*;
    into_inner(&this) -> T;
    position(&this) -> u64;
    set_position(mut &this, pos: u64) -> void;
}

implement struct Cursor<T> {
    /// Creates a new cursor wrapping the given value.
    Cursor(inner: T) -> Cursor<T> {
        return Cursor {
            inner: inner,
            pos: 0
        };
    }

    /// Returns a reference to the underlying value.
    get_ref(&this) -> T* {
        return &this.inner;
    }

    /// Returns a mutable reference to the underlying value.
    get_mut(mut &this) -> T* {
        return &this.inner;
    }

    /// Consumes the cursor and returns the underlying value.
    into_inner(&this) -> T {
        return this.inner;
    }

    /// Returns the current position.
    position(&this) -> u64 {
        return this.pos;
    }

    /// Sets the position.
    set_position(mut &this, pos: u64) -> void {
        this.pos = pos;
    }
}

// ============================================================================
// ByteCursor - Cursor over byte slice
// ============================================================================

/// A cursor over a byte slice.
type struct ByteCursor {
    data: u8*;
    len: u64;
    pos: u64;

    // Method signatures
    ByteCursor(data: u8*, len: u64) -> ByteCursor;
    len(&this) -> u64;
    remaining(&this) -> u64;
    position(&this) -> u64;
    set_position(mut &this, pos: u64) -> void;
    remaining_slice(&this) -> u8*;
    read(mut &this, buf: u8*, len: u64) -> IoResult<u64>;
    seek(mut &this, pos: SeekFrom) -> IoResult<u64>;
}

implement struct ByteCursor {
    /// Creates a new cursor over a byte slice.
    ByteCursor(data: u8*, len: u64) -> ByteCursor {
        return ByteCursor {
            data: data,
            len: len,
            pos: 0
        };
    }

    /// Returns the length of the underlying data.
    len(&this) -> u64 {
        return this.len;
    }

    /// Returns the remaining bytes.
    remaining(&this) -> u64 {
        if (this.pos >= this.len) {
            return 0;
        }
        return this.len - this.pos;
    }

    /// Returns the current position.
    position(&this) -> u64 {
        return this.pos;
    }

    /// Sets the position.
    set_position(mut &this, pos: u64) -> void {
        this.pos = pos;
    }

    /// Returns a pointer to the remaining data.
    remaining_slice(&this) -> u8* {
        if (this.pos >= this.len) {
            return null;
        }
        return &this.data[this.pos];
    }

    /// Reads bytes from the cursor.
    read(mut &this, buf: u8*, len: u64) -> IoResult<u64> {
        const remaining: u64 = this.remaining();
        if (remaining == 0) {
            return IoResult::Ok(0);
        }

        mut to_read: u64 = len;
        if (to_read > remaining) {
            to_read = remaining;
        }

        memcpy(buf, &this.data[this.pos], to_read);
        this.pos = this.pos + to_read;

        return IoResult::Ok(to_read);
    }

    /// Seeks to a position.
    seek(mut &this, pos: SeekFrom) -> IoResult<u64> {
        mut new_pos: i64;

        match (pos) {
            SeekFrom::Start(offset) => {
                new_pos = offset;
            }
            SeekFrom::End(offset) => {
                new_pos = this.len + offset;
            }
            SeekFrom::Current(offset) => {
                new_pos = this.pos + offset;
            }
        }

        if (new_pos < 0) {
            return IoResult::Err(IoError::invalid_input("seek to negative position"));
        }

        this.pos = new_pos;
        return IoResult::Ok(this.pos);
    }
}

// ============================================================================
// VecCursor - Cursor over Vec<u8>
// ============================================================================

/// A cursor over a Vec<u8> that supports both reading and writing.
type struct VecCursor {
    data: Vec<u8>;
    pos: u64;

    // Method signatures
    VecCursor() -> VecCursor;
    from_vec(v: Vec<u8>) -> VecCursor;
    from_slice(data: u8*, len: u64) -> VecCursor;
    len(&this) -> u64;
    remaining(&this) -> u64;
    position(&this) -> u64;
    set_position(mut &this, pos: u64) -> void;
    get_ref(&this) -> Vec<u8>*;
    into_vec(&this) -> Vec<u8>;
    read(mut &this, buf: u8*, len: u64) -> IoResult<u64>;
    write(mut &this, buf: u8*, len: u64) -> IoResult<u64>;
    seek(mut &this, pos: SeekFrom) -> IoResult<u64>;
    flush(&this) -> IoResult<void>;
    drop(&this) -> void;
}

implement struct VecCursor {
    /// Creates a new empty cursor.
    VecCursor() -> VecCursor {
        return VecCursor {
            data: Vec::new(),
            pos: 0
        };
    }

    /// Creates a cursor from a Vec.
    static from_vec(v: Vec<u8>) -> VecCursor {
        return VecCursor {
            data: v,
            pos: 0
        };
    }

    /// Creates a cursor with initial data.
    static from_slice(data: u8*, len: u64) -> VecCursor {
        return VecCursor {
            data: Vec::from_slice(data, len),
            pos: 0
        };
    }

    /// Returns the length of the data.
    len(&this) -> u64 {
        return this.data.len();
    }

    /// Returns the remaining bytes.
    remaining(&this) -> u64 {
        if (this.pos >= this.data.len()) {
            return 0;
        }
        return this.data.len() - this.pos;
    }

    /// Returns the current position.
    position(&this) -> u64 {
        return this.pos;
    }

    /// Sets the position.
    set_position(mut &this, pos: u64) -> void {
        this.pos = pos;
    }

    /// Returns a reference to the underlying Vec.
    get_ref(&this) -> Vec<u8>* {
        return &this.data;
    }

    /// Consumes the cursor and returns the Vec.
    into_vec(&this) -> Vec<u8> {
        return this.data;
    }

    /// Reads bytes from the cursor.
    read(mut &this, buf: u8*, len: u64) -> IoResult<u64> {
        const remaining: u64 = this.remaining();
        if (remaining == 0) {
            return IoResult::Ok(0);
        }

        mut to_read: u64 = len;
        if (to_read > remaining) {
            to_read = remaining;
        }

        memcpy(buf, &this.data.as_ptr()[this.pos], to_read);
        this.pos = this.pos + to_read;

        return IoResult::Ok(to_read);
    }

    /// Writes bytes to the cursor.
    write(mut &this, buf: u8*, len: u64) -> IoResult<u64> {
        if (len == 0) {
            return IoResult::Ok(0);
        }

        // Extend the vec if necessary
        const end_pos: u64 = this.pos + len;
        if (end_pos > this.data.len()) {
            // Reserve space
            this.data.reserve(end_pos - this.data.len());

            // Fill with zeros up to pos
            while (this.data.len() < this.pos) {
                this.data.push(0);
            }

            // Add the new data
            mut i: u64 = 0;
            while (i < len) {
                if (this.pos + i < this.data.len()) {
                    this.data.set(this.pos + i, buf[i]);
                } else {
                    this.data.push(buf[i]);
                }
                i = i + 1;
            }
        } else {
            // Overwrite existing data
            mut i: u64 = 0;
            while (i < len) {
                this.data.set(this.pos + i, buf[i]);
                i = i + 1;
            }
        }

        this.pos = this.pos + len;
        return IoResult::Ok(len);
    }

    /// Seeks to a position.
    seek(mut &this, pos: SeekFrom) -> IoResult<u64> {
        mut new_pos: i64;

        match (pos) {
            SeekFrom::Start(offset) => {
                new_pos = offset;
            }
            SeekFrom::End(offset) => {
                new_pos = this.data.len() + offset;
            }
            SeekFrom::Current(offset) => {
                new_pos = this.pos + offset;
            }
        }

        if (new_pos < 0) {
            return IoResult::Err(IoError::invalid_input("seek to negative position"));
        }

        this.pos = new_pos;
        return IoResult::Ok(this.pos);
    }

    /// Flushes (no-op for VecCursor).
    flush(&this) -> IoResult<void> {
        return IoResult::Ok(void);
    }

    /// Drops the cursor.
    drop(&this) -> void {
        this.data.drop();
    }
}

// ============================================================================
// SliceMutCursor - Cursor over mutable slice
// ============================================================================

/// A cursor over a mutable byte slice.
type struct SliceMutCursor {
    data: u8*;
    len: u64;
    pos: u64;

    // Method signatures
    SliceMutCursor(data: u8*, len: u64) -> SliceMutCursor;
    len(&this) -> u64;
    remaining(&this) -> u64;
    position(&this) -> u64;
    set_position(mut &this, pos: u64) -> void;
    read(mut &this, buf: u8*, len: u64) -> IoResult<u64>;
    write(mut &this, buf: u8*, len: u64) -> IoResult<u64>;
    seek(mut &this, pos: SeekFrom) -> IoResult<u64>;
}

implement struct SliceMutCursor {
    /// Creates a cursor over a mutable slice.
    SliceMutCursor(data: u8*, len: u64) -> SliceMutCursor {
        return SliceMutCursor {
            data: data,
            len: len,
            pos: 0
        };
    }

    /// Returns the length.
    len(&this) -> u64 {
        return this.len;
    }

    /// Returns the remaining capacity.
    remaining(&this) -> u64 {
        if (this.pos >= this.len) {
            return 0;
        }
        return this.len - this.pos;
    }

    /// Returns the current position.
    position(&this) -> u64 {
        return this.pos;
    }

    /// Sets the position.
    set_position(mut &this, pos: u64) -> void {
        this.pos = pos;
    }

    /// Reads bytes.
    read(mut &this, buf: u8*, len: u64) -> IoResult<u64> {
        const remaining: u64 = this.remaining();
        if (remaining == 0) {
            return IoResult::Ok(0);
        }

        mut to_read: u64 = len;
        if (to_read > remaining) {
            to_read = remaining;
        }

        memcpy(buf, &this.data[this.pos], to_read);
        this.pos = this.pos + to_read;

        return IoResult::Ok(to_read);
    }

    /// Writes bytes.
    write(mut &this, buf: u8*, len: u64) -> IoResult<u64> {
        const remaining: u64 = this.remaining();
        if (remaining == 0) {
            return IoResult::Ok(0);
        }

        mut to_write: u64 = len;
        if (to_write > remaining) {
            to_write = remaining;
        }

        memcpy(&this.data[this.pos], buf, to_write);
        this.pos = this.pos + to_write;

        return IoResult::Ok(to_write);
    }

    /// Seeks to a position.
    seek(mut &this, pos: SeekFrom) -> IoResult<u64> {
        mut new_pos: i64;

        match (pos) {
            SeekFrom::Start(offset) => {
                new_pos = offset;
            }
            SeekFrom::End(offset) => {
                new_pos = this.len + offset;
            }
            SeekFrom::Current(offset) => {
                new_pos = this.pos + offset;
            }
        }

        if (new_pos < 0) {
            return IoResult::Err(IoError::invalid_input("seek to negative position"));
        }

        this.pos = new_pos;
        return IoResult::Ok(this.pos);
    }
}

// ============================================================================
// Helper Functions
// ============================================================================

/// Creates a cursor over a byte slice.
function byte_cursor(data: u8*, len: u64) -> ByteCursor {
    return ByteCursor::new(data, len);
}

/// Creates an empty Vec cursor.
function vec_cursor() -> VecCursor {
    return VecCursor::new();
}

/// Creates a Vec cursor from initial data.
function vec_cursor_from(data: u8*, len: u64) -> VecCursor {
    return VecCursor::from_slice(data, len);
}

/// Creates a cursor over a mutable slice.
function slice_mut_cursor(data: u8*, len: u64) -> SliceMutCursor {
    return SliceMutCursor::new(data, len);
}
