[
    {
        "key": "ctrl+shift+f5",
        "command": "workbench.action.tasks.runTask",
        "args": "LSP: Full Development Build",
        "when": "workspaceFolderCount > 0"
    },
    {
        "key": "ctrl+f5",
        "command": "workbench.action.tasks.runTask",
        "args": "LSP: Quick Rebuild (Skip Compiler)",
        "when": "workspaceFolderCount > 0"
    },
    {
        "key": "ctrl+shift+f6",
        "command": "workbench.action.tasks.runTask",
        "args": "LSP: Shutdown Server",
        "when": "workspaceFolderCount > 0"
    },
    {
        "key": "ctrl+f6",
        "command": "workbench.action.tasks.runTask",
        "args": "LSP: Restart Server",
        "when": "workspaceFolderCount > 0"
    }
]
